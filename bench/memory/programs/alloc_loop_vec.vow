module AllocLoopVec

fn fill_vec() -> i64 {
    let nums: Vec<i64> = Vec::new();
    let mut i: i64 = 0;
    while i < 32 {
        nums.push(i);
        i = i + 1;
    }
    nums.len() + nums[0] + nums[31]
}

fn main() -> i32 [io] {
    let mut i: i64 = 0;
    let mut total: i64 = 0;
    while i < 70000 {
        total = total + fill_vec();
        i = i + 1;
    }
    print_i64(total);
    print_str("\n");
    0
}
