module ChessUci

const EMPTY: i64 = 0;
const WHITE: i64 = 1;
const BLACK: i64 = -1;

const PAWN: i64 = 1;
const KNIGHT: i64 = 2;
const BISHOP: i64 = 3;
const ROOK: i64 = 4;
const QUEEN: i64 = 5;
const KING: i64 = 6;

const INF: i64 = 100000000;
const MATE: i64 = 1000000;
const MATE_THRESHOLD: i64 = 999000;
const MAX_DEPTH: i64 = 64;
const QUIESCE_DEPTH: i64 = 6;
const KILLER_SLOTS: i64 = 132;
const HISTORY_SIZE: i64 = 4096;
const HISTORY_ORDER_CAP: i64 = 60000;
const KILLER1_BONUS: i64 = 90000;
const KILLER2_BONUS: i64 = 80000;
const TT_MOVE_BONUS: i64 = 3000000;

const ZOB_SIZE: i64 = 781;
const TT_SIZE: i64 = 1048576;
const TT_MASK: i64 = 1048575;
const TT_EXACT: i64 = 1;
const TT_LOWER: i64 = 2;
const TT_UPPER: i64 = 3;
const REP_SIZE: i64 = 512;
const REP_CONTEXT_SEED: i64 = 7640891576956012809;
const REP_CONTEXT_BOUNDARY: i64 = -7046029254386353131;

struct ChessMove {
    from: i64,
    to: i64,
    promote: i64,
    en_passant: i64,
    castle: i64,
}

struct Board {
    // a1 = 0, b1 = 1, ..., h8 = 63
    squares: Vec<i64>,
    side: i64,
    ep: i64,
    wk: i64,
    wq: i64,
    bk: i64,
    bq: i64,
    wk_sq: i64,
    bk_sq: i64,
    halfmove: i64,
    non_king_count: i64,
}

struct UndoInfo {
    from_sq: i64,
    to_sq: i64,
    ep_capture_sq: i64,
    ep_capture_piece: i64,
    old_ep: i64,
    old_side: i64,
    old_wk: i64,
    old_wq: i64,
    old_bk: i64,
    old_bq: i64,
    castle_rook_from: i64,
    castle_rook_to: i64,
    castle_rook_piece: i64,
    placed: i64,
    old_halfmove: i64,
    old_non_king_count: i64,
}

struct TTEntry {
    key: i64,
    depth: i64,
    score: i64,
    flag: i64,
    movekey: i64,
    generation: i64,
}

struct SearchState {
    stopped: i64,
    nodes: i64,
    deadline: i64,
    infinite: i64,
    killers: Vec<i64>,
    history: Vec<i64>,
    ztab: Vec<i64>,
    tt: Vec<TTEntry>,
    pst: Vec<i64>,
    rep: Vec<i64>,
    rep_context: Vec<i64>,
    rep_base: i64,
    tt_generation: i64,
    pending: Vec<String>,
}

// Fixed-capacity ring of played-game positions since the last irreversible
// move. SearchState.rep owns the separate search-line suffix.
struct GameHistory {
    keys: Vec<i64>,
    start: i64,
    len: i64,
}

struct UciState {
    board: Board,
    running: i64,
    ztab: Vec<i64>,
    tt: Vec<TTEntry>,
    pst: Vec<i64>,
    game_rep: GameHistory,
    tt_generation: i64,
}

// Parsed `go` limits. If fixed_depth > 0, search exactly that depth with no
// clock. Infinite searches also have no clock and run up to MAX_DEPTH. All
// other searches use budget_ms of wall-clock time.
struct GoLimits {
    fixed_depth: i64,
    budget_ms: i64,
    infinite: i64,
}

fn abs_i64(x: i64) -> i64 {
    if x < 0 {
        -x
    } else {
        x
    }
}

fn max_i64(a: i64, b: i64) -> i64 {
    if a > b {
        a
    } else {
        b
    }
}

fn min_i64(a: i64, b: i64) -> i64 {
    if a < b {
        a
    } else {
        b
    }
}

fn file_of(sq: i64) -> i64 {
    sq % 8
}

fn rank_of(sq: i64) -> i64 {
    sq / 8
}

fn make_sq(file: i64, rank: i64) -> i64 {
    rank * 8 + file
}

fn on_board(file: i64, rank: i64) -> bool {
    file >= 0 && file < 8 && rank >= 0 && rank < 8
}

fn piece_color(piece: i64) -> i64 {
    if piece > 0 {
        WHITE
    } else {
        if piece < 0 {
            BLACK
        } else {
            0
        }
    }
}

fn piece_kind(piece: i64) -> i64 {
    abs_i64(piece)
}

fn piece_value(kind: i64) -> i64 {
    if kind == 1 {
        return 100;
    }
    if kind == 2 {
        return 320;
    }
    if kind == 3 {
        return 330;
    }
    if kind == 4 {
        return 500;
    }
    if kind == 5 {
        return 900;
    }
    0
}

fn null_move() -> ChessMove {
    ChessMove { from: -1, to: -1, promote: 0, en_passant: 0, castle: 0 }
}

fn is_null_move(mv: ChessMove) -> bool {
    mv.from < 0
}

fn add_move(moves: Vec<ChessMove>, from: i64, to: i64, promote: i64, en_passant: i64, castle: i64) {
    let mv: ChessMove = ChessMove {
        from: from,
        to: to,
        promote: promote,
        en_passant: en_passant,
        castle: castle,
    };
    moves.push(mv);
}

fn add_promotions(moves: Vec<ChessMove>, from: i64, to: i64, en_passant: i64) {
    add_move(moves, from, to, QUEEN, en_passant, 0);
    add_move(moves, from, to, ROOK, en_passant, 0);
    add_move(moves, from, to, BISHOP, en_passant, 0);
    add_move(moves, from, to, KNIGHT, en_passant, 0);
}

fn start_board() -> Board {
    let b: Board = Board {
        squares: Vec::new(),
        side: WHITE,
        ep: -1,
        wk: 1,
        wq: 1,
        bk: 1,
        bq: 1,
        wk_sq: 4,
        bk_sq: 60,
        halfmove: 0,
        non_king_count: 30,
    };
    let sqs: Vec<i64> = b.squares;
    let mut i: i64 = 0;
    while i < 64 {
        sqs.push(EMPTY);
        i = i + 1;
    }

    sqs[0] = ROOK;
    sqs[1] = KNIGHT;
    sqs[2] = BISHOP;
    sqs[3] = QUEEN;
    sqs[4] = KING;
    sqs[5] = BISHOP;
    sqs[6] = KNIGHT;
    sqs[7] = ROOK;

    sqs[8] = PAWN;
    sqs[9] = PAWN;
    sqs[10] = PAWN;
    sqs[11] = PAWN;
    sqs[12] = PAWN;
    sqs[13] = PAWN;
    sqs[14] = PAWN;
    sqs[15] = PAWN;

    sqs[48] = -PAWN;
    sqs[49] = -PAWN;
    sqs[50] = -PAWN;
    sqs[51] = -PAWN;
    sqs[52] = -PAWN;
    sqs[53] = -PAWN;
    sqs[54] = -PAWN;
    sqs[55] = -PAWN;

    sqs[56] = -ROOK;
    sqs[57] = -KNIGHT;
    sqs[58] = -BISHOP;
    sqs[59] = -QUEEN;
    sqs[60] = -KING;
    sqs[61] = -BISHOP;
    sqs[62] = -KNIGHT;
    sqs[63] = -ROOK;
    b
}

fn find_king(b: Board, color: i64) -> i64 {
    if color == WHITE {
        b.wk_sq
    } else {
        b.bk_sq
    }
}

// Walk a ray from (file,rank) in direction (df,dr); return true if the first
// piece hit is piece1 or piece2. Allocation-free (scalar, no direction Vecs).
fn ray_hits(sqs: Vec<i64>, file: i64, rank: i64, df: i64, dr: i64, piece1: i64, piece2: i64) -> bool {
    let mut f: i64 = file + df;
    let mut r: i64 = rank + dr;
    while on_board(f, r) {
        let p: i64 = sqs[make_sq(f, r)];
        if p != 0 {
            return p == piece1 || p == piece2;
        }
        f = f + df;
        r = r + dr;
    }
    false
}

fn step_hits(sqs: Vec<i64>, file: i64, rank: i64, df: i64, dr: i64, target: i64) -> bool {
    let f: i64 = file + df;
    let r: i64 = rank + dr;
    on_board(f, r) && sqs[make_sq(f, r)] == target
}

fn square_attacked(b: Board, sq: i64, by_color: i64) -> bool {
    let sqs: Vec<i64> = b.squares;
    let file: i64 = file_of(sq);
    let rank: i64 = rank_of(sq);

    // Pawn attacks (color-asymmetric, kept inline)
    if by_color == 1 {
        if file > 0 && rank > 0 && sqs[sq - 9] == 1 {
            return true;
        }
        if file < 7 && rank > 0 && sqs[sq - 7] == 1 {
            return true;
        }
    } else {
        if file > 0 && rank < 7 && sqs[sq + 7] == -1 {
            return true;
        }
        if file < 7 && rank < 7 && sqs[sq + 9] == -1 {
            return true;
        }
    }

    // Knight
    let n: i64 = by_color * KNIGHT;
    if step_hits(sqs, file, rank, 1, 2, n) || step_hits(sqs, file, rank, 2, 1, n)
        || step_hits(sqs, file, rank, -1, 2, n) || step_hits(sqs, file, rank, -2, 1, n)
        || step_hits(sqs, file, rank, 1, -2, n) || step_hits(sqs, file, rank, 2, -1, n)
        || step_hits(sqs, file, rank, -1, -2, n) || step_hits(sqs, file, rank, -2, -1, n) {
        return true;
    }

    // Bishop/Queen (diagonals)
    let bshp: i64 = by_color * BISHOP;
    let q: i64 = by_color * QUEEN;
    if ray_hits(sqs, file, rank, 1, 1, bshp, q) || ray_hits(sqs, file, rank, -1, 1, bshp, q)
        || ray_hits(sqs, file, rank, 1, -1, bshp, q) || ray_hits(sqs, file, rank, -1, -1, bshp, q) {
        return true;
    }

    // Rook/Queen (straights)
    let rk: i64 = by_color * ROOK;
    if ray_hits(sqs, file, rank, 1, 0, rk, q) || ray_hits(sqs, file, rank, -1, 0, rk, q)
        || ray_hits(sqs, file, rank, 0, 1, rk, q) || ray_hits(sqs, file, rank, 0, -1, rk, q) {
        return true;
    }

    // King
    let k: i64 = by_color * KING;
    step_hits(sqs, file, rank, -1, -1, k) || step_hits(sqs, file, rank, 0, -1, k) || step_hits(sqs, file, rank, 1, -1, k)
        || step_hits(sqs, file, rank, -1, 0, k) || step_hits(sqs, file, rank, 1, 0, k)
        || step_hits(sqs, file, rank, -1, 1, k) || step_hits(sqs, file, rank, 0, 1, k) || step_hits(sqs, file, rank, 1, 1, k)
}

fn in_check(b: Board, color: i64) -> bool {
    let king_sq: i64 = find_king(b, color);
    if king_sq < 0 {
        true
    } else {
        square_attacked(b, king_sq, -color)
    }
}

fn gen_slider_dir(moves: Vec<ChessMove>, b: Board, sq: i64, df: i64, dr: i64) {
    let sqs: Vec<i64> = b.squares;
    let mut file: i64 = file_of(sq) + df;
    let mut rank: i64 = rank_of(sq) + dr;
    while on_board(file, rank) {
        let to: i64 = make_sq(file, rank);
        let target: i64 = sqs[to];
        if target == 0 {
            add_move(moves, sq, to, 0, 0, 0);
        } else {
            if piece_color(target) != b.side {
                add_move(moves, sq, to, 0, 0, 0);
            }
            return;
        }
        file = file + df;
        rank = rank + dr;
    }
}

fn gen_jump(moves: Vec<ChessMove>, b: Board, sq: i64, df: i64, dr: i64) {
    let sqs: Vec<i64> = b.squares;
    let file: i64 = file_of(sq) + df;
    let rank: i64 = rank_of(sq) + dr;
    if on_board(file, rank) {
        let to: i64 = make_sq(file, rank);
        let target: i64 = sqs[to];
        if piece_color(target) != b.side {
            add_move(moves, sq, to, 0, 0, 0);
        }
    }
}

fn gen_pawn_moves(moves: Vec<ChessMove>, b: Board, sq: i64) {
    let sqs: Vec<i64> = b.squares;
    let file: i64 = file_of(sq);
    let rank: i64 = rank_of(sq);
    let piece: i64 = sqs[sq];

    if piece == 1 {
        if rank < 7 {
            let one: i64 = sq + 8;
            if sqs[one] == 0 {
                if rank == 6 {
                    add_promotions(moves, sq, one, 0);
                } else {
                    add_move(moves, sq, one, 0, 0, 0);
                    if rank == 1 {
                        let two: i64 = sq + 16;
                        if sqs[two] == 0 {
                            add_move(moves, sq, two, 0, 0, 0);
                        }
                    }
                }
            }

            if file > 0 {
                let left: i64 = sq + 7;
                let target: i64 = sqs[left];
                if piece_color(target) == -1 {
                    if rank == 6 {
                        add_promotions(moves, sq, left, 0);
                    } else {
                        add_move(moves, sq, left, 0, 0, 0);
                    }
                } else {
                    if b.ep == left {
                        add_move(moves, sq, left, 0, 1, 0);
                    }
                }
            }

            if file < 7 {
                let right: i64 = sq + 9;
                let target2: i64 = sqs[right];
                if piece_color(target2) == -1 {
                    if rank == 6 {
                        add_promotions(moves, sq, right, 0);
                    } else {
                        add_move(moves, sq, right, 0, 0, 0);
                    }
                } else {
                    if b.ep == right {
                        add_move(moves, sq, right, 0, 1, 0);
                    }
                }
            }
        }
    } else {
        if rank > 0 {
            let one2: i64 = sq - 8;
            if sqs[one2] == 0 {
                if rank == 1 {
                    add_promotions(moves, sq, one2, 0);
                } else {
                    add_move(moves, sq, one2, 0, 0, 0);
                    if rank == 6 {
                        let two2: i64 = sq - 16;
                        if sqs[two2] == 0 {
                            add_move(moves, sq, two2, 0, 0, 0);
                        }
                    }
                }
            }

            if file > 0 {
                let left2: i64 = sq - 9;
                let target3: i64 = sqs[left2];
                if piece_color(target3) == 1 {
                    if rank == 1 {
                        add_promotions(moves, sq, left2, 0);
                    } else {
                        add_move(moves, sq, left2, 0, 0, 0);
                    }
                } else {
                    if b.ep == left2 {
                        add_move(moves, sq, left2, 0, 1, 0);
                    }
                }
            }

            if file < 7 {
                let right2: i64 = sq - 7;
                let target4: i64 = sqs[right2];
                if piece_color(target4) == 1 {
                    if rank == 1 {
                        add_promotions(moves, sq, right2, 0);
                    } else {
                        add_move(moves, sq, right2, 0, 0, 0);
                    }
                } else {
                    if b.ep == right2 {
                        add_move(moves, sq, right2, 0, 1, 0);
                    }
                }
            }
        }
    }
}

fn gen_knight_moves(moves: Vec<ChessMove>, b: Board, sq: i64) {
    gen_jump(moves, b, sq, 1, 2);
    gen_jump(moves, b, sq, 2, 1);
    gen_jump(moves, b, sq, -1, 2);
    gen_jump(moves, b, sq, -2, 1);
    gen_jump(moves, b, sq, 1, -2);
    gen_jump(moves, b, sq, 2, -1);
    gen_jump(moves, b, sq, -1, -2);
    gen_jump(moves, b, sq, -2, -1);
}

fn gen_bishop_moves(moves: Vec<ChessMove>, b: Board, sq: i64) {
    gen_slider_dir(moves, b, sq, 1, 1);
    gen_slider_dir(moves, b, sq, -1, 1);
    gen_slider_dir(moves, b, sq, 1, -1);
    gen_slider_dir(moves, b, sq, -1, -1);
}

fn gen_rook_moves(moves: Vec<ChessMove>, b: Board, sq: i64) {
    gen_slider_dir(moves, b, sq, 1, 0);
    gen_slider_dir(moves, b, sq, -1, 0);
    gen_slider_dir(moves, b, sq, 0, 1);
    gen_slider_dir(moves, b, sq, 0, -1);
}

fn gen_king_moves(moves: Vec<ChessMove>, b: Board, sq: i64) {
    let sqs: Vec<i64> = b.squares;

    gen_jump(moves, b, sq, -1, -1);
    gen_jump(moves, b, sq, 0, -1);
    gen_jump(moves, b, sq, 1, -1);
    gen_jump(moves, b, sq, -1, 0);
    gen_jump(moves, b, sq, 1, 0);
    gen_jump(moves, b, sq, -1, 1);
    gen_jump(moves, b, sq, 0, 1);
    gen_jump(moves, b, sq, 1, 1);

    if b.side == 1 && sq == 4 {
        if b.wk == 1 && sqs[5] == 0 && sqs[6] == 0 && sqs[7] == 4 {
            if !square_attacked(b, 4, BLACK) && !square_attacked(b, 5, BLACK) && !square_attacked(b, 6, BLACK) {
                add_move(moves, 4, 6, 0, 0, 1);
            }
        }
        if b.wq == 1 && sqs[0] == 4 && sqs[1] == 0 && sqs[2] == 0 && sqs[3] == 0 {
            if !square_attacked(b, 4, BLACK) && !square_attacked(b, 3, BLACK) && !square_attacked(b, 2, BLACK) {
                add_move(moves, 4, 2, 0, 0, 2);
            }
        }
    }

    if b.side == -1 && sq == 60 {
        if b.bk == 1 && sqs[61] == 0 && sqs[62] == 0 && sqs[63] == -4 {
            if !square_attacked(b, 60, WHITE) && !square_attacked(b, 61, WHITE) && !square_attacked(b, 62, WHITE) {
                add_move(moves, 60, 62, 0, 0, 1);
            }
        }
        if b.bq == 1 && sqs[56] == -4 && sqs[57] == 0 && sqs[58] == 0 && sqs[59] == 0 {
            if !square_attacked(b, 60, WHITE) && !square_attacked(b, 59, WHITE) && !square_attacked(b, 58, WHITE) {
                add_move(moves, 60, 58, 0, 0, 2);
            }
        }
    }
}

fn generate_pseudo_moves(b: Board) -> Vec<ChessMove> {
    let moves: Vec<ChessMove> = Vec::new();
    let sqs: Vec<i64> = b.squares;
    let mut sq: i64 = 0;
    while sq < 64 {
        let piece: i64 = sqs[sq];
        if piece != 0 && piece_color(piece) == b.side {
            let kind: i64 = piece_kind(piece);
            if kind == 1 {
                gen_pawn_moves(moves, b, sq);
            } else {
                if kind == 2 {
                    gen_knight_moves(moves, b, sq);
                } else {
                    if kind == 3 {
                        gen_bishop_moves(moves, b, sq);
                    } else {
                        if kind == 4 {
                            gen_rook_moves(moves, b, sq);
                        } else {
                            if kind == 5 {
                                gen_bishop_moves(moves, b, sq);
                                gen_rook_moves(moves, b, sq);
                            } else {
                                if kind == 6 {
                                    gen_king_moves(moves, b, sq);
                                }
                            }
                        }
                    }
                }
            }
        }
        sq = sq + 1;
    }
    moves
}

fn make_move(b: Board, mv: ChessMove) -> UndoInfo {
    let sqs: Vec<i64> = b.squares;
    let moving: i64 = sqs[mv.from];
    let captured: i64 = sqs[mv.to];

    let old_ep: i64 = b.ep;
    let old_side: i64 = b.side;
    let old_wk: i64 = b.wk;
    let old_wq: i64 = b.wq;
    let old_bk: i64 = b.bk;
    let old_bq: i64 = b.bq;
    let old_halfmove: i64 = b.halfmove;
    let old_non_king_count: i64 = b.non_king_count;

    // Halfmove clock: reset on a pawn move or any capture (irreversible), else +1.
    if piece_kind(moving) == 1 || captured != 0 || mv.en_passant == 1 {
        b.halfmove = 0;
    } else {
        b.halfmove = old_halfmove + 1;
    }
    if captured != 0 && piece_kind(captured) != KING {
        b.non_king_count = b.non_king_count - 1;
    }
    if mv.en_passant == 1 {
        b.non_king_count = b.non_king_count - 1;
    }

    let mut ep_capture_sq: i64 = -1;
    let mut ep_capture_piece: i64 = 0;

    b.ep = -1;
    sqs[mv.from] = EMPTY;

    if mv.en_passant == 1 {
        if moving > 0 {
            ep_capture_sq = mv.to - 8;
        } else {
            ep_capture_sq = mv.to + 8;
        }
        ep_capture_piece = sqs[ep_capture_sq];
        sqs[ep_capture_sq] = EMPTY;
    }

    let mut castle_rook_from: i64 = -1;
    let mut castle_rook_to: i64 = -1;
    let mut castle_rook_piece: i64 = 0;

    if mv.castle == 1 {
        if moving > 0 {
            castle_rook_from = 7;
            castle_rook_to = 5;
            castle_rook_piece = sqs[7];
            sqs[7] = EMPTY;
            sqs[5] = ROOK;
        } else {
            castle_rook_from = 63;
            castle_rook_to = 61;
            castle_rook_piece = sqs[63];
            sqs[63] = EMPTY;
            sqs[61] = -ROOK;
        }
    }
    if mv.castle == 2 {
        if moving > 0 {
            castle_rook_from = 0;
            castle_rook_to = 3;
            castle_rook_piece = sqs[0];
            sqs[0] = EMPTY;
            sqs[3] = ROOK;
        } else {
            castle_rook_from = 56;
            castle_rook_to = 59;
            castle_rook_piece = sqs[56];
            sqs[56] = EMPTY;
            sqs[59] = -ROOK;
        }
    }

    let mut placed: i64 = moving;
    if mv.promote != 0 {
        if moving > 0 {
            placed = mv.promote;
        } else {
            placed = -mv.promote;
        }
    }
    sqs[mv.to] = placed;

    if moving == 6 {
        b.wk = 0;
        b.wq = 0;
        b.wk_sq = mv.to;
    }
    if moving == -6 {
        b.bk = 0;
        b.bq = 0;
        b.bk_sq = mv.to;
    }

    if moving == 4 && mv.from == 0 {
        b.wq = 0;
    }
    if moving == 4 && mv.from == 7 {
        b.wk = 0;
    }
    if moving == -4 && mv.from == 56 {
        b.bq = 0;
    }
    if moving == -4 && mv.from == 63 {
        b.bk = 0;
    }

    if captured == 4 && mv.to == 0 {
        b.wq = 0;
    }
    if captured == 4 && mv.to == 7 {
        b.wk = 0;
    }
    if captured == -4 && mv.to == 56 {
        b.bq = 0;
    }
    if captured == -4 && mv.to == 63 {
        b.bk = 0;
    }

    if moving == 1 && mv.to - mv.from == 16 {
        b.ep = mv.from + 8;
    }
    if moving == -1 && mv.from - mv.to == 16 {
        b.ep = mv.from - 8;
    }

    b.side = -old_side;

    UndoInfo {
        from_sq: moving,
        to_sq: captured,
        ep_capture_sq: ep_capture_sq,
        ep_capture_piece: ep_capture_piece,
        old_ep: old_ep,
        old_side: old_side,
        old_wk: old_wk,
        old_wq: old_wq,
        old_bk: old_bk,
        old_bq: old_bq,
        castle_rook_from: castle_rook_from,
        castle_rook_to: castle_rook_to,
        castle_rook_piece: castle_rook_piece,
        placed: placed,
        old_halfmove: old_halfmove,
        old_non_king_count: old_non_king_count,
    }
}

fn unmake_move(b: Board, mv: ChessMove, u: UndoInfo) {
    let sqs: Vec<i64> = b.squares;

    sqs[mv.to] = u.to_sq;
    sqs[mv.from] = u.from_sq;

    if u.ep_capture_sq >= 0 {
        sqs[u.ep_capture_sq] = u.ep_capture_piece;
    }

    if u.castle_rook_from >= 0 {
        sqs[u.castle_rook_to] = EMPTY;
        sqs[u.castle_rook_from] = u.castle_rook_piece;
    }

    b.ep = u.old_ep;
    b.side = u.old_side;
    b.wk = u.old_wk;
    b.wq = u.old_wq;
    b.bk = u.old_bk;
    b.bq = u.old_bq;
    if u.from_sq == 6 {
        b.wk_sq = mv.from;
    }
    if u.from_sq == -6 {
        b.bk_sq = mv.from;
    }
    b.halfmove = u.old_halfmove;
    b.non_king_count = u.old_non_king_count;
}

fn generate_legal_moves(b: Board) -> Vec<ChessMove> {
    let pseudo: Vec<ChessMove> = generate_pseudo_moves(b);
    let legal: Vec<ChessMove> = Vec::new();
    let mover: i64 = b.side;
    let mut i: i64 = 0;
    while i < pseudo.len() {
        let mv: ChessMove = pseudo[i];
        let undo: UndoInfo = make_move(b, mv);
        let check: bool = in_check(b, mover);
        unmake_move(b, mv, undo);
        if !check {
            legal.push(mv);
        }
        i = i + 1;
    }
    legal
}

fn perft(b: Board, depth: i64) -> i64 {
    if depth <= 0 {
        return 1;
    }
    let moves: Vec<ChessMove> = generate_legal_moves(b);
    if depth == 1 {
        return moves.len();
    }
    let mut total: i64 = 0;
    let mut i: i64 = 0;
    while i < moves.len() {
        let mv: ChessMove = moves[i];
        let undo: UndoInfo = make_move(b, mv);
        total = total + perft(b, depth - 1);
        unmake_move(b, mv, undo);
        i = i + 1;
    }
    total
}

fn center_distance(file: i64, rank: i64) -> i64 {
    let file_dist: i64 = min_i64(abs_i64(file - 3), abs_i64(file - 4));
    let rank_dist: i64 = min_i64(abs_i64(rank - 3), abs_i64(rank - 4));
    file_dist + rank_dist
}

fn center_bonus(file: i64, rank: i64) -> i64 {
    let score: i64 = 6 - 2 * center_distance(file, rank);
    max_i64(score, 0)
}

fn side_structure_score(b: Board, color: i64) -> i64 {
    let sqs: Vec<i64> = b.squares;
    let mut score: i64 = 0;
    let mut bishops: i64 = 0;
    let mut knights: i64 = 0;
    let mut sq: i64 = 0;
    while sq < 64 {
        let piece: i64 = sqs[sq];
        if piece_color(piece) == color {
            if piece_kind(piece) == 3 {
                bishops = bishops + 1;
            }
            if piece_kind(piece) == 2 {
                knights = knights + 1;
            }
        }
        sq = sq + 1;
    }

    if bishops >= 2 {
        score = score + 24;
    }

    // Development bonus: only award if the piece type still exists on the
    // board. Without this guard, captured pieces give a permanent bonus
    // because the starting square is empty.
    if color == 1 {
        if knights > 0 {
            if sqs[1] != 2 {
                score = score + 18;
            }
            if sqs[6] != 2 {
                score = score + 18;
            }
        }
        if bishops > 0 {
            if sqs[2] != 3 {
                score = score + 16;
            }
            if sqs[5] != 3 {
                score = score + 16;
            }
        }
        if sqs[6] == 6 || sqs[2] == 6 {
            score = score + 40;
        }
    } else {
        if knights > 0 {
            if sqs[57] != -2 {
                score = score + 18;
            }
            if sqs[62] != -2 {
                score = score + 18;
            }
        }
        if bishops > 0 {
            if sqs[58] != -3 {
                score = score + 16;
            }
            if sqs[61] != -3 {
                score = score + 16;
            }
        }
        if sqs[62] == -6 || sqs[58] == -6 {
            score = score + 40;
        }
    }

    score
}

// Positional terms beyond the PeSTO tables: pawn structure
// (doubled/isolated/passed), rook activity (open/semi-open files, 7th rank),
// and tapered king safety. Returned white-positive.
fn positional_score(b: Board) -> i64 {
    let sqs: Vec<i64> = b.squares;
    let wfile: Vec<i64> = make_zeros(8);
    let bfile: Vec<i64> = make_zeros(8);
    let wmin: Vec<i64> = make_zeros(8);
    let bmax: Vec<i64> = make_zeros(8);
    let mut f: i64 = 0;
    while f < 8 {
        wmin[f] = 8;
        bmax[f] = -1;
        f = f + 1;
    }

    let mut sq: i64 = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        if p == 1 {
            let ff: i64 = file_of(sq);
            let rr: i64 = rank_of(sq);
            wfile[ff] = wfile[ff] + 1;
            if rr < wmin[ff] {
                wmin[ff] = rr;
            }
        } else if p == -1 {
            let ff: i64 = file_of(sq);
            let rr: i64 = rank_of(sq);
            bfile[ff] = bfile[ff] + 1;
            if rr > bmax[ff] {
                bmax[ff] = rr;
            }
        }
        sq = sq + 1;
    }

    let mut score: i64 = 0;
    sq = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        if p == 1 {
            let ff: i64 = file_of(sq);
            let rr: i64 = rank_of(sq);
            if wfile[ff] >= 2 {
                score = score - 12;
            }
            let wl: i64 = if ff > 0 { wfile[ff - 1] } else { 0 };
            let wr: i64 = if ff < 7 { wfile[ff + 1] } else { 0 };
            if wl == 0 && wr == 0 {
                score = score - 16;
            }
            let bl: i64 = if ff > 0 { bmax[ff - 1] } else { -1 };
            let br: i64 = if ff < 7 { bmax[ff + 1] } else { -1 };
            if bl <= rr && bmax[ff] <= rr && br <= rr {
                score = score + rr * rr * 3 + 10;
            }
        } else if p == -1 {
            let ff: i64 = file_of(sq);
            let rr: i64 = rank_of(sq);
            if bfile[ff] >= 2 {
                score = score + 12;
            }
            let bl2: i64 = if ff > 0 { bfile[ff - 1] } else { 0 };
            let br2: i64 = if ff < 7 { bfile[ff + 1] } else { 0 };
            if bl2 == 0 && br2 == 0 {
                score = score + 16;
            }
            let wl2: i64 = if ff > 0 { wmin[ff - 1] } else { 8 };
            let wr2: i64 = if ff < 7 { wmin[ff + 1] } else { 8 };
            if wl2 >= rr && wmin[ff] >= rr && wr2 >= rr {
                let adv: i64 = 7 - rr;
                score = score - (adv * adv * 3 + 10);
            }
        }
        sq = sq + 1;
    }

    sq = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        let ff: i64 = file_of(sq);
        let rr: i64 = rank_of(sq);
        if p == 4 {
            if wfile[ff] == 0 {
                if bfile[ff] == 0 {
                    score = score + 20;
                } else {
                    score = score + 10;
                }
            }
            if rr == 6 {
                score = score + 20;
            }
        } else if p == -4 {
            if bfile[ff] == 0 {
                if wfile[ff] == 0 {
                    score = score - 20;
                } else {
                    score = score - 10;
                }
            }
            if rr == 1 {
                score = score - 20;
            }
        }
        sq = sq + 1;
    }

    score
}

fn basic_mop_up_bonus(own_king: i64, enemy_king: i64, mating_piece: i64) -> i64 {
    let enemy_file: i64 = file_of(enemy_king);
    let enemy_rank: i64 = rank_of(enemy_king);
    let file_edge: i64 = min_i64(enemy_file, 7 - enemy_file);
    let rank_edge: i64 = min_i64(enemy_rank, 7 - enemy_rank);
    let corner_closeness: i64 = 6 - (file_edge + rank_edge);
    let king_distance: i64 = abs_i64(file_of(own_king) - enemy_file) + abs_i64(rank_of(own_king) - enemy_rank);
    let king_closeness: i64 = 14 - king_distance;
    let piece_distance: i64 = abs_i64(file_of(mating_piece) - enemy_file) + abs_i64(rank_of(mating_piece) - enemy_rank);
    let piece_closeness: i64 = 14 - piece_distance;
    corner_closeness * 7 + king_closeness * king_closeness * 2 + piece_closeness * piece_closeness
}

fn minor_mop_up_bonus(own_king: i64, enemy_king: i64, bishop_colour: i64, correct_bishop_corner: bool) -> i64 {
    let enemy_file: i64 = file_of(enemy_king);
    let enemy_rank: i64 = rank_of(enemy_king);
    let king_distance: i64 = abs_i64(file_of(own_king) - enemy_file) + abs_i64(rank_of(own_king) - enemy_rank);
    let king_closeness: i64 = 14 - king_distance;
    let mut corner_closeness: i64 = 0;
    if correct_bishop_corner {
        let mut first_distance: i64 = 0;
        let mut second_distance: i64 = 0;
        if bishop_colour == 0 {
            first_distance = enemy_file + enemy_rank;
            second_distance = (7 - enemy_file) + (7 - enemy_rank);
        } else {
            first_distance = (7 - enemy_file) + enemy_rank;
            second_distance = enemy_file + (7 - enemy_rank);
        }
        corner_closeness = 7 - min_i64(first_distance, second_distance);
    } else {
        let file_edge: i64 = min_i64(enemy_file, 7 - enemy_file);
        let rank_edge: i64 = min_i64(enemy_rank, 7 - enemy_rank);
        corner_closeness = 6 - (file_edge + rank_edge);
    }
    king_closeness * king_closeness * 2 + corner_closeness * 20
}

// Return a white-positive mating gradient only for the exact basic-mate
// material sets KQ/KR/KBB/KBN versus a bare king.
fn mop_up_score(b: Board) -> i64 {
    let sqs: Vec<i64> = b.squares;
    let mut white_non_king: i64 = 0;
    let mut black_non_king: i64 = 0;
    let mut white_queens: i64 = 0;
    let mut black_queens: i64 = 0;
    let mut white_rooks: i64 = 0;
    let mut black_rooks: i64 = 0;
    let mut white_bishops: i64 = 0;
    let mut black_bishops: i64 = 0;
    let mut white_knights: i64 = 0;
    let mut black_knights: i64 = 0;
    let mut white_even_bishops: i64 = 0;
    let mut black_even_bishops: i64 = 0;
    let mut white_bishop_colour: i64 = -1;
    let mut black_bishop_colour: i64 = -1;
    let mut white_mating_piece: i64 = -1;
    let mut black_mating_piece: i64 = -1;
    let mut sq: i64 = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        let kind: i64 = piece_kind(p);
        if kind != EMPTY && kind != KING {
            if p > 0 {
                white_non_king = white_non_king + 1;
                if kind == QUEEN {
                    white_queens = white_queens + 1;
                    white_mating_piece = sq;
                } else {
                    if kind == ROOK {
                        white_rooks = white_rooks + 1;
                        white_mating_piece = sq;
                    } else {
                        if kind == BISHOP {
                            white_bishops = white_bishops + 1;
                            white_bishop_colour = (file_of(sq) + rank_of(sq)) % 2;
                            if white_bishop_colour == 0 {
                                white_even_bishops = white_even_bishops + 1;
                            }
                        } else {
                            if kind == KNIGHT {
                                white_knights = white_knights + 1;
                            }
                        }
                    }
                }
            } else {
                black_non_king = black_non_king + 1;
                if kind == QUEEN {
                    black_queens = black_queens + 1;
                    black_mating_piece = sq;
                } else {
                    if kind == ROOK {
                        black_rooks = black_rooks + 1;
                        black_mating_piece = sq;
                    } else {
                        if kind == BISHOP {
                            black_bishops = black_bishops + 1;
                            black_bishop_colour = (file_of(sq) + rank_of(sq)) % 2;
                            if black_bishop_colour == 0 {
                                black_even_bishops = black_even_bishops + 1;
                            }
                        } else {
                            if kind == KNIGHT {
                                black_knights = black_knights + 1;
                            }
                        }
                    }
                }
            }
        }
        sq = sq + 1;
    }

    if black_non_king == 0 && white_non_king == 1 && (white_queens == 1 || white_rooks == 1) {
        return basic_mop_up_bonus(b.wk_sq, b.bk_sq, white_mating_piece);
    }
    if black_non_king == 0 && white_non_king == 2 {
        if white_bishops == 2 && white_even_bishops == 1 {
            return minor_mop_up_bonus(b.wk_sq, b.bk_sq, -1, false);
        }
        if white_bishops == 1 && white_knights == 1 {
            return minor_mop_up_bonus(b.wk_sq, b.bk_sq, white_bishop_colour, true);
        }
    }
    if white_non_king == 0 && black_non_king == 1 && (black_queens == 1 || black_rooks == 1) {
        return -basic_mop_up_bonus(b.bk_sq, b.wk_sq, black_mating_piece);
    }
    if white_non_king == 0 && black_non_king == 2 {
        if black_bishops == 2 && black_even_bishops == 1 {
            return -minor_mop_up_bonus(b.bk_sq, b.wk_sq, -1, false);
        }
        if black_bishops == 1 && black_knights == 1 {
            return -minor_mop_up_bonus(b.bk_sq, b.wk_sq, black_bishop_colour, true);
        }
    }
    0
}

// PeSTO tapered piece-square evaluation. Each side's material+placement is
// accumulated for midgame and endgame from the pst tables, then blended by the
// game phase. White uses pst[sq]; black mirrors the rank (sq ^ 56) and negates.
fn evaluate_board(b: Board, pst: Vec<i64>) -> i64 {
    let sqs: Vec<i64> = b.squares;
    let mut mg: i64 = 0;
    let mut eg: i64 = 0;
    let mut phase: i64 = 0;
    let mut sq: i64 = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        if p != 0 {
            let kind: i64 = piece_kind(p);
            if kind == 2 || kind == 3 {
                phase = phase + 1;
            } else if kind == 4 {
                phase = phase + 2;
            } else if kind == 5 {
                phase = phase + 4;
            }
            if p > 0 {
                mg = mg + pst[(kind - 1) * 64 + sq];
                eg = eg + pst[(6 + kind - 1) * 64 + sq];
            } else {
                let msq: i64 = sq ^ 56;
                mg = mg - pst[(kind - 1) * 64 + msq];
                eg = eg - pst[(6 + kind - 1) * 64 + msq];
            }
        }
        sq = sq + 1;
    }
    if phase > 24 {
        phase = 24;
    }
    let mut score: i64 = (mg * phase + eg * (24 - phase)) / 24;
    score = score + side_structure_score(b, 1) - side_structure_score(b, -1) + positional_score(b);
    // The largest named KX set is KQvK (phase 4). Reuse the PeSTO phase as a
    // cheap hot-path gate so ordinary positions never pay for another scan.
    if phase <= 4 {
        score = score + mop_up_score(b);
    }
    score
}

fn captured_piece_value(b: Board, mv: ChessMove) -> i64 {
    let sqs: Vec<i64> = b.squares;
    if mv.en_passant == 1 {
        return piece_value(1);
    }
    let target: i64 = sqs[mv.to];
    if target == 0 {
        0
    } else {
        piece_value(piece_kind(target))
    }
}

fn move_key(mv: ChessMove) -> i64 {
    mv.from + mv.to * 64 + mv.promote * 4096
}

fn make_zeros(n: i64) -> Vec<i64> {
    let v: Vec<i64> = Vec::new();
    let mut i: i64 = 0;
    while i < n {
        v.push(0);
        i = i + 1;
    }
    v
}

// Deterministic Zobrist table (splitmix64, fixed seed). Layout: [0..768) piece
// x square, [768] side-to-move, [769..773) castling, [773..781) ep file.
fn build_ztab() -> Vec<i64> {
    let t: Vec<i64> = Vec::new();
    let mut state: u64 = 8378711321616135283u64;
    let mut i: i64 = 0;
    while i < ZOB_SIZE {
        state = state + 11400714819323198485u64;
        let mut z: u64 = state;
        z = (z ^ (z >> 30u32)) * 13787848793156543929u64;
        z = (z ^ (z >> 27u32)) * 10723151780598845931u64;
        z = z ^ (z >> 31u32);
        t.push(z as i64);
        i = i + 1;
    }
    t
}

fn mix_repetition_context(context: i64, key: i64) -> i64 {
    let mut z: u64 = (context as u64) ^ (key as u64);
    z = z + 11400714819323198485u64;
    z = (z ^ (z >> 30u32)) * 13787848793156543929u64;
    z = (z ^ (z >> 27u32)) * 10723151780598845931u64;
    (z ^ (z >> 31u32)) as i64
}

fn build_tt() -> Vec<TTEntry> {
    let tt: Vec<TTEntry> = Vec::new();
    let mut i: i64 = 0;
    while i < TT_SIZE {
        tt.push(TTEntry { key: 0, depth: 0, score: 0, flag: 0, movekey: 0, generation: 0 });
        i = i + 1;
    }
    tt
}

