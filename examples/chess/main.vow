fn zob_piece_index(piece: i64) -> i64 {
    if piece > 0 {
        piece - 1
    } else {
        5 + (-piece)
    }
}

fn legal_en_passant_from(b: Board, from: i64) -> bool {
    if from < 0 || from >= 64 || b.ep < 0 || b.ep >= 64 {
        return false;
    }
    let sqs: Vec<i64> = b.squares;
    if sqs[from] != b.side * PAWN {
        return false;
    }
    let mv: ChessMove = ChessMove { from: from, to: b.ep, promote: 0, en_passant: 1, castle: 0 };
    let mover: i64 = b.side;
    let undo: UndoInfo = make_move(b, mv);
    let legal: bool = !in_check(b, mover);
    unmake_move(b, mv, undo);
    legal
}

// FIDE position identity includes an en-passant file only when the side to
// move has a legal capture. A merely adjacent but pinned pawn does not count.
fn has_legal_en_passant(b: Board) -> bool {
    if b.ep < 0 || b.ep >= 64 {
        return false;
    }
    let sqs: Vec<i64> = b.squares;
    let ep_file: i64 = file_of(b.ep);
    if sqs[b.ep] != EMPTY {
        return false;
    }
    if b.side == WHITE {
        if rank_of(b.ep) != 5 || sqs[b.ep - 8] != -PAWN {
            return false;
        }
        if ep_file > 0 && legal_en_passant_from(b, b.ep - 9) {
            return true;
        }
        if ep_file < 7 && legal_en_passant_from(b, b.ep - 7) {
            return true;
        }
    } else {
        if rank_of(b.ep) != 2 || sqs[b.ep + 8] != PAWN {
            return false;
        }
        if ep_file > 0 && legal_en_passant_from(b, b.ep + 7) {
            return true;
        }
        if ep_file < 7 && legal_en_passant_from(b, b.ep + 9) {
            return true;
        }
    }
    false
}

fn compute_zkey(b: Board, ztab: Vec<i64>) -> i64 {
    let sqs: Vec<i64> = b.squares;
    let mut key: i64 = 0;
    let mut sq: i64 = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        if p != 0 {
            key = key ^ ztab[zob_piece_index(p) * 64 + sq];
        }
        sq = sq + 1;
    }
    if b.side == -1 {
        key = key ^ ztab[768];
    }
    if b.wk == 1 {
        key = key ^ ztab[769];
    }
    if b.wq == 1 {
        key = key ^ ztab[770];
    }
    if b.bk == 1 {
        key = key ^ ztab[771];
    }
    if b.bq == 1 {
        key = key ^ ztab[772];
    }
    if has_legal_en_passant(b) {
        key = key ^ ztab[773 + file_of(b.ep)];
    }
    key
}

// Ordering score. Tacticals (captures, promotions) occupy bands far above any
// quiet move so that killer/history bonuses on quiets can never overtake a real
// capture. Relative order within tacticals is unchanged from the original
// scheme (a constant offset preserves it), so quiescence ordering is identical.
fn move_order_score(b: Board, mv: ChessMove) -> i64 {
    let sqs: Vec<i64> = b.squares;
    let moving: i64 = sqs[mv.from];
    let moving_value: i64 = piece_value(piece_kind(moving));
    let capture_value: i64 = captured_piece_value(b, mv);
    let mut score: i64 = 4 * center_bonus(file_of(mv.to), rank_of(mv.to));

    if capture_value > 0 {
        score = score + 1000000 + 12 * capture_value - moving_value;
    }
    if mv.promote != 0 {
        score = score + 2000000 + piece_value(mv.promote);
    }
    if mv.castle != 0 {
        score = score + 1200;
    }
    if piece_kind(moving) == 1 && (file_of(mv.to) == 3 || file_of(mv.to) == 4) {
        score = score + 80;
    }
    if piece_kind(moving) == 2 || piece_kind(moving) == 3 {
        score = score + 40;
    }
    score
}

// Negamax move scoring: base ordering plus killer and history bonuses for quiet
// moves. Quiet bonuses live below the capture band so tacticals stay first.
fn score_moves_ns(b: Board, moves: Vec<ChessMove>, ss: SearchState, ply: i64, tt_move_key: i64) -> Vec<i64> {
    let scores: Vec<i64> = Vec::new();
    let k0: i64 = if ply >= 0 && ply < KILLER_SLOTS / 2 { ss.killers[ply * 2] } else { 0 };
    let k1: i64 = if ply >= 0 && ply < KILLER_SLOTS / 2 { ss.killers[ply * 2 + 1] } else { 0 };
    let mut i: i64 = 0;
    while i < moves.len() {
        let mv: ChessMove = moves[i];
        let mut s: i64 = move_order_score(b, mv);
        if tt_move_key != 0 && move_key(mv) == tt_move_key {
            s = s + TT_MOVE_BONUS;
        }
        if mv.promote == 0 && captured_piece_value(b, mv) == 0 {
            let key: i64 = move_key(mv);
            if key == k0 {
                s = s + KILLER1_BONUS;
            } else if key == k1 {
                s = s + KILLER2_BONUS;
            }
            let h: i64 = ss.history[mv.from * 64 + mv.to];
            if h > HISTORY_ORDER_CAP {
                s = s + HISTORY_ORDER_CAP;
            } else {
                s = s + h;
            }
        }
        scores.push(s);
        i = i + 1;
    }
    scores
}

fn record_cutoff(ss: SearchState, b: Board, mv: ChessMove, depth: i64, ply: i64) {
    if mv.promote != 0 || captured_piece_value(b, mv) > 0 {
        return;
    }
    if ply >= 0 && ply < KILLER_SLOTS / 2 {
        let key: i64 = move_key(mv);
        if ss.killers[ply * 2] != key {
            ss.killers[ply * 2 + 1] = ss.killers[ply * 2];
            ss.killers[ply * 2] = key;
        }
    }
    ss.history[mv.from * 64 + mv.to] = ss.history[mv.from * 64 + mv.to] + depth * depth;
}

// Score every move once. Ordering is applied lazily via pick_best_to_front,
// which selects the current best from the precomputed scores without rescoring
// (the board is unchanged across a node's move loop, so scores are constant).
// This turns per-node ordering from O(n^2) scoring into O(n) scoring.
fn score_moves(b: Board, moves: Vec<ChessMove>) -> Vec<i64> {
    let scores: Vec<i64> = Vec::new();
    let mut i: i64 = 0;
    while i < moves.len() {
        scores.push(move_order_score(b, moves[i]));
        i = i + 1;
    }
    scores
}

fn pick_best_to_front(moves: Vec<ChessMove>, scores: Vec<i64>, start: i64) {
    let mut best_idx: i64 = start;
    let mut best_score: i64 = scores[start];
    let mut i: i64 = start + 1;
    while i < moves.len() {
        if scores[i] > best_score {
            best_score = scores[i];
            best_idx = i;
        }
        i = i + 1;
    }
    if best_idx != start {
        swap_moves(moves, start, best_idx);
        let tmp: i64 = scores[start];
        scores[start] = scores[best_idx];
        scores[best_idx] = tmp;
    }
}

fn swap_moves(moves: Vec<ChessMove>, a: i64, b: i64) {
    if a != b {
        let tmp: ChessMove = moves[a];
        moves[a] = moves[b];
        moves[b] = tmp;
    }
}

fn is_tactical_move(b: Board, mv: ChessMove) -> bool {
    mv.promote != 0 || captured_piece_value(b, mv) > 0
}

// Quiescence capture generator: filters pseudo-moves to tacticals (captures +
// promotions) FIRST, then runs the expensive make/in-check legality test only
// on those few moves — instead of legality-checking every quiet move via
// generate_legal_moves and discarding them. Produces the same set as
// { m in generate_legal_moves(b) : is_tactical_move(b, m) } (see `captest`).
fn generate_captures(b: Board) -> Vec<ChessMove> {
    let pseudo: Vec<ChessMove> = generate_pseudo_moves(b);
    let result: Vec<ChessMove> = Vec::new();
    let mover: i64 = b.side;
    let mut i: i64 = 0;
    while i < pseudo.len() {
        let mv: ChessMove = pseudo[i];
        if is_tactical_move(b, mv) {
            let undo: UndoInfo = make_move(b, mv);
            let chk: bool = in_check(b, mover);
            unmake_move(b, mv, undo);
            if !chk {
                result.push(mv);
            }
        }
        i = i + 1;
    }
    result
}

fn move_full_eq(a: ChessMove, b: ChessMove) -> bool {
    a.from == b.from && a.to == b.to && a.promote == b.promote && a.en_passant == b.en_passant && a.castle == b.castle
}

fn move_in_list(mv: ChessMove, list: Vec<ChessMove>) -> bool {
    let mut i: i64 = 0;
    while i < list.len() {
        if move_full_eq(mv, list[i]) {
            return true;
        }
        i = i + 1;
    }
    false
}

// Differential check: generate_captures(b) must equal, as a set, the tactical
// subset of generate_legal_moves(b). Returns 1 if they diverge, else 0.
fn captures_mismatch(b: Board) -> i64 {
    let caps: Vec<ChessMove> = generate_captures(b);
    let legal: Vec<ChessMove> = generate_legal_moves(b);
    let tac: Vec<ChessMove> = Vec::new();
    let mut i: i64 = 0;
    while i < legal.len() {
        let mv: ChessMove = legal[i];
        if is_tactical_move(b, mv) {
            tac.push(mv);
        }
        i = i + 1;
    }
    if caps.len() != tac.len() {
        return 1;
    }
    let mut j: i64 = 0;
    while j < caps.len() {
        if !move_in_list(caps[j], tac) {
            return 1;
        }
        j = j + 1;
    }
    0
}

fn captest(b: Board, depth: i64) -> i64 {
    let mut bad: i64 = captures_mismatch(b);
    if depth <= 1 {
        return bad;
    }
    let moves: Vec<ChessMove> = generate_legal_moves(b);
    let mut i: i64 = 0;
    while i < moves.len() {
        let mv: ChessMove = moves[i];
        let undo: UndoInfo = make_move(b, mv);
        bad = bad + captest(b, depth - 1);
        unmake_move(b, mv, undo);
        i = i + 1;
    }
    bad
}

fn check_stop(ss: SearchState) [io, read] {
    ss.nodes = ss.nodes + 1;
    if ss.stopped == 0 && ss.nodes % 1024 == 0 {
        if ss.deadline > 0 && time_unix_ms() >= ss.deadline {
            ss.stopped = 1;
        }
        if stdin_ready() {
            let line: String = stdin_read_line();
            if line.len() == 0 {
                ss.stopped = 1;
            } else {
                let trimmed: String = trim_line(line);
                if trimmed.eq(String::from("stop")) {
                    ss.stopped = 1;
                } else {
                    if trimmed.len() > 0 {
                        // `quit` must end a deadline-free infinite search; it is still
                        // queued so the post-search drain dispatches it and shuts down.
                        if trimmed.eq(String::from("quit")) {
                            ss.stopped = 1;
                        }
                        ss.pending.push(trimmed);
                    }
                }
            }
        }
    }
}

// Record the current node in the combined game/search repetition stack and
// report automatic/claimable draws. The caller handles mate/stalemate first.
fn is_draw_node(b: Board, ply: i64, zkey: i64, ss: SearchState) -> bool {
    if ply < 1 {
        return false;
    }
    if b.halfmove >= 100 {
        return true;
    }
    let rep_idx: i64 = ss.rep_base + ply;
    if rep_idx < 0 || rep_idx >= REP_SIZE {
        return false;
    }
    let mut lim: i64 = rep_idx - b.halfmove;
    if lim < 0 {
        lim = 0;
    }
    let mut game_matches: i64 = 0;
    let mut back: i64 = rep_idx - 2;
    while back >= lim {
        if ss.rep[back] == zkey {
            if back >= ss.rep_base {
                return true;
            }
            game_matches = game_matches + 1;
            if game_matches >= 2 {
                return true;
            }
        }
        back = back - 2;
    }
    ss.rep[rep_idx] = zkey;
    if b.halfmove == 0 {
        ss.rep_context[rep_idx] = mix_repetition_context(REP_CONTEXT_SEED, zkey);
    } else {
        ss.rep_context[rep_idx] = mix_repetition_context(ss.rep_context[rep_idx - 1], zkey);
    }
    false
}

fn quiesce(b: Board, alpha_in: i64, beta_in: i64, qdepth: i64, ply: i64, ss: SearchState) -> i64 [io, read] {
    let mut alpha: i64 = alpha_in;
    let beta: i64 = beta_in;
    let mut moves: Vec<ChessMove> = Vec::new();
    let mut is_in_check: i64 = 0;

    if b.non_king_count <= 2 && is_insufficient_material(b) {
        return 0;
    }
    if in_check(b, b.side) {
        is_in_check = 1;
        moves = generate_legal_moves(b);
        if moves.len() == 0 {
            return -MATE;
        }
        if is_draw_node(b, ply, compute_zkey(b, ss.ztab), ss) {
            return 0;
        }
        if qdepth <= 0 {
            return alpha_in;
        }
    } else {
        if is_draw_node(b, ply, compute_zkey(b, ss.ztab), ss) {
            return 0;
        }
        let stand_pat: i64 = b.side * evaluate_board(b, ss.pst);
        if stand_pat >= beta {
            return stand_pat;
        }
        if stand_pat > alpha {
            alpha = stand_pat;
        }
        moves = generate_captures(b);
        if moves.len() == 0 {
            return stand_pat;
        }
    }

    let mut best: i64 = -INF;
    if is_in_check == 0 {
        best = alpha;
    }
    let scores: Vec<i64> = score_moves(b, moves);
    let mut i: i64 = 0;
    while i < moves.len() {
        check_stop(ss);
        if ss.stopped == 1 {
            break;
        }
        pick_best_to_front(moves, scores, i);
        let mv: ChessMove = moves[i];
        let undo: UndoInfo = make_move(b, mv);
        let score: i64 = -quiesce(b, -beta, -alpha, qdepth - 1, ply + 1, ss);
        unmake_move(b, mv, undo);
        if score > best {
            best = score;
        }
        if score > alpha {
            alpha = score;
        }
        if alpha >= beta {
            return best;
        }
        i = i + 1;
    }
    best
}

// White has one quiet check evasion (Ka1-b1). The resulting position is
// already present in the search-line repetition stack, so recursive quiescence
// must score the evasion as a draw rather than the losing static position.
fn quiesce_repetition_self_test(us: UciState) -> i64 [io, read] {
    let sqs: Vec<i64> = make_zeros(64);
    sqs[0] = KING;
    sqs[18] = -QUEEN;
    sqs[56] = -ROOK;
    sqs[63] = -KING;
    let b: Board = Board { squares: sqs, side: WHITE, ep: -1, wk: 0, wq: 0, bk: 0, bq: 0, wk_sq: 0, bk_sq: 63, halfmove: 4 };
    let legal: Vec<ChessMove> = generate_legal_moves(b);
    if legal.len() != 1 || legal[0].from != 0 || legal[0].to != 1 {
        return 1;
    }

    let evasion: ChessMove = legal[0];
    let undo: UndoInfo = make_move(b, evasion);
    let repeated_key: i64 = compute_zkey(b, us.ztab);
    unmake_move(b, evasion, undo);

    let rep: Vec<i64> = make_zeros(REP_SIZE);
    rep[4] = repeated_key;
    let ss: SearchState = SearchState { stopped: 0, nodes: 0, deadline: 0, infinite: 0, killers: make_zeros(KILLER_SLOTS), history: make_zeros(HISTORY_SIZE), ztab: us.ztab, tt: us.tt, pst: us.pst, rep: rep, rep_context: make_zeros(REP_SIZE), rep_base: 4, tt_generation: us.tt_generation, pending: Vec::new() };
    let score: i64 = quiesce(b, -INF, INF, 1, 1, ss);
    if score == 0 { 0 } else { 1 }
}

// Warm the same TT position under two search histories. In the first, the
// forced Kb1 evasion repeats the search root and is a draw; in the second it is
// not. A cutoff cached for the checked position must not cross those contexts.
fn tt_repetition_path_self_test(us: UciState) -> i64 [io, read] {
    let sqs: Vec<i64> = make_zeros(64);
    sqs[0] = KING;
    sqs[18] = -QUEEN;
    sqs[56] = -ROOK;
    sqs[63] = -KING;
    let b: Board = Board { squares: sqs, side: WHITE, ep: -1, wk: 0, wq: 0, bk: 0, bq: 0, wk_sq: 0, bk_sq: 63, halfmove: 4 };
    let legal: Vec<ChessMove> = generate_legal_moves(b);
    if legal.len() != 1 || legal[0].from != 0 || legal[0].to != 1 {
        return 1;
    }

    let undo: UndoInfo = make_move(b, legal[0]);
    let repeated_key: i64 = compute_zkey(b, us.ztab);
    unmake_move(b, legal[0], undo);

    let repeated_rep: Vec<i64> = make_zeros(REP_SIZE);
    repeated_rep[4] = repeated_key;
    let repeated_context: Vec<i64> = make_zeros(REP_SIZE);
    repeated_context[4] = mix_repetition_context(mix_repetition_context(REP_CONTEXT_SEED, repeated_key), REP_CONTEXT_BOUNDARY);
    let repeated_ss: SearchState = SearchState { stopped: 0, nodes: 0, deadline: 0, infinite: 0, killers: make_zeros(KILLER_SLOTS), history: make_zeros(HISTORY_SIZE), ztab: us.ztab, tt: us.tt, pst: us.pst, rep: repeated_rep, rep_context: repeated_context, rep_base: 4, tt_generation: -1, pending: Vec::new() };
    let repeated_score: i64 = negamax(b, 1, 1, -INF, INF, repeated_ss);

    let clear_context: Vec<i64> = make_zeros(REP_SIZE);
    clear_context[4] = mix_repetition_context(mix_repetition_context(REP_CONTEXT_SEED, 0), REP_CONTEXT_BOUNDARY);
    let stale_ss: SearchState = SearchState { stopped: 0, nodes: 0, deadline: 0, infinite: 0, killers: make_zeros(KILLER_SLOTS), history: make_zeros(HISTORY_SIZE), ztab: us.ztab, tt: us.tt, pst: us.pst, rep: make_zeros(REP_SIZE), rep_context: clear_context, rep_base: 4, tt_generation: -1, pending: Vec::new() };
    let stale_score: i64 = negamax(b, 1, 1, -INF, INF, stale_ss);

    let fresh_context: Vec<i64> = make_zeros(REP_SIZE);
    fresh_context[4] = mix_repetition_context(mix_repetition_context(REP_CONTEXT_SEED, 0), REP_CONTEXT_BOUNDARY);
    let fresh_ss: SearchState = SearchState { stopped: 0, nodes: 0, deadline: 0, infinite: 0, killers: make_zeros(KILLER_SLOTS), history: make_zeros(HISTORY_SIZE), ztab: us.ztab, tt: us.tt, pst: us.pst, rep: make_zeros(REP_SIZE), rep_context: fresh_context, rep_base: 4, tt_generation: -2, pending: Vec::new() };
    let fresh_score: i64 = negamax(b, 1, 1, -INF, INF, fresh_ss);

    if repeated_score != 0 || stale_score != fresh_score { 1 } else { 0 }
}

fn has_non_pawn_material(b: Board, color: i64) -> bool {
    let sqs: Vec<i64> = b.squares;
    let mut sq: i64 = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        if piece_color(p) == color {
            let k: i64 = piece_kind(p);
            if k == 2 || k == 3 || k == 4 || k == 5 {
                return true;
            }
        }
        sq = sq + 1;
    }
    false
}

// Dead positions covered by the standard insufficient-material cases used by
// the engine: bare kings, one bishop or knight against a bare king, and one
// bishop per side when both bishops live on the same square colour.
fn is_insufficient_material(b: Board) -> bool {
    let sqs: Vec<i64> = b.squares;
    let mut white_bishops: i64 = 0;
    let mut black_bishops: i64 = 0;
    let mut white_knights: i64 = 0;
    let mut black_knights: i64 = 0;
    let mut first_bishop_colour: i64 = -1;
    let mut bishops_same_colour: bool = true;
    let mut sq: i64 = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        let kind: i64 = piece_kind(p);
        if kind == BISHOP {
            if p > 0 {
                white_bishops = white_bishops + 1;
            } else {
                black_bishops = black_bishops + 1;
            }
            let square_colour: i64 = (file_of(sq) + rank_of(sq)) % 2;
            if first_bishop_colour < 0 {
                first_bishop_colour = square_colour;
            } else {
                if square_colour != first_bishop_colour {
                    bishops_same_colour = false;
                }
            }
        } else {
            if kind == KNIGHT {
                if p > 0 {
                    white_knights = white_knights + 1;
                } else {
                    black_knights = black_knights + 1;
                }
            } else {
                if kind != EMPTY && kind != KING {
                    return false;
                }
            }
        }
        if white_bishops + black_bishops + white_knights + black_knights > 2 {
            return false;
        }
        sq = sq + 1;
    }

    let bishops: i64 = white_bishops + black_bishops;
    let knights: i64 = white_knights + black_knights;
    let minors: i64 = bishops + knights;
    if minors == 0 {
        return true;
    }
    if minors == 1 {
        return true;
    }
    bishops == 2 && knights == 0 && white_bishops == 1 && black_bishops == 1 && bishops_same_colour
}

fn negamax(b: Board, depth: i64, ply: i64, alpha_in: i64, beta_in: i64, ss: SearchState) -> i64 [io, read] {
    let legal: Vec<ChessMove> = generate_legal_moves(b);
    let in_chk: bool = in_check(b, b.side);
    if legal.len() == 0 {
        if in_chk {
            return -MATE + ply;
        } else {
            return 0;
        }
    }
    if b.non_king_count <= 2 && is_insufficient_material(b) {
        return 0;
    }

    // Check extension: search one ply deeper when in check (forcing lines). The
    // extension is disabled past MAX_DEPTH*2 plies so a pathological forced-check
    // line (which the 50-move rule already bounds in practice) can never sustain
    // the recursion indefinitely — defence in depth against stack exhaustion.
    // Keep repetition_history_capacity's check-extension and QUIESCE_DEPTH
    // headroom derivation in sync with this cutoff and the quiescence call.
    let mut d: i64 = depth;
    if in_chk && ply < MAX_DEPTH * 2 {
        d = d + 1;
    }

    let zkey: i64 = compute_zkey(b, ss.ztab);

    // Draw detection is shared with recursive quiescence. Before rep_base, two
    // matching played positions make this node the third occurrence. At or
    // after rep_base, one match retains the existing search-cycle cutoff.
    if is_draw_node(b, ply, zkey, ss) {
        return 0;
    }

    if d <= 0 {
        return quiesce(b, alpha_in, beta_in, QUIESCE_DEPTH, ply, ss);
    }

    let mut alpha: i64 = alpha_in;
    let beta: i64 = beta_in;

    // Transposition table probe. Position and rolling repetition context are
    // folded into the stored key, so cutoffs cannot cross different search paths
    // within the same `go` without growing every entry. Generation rejects other
    // UCI histories.
    let rep_idx: i64 = ss.rep_base + ply;
    let tt_context_valid: bool = rep_idx >= 0 && rep_idx < REP_SIZE;
    let mut tt_rep_context: i64 = 0;
    let mut tt_key: i64 = 0;
    if tt_context_valid {
        tt_rep_context = mix_repetition_context(ss.rep_context[rep_idx], b.halfmove);
        tt_key = mix_repetition_context(zkey, tt_rep_context);
    }
    let tt_idx: i64 = zkey & TT_MASK;
    let ttv: Vec<TTEntry> = ss.tt;
    let e: TTEntry = ttv[tt_idx];
    let mut tt_move_key: i64 = 0;
    if tt_context_valid && e.flag != 0 && e.key == tt_key && e.generation == ss.tt_generation {
        tt_move_key = e.movekey;
        if e.depth >= d {
            if e.flag == TT_EXACT {
                return e.score;
            }
            if e.flag == TT_LOWER && e.score >= beta {
                return e.score;
            }
            if e.flag == TT_UPPER && e.score <= alpha {
                return e.score;
            }
        }
    }

    // Null-move pruning: if we can pass and still fail high, the position is so
    // good that we prune. Skipped in check and when the side to move has only
    // pawns (zugzwang risk).
    if d >= 3 && !in_chk && beta < MATE_THRESHOLD && beta > -MATE_THRESHOLD && has_non_pawn_material(b, b.side) {
        let r_null: i64 = 2;
        let saved_ep: i64 = b.ep;
        b.ep = -1;
        b.side = -b.side;
        let nscore: i64 = -negamax(b, d - 1 - r_null, ply + 1, -beta, -beta + 1, ss);
        b.side = -b.side;
        b.ep = saved_ep;
        if ss.stopped == 0 && nscore >= beta {
            return beta;
        }
    }

    let mut best: i64 = -INF;
    let mut best_move_key: i64 = 0;
    let scores: Vec<i64> = score_moves_ns(b, legal, ss, ply, tt_move_key);
    let mut i: i64 = 0;
    let mut searched: i64 = 0;
    while i < legal.len() {
        check_stop(ss);
        if ss.stopped == 1 {
            break;
        }
        pick_best_to_front(legal, scores, i);
        let mv: ChessMove = legal[i];
        let quiet: bool = mv.promote == 0 && captured_piece_value(b, mv) == 0;
        let undo: UndoInfo = make_move(b, mv);
        let mut score: i64 = 0;
        if searched == 0 {
            score = -negamax(b, d - 1, ply + 1, -beta, -alpha, ss);
        } else {
            let mut red: i64 = 0;
            if d >= 3 && searched >= 4 && quiet && !in_chk {
                red = 1;
                if searched >= 8 {
                    red = 2;
                }
            }
            score = -negamax(b, d - 1 - red, ply + 1, -alpha - 1, -alpha, ss);
            if score > alpha && red > 0 {
                score = -negamax(b, d - 1, ply + 1, -alpha - 1, -alpha, ss);
            }
            if score > alpha && score < beta {
                score = -negamax(b, d - 1, ply + 1, -beta, -alpha, ss);
            }
        }
        unmake_move(b, mv, undo);
        if score > best {
            best = score;
            best_move_key = move_key(mv);
        }
        if score > alpha {
            alpha = score;
        }
        if alpha >= beta {
            record_cutoff(ss, b, mv, d, ply);
            if ss.stopped == 0 && tt_context_valid {
                ttv[tt_idx] = TTEntry { key: tt_key, depth: d, score: best, flag: TT_LOWER, movekey: best_move_key, generation: ss.tt_generation };
            }
            return best;
        }
        searched = searched + 1;
        i = i + 1;
    }

    if ss.stopped == 0 && tt_context_valid {
        let mut flag: i64 = TT_EXACT;
        if best <= alpha_in {
            flag = TT_UPPER;
        }
        ttv[tt_idx] = TTEntry { key: tt_key, depth: d, score: best, flag: flag, movekey: best_move_key, generation: ss.tt_generation };
    }
    best
}

fn moves_equal(a: ChessMove, b: ChessMove) -> bool {
    a.from == b.from && a.to == b.to && a.promote == b.promote
}

fn repetition_history_capacity() -> i64 {
    // A check extension can keep depth from draining until MAX_DEPTH * 2 plies,
    // after which the remaining normal depth and recursive quiescence still need
    // repetition slots. Keep this synchronized with negamax and QUIESCE_DEPTH.
    let search_headroom: i64 = MAX_DEPTH * 3 + QUIESCE_DEPTH;
    let capacity: i64 = REP_SIZE - search_headroom;
    if capacity < 1 { 1 } else { capacity }
}

fn repetition_headroom_self_test() -> i64 {
    let required: i64 = MAX_DEPTH * 3 + QUIESCE_DEPTH;
    if repetition_history_capacity() + required <= REP_SIZE { 0 } else { 1 }
}

fn make_game_history() -> GameHistory {
    GameHistory { keys: make_zeros(repetition_history_capacity()), start: 0, len: 0 }
}

fn clear_game_history(history: GameHistory) {
    history.start = 0;
    history.len = 0;
}

fn game_history_key_at(history: GameHistory, index: i64) -> i64 {
    history.keys[(history.start + index) % history.keys.len()]
}

fn push_game_history(history: GameHistory, key: i64) {
    let capacity: i64 = history.keys.len();
    if history.len < capacity {
        let index: i64 = (history.start + history.len) % capacity;
        history.keys[index] = key;
        history.len = history.len + 1;
    } else {
        history.keys[history.start] = key;
        history.start = (history.start + 1) % capacity;
    }
}

fn seed_repetition_history(b: Board, game_rep: GameHistory, ss: SearchState) {
    let root_key: i64 = compute_zkey(b, ss.ztab);
    ss.rep_base = 0;
    if game_rep.len == 0 || game_history_key_at(game_rep, game_rep.len - 1) != root_key {
        ss.rep[0] = root_key;
        ss.rep_context[0] = mix_repetition_context(mix_repetition_context(REP_CONTEXT_SEED, root_key), REP_CONTEXT_BOUNDARY);
        return;
    }

    let mut copied: i64 = 0;
    let mut context: i64 = REP_CONTEXT_SEED;
    while copied < game_rep.len {
        let key: i64 = game_history_key_at(game_rep, copied);
        ss.rep[copied] = key;
        context = mix_repetition_context(context, key);
        ss.rep_context[copied] = context;
        copied = copied + 1;
    }
    ss.rep_base = copied - 1;
    ss.rep_context[ss.rep_base] = mix_repetition_context(context, REP_CONTEXT_BOUNDARY);
}

// Iterative deepening: search depth 1, 2, ..., max_depth. The best move from
// each iteration is tried first in the next (PV move ordering).
fn print_info(depth: i64, score: i64, nodes: i64, elapsed_ms: i64, mv: ChessMove) [io] {
    let out: String = String::from("info depth ");
    out.push_str(i64_to_string(depth));
    out.push_str(String::from(" score "));
    if score >= MATE_THRESHOLD {
        out.push_str(String::from("mate "));
        out.push_str(i64_to_string((MATE - score + 1) / 2));
    } else if score <= -MATE_THRESHOLD {
        out.push_str(String::from("mate -"));
        out.push_str(i64_to_string((MATE + score + 1) / 2));
    } else {
        out.push_str(String::from("cp "));
        out.push_str(i64_to_string(score));
    }
    out.push_str(String::from(" nodes "));
    out.push_str(i64_to_string(nodes));
    out.push_str(String::from(" time "));
    out.push_str(i64_to_string(elapsed_ms));
    let mut nps: i64 = 0;
    if elapsed_ms > 0 {
        nps = nodes * 1000 / elapsed_ms;
    }
    out.push_str(String::from(" nps "));
    out.push_str(i64_to_string(nps));
    out.push_str(String::from(" pv "));
    out.push_str(move_to_uci(mv));
    print_line(out);
}

// Iterative deepening bounded by max_depth, ss.deadline for timed searches, or
// an observed stop command. Once the PV move completes, its result can improve
// best_mv even if the rest of that iteration is interrupted; an interruption
// before then retains the previous iteration's result. Root moves are re-ordered
// PV-first each iteration.
fn search_best_move(b: Board, max_depth_in: i64, game_rep: GameHistory, ss: SearchState) -> ChessMove [io, read] {
    let legal: Vec<ChessMove> = generate_legal_moves(b);
    if legal.len() == 0 {
        return null_move();
    }

    let mut max_depth: i64 = max_depth_in;
    if max_depth < 1 {
        max_depth = 1;
    }
    if max_depth > MAX_DEPTH {
        max_depth = MAX_DEPTH;
    }

    ss.stopped = 0;
    ss.nodes = 0;
    seed_repetition_history(b, game_rep, ss);
    let start_ms: i64 = time_unix_ms();
    let mut best_mv: ChessMove = legal[0];
    let mut d: i64 = 1;
    while d <= max_depth {
        if ss.stopped == 1 {
            break;
        }

        if d > 1 {
            let mut j: i64 = 0;
            while j < legal.len() {
                if moves_equal(legal[j], best_mv) {
                    swap_moves(legal, 0, j);
                    break;
                }
                j = j + 1;
            }
        }

        let mut best_score: i64 = -INF;
        let mut alpha: i64 = -INF;
        let beta: i64 = INF;
        let mut iter_best: ChessMove = legal[0];
        let mut done_moves: i64 = 0;

        let scores: Vec<i64> = score_moves(b, legal);
        let mut i: i64 = 0;
        while i < legal.len() {
            check_stop(ss);
            if ss.stopped == 1 {
                break;
            }
            if d <= 1 || i > 0 {
                pick_best_to_front(legal, scores, i);
            }
            let mv: ChessMove = legal[i];
            let undo: UndoInfo = make_move(b, mv);
            let score: i64 = -negamax(b, d - 1, 1, -beta, -alpha, ss);
            unmake_move(b, mv, undo);
            // Discard a move whose search was aborted by the deadline: its score
            // is unreliable. Moves completed before the abort are still valid.
            if ss.stopped == 1 {
                break;
            }
            if score > best_score {
                best_score = score;
                iter_best = mv;
            }
            if score > alpha {
                alpha = score;
            }
            done_moves = done_moves + 1;
            i = i + 1;
        }

        // Commit the best move found this iteration as long as at least the PV
        // move completed. Root searches PV-first, so best-so-far never regresses
        // below the previous depth's choice — capturing partial deeper searches
        // instead of wasting the time spent on an unfinished iteration.
        if done_moves >= 1 {
            best_mv = iter_best;
        }
        if i >= legal.len() {
            let now_ms: i64 = time_unix_ms();
            print_info(d, best_score, ss.nodes, now_ms - start_ms, best_mv);
            if ss.infinite == 0 && (best_score >= MATE_THRESHOLD || best_score <= -MATE_THRESHOLD) {
                break;
            }
        }
        d = d + 1;
    }
    best_mv
}

fn append_square(out: String, sq: i64) {
    out.push_byte(97 + file_of(sq));
    out.push_byte(49 + rank_of(sq));
}

fn move_to_uci(mv: ChessMove) -> String {
    if is_null_move(mv) {
        return String::from("0000");
    }

    let out: String = String::from("");
    append_square(out, mv.from);
    append_square(out, mv.to);
    if mv.promote != 0 {
        if mv.promote == 5 {
            out.push_byte(113);
        } else {
            if mv.promote == 4 {
                out.push_byte(114);
            } else {
                if mv.promote == 3 {
                    out.push_byte(98);
                } else {
                    out.push_byte(110);
                }
            }
        }
    }
    out
}

fn print_line(s: String) [io] {
    print_str(s);
    print_str(String::from("\n"));
}

fn is_space_byte(b: i64) -> bool {
    b == 32 || b == 9 || b == 10 || b == 13
}

fn trim_line(s: String) -> String {
    let mut start: i64 = 0;
    let mut end: i64 = s.len();
    while start < end && is_space_byte(s.byte_at(start)) {
        start = start + 1;
    }
    while end > start && is_space_byte(s.byte_at(end - 1)) {
        end = end - 1;
    }
    s.substring(start, end)
}

fn split_words(s: String) -> Vec<String> {
    let out: Vec<String> = Vec::new();
    let mut i: i64 = 0;
    let n: i64 = s.len();
    while i < n {
        while i < n && is_space_byte(s.byte_at(i)) {
            i = i + 1;
        }
        let start: i64 = i;
        while i < n && !is_space_byte(s.byte_at(i)) {
            i = i + 1;
        }
        if start < i {
            out.push(s.substring(start, i));
        }
    }
    out
}

fn parse_i64_or(s: String, fallback: i64) -> i64 {
    let n: i64 = s.len();
    if n == 0 {
        return fallback;
    }

    let mut i: i64 = 0;
    let mut sign: i64 = 1;
    if s.byte_at(0) == 45 {
        sign = -1;
        i = 1;
        if i == n {
            return fallback;
        }
    }

    let mut value: i64 = 0;
    while i < n {
        let b: i64 = s.byte_at(i);
        if b < 48 || b > 57 {
            return fallback;
        }
        value = value * 10 + (b - 48);
        i = i + 1;
    }
    sign * value
}

fn find_go_int(tokens: Vec<String>, key: String) -> i64 {
    let mut i: i64 = 1;
    while i + 1 < tokens.len() {
        let k: String = tokens[i];
        if k.eq(key) {
            return parse_i64_or(tokens[i + 1], -1);
        }
        i = i + 1;
    }
    -1
}

fn parse_go_limits(tokens: Vec<String>, side: i64) -> GoLimits {
    let depth: i64 = find_go_int(tokens, String::from("depth"));
    if depth >= 1 {
        return GoLimits { fixed_depth: depth, budget_ms: 0, infinite: 0 };
    }

    let mt: i64 = find_go_int(tokens, String::from("movetime"));
    if mt >= 0 {
        let mut budget: i64 = mt;
        if budget < 5 {
            budget = 5;
        }
        return GoLimits { fixed_depth: 0, budget_ms: budget, infinite: 0 };
    }

    let time_key: String = if side == 1 {
        String::from("wtime")
    } else {
        String::from("btime")
    };
    let inc_key: String = if side == 1 {
        String::from("winc")
    } else {
        String::from("binc")
    };
    let remaining: i64 = find_go_int(tokens, time_key);
    if remaining >= 0 {
        let mut inc: i64 = find_go_int(tokens, inc_key);
        if inc < 0 {
            inc = 0;
        }
        let mut mtg: i64 = find_go_int(tokens, String::from("movestogo"));
        if mtg < 1 {
            mtg = 30;
        }
        // Allocate a slice of the remaining time plus most of the increment,
        // never more than half of what is left on the clock.
        let mut budget: i64 = remaining / mtg + (inc * 3) / 4;
        let cap: i64 = remaining / 2;
        if budget > cap {
            budget = cap;
        }
        if budget < 5 {
            budget = 5;
        }
        return GoLimits { fixed_depth: 0, budget_ms: budget, infinite: 0 };
    }

    let mut i: i64 = 1;
    while i < tokens.len() {
        let token: String = tokens[i];
        if token.eq(String::from("infinite")) {
            return GoLimits { fixed_depth: 0, budget_ms: 0, infinite: 1 };
        }
        i = i + 1;
    }

    // `go` with no recognised limits uses the default think time.
    GoLimits { fixed_depth: 0, budget_ms: 1000, infinite: 0 }
}

fn find_legal_move(b: Board, uci: String) -> ChessMove {
    let legal: Vec<ChessMove> = generate_legal_moves(b);
    let mut i: i64 = 0;
    while i < legal.len() {
        let mv: ChessMove = legal[i];
        let text: String = move_to_uci(mv);
        if text.eq(uci) {
            return mv;
        }
        i = i + 1;
    }
    null_move()
}

fn apply_uci_moves(b: Board, tokens: Vec<String>, start_idx: i64, ztab: Vec<i64>, game_rep: GameHistory) -> Board [io] {
    let mut i: i64 = start_idx;
    while i < tokens.len() {
        let text: String = tokens[i];
        let mv: ChessMove = find_legal_move(b, text);
        if is_null_move(mv) {
            let msg: String = String::from("info string invalid move: ");
            msg.push_str(text);
            print_line(msg);
            return b;
        }
        make_move(b, mv);
        if b.halfmove == 0 {
            clear_game_history(game_rep);
        }
        push_game_history(game_rep, compute_zkey(b, ztab));
        i = i + 1;
    }
    b
}

fn fen_char_to_piece(ch: i64) -> i64 {
    if ch == 80 { return PAWN; }
    if ch == 78 { return KNIGHT; }
    if ch == 66 { return BISHOP; }
    if ch == 82 { return ROOK; }
    if ch == 81 { return QUEEN; }
    if ch == 75 { return KING; }
    if ch == 112 { return -PAWN; }
    if ch == 110 { return -KNIGHT; }
    if ch == 98 { return -BISHOP; }
    if ch == 114 { return -ROOK; }
    if ch == 113 { return -QUEEN; }
    if ch == 107 { return -KING; }
    0
}

fn parse_fen_board(placement: String) -> Vec<i64> {
    let sqs: Vec<i64> = Vec::new();
    let mut i: i64 = 0;
    while i < 64 {
        sqs.push(EMPTY);
        i = i + 1;
    }

    let mut rank: i64 = 7;
    let mut file: i64 = 0;
    let mut idx: i64 = 0;
    let n: i64 = placement.len();
    while idx < n {
        let ch: i64 = placement.byte_at(idx);
        if ch == 47 {
            rank = rank - 1;
            file = 0;
        } else {
            if ch >= 49 && ch <= 56 {
                file = file + (ch - 48);
            } else {
                let piece: i64 = fen_char_to_piece(ch);
                if piece != 0 && file < 8 && rank >= 0 {
                    sqs[rank * 8 + file] = piece;
                }
                file = file + 1;
            }
        }
        idx = idx + 1;
    }
    sqs
}

fn parse_fen_castling(s: String) -> Vec<i64> {
    let rights: Vec<i64> = Vec::new();
    let mut wk: i64 = 0;
    let mut wq: i64 = 0;
    let mut bk: i64 = 0;
    let mut bq: i64 = 0;
    let mut i: i64 = 0;
    while i < s.len() {
        let ch: i64 = s.byte_at(i);
        if ch == 75 { wk = 1; }
        if ch == 81 { wq = 1; }
        if ch == 107 { bk = 1; }
        if ch == 113 { bq = 1; }
        i = i + 1;
    }
    rights.push(wk);
    rights.push(wq);
    rights.push(bk);
    rights.push(bq);
    rights
}

fn parse_fen_ep(s: String) -> i64 {
    if s.len() < 2 {
        return -1;
    }
    let file_ch: i64 = s.byte_at(0);
    let rank_ch: i64 = s.byte_at(1);
    if file_ch < 97 || file_ch > 104 {
        return -1;
    }
    if rank_ch < 49 || rank_ch > 56 {
        return -1;
    }
    let file: i64 = file_ch - 97;
    let rank: i64 = rank_ch - 49;
    rank * 8 + file
}

fn parse_fen(tokens: Vec<String>, start_idx: i64) -> Board {
    let placement: String = tokens[start_idx];
    let sqs: Vec<i64> = parse_fen_board(placement);

    let mut side: i64 = WHITE;
    if start_idx + 1 < tokens.len() {
        let color_str: String = tokens[start_idx + 1];
        if color_str.eq(String::from("b")) {
            side = BLACK;
        }
    }

    let mut wk: i64 = 0;
    let mut wq: i64 = 0;
    let mut bk: i64 = 0;
    let mut bq: i64 = 0;
    if start_idx + 2 < tokens.len() {
        let castle_str: String = tokens[start_idx + 2];
        let rights: Vec<i64> = parse_fen_castling(castle_str);
        wk = rights[0];
        wq = rights[1];
        bk = rights[2];
        bq = rights[3];
    }

    let mut ep: i64 = -1;
    if start_idx + 3 < tokens.len() {
        let ep_str: String = tokens[start_idx + 3];
        ep = parse_fen_ep(ep_str);
    }

    let mut wksq: i64 = -1;
    let mut bksq: i64 = -1;
    let mut non_king_count: i64 = 0;
    let mut sq: i64 = 0;
    while sq < 64 {
        let p: i64 = sqs[sq];
        if p == KING {
            wksq = sq;
        } else if p == -KING {
            bksq = sq;
        } else if p != EMPTY {
            non_king_count = non_king_count + 1;
        }
        sq = sq + 1;
    }

    let mut halfmove: i64 = 0;
    if start_idx + 4 < tokens.len() {
        halfmove = parse_i64_or(tokens[start_idx + 4], 0);
    }

    Board {
        squares: sqs,
        side: side,
        ep: ep,
        wk: wk,
        wq: wq,
        bk: bk,
        bq: bq,
        wk_sq: wksq,
        bk_sq: bksq,
        halfmove: halfmove,
        non_king_count: non_king_count,
    }
}

fn seed_game_history(b: Board, ztab: Vec<i64>, game_rep: GameHistory) {
    clear_game_history(game_rep);
    push_game_history(game_rep, compute_zkey(b, ztab));
}

fn handle_position(tokens: Vec<String>, current: Board, ztab: Vec<i64>, game_rep: GameHistory) -> Board [io] {
    if tokens.len() < 2 {
        return current;
    }

    let mode: String = tokens[1];
    if mode.eq(String::from("startpos")) {
        let board: Board = start_board();
        seed_game_history(board, ztab, game_rep);
        if tokens.len() >= 3 {
            let next: String = tokens[2];
            if next.eq(String::from("moves")) {
                return apply_uci_moves(board, tokens, 3, ztab, game_rep);
            }
        }
        return board;
    }

    if mode.eq(String::from("fen")) {
        if tokens.len() < 3 {
            return current;
        }
        let board: Board = parse_fen(tokens, 2);
        seed_game_history(board, ztab, game_rep);
        let mut moves_idx: i64 = 2;
        while moves_idx < tokens.len() {
            let tok: String = tokens[moves_idx];
            if tok.eq(String::from("moves")) {
                return apply_uci_moves(board, tokens, moves_idx + 1, ztab, game_rep);
            }
            moves_idx = moves_idx + 1;
        }
        return board;
    }

    current
}

fn reset_for_new_game(us: UciState) {
    // Canonical per-game reset point: cutechess-cli reuses one engine process
    // across a match, so ucinewgame is the only per-game teardown signal. The
    // killer/history tables are rebuilt fresh per `go`, so only the board and
    // persistent game-position history need resetting here.
    //
    // The transposition table allocation is intentionally retained across games.
    // Clearing it in place (writing struct literals across all ~1M slots from
    // this scope) is not free in the region model — those writes root fresh
    // allocations and leak the table on every `ucinewgame`. Instead, advancing
    // the generation makes all prior entries ineligible without rewriting them.
    us.board = start_board();
    seed_game_history(us.board, us.ztab, us.game_rep);
    us.tt_generation = us.tt_generation + 1;
}

fn handle_perft(tokens: Vec<String>, b: Board) [io] {
    let mut depth: i64 = 1;
    if tokens.len() >= 2 {
        depth = parse_i64_or(tokens[1], 1);
    }
    let moves: Vec<ChessMove> = generate_legal_moves(b);
    let mut total: i64 = 0;
    let mut i: i64 = 0;
    while i < moves.len() {
        let mv: ChessMove = moves[i];
        let undo: UndoInfo = make_move(b, mv);
        let sub: i64 = perft(b, depth - 1);
        unmake_move(b, mv, undo);
        total = total + sub;
        let line: String = move_to_uci(mv);
        line.push_str(String::from(": "));
        line.push_str(i64_to_string(sub));
        print_line(line);
        i = i + 1;
    }
    let summary: String = String::from("Nodes searched: ");
    summary.push_str(i64_to_string(total));
    print_line(summary);
}

fn dispatch_command(us: UciState, line: String) [io, read] {
    let tokens: Vec<String> = split_words(line);
    if tokens.len() == 0 {
        return;
    }
    let cmd: String = tokens[0];

    if cmd.eq(String::from("uci")) {
        print_line(String::from("id name Vow Chess UCI"));
        print_line(String::from("id author Vow Project"));
        print_line(String::from("uciok"));
    } else {
        if cmd.eq(String::from("isready")) {
            print_line(String::from("readyok"));
        } else {
            if cmd.eq(String::from("ucinewgame")) {
                reset_for_new_game(us);
            } else {
                if cmd.eq(String::from("position")) {
                    // GUIs resend the accumulated game before each go. Advancing
                    // here deliberately trades cross-move TT reuse for correctness:
                    // even an incrementally extended history changes which future
                    // nodes can become repetition draws.
                    us.tt_generation = us.tt_generation + 1;
                    us.board = handle_position(tokens, us.board, us.ztab, us.game_rep);
                } else if cmd.eq(String::from("perft")) {
                    handle_perft(tokens, us.board);
                } else if cmd.eq(String::from("captest")) {
                    let cdepth: i64 = if tokens.len() >= 2 { parse_i64_or(tokens[1], 3) } else { 3 };
                    let bad: i64 = captest(us.board, cdepth);
                    let msg: String = String::from("captest mismatches: ");
                    msg.push_str(i64_to_string(bad));
                    print_line(msg);
                } else if cmd.eq(String::from("ttreptest")) {
                    let bad: i64 = tt_repetition_path_self_test(us);
                    let msg: String = String::from("ttreptest mismatches: ");
                    msg.push_str(i64_to_string(bad));
                    print_line(msg);
                } else {
                    if cmd.eq(String::from("reptest")) {
                        let bad: i64 = quiesce_repetition_self_test(us) + repetition_headroom_self_test();
                        let msg: String = String::from("reptest mismatches: ");
                        msg.push_str(i64_to_string(bad));
                        print_line(msg);
                    } else if cmd.eq(String::from("go")) {
                        let limits: GoLimits = parse_go_limits(tokens, us.board.side);
                        let fd: i64 = limits.fixed_depth;
                        let budget: i64 = limits.budget_ms;
                        let infinite: i64 = limits.infinite;
                        let mut deadline: i64 = 0;
                        let mut max_depth: i64 = MAX_DEPTH;
                        if fd > 0 {
                            max_depth = fd;
                        } else {
                            if infinite == 0 {
                                let now: i64 = time_unix_ms();
                                let mut margin: i64 = budget / 20;
                                if margin > 50 {
                                    margin = 50;
                                }
                                if margin < 1 {
                                    margin = 1;
                                }
                                let mut think: i64 = budget - margin;
                                if think < 1 {
                                    think = 1;
                                }
                                deadline = now + think;
                            }
                        }
                        let ss: SearchState = SearchState { stopped: 0, nodes: 0, deadline: deadline, infinite: infinite, killers: make_zeros(KILLER_SLOTS), history: make_zeros(HISTORY_SIZE), ztab: us.ztab, tt: us.tt, pst: us.pst, rep: make_zeros(REP_SIZE), rep_context: make_zeros(REP_SIZE), rep_base: 0, tt_generation: us.tt_generation, pending: Vec::new() };
                        let best: ChessMove = search_best_move(us.board, max_depth, us.game_rep, ss);
                        let out: String = String::from("bestmove ");
                        out.push_str(move_to_uci(best));
                        print_line(out);
                        let mut pi: i64 = 0;
                        while pi < ss.pending.len() {
                            dispatch_command(us, ss.pending[pi]);
                            pi = pi + 1;
                        }
                    } else {
                        if cmd.eq(String::from("stop")) {
                        } else {
                            if cmd.eq(String::from("setoption")) {
                            } else {
                                if cmd.eq(String::from("quit")) {
                                    us.running = 0;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn main() [io, read] {
    let board: Board = start_board();
    let ztab: Vec<i64> = build_ztab();
    let game_rep: GameHistory = make_game_history();
    push_game_history(game_rep, compute_zkey(board, ztab));
    let us: UciState = UciState { board: board, running: 1, ztab: ztab, tt: build_tt(), pst: build_pst(), game_rep: game_rep, tt_generation: 1 };

    while us.running == 1 {
        let raw: String = stdin_read_line();
        if raw.len() == 0 {
            break;
        }

        let line: String = trim_line(raw);
        if line.len() > 0 {
            dispatch_command(us, line);
        }
    }
}
