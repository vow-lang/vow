module VecFill

fn fill_vec(n: i64) -> Vec<i64> vow {
  requires: n >= 0,
  ensures: result.len() == n
} {
  let v: Vec<i64> = Vec::new();
  let mut i: i64 = 0;
  while i < n vow {
    invariant: i >= 0,
    invariant: i <= n
  } {
    v.push(i);
    i = i + 1;
  }
  v
}

fn main() -> i32 [io] {
  let v: Vec<i64> = fill_vec(5);
  print_i64(v.len());
  0
}
