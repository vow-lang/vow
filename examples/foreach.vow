module ForEach

fn sum_vec(v: Vec<i64>) -> i64 {
    let mut total: i64 = 0;
    for x in v {
        total = total + x;
    }
    total
}

fn main() -> i32 [io] {
    let nums: Vec<i64> = Vec::new();
    nums.push(10);
    nums.push(20);
    nums.push(30);
    let result: i64 = sum_vec(nums);
    print_i64(result);
    0
}
