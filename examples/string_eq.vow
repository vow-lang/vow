module StringEq

fn get_greeting() -> String {
  String::from("hello")
}

fn get_name() -> String {
  String::from("world")
}

fn main() -> i32 [io] {
  let a: String = get_greeting();
  let b: String = String::from("hello");
  if a == b {
    print_i64(1)
  } else {
    print_i64(0)
  };
  let c: String = get_name();
  if a == c {
    print_i64(0)
  } else {
    print_i64(1)
  };
  0
}
