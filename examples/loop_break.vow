module LoopBreak

fn find_square_over(limit: i64) -> i64 [io] {
    let mut i: i64 = 0;
    while true {
        let sq: i64 = i * i;
        if sq > limit {
            break;
        }
        i = i + 1;
    }
    i * i
}

fn main() -> i64 [io] {
    let result: i64 = find_square_over(50);
    print_i64(result);
    print_str("\n");
    0
}
