module ForwardRef

fn make_point(x: i64, y: i64) -> Point {
  Point { x: x, y: y }
}

fn distance(a: Point, b: Point) -> i64 {
  let dx: i64 = a.x - b.x;
  let dy: i64 = a.y - b.y;
  dx * dx + dy * dy
}

struct Point {
  x: i64,
  y: i64,
}

fn main() -> i32 [io] {
  let p1: Point = make_point(3, 4);
  let p2: Point = make_point(0, 0);
  let d: i64 = distance(p1, p2);
  print_i64(d);
  0
}
