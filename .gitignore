.env
/target/
compiler/main
build/
compiler/*.o
compiler/*.vow.c
/.claude/*.local.json
/.claude/worktrees/
/.chief/
/.claire/
/.ultraplan/
/codecov
/lcov.info
bench/results/
workflow/results/
__pycache__/

.claude/settings.local.json

# Auto-installed by `vowc build`; regenerates from compiler source, so
# tracking a snapshot would drift relative to the binary. Downstream
# projects (per README) commit their own copy; vow-lang/vow does not.
/.claude/skills/vow/

# vow-mutants outputs
mutants.out
mutants-shard-*/
.clawpatch/

# verifier-evaluation harness output (issue #334)
verify-eval.out/

# MkDocs documentation site. Pages under website/docs/reference/ and
# website/docs/stdlib.md are GENERATED from docs/spec/ by
# scripts/build_docs_site.py; only the hand-written pages are tracked.
/website/site/
/website/docs/reference/*.md
!/website/docs/reference/index.md
/website/docs/reference/schemas/
/website/docs/stdlib.md
/website/.cache/
