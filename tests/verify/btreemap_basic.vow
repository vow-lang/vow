module BTreeMapBasic

fn store_entry(k: i64, v: i64) -> BTreeMap<i64, i64> vow {
  ensures: result.contains(k),
  ensures: result.len() == 1
} {
  let m: BTreeMap<i64, i64> = BTreeMap::new();
  m.insert(k, v);
  m
}

fn main() -> i32 [io] {
  let m: BTreeMap<i64, i64> = store_entry(42, 100);
  print_i64(m.len());
  0
}
