// TEST: category callee-blame
// Fixed version of postcondition_too_strong: uses >= instead of >.
module PostconditionCorrect

fn positive_or_zero(x: i64) -> i64 vow {
  requires: x >= 0,
  ensures: result >= 0
} {
  if x == 0 {
    0
  } else {
    x
  }
}

fn main() -> i32 [io] {
  print_i64(positive_or_zero(5));
  0
}
