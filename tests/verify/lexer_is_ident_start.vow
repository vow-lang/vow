// TEST: category model-drift
module LexerIsIdentStartVerify

fn is_alpha(b: i64) -> bool vow {
    requires: b >= 0,
    requires: b <= 255,
    ensures: result == ((b >= 65 && b <= 90) || (b >= 97 && b <= 122))
} {
    (b >= 65 && b <= 90) || (b >= 97 && b <= 122)
}

fn is_ident_start(b: i64) -> bool vow {
    requires: b >= 0,
    requires: b <= 255,
    ensures: result == (is_alpha(b) || b == 95)
} {
    is_alpha(b) || b == 95
}

fn main() -> i32 {
    if is_ident_start(95) { 0 } else { 1 }
}
