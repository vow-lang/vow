module VecOfVecNonModelable

// Regression test for issue #505. Before the fix, the verifier C model
// emitted ill-typed C (`int64_t = __vow_vec_t`) for any function pushing
// nested Vec values. Now `count_buckets` is correctly marked non-modelable
// and skipped, while `safe_div` with a flat-i64 contract still verifies.
// The whole file must verify cleanly.
// No contract here: a contract on this function would make verification
// status Skipped (it is now flagged non-modelable). The point of this file
// is that the *verifier pipeline* runs cleanly on a program that contains
// __vow_vec_push_val of a Vec value — pre-fix the C emitter produced
// `int64_t = __vow_vec_t` and ESBMC refused to compile.
fn count_buckets(n: i64) -> i64 {
  let buckets: Vec<Vec<i64>> = Vec::new();
  let mut i: i64 = 0;
  while i < n {
    buckets.push(Vec::new());
    i = i + 1;
  }
  buckets.len()
}

fn safe_div(x: i64, y: i64) -> i64 vow {
  requires: y != 0
} {
  x / y
}

fn main() -> i32 [io] {
  print_i64(count_buckets(3));
  print_i64(safe_div(21, 7));
  0
}
