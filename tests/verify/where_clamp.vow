// TEST: category overflow
module WhereClamp

fn bounded_add(a: i64 where a >= 0, b: i64 where b >= 0) -> i64 vow {
  requires: a <= 9223372036854775807 - b,
  ensures: result == a + b,
  ensures: result >= 0
} {
  a + b
}

fn main() -> i32 [io] {
  print_i64(bounded_add(3, 4));
  print_i64(bounded_add(0, 0));
  0
}
