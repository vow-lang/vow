// TEST: category bounds
module StringLiteralByteAt

fn literal_first_byte() -> i64 vow {
    ensures: result == 104
} {
    let s: String = String::from("hello");
    s.byte_at(0)
}

fn literal_first_byte_direct() -> i64 vow {
    ensures: result == 104
} {
    let s: String = "hello";
    s.byte_at(0)
}

fn main() -> i32 {
    0
}
