// TEST: stdout "1\n0\n1\n1\n1\n1\n"
module Issue843

// Regression for #843: a u64-producing match expression must keep its unsigned
// result type in unsigned operations, without an annotated `let: u64` in between.

enum Pick {
    Big,
    Zero,
}

fn exiting_first_arm_compare(p: Pick) -> i64 {
    let value = match p {
        Pick::Big => { return 0 },
        Pick::Zero => { 9223372036854775808u64 },
    };
    if value > 0u64 {
        1
    } else {
        0
    }
}

fn exiting_first_arm_shift(p: Pick) -> u64 {
    let value = match p {
        Pick::Big => { return 0u64 },
        Pick::Zero => { 9223372036854775808u64 },
    };
    value >> 63
}

fn literal_first_arm_compare(p: Pick) -> i64 {
    let value = match p {
        Pick::Big => { 0 },
        Pick::Zero => { 9223372036854775808u64 },
    };
    if value > 0u64 {
        1
    } else {
        0
    }
}

fn main() -> i32 [io] {
    let big: Pick = Pick::Big {};
    let zero: Pick = Pick::Zero {};

    let high = match big {
        Pick::Big => { 9223372036854775808u64 },
        Pick::Zero => { 0u64 },
    };
    if high > 0u64 {
        print_str("1\n");
    } else {
        print_str("0\n");
    }

    let low = match zero {
        Pick::Big => { 9223372036854775808u64 },
        Pick::Zero => { 0u64 },
    };
    if low > 0u64 {
        print_str("1\n");
    } else {
        print_str("0\n");
    }

    print_u64(high >> 63);
    print_str("\n");

    print_i64(exiting_first_arm_compare(zero));
    print_str("\n");

    print_u64(exiting_first_arm_shift(zero));
    print_str("\n");

    print_i64(literal_first_arm_compare(zero));
    print_str("\n");

    0
}
