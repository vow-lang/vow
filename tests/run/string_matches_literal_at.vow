// TEST: stdout "name=1\nid=1\nmiss=0\nloop=4\n"
module StringMatchesLiteralAt

fn count_name_keys(line: String) -> i64 {
    let mut count: i64 = 0;
    let mut i: i64 = 0;
    while i < line.len() {
        if string_matches_literal_at(line, i, "\"name\"") == 1 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

fn main() -> i32 [io] {
    let line: String = String::from("{\"name\":\"vow\",\"id\":42,\"name\":\"agent\",\"name\":\"parser\",\"name\":\"hot\"}");
    print_str(String::from("name="));
    print_i64(string_matches_literal_at(line, 1, "\"name\""));
    print_str(String::from("\n"));

    print_str(String::from("id="));
    print_i64(string_matches_literal_at(line, 14, "\"id\""));
    print_str(String::from("\n"));

    print_str(String::from("miss="));
    print_i64(string_matches_literal_at(line, 2, "\"name\""));
    print_str(String::from("\n"));

    print_str(String::from("loop="));
    print_i64(count_name_keys(line));
    print_str(String::from("\n"));
    0
}
