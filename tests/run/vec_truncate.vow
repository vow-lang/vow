// TEST: stdout "init:12345trunc3:len3:123trunc3_noop:len3:123trunc5_noop:len3:123trunc0:len0:push_after:67done"
module vec_truncate

fn main() -> i32 [io] {
    let v: Vec<i64> = Vec::new();
    v.push(1);
    v.push(2);
    v.push(3);
    v.push(4);
    v.push(5);

    print_str("init:");
    print_i64(v[0]);
    print_i64(v[1]);
    print_i64(v[2]);
    print_i64(v[3]);
    print_i64(v[4]);

    v.truncate(3);
    print_str("trunc3:len");
    print_i64(v.len());
    print_str(":");
    print_i64(v[0]);
    print_i64(v[1]);
    print_i64(v[2]);

    // no-op: same size
    v.truncate(3);
    print_str("trunc3_noop:len");
    print_i64(v.len());
    print_str(":");
    print_i64(v[0]);
    print_i64(v[1]);
    print_i64(v[2]);

    // no-op: larger than current size
    v.truncate(5);
    print_str("trunc5_noop:len");
    print_i64(v.len());
    print_str(":");
    print_i64(v[0]);
    print_i64(v[1]);
    print_i64(v[2]);

    v.truncate(0);
    print_str("trunc0:len");
    print_i64(v.len());
    print_str(":");

    v.push(6);
    v.push(7);
    print_str("push_after:");
    print_i64(v[0]);
    print_i64(v[1]);

    print_str("done");
    0
}
