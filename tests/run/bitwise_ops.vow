// TEST: stdout "6 & 3 = 2\n6 | 3 = 7\n1 << 5 = 32\n-8 >> 1 = -4\n8u64 >> 1u64 = 4\n"
module BitwiseOps

fn main() [io] {
    let a: i64 = 6;
    let b: i64 = 3;
    let left: i64 = 1;
    let neg: i64 = -8;
    let ux: u64 = 8u64;
    let uy: u64 = 1u64;

    print_str(String::from("6 & 3 = "));
    print_i64(a & b);
    print_str(String::from("\n"));

    print_str(String::from("6 | 3 = "));
    print_i64(a | b);
    print_str(String::from("\n"));

    print_str(String::from("1 << 5 = "));
    print_i64(left << 5);
    print_str(String::from("\n"));

    print_str(String::from("-8 >> 1 = "));
    print_i64(neg >> 1);
    print_str(String::from("\n"));

    print_str(String::from("8u64 >> 1u64 = "));
    print_u64(ux >> uy);
    print_str(String::from("\n"));
}
