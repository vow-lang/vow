// TEST: stdout "0"
// Verifies the self-hosted .vmod region encoder/decoder (issue #197,
// spec §12.1 / §15 Phase 2a). This is the acceptance test for the
// "HiddenRegionIdx carried by Caller" round-trip the issue calls out.
module VmodRegionRoundtrip

fn REGION_KIND_BLOCK()  -> i64 vow { ensures: result >= 0 } { 0 }
fn REGION_KIND_CALLER() -> i64 vow { ensures: result >= 0 } { 1 }
fn REGION_KIND_ROOT()   -> i64 vow { ensures: result >= 0 } { 2 }
fn REGION_KIND_RODATA() -> i64 vow { ensures: result >= 0 } { 3 }

fn region_pack(kind: i64, val: i64) -> i64 vow {
    requires: kind >= 0,
    requires: kind <= 3,
    requires: val >= 0,
    requires: val <= 4294967295,
    ensures: result == val * 4 + kind,
    ensures: result >= 0
} { val * 4 + kind }

fn region_kind(r: i64) -> i64 vow {
    requires: r >= 0,
    ensures: result == r - (r / 4) * 4,
    ensures: result >= 0,
    ensures: result <= 3
} { r - (r / 4) * 4 }
fn region_val(r: i64)  -> i64 vow {
    requires: r >= 0,
    ensures: result == r / 4,
    ensures: result >= 0
} { r / 4 }

fn region_encode(out: Vec<i64>, rgn: i64) vow {
    requires: rgn >= 0,
    requires: region_val(rgn) <= 4294967295,
    requires: region_kind(rgn) <= 1 || region_val(rgn) == 0
} {
    let kind: i64 = region_kind(rgn);
    let payload: i64 = region_val(rgn);
    out.push(kind);
    out.push(payload % 256);
    out.push((payload / 256) % 256);
    out.push((payload / 65536) % 256);
    out.push((payload / 16777216) % 256);
}

fn region_decode(buf: Vec<i64>, pos: i64) -> i64 vow {
    requires: pos >= 0,
    requires: pos + 4 < buf.len(),
    requires: buf[pos] >= 0,
    requires: buf[pos] <= 3,
    requires: buf[pos] <= 1 || (buf[pos + 1] == 0 && buf[pos + 2] == 0 && buf[pos + 3] == 0 && buf[pos + 4] == 0)
} {
    let kind: i64 = buf[pos];
    let b0: i64 = buf[pos + 1];
    let b1: i64 = buf[pos + 2];
    let b2: i64 = buf[pos + 3];
    let b3: i64 = buf[pos + 4];
    let payload: i64 = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216;
    region_pack(kind, payload)
}

fn check_round_trip(rgn: i64) -> i64 vow {
    requires: rgn >= 0,
    requires: region_val(rgn) <= 4294967295,
    requires: region_kind(rgn) <= 1 || region_val(rgn) == 0
} {
    let buf: Vec<i64> = Vec::new();
    region_encode(buf, rgn);
    let got: i64 = region_decode(buf, 0);
    if got != rgn { return 1; }
    0
}

fn main() -> i32 [io] {
    let mut fail: i64 = 0;
    fail = fail + check_round_trip(region_pack(REGION_KIND_ROOT(), 0));
    fail = fail + check_round_trip(region_pack(REGION_KIND_RODATA(), 0));
    fail = fail + check_round_trip(region_pack(REGION_KIND_BLOCK(), 3));
    fail = fail + check_round_trip(region_pack(REGION_KIND_BLOCK(), 257));
    // The issue's specific target: HiddenRegionIdx carried by Caller.
    fail = fail + check_round_trip(region_pack(REGION_KIND_CALLER(), 7));
    fail = fail + check_round_trip(region_pack(REGION_KIND_CALLER(), 100000));
    print_i64(fail);
    0
}
