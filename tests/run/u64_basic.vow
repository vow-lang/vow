// TEST: stdout "52\n32\n420\n4\n2\n18446744073709551615\nx > y\n42\n42\n"
module U64Basic

fn main() -> i32 [io] {
    let x: u64 = 42;
    let y: u64 = 10;
    let sum: u64 = x + y;
    let diff: u64 = x - y;
    let prod: u64 = x * y;
    let quot: u64 = x / y;
    let rem: u64 = x % y;
    print_u64(sum);
    print_str("\n");
    print_u64(diff);
    print_str("\n");
    print_u64(prod);
    print_str("\n");
    print_u64(quot);
    print_str("\n");
    print_u64(rem);
    print_str("\n");
    let big: u64 = 18446744073709551615u64;
    print_u64(big);
    print_str("\n");
    let cmp: bool = x > y;
    if cmp {
        print_str("x > y\n");
    } else {
        print_str("x <= y\n");
    };
    let cast_val: i64 = x as i64;
    print_i64(cast_val);
    print_str("\n");
    let back: u64 = cast_val as u64;
    print_u64(back);
    print_str("\n");
    0
}
