// TEST: stdout "first_inserted_returned_some=0\nsecond_inserted_returned_some=42\nv=99\n"
module BTreeMapOverwrite

// Prints "label=N" if `o` is Some(N), else "label=0" by short-circuit:
// Caller relies on the printed line being absent (no "\n") when None.
// To make output deterministic regardless of path, we always print the label
// then short-circuit on None, so callers must know what to expect.
fn announce(label: String, o: Option<i64>) -> Option<i64> [io] {
    print_str(label);
    let v: i64 = o?;
    print_i64(v);
    print_str(String::from("\n"));
    Option::Some(v)
}

fn fetch(m: BTreeMap<i64, i64>) -> Option<i64> [io] {
    let v: i64 = m.get(7)?;
    print_str(String::from("v="));
    print_i64(v);
    print_str(String::from("\n"));
    Option::Some(v)
}

fn main() -> i32 [io] {
    let m: BTreeMap<i64, i64> = BTreeMap::new();
    let first: Option<i64> = m.insert(7, 42);
    // first should be None → announce prints "first_inserted_returned_some=" then short-circuits.
    // We append a 0 line afterwards so the test sees a clean newline even on None.
    announce(String::from("first_inserted_returned_some="), first);
    print_str(String::from("0\n"));
    let second: Option<i64> = m.insert(7, 99);
    // second should be Some(42) → announce prints "second_inserted_returned_some=42\n".
    announce(String::from("second_inserted_returned_some="), second);
    fetch(m);
    0
}
