// TEST: stdout "first_inserted_returned_some=0\nsecond_inserted_returned_some=42\nv=99\n"
module BTreeMapOverwrite

// Prints "<label><N>\n" if `o` is Some(N); short-circuits on None so callers
// must know which path they expect. Caller append a "0\n" line to keep
// stdout deterministic on the None path.
fn announce(label: String, o: Option<i64>) -> Option<i64> [io] {
    print_str(label);
    let v: i64 = o?;
    print_i64(v);
    print_str(String::from("\n"));
    Option::Some(v)
}

fn fetch(m: BTreeMap<i64, i64>) -> Option<i64> [io] {
    let r: Option<i64> = m.get(7);
    let v: i64 = r?;
    print_str(String::from("v="));
    print_i64(v);
    print_str(String::from("\n"));
    Option::Some(v)
}

fn main() -> i32 [io] {
    let m: BTreeMap<i64, i64> = BTreeMap::new();
    let first: Option<i64> = m.insert(7, 42);
    // first is None → announce prints label only and short-circuits.
    announce(String::from("first_inserted_returned_some="), first);
    print_str(String::from("0\n"));
    let second: Option<i64> = m.insert(7, 99);
    // second is Some(42) → announce prints "second_inserted_returned_some=42\n".
    announce(String::from("second_inserted_returned_some="), second);
    fetch(m);
    0
}
