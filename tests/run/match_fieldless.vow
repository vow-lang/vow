// TEST: stdout "001-1"
module match_fieldless

enum Dir {
    North,
    South,
    East,
    West,
}

fn to_dx(d: Dir) -> i64 {
    match d {
        Dir::North => { 0 },
        Dir::South => { 0 },
        Dir::East => { 1 },
        Dir::West => { -1 },
    }
}

fn main() -> i32 [io] {
    let n: Dir = Dir::North {};
    let s: Dir = Dir::South {};
    let e: Dir = Dir::East {};
    let w: Dir = Dir::West {};
    print_i64(to_dx(n));
    print_i64(to_dx(s));
    print_i64(to_dx(e));
    print_i64(to_dx(w));
    0
}
