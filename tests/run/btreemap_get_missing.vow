// TEST: stdout "before_get\nafter_get_short_circuited\n"
module BTreeMapGetMissing

// `?` propagates None to caller. If get(99) returns None on an empty map,
// `try_get` short-circuits and the line "got_value=..." is NEVER printed.
fn try_get(m: BTreeMap<i64, i64>) -> Option<i64> [io] {
    let v: i64 = m.get(99)?;
    print_str(String::from("got_value="));
    print_i64(v);
    print_str(String::from("\n"));
    Option::Some(v)
}

fn main() -> i32 [io] {
    let m: BTreeMap<i64, i64> = BTreeMap::new();
    print_str(String::from("before_get\n"));
    try_get(m);
    print_str(String::from("after_get_short_circuited\n"));
    0
}
