// TEST: stdout "len1:3alias_push:4match:1second:2done"
module vec_string_alias

fn main() -> i32 [io] {
    let strings: Vec<String> = Vec::new();
    strings.push(String::from("abc"));
    strings.push(String::from("xy"));

    // index copies the String pointer — creates alias
    let s: String = strings[0];
    print_str("len1:");
    print_i64(s.len());

    // mutate through the alias
    s.push_byte(65);
    print_str("alias_push:");
    let s2: String = strings[0];
    print_i64(s2.len());

    // verify content via equality
    let expected: String = String::from("abcA");
    print_str("match:");
    if s2.eq(expected) {
        print_i64(1);
    } else {
        print_i64(0);
    }

    // second string is independent
    let other: String = strings[1];
    print_str("second:");
    print_i64(other.len());

    print_str("done");
    0
}
