// TEST: exit 1
// TEST: stderr "blame=Caller"
//
// Runtime caller-blame anchor for the verifier-evaluation suite (#334). A
// `requires` violation is blamed on the Caller at runtime under --mode debug.
// This is the runtime half of caller-blame coverage; the static half is the
// known-soundness-gap entry tests/verify/caller_requires_unchecked.vow,
// because static verify does not currently assert a callee's `requires` at
// in-module call sites (tracked in #764).
module CallerBlameDebug

fn checked_div(x: i64, y: i64) -> i64 vow {
  requires: y != 0
} {
  x / y
}

fn main() -> i32 [io] {
  print_i64(checked_div(10, 0));
  0
}
