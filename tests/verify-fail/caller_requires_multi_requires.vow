// TEST: category caller-blame
// TEST: counterexample-fn "f"
// TEST: counterexample-blame caller
// TEST: counterexample-vow-id 1
// TEST: counterexample-violation "requires y != 0"
// TEST: counterexample-call-site-fn "f"
// TEST: counterexample-violating-arg-param "y"
// TEST: counterexample-violating-arg-value "0"
module CallerRequiresMultiRequires

fn g(x: i64, y: i64) -> i64 vow {
  requires: x > 0
  requires: y != 0
} {
  x / y
}

fn f() -> i64 vow {
  ensures: result == 0
} {
  let unused: i64 = g(1, 0);
  0
}

fn main() -> i32 [io] {
  print_i64(f());
  0
}
