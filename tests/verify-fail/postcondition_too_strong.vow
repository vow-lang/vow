// TEST: category callee-blame
// TEST: counterexample-vow-id 1
// TEST: counterexample-fn "positive_or_zero"
// TEST: counterexample-blame callee
// Postcondition is too strong: claims result > 0 but function
// returns 0 when x == 0 (which satisfies requires: x >= 0).
module PostconditionTooStrong

fn positive_or_zero(x: i64) -> i64 vow {
  requires: x >= 0,
  ensures: result > 0
} {
  if x == 0 {
    0
  } else {
    x
  }
}

fn main() -> i32 [io] {
  print_i64(positive_or_zero(5));
  0
}
