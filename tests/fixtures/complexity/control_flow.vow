module ControlFlow

fn classify(n: i64) -> i64 {
    if n > 0 {
        1
    } else if n < 0 {
        2
    } else {
        0
    }
}

fn count_up(n: i64) -> i64 {
    let mut s: i64 = 0;
    let mut i: i64 = 0;
    while i < n {
        if i % 2 == 0 && i > 0 {
            s = s + i;
        }
        i = i + 1;
    }
    s
}
