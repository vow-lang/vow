module Contracts

fn divide(x: i64, y: i64) -> i64 vow {
    requires: y != 0,
    ensures: result == x / y
} {
    x / y
}

fn bounded(lo: i64, hi: i64) -> i64 vow {
    requires: hi >= lo
} {
    let mut lo: i64 = lo;
    let hi: i64 = hi;
    while lo + 1 < hi vow {
        invariant: hi - lo >= 0
    } {
        let mid: i64 = lo + (hi - lo) / 2;
        lo = mid;
    }
    lo
}

fn loose(n: i64) -> i64 {
    let mut i: i64 = n;
    while i > 0 {
        i = i - 1;
    }
    i
}

fn heavy(a: i64, b: i64, c: i64, d: i64) -> i64 vow {
    requires: a > 0,
    requires: b > 0,
    requires: c > 0,
    requires: d > 0,
    requires: a + b + c + d > 10,
    requires: a < b,
    requires: c < d
} {
    a + b + c + d
}
