module ExpressionEval

fn eval_rpn(ops: Vec<i64>) -> i64 vow {
  requires: ops.len() >= 1,
  requires: ops.len() <= 6,
  ensures: result >= 0
} {
  let stack: Vec<i64> = Vec::new();
  let mut j: i64 = 0;
  while j < 8 vow {
    invariant: j >= 0,
    invariant: j <= 8
  } {
    stack.push(0);
    j = j + 1;
  }
  let mut sp: i64 = 0;
  let mut i: i64 = 0;
  while i < ops.len() vow {
    invariant: i >= 0,
    invariant: i <= ops.len(),
    invariant: sp >= 0,
    invariant: sp <= 8
  } {
    if ops[i] < 100 {
      stack[sp] = ops[i];
      sp = sp + 1;
    } else {
      if ops[i] == 100 {
        if sp >= 2 {
          sp = sp - 1;
          let a: i64 = stack[sp];
          sp = sp - 1;
          let b: i64 = stack[sp];
          stack[sp] = a + b;
          sp = sp + 1;
        } else {
          0;
        }
      } else {
        if sp >= 1 {
          sp = sp - 1;
          let v: i64 = stack[sp];
          stack[sp] = 0 - v;
          sp = sp + 1;
        } else {
          0;
        }
      }
    }
    i = i + 1;
  }
  if sp > 0 {
    stack[sp - 1]
  } else {
    0
  }
}

fn main() -> i32 [io] {
  let ops: Vec<i64> = Vec::new();
  ops.push(3);
  ops.push(4);
  ops.push(100);
  print_i64(eval_rpn(ops));
  0
}
