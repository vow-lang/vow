module PowerOfTwo

fn pow2(n: i64) -> i64 vow {
  requires: n >= 0,
  requires: n <= 8,
  ensures: result >= 1
} {
  let mut r: i64 = 1;
  let mut i: i64 = 0;
  while i < n vow {
    invariant: r >= 1,
    invariant: i >= 0,
    invariant: i <= n
  } {
    r = r * 2;
    i = i + 1;
  }
  r
}

fn main() -> i32 [io] {
  print_i64(pow2(0));
  print_i64(pow2(3));
  print_i64(pow2(8));
  0
}
