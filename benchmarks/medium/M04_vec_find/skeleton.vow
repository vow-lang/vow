module VecFind

fn vec_find(v: Vec<i64>, target: i64) -> i64 vow {
  requires: v.len() >= 0,
  requires: v.len() <= 8,
  ensures: result >= 0 - 1,
  ensures: result < v.len()
} {
  0 - 1
}

fn main() -> i32 [io] {
  let v: Vec<i64> = Vec::new();
  v.push(10);
  v.push(20);
  v.push(30);
  print_i64(vec_find(v, 20));
  0
}
