module BinarySearch

fn bisect(lo: i64, hi: i64) -> i64 vow {
  requires: lo >= 0,
  requires: hi >= lo,
  requires: hi <= 100
} {
  let mut lo: i64 = lo;
  let mut hi: i64 = hi;
  while lo + 1 < hi vow {
    invariant: lo >= 0,
    invariant: hi >= lo,
    invariant: hi <= 100
  } {
    let mid: i64 = lo + (hi - lo) / 2;
    lo = mid;
  }
  lo
}

fn main() -> i32 [io] {
  let r: i64 = bisect(0, 64);
  print_i64(r);
  0
}
