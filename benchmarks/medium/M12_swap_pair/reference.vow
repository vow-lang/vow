module SwapPair

fn select_first(a: i64, b: i64) -> i64 vow {
  ensures: result == a
} {
  a
}

fn select_second(a: i64, b: i64) -> i64 vow {
  ensures: result == b
} {
  b
}

fn sum_pair(a: i64, b: i64) -> i64 vow {
  requires: a >= 0,
  requires: b >= 0,
  requires: a <= 1000,
  requires: b <= 1000,
  ensures: result == a + b
} {
  a + b
}

fn main() -> i32 [io] {
  print_i64(select_first(10, 20));
  print_i64(select_second(10, 20));
  print_i64(sum_pair(10, 20));
  0
}
