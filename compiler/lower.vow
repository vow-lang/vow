        // Include transitive sources so Phi/Upsilon aliases aren't freed.
        if !lctx_is_terminated(ctx) {
            let loop_live_out2: Vec<i64> = Vec::new();
            let mut lli: i64 = 0;
            while lli < nassigned {
                let vname: String = assigned[lli];
                let cur: i64 = lctx_lookup(ctx, vname);
