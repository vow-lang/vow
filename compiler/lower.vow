module Lower

use ast
use ir

struct LowerCtx {
    func: IrFunction,
    current_block: i64,
    next_inst_id: i64,
    scope_vars: Vec<String>,
    scope_vals: Vec<i64>,
    scope_starts: Vec<i64>,
    string_pool: Vec<String>,
    func_names: Vec<String>,
    func_ret_tys: Vec<i64>,
    struct_names: Vec<String>,
    struct_field_lists: Vec<Vec<String>>,
    struct_field_type_names: Vec<Vec<String>>,
    struct_field_vec_elems: Vec<Vec<String>>,
    enum_names: Vec<String>,
    enum_variant_lists: Vec<Vec<String>>,
    tag_inst_ids: Vec<i64>,
    tag_names: Vec<String>,
    arena: AstArena,
    cur_vow_lid: i64,
    str_eids: Vec<i64>,
    const_names: Vec<String>,
    const_values: Vec<i64>,
    const_tids: Vec<i64>,
    loop_exit_blocks: Vec<i64>,
    loop_header_blocks: Vec<i64>,
    loop_continue_phi_names: Vec<Vec<String>>,
    loop_continue_phi_ids: Vec<Vec<i64>>,
    loop_continue_idx_phi: Vec<i64>,
    loop_continue_scope_depth: Vec<i64>,
    loop_is_loop: Vec<i64>,
    loop_break_up_ids: Vec<i64>,
    loop_break_up_blocks: Vec<i64>,
    loop_break_up_tys: Vec<i64>,
    loop_break_counts: Vec<i64>,
    vec_elem_inst_ids: Vec<i64>,
    vec_elem_names: Vec<String>,
    warnings: Vec<String>,
    alloc_ids: Vec<i64>,
    alloc_tags: Vec<String>,
    alloc_sizes: Vec<i64>,
    escaped_ids: Vec<i64>,
    alloc_scope_starts: Vec<i64>,
    loop_alloc_scope_depths: Vec<i64>,
    file: String,
}

struct ScopeSnap {
    vars_len: i64,
    vals_len: i64,
    starts_len: i64,
}

fn lctx_new(name: String, return_ty: i64, effects: i64, arena: AstArena, str_eids: Vec<i64>) -> LowerCtx {
    let f: IrFunction = ir_function_new(0, name, return_ty, effects);
    let entry: IrBlock = ir_block_new(0);
    f.blocks.push(entry);
    LowerCtx {
        func: f,
        current_block: 0,
        next_inst_id: 0,
        scope_vars: Vec::new(),
        scope_vals: Vec::new(),
        scope_starts: Vec::new(),
        string_pool: Vec::new(),
        func_names: Vec::new(),
        func_ret_tys: Vec::new(),
        struct_names: Vec::new(),
        struct_field_lists: Vec::new(),
        struct_field_type_names: Vec::new(),
        struct_field_vec_elems: Vec::new(),
        enum_names: Vec::new(),
        enum_variant_lists: Vec::new(),
        tag_inst_ids: Vec::new(),
        tag_names: Vec::new(),
        arena: arena,
        cur_vow_lid: -1,
        str_eids: str_eids,
        const_names: Vec::new(),
        const_values: Vec::new(),
        const_tids: Vec::new(),
        loop_exit_blocks: Vec::new(),
        loop_header_blocks: Vec::new(),
        loop_continue_phi_names: Vec::new(),
        loop_continue_phi_ids: Vec::new(),
        loop_continue_idx_phi: Vec::new(),
        loop_continue_scope_depth: Vec::new(),
        loop_is_loop: Vec::new(),
        loop_break_up_ids: Vec::new(),
        loop_break_up_blocks: Vec::new(),
        loop_break_up_tys: Vec::new(),
        loop_break_counts: Vec::new(),
        vec_elem_inst_ids: Vec::new(),
        vec_elem_names: Vec::new(),
        warnings: Vec::new(),
        alloc_ids: Vec::new(),
        alloc_tags: Vec::new(),
        alloc_sizes: Vec::new(),
        escaped_ids: Vec::new(),
        alloc_scope_starts: Vec::new(),
        loop_alloc_scope_depths: Vec::new(),
        file: String::from(""),
    }
}

fn lctx_new_block(ctx: LowerCtx) -> i64 {
    let bid: i64 = ctx.func.blocks.len();
    let blk: IrBlock = ir_block_new(bid);
    ctx.func.blocks.push(blk);
    bid
}

fn lctx_switch_to_block(ctx: LowerCtx, bid: i64) {
    ctx.current_block = bid;
}

fn lctx_is_terminated(ctx: LowerCtx) -> bool {
    let blk: IrBlock = ctx.func.blocks[ctx.current_block];
    let n: i64 = blk.insts.len();
    if n == 0 { return false; }
    let last: IrInst = blk.insts[n - 1];
    iop_is_terminal(last.op)
}

fn lctx_block_terminated(ctx: LowerCtx, block_id: i64) -> bool {
    let blk: IrBlock = ctx.func.blocks[block_id];
    let n: i64 = blk.insts.len();
    if n == 0 { return false; }
    let last: IrInst = blk.insts[n - 1];
    iop_is_terminal(last.op)
}

fn lctx_inst_ty(ctx: LowerCtx, inst_id: i64) -> i64 {
    let nb: i64 = ctx.func.blocks.len();
    let mut bi: i64 = 0;
    while bi < nb {
        let blk: IrBlock = ctx.func.blocks[bi];
        let ni: i64 = blk.insts.len();
        let mut ii: i64 = 0;
        while ii < ni {
            let inst: IrInst = blk.insts[ii];
            if inst.id == inst_id {
                return inst.ty;
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    ITY_I64()
}

fn lctx_emit(ctx: LowerCtx, op: i64, ty: i64, args: Vec<i64>, dk: i64, dv: i64, dv2: i64, ds: String) -> i64 {
    if lctx_is_terminated(ctx) {
        return ctx.next_inst_id;
    }
    let id: i64 = ctx.next_inst_id;
    ctx.next_inst_id = id + 1;
    let inst: IrInst = ir_inst_new(id, op, ty, args, dk, dv, dv2, ds);
    let blk: IrBlock = ctx.func.blocks[ctx.current_block];
    blk.insts.push(inst);
    id
}

fn lctx_push_scope(ctx: LowerCtx) {
    ctx.scope_starts.push(ctx.scope_vars.len());
}

fn lctx_pop_scope(ctx: LowerCtx) {
    let n: i64 = ctx.scope_starts.len();
    if n == 0 { return; }
    let start: i64 = ctx.scope_starts[n - 1];
    let cur: i64 = ctx.scope_vars.len();
    let mut i: i64 = cur;
    while i > start {
        i = i - 1;
        ctx.scope_vars.pop();
        ctx.scope_vals.pop();
    }
    ctx.scope_starts.pop();
}

fn lctx_define(ctx: LowerCtx, name: String, val: i64) {
    ctx.scope_vars.push(name);
    ctx.scope_vals.push(val);
}

fn lctx_assign(ctx: LowerCtx, name: String, val: i64) {
    let n: i64 = ctx.scope_vars.len();
    let mut i: i64 = n;
    while i > 0 {
        i = i - 1;
        if ctx.scope_vars[i] == name {
            ctx.scope_vals[i] = val;
            return;
        }
    }
}

fn lctx_lookup(ctx: LowerCtx, name: String) -> i64 {
    let n: i64 = ctx.scope_vars.len();
    let mut i: i64 = n;
    while i > 0 {
        i = i - 1;
        if ctx.scope_vars[i] == name {
            return ctx.scope_vals[i];
        }
    }
    -1
}

fn lctx_lookup_at_depth(ctx: LowerCtx, name: String, depth: i64) -> i64 {
    let mut i: i64 = depth;
    while i > 0 {
        i = i - 1;
        if ctx.scope_vars[i] == name {
            return ctx.scope_vals[i];
        }
    }
    -1
}

fn lctx_snapshot(ctx: LowerCtx) -> ScopeSnap {
    ScopeSnap {
        vars_len: ctx.scope_vars.len(),
        vals_len: ctx.scope_vals.len(),
        starts_len: ctx.scope_starts.len(),
    }
}

fn lctx_restore(ctx: LowerCtx, snap: ScopeSnap) {
    let cur_vars: i64 = ctx.scope_vars.len();
    let mut i: i64 = cur_vars;
    while i > snap.vars_len {
        i = i - 1;
        ctx.scope_vars.pop();
        ctx.scope_vals.pop();
    }
    let cur_starts: i64 = ctx.scope_starts.len();
    let mut j: i64 = cur_starts;
    while j > snap.starts_len {
        j = j - 1;
        ctx.scope_starts.pop();
    }
}


fn lctx_tag(ctx: LowerCtx, inst_id: i64, name: String) {
    ctx.tag_inst_ids.push(inst_id);
    ctx.tag_names.push(name);
}

fn lctx_get_tag(ctx: LowerCtx, inst_id: i64) -> String {
    let n: i64 = ctx.tag_inst_ids.len();
    let mut i: i64 = n;
    while i > 0 {
        i = i - 1;
        if ctx.tag_inst_ids[i] == inst_id {
            return ctx.tag_names[i];
        }
    }
    String::from("")
}

fn lctx_track_alloc(ctx: LowerCtx, id: i64, tag: String, alloc_size: i64) {
    ctx.alloc_ids.push(id);
    ctx.alloc_tags.push(tag);
    ctx.alloc_sizes.push(alloc_size);
}

fn lctx_push_alloc_scope(ctx: LowerCtx) {
    ctx.alloc_scope_starts.push(ctx.alloc_ids.len());
}

fn lctx_pop_alloc_scope_frees(ctx: LowerCtx, live_out: Vec<i64>) {
    let scope_start: i64 = ctx.alloc_scope_starts[ctx.alloc_scope_starts.len() - 1];
    ctx.alloc_scope_starts.pop();
    let n: i64 = ctx.alloc_ids.len();
    let mut i: i64 = scope_start;
    while i < n {
        let id: i64 = ctx.alloc_ids[i];
        let tag: String = ctx.alloc_tags[i];
        let mut skip: bool = lctx_is_escaped(ctx, id);
        if !skip {
            let mut li: i64 = 0;
            while li < live_out.len() {
                if live_out[li] == id {
                    skip = true;
                }
                li = li + 1;
            }
        }
        if !skip {
            if lower_str_starts_with(tag, String::from("region:")) {
                let size: i64 = ctx.alloc_sizes[i];
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_REGION_FREE(), ITY_UNIT(), free_args, IDATA_ALLOC_SIZE(), size, 8, String::from(""));
            }
            if tag == String::from("String") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_string_free"));
            }
            if tag == String::from("Vec") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_vec_free_val"));
            }
            if tag == String::from("HashMap") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_map_free"));
            }
        }
        i = i + 1;
    }
    // Truncate the alloc arrays back to the scope start.
    while ctx.alloc_ids.len() > scope_start {
        ctx.alloc_ids.pop();
        ctx.alloc_tags.pop();
        ctx.alloc_sizes.pop();
    }
}

fn lctx_discard_alloc_scope(ctx: LowerCtx) {
    let scope_start: i64 = ctx.alloc_scope_starts[ctx.alloc_scope_starts.len() - 1];
    ctx.alloc_scope_starts.pop();
    while ctx.alloc_ids.len() > scope_start {
        ctx.alloc_ids.pop();
        ctx.alloc_tags.pop();
        ctx.alloc_sizes.pop();
    }
}

fn lctx_emit_alloc_frees_to_depth(ctx: LowerCtx, target_depth: i64, live_out: Vec<i64>) {
    let n: i64 = ctx.alloc_ids.len();
    let mut i: i64 = target_depth;
    while i < n {
        let id: i64 = ctx.alloc_ids[i];
        let tag: String = ctx.alloc_tags[i];
        let mut skip: bool = lctx_is_escaped(ctx, id);
        if !skip {
            let mut li: i64 = 0;
            while li < live_out.len() {
                if live_out[li] == id {
                    skip = true;
                }
                li = li + 1;
            }
        }
        if !skip {
            if lower_str_starts_with(tag, String::from("region:")) {
                let size: i64 = ctx.alloc_sizes[i];
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_REGION_FREE(), ITY_UNIT(), free_args, IDATA_ALLOC_SIZE(), size, 8, String::from(""));
            }
            if tag == String::from("String") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_string_free"));
            }
            if tag == String::from("Vec") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_vec_free_val"));
            }
            if tag == String::from("HashMap") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_map_free"));
            }
        }
        i = i + 1;
    }
}

fn lctx_mark_escaped(ctx: LowerCtx, id: i64) {
    ctx.escaped_ids.push(id);
}

fn lctx_is_escaped(ctx: LowerCtx, id: i64) -> bool {
    let n: i64 = ctx.escaped_ids.len();
    let mut i: i64 = 0;
    while i < n {
        if ctx.escaped_ids[i] == id {
            return true;
        }
        i = i + 1;
    }
    false
}

fn lower_str_starts_with(s: String, prefix: String) -> bool {
    let plen: i64 = prefix.len();
    if s.len() < plen { return false; }
    let mut i: i64 = 0;
    while i < plen {
        if s.byte_at(i) != prefix.byte_at(i) { return false; }
        i = i + 1;
    }
    true
}

fn lctx_collect_return_sources(ctx: LowerCtx, return_val: i64) -> Vec<i64> {
    let mut sources: Vec<i64> = Vec::new();
    sources.push(return_val);
    let mut wi: i64 = 0;
    while wi < sources.len() {
        let val: i64 = sources[wi];
        let nb: i64 = ctx.func.blocks.len();
        let mut bi: i64 = 0;
        while bi < nb {
            let blk: IrBlock = ctx.func.blocks[bi];
            let ni: i64 = blk.insts.len();
            let mut ii: i64 = 0;
            while ii < ni {
                let inst: IrInst = blk.insts[ii];
                if inst.op == IOP_UPSILON() && inst.dk == IDATA_PHI_TARGET() && inst.dv == val {
                    if inst.args.len() > 0 {
                        let src: i64 = inst.args[0];
                        let mut found: bool = false;
                        let mut si: i64 = 0;
                        while si < sources.len() {
                            if sources[si] == src {
                                found = true;
                            }
                            si = si + 1;
                        }
                        if !found {
                            sources.push(src);
                        }
                    }
                }
                ii = ii + 1;
            }
            bi = bi + 1;
        }
        wi = wi + 1;
    }
    sources
}

fn lctx_emit_return_frees(ctx: LowerCtx, return_val: i64) {
    let sources: Vec<i64> = lctx_collect_return_sources(ctx, return_val);
    let n: i64 = ctx.alloc_ids.len();
    let mut i: i64 = 0;
    while i < n {
        let id: i64 = ctx.alloc_ids[i];
        let tag: String = ctx.alloc_tags[i];
        let mut skip: bool = lctx_is_escaped(ctx, id);
        if !skip {
            let mut si: i64 = 0;
            while si < sources.len() {
                if sources[si] == id {
                    skip = true;
                }
                si = si + 1;
            }
        }
        if !skip {
            if lower_str_starts_with(tag, String::from("region:")) {
                let size: i64 = ctx.alloc_sizes[i];
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_REGION_FREE(), ITY_UNIT(), free_args, IDATA_ALLOC_SIZE(), size, 8, String::from(""));
            }
            if tag == String::from("String") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_string_free"));
            }
            if tag == String::from("Vec") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_vec_free_val"));
            }
            if tag == String::from("HashMap") {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_map_free"));
            }
        }
        i = i + 1;
    }
}

fn lctx_is_str_eid(ctx: LowerCtx, eid: i64) -> bool {
    let n: i64 = ctx.str_eids.len();
    let mut i: i64 = 0;
    while i < n {
        if ctx.str_eids[i] == eid {
            return true;
        }
        i = i + 1;
    }
    false
}

fn lctx_tag_vec_elem(ctx: LowerCtx, inst_id: i64, elem_name: String) {
    ctx.vec_elem_inst_ids.push(inst_id);
    ctx.vec_elem_names.push(elem_name);
}

fn lctx_get_vec_elem(ctx: LowerCtx, inst_id: i64) -> String {
    let n: i64 = ctx.vec_elem_inst_ids.len();
    let mut i: i64 = n;
    while i > 0 {
        i = i - 1;
        if ctx.vec_elem_inst_ids[i] == inst_id {
            return ctx.vec_elem_names[i];
        }
    }
    String::from("")
}

fn lctx_intern_str(ctx: LowerCtx, s: String) -> i64 {
    let n: i64 = ctx.string_pool.len();
    let mut i: i64 = 0;
    while i < n {
        if ctx.string_pool[i] == s {
            return i;
        }
        i = i + 1;
    }
    ctx.string_pool.push(s);
    n
}

fn lctx_find_func(ctx: LowerCtx, name: String) -> i64 {
    let n: i64 = ctx.func_names.len();
    let mut i: i64 = 0;
    while i < n {
        if ctx.func_names[i] == name {
            return i;
        }
        i = i + 1;
    }
    -1
}

fn lctx_find_struct(ctx: LowerCtx, name: String) -> i64 {
    let n: i64 = ctx.struct_names.len();
    let mut i: i64 = 0;
    while i < n {
        if ctx.struct_names[i] == name {
            return i;
        }
        i = i + 1;
    }
    -1
}

fn lctx_find_enum(ctx: LowerCtx, name: String) -> i64 {
    let n: i64 = ctx.enum_names.len();
    let mut i: i64 = 0;
    while i < n {
        if ctx.enum_names[i] == name {
            return i;
        }
        i = i + 1;
    }
    -1
}

fn lctx_find_variant_tag(ctx: LowerCtx, enum_name: String, variant_name: String) -> i64 {
    let eidx: i64 = lctx_find_enum(ctx, enum_name);
    if eidx == -1 { return 0; }
    let variants: Vec<String> = ctx.enum_variant_lists[eidx];
    let n: i64 = variants.len();
    let mut i: i64 = 0;
    while i < n {
        if variants[i] == variant_name {
            return i;
        }
        i = i + 1;
    }
    0
}

fn lctx_struct_field_index(ctx: LowerCtx, struct_name: String, field_name: String) -> i64 {
    let sidx: i64 = lctx_find_struct(ctx, struct_name);
    if sidx == -1 {
        if struct_name.len() > 0 {
            let w: String = String::from("warning: struct '");
            w.push_str(struct_name);
            w.push_str(String::from("' not registered -- field lookup defaulting to index 0"));
            ctx.warnings.push(w);
        }
        return 0;
    }
    let fields: Vec<String> = ctx.struct_field_lists[sidx];
    let n: i64 = fields.len();
    let mut i: i64 = 0;
    while i < n {
        if fields[i] == field_name {
            return i;
        }
        i = i + 1;
    }
    if struct_name.len() > 0 {
        let w: String = String::from("warning: field '");
        w.push_str(field_name);
        w.push_str(String::from("' not found in struct '"));
        w.push_str(struct_name);
        w.push_str(String::from("' -- defaulting to index 0"));
        ctx.warnings.push(w);
    }
    0
}

fn lctx_struct_field_type(ctx: LowerCtx, struct_name: String, field_idx: i64) -> String {
    let sidx: i64 = lctx_find_struct(ctx, struct_name);
    if sidx == -1 { return String::from(""); }
    let type_names: Vec<String> = ctx.struct_field_type_names[sidx];
    if field_idx < type_names.len() {
        return type_names[field_idx];
    }
    String::from("")
}

fn lctx_struct_field_vec_elem(ctx: LowerCtx, struct_name: String, field_idx: i64) -> String {
    let sidx: i64 = lctx_find_struct(ctx, struct_name);
    if sidx == -1 { return String::from(""); }
    let vec_elems: Vec<String> = ctx.struct_field_vec_elems[sidx];
    if field_idx < vec_elems.len() {
        return vec_elems[field_idx];
    }
    String::from("")
}

fn lctx_alloc_vow(ctx: LowerCtx, desc: String, blame: i64, binding_ids: Vec<i64>, binding_names: Vec<String>, offset: i64) -> i64 {
    let vid: i64 = ctx.func.vows.len();
    let entry: IrVowEntry = IrVowEntry {
        id: vid,
        description: desc,
        blame: blame,
        binding_ids: binding_ids,
        binding_names: binding_names,
        file: ctx.file,
        offset: offset,
    };
    ctx.func.vows.push(entry);
    vid
}

fn lower_ast_ty(a: AstArena, tid: i64) -> i64 {
    if tid == -1 { return ITY_UNIT(); }
    let tag: i64 = type_tag(a, tid);
    if tag == TY_UNIT() { return ITY_UNIT(); }
    if tag == TY_NAMED() {
        let name_sid: i64 = type_a(a, tid);
        let name: String = arena_str(a, name_sid);
        if name == String::from("i32") { return ITY_I32(); }
        if name == String::from("i64") { return ITY_I64(); }
        if name == String::from("u64") { return ITY_U64(); }
        if name == String::from("f32") { return ITY_F32(); }
        if name == String::from("f64") { return ITY_F64(); }
        if name == String::from("bool") { return ITY_BOOL(); }
        if name == String::from("String") { return ITY_PTR(); }
        if name == String::from("str") { return ITY_PTR(); }
        return ITY_PTR();
    }
    if tag == TY_GENERIC() { return ITY_PTR(); }
    ITY_UNIT()
}

fn binop_opcode(op: i64, operand_ty: i64) -> i64 vow {
    requires: op >= 0
} {
    let is_u64: bool = operand_ty == ITY_U64();
    if op == BINOP_ADD() { return if is_u64 { IOP_WADD_U64() } else { IOP_WADD_I64() }; }
    if op == BINOP_SUB() { return if is_u64 { IOP_WSUB_U64() } else { IOP_WSUB_I64() }; }
    if op == BINOP_MUL() { return if is_u64 { IOP_WMUL_U64() } else { IOP_WMUL_I64() }; }
    if op == BINOP_DIV() { return if is_u64 { IOP_WDIV_U64() } else { IOP_WDIV_I64() }; }
    if op == BINOP_REM() { return if is_u64 { IOP_WREM_U64() } else { IOP_WREM_I64() }; }
    if op == BINOP_ADD_CHK() { return if is_u64 { IOP_CADD_U64() } else { IOP_CADD_I64() }; }
    if op == BINOP_SUB_CHK() { return if is_u64 { IOP_CSUB_U64() } else { IOP_CSUB_I64() }; }
    if op == BINOP_MUL_CHK() { return if is_u64 { IOP_CMUL_U64() } else { IOP_CMUL_I64() }; }
    if op == BINOP_DIV_CHK() { return if is_u64 { IOP_CDIV_U64() } else { IOP_CDIV_I64() }; }
    if op == BINOP_REM_CHK() { return if is_u64 { IOP_CREM_U64() } else { IOP_CREM_I64() }; }
    if op == BINOP_EQ() { return if is_u64 { IOP_EQ_U64() } else { IOP_EQ_I64() }; }
    if op == BINOP_NE() { return if is_u64 { IOP_NE_U64() } else { IOP_NE_I64() }; }
    if op == BINOP_LT() { return if is_u64 { IOP_LT_U64() } else { IOP_LT_I64() }; }
    if op == BINOP_LE() { return if is_u64 { IOP_LE_U64() } else { IOP_LE_I64() }; }
    if op == BINOP_GT() { return if is_u64 { IOP_GT_U64() } else { IOP_GT_I64() }; }
    if op == BINOP_GE() { return if is_u64 { IOP_GE_U64() } else { IOP_GE_I64() }; }
    if op == BINOP_AND() { return IOP_AND(); }
    if op == BINOP_OR() { return IOP_OR(); }
    if op == BINOP_BITAND() { return if is_u64 { IOP_BITAND_U64() } else { IOP_BITAND_I64() }; }
    if op == BINOP_BITOR() { return if is_u64 { IOP_BITOR_U64() } else { IOP_BITOR_I64() }; }
    if op == BINOP_XOR() { return if is_u64 { IOP_XOR_U64() } else { IOP_XOR_I64() }; }
    if op == BINOP_SHL() { return if is_u64 { IOP_SHL_U64() } else { IOP_SHL_I64() }; }
    if op == BINOP_SHR() { return if is_u64 { IOP_SHR_U64() } else { IOP_SHR_I64() }; }
    IOP_WADD_I64()
}

fn binop_result_ty(op: i64, operand_ty: i64) -> i64 vow {
    requires: op >= 0
} {
    if op == BINOP_EQ() { return ITY_BOOL(); }
    if op == BINOP_NE() { return ITY_BOOL(); }
    if op == BINOP_LT() { return ITY_BOOL(); }
    if op == BINOP_LE() { return ITY_BOOL(); }
    if op == BINOP_GT() { return ITY_BOOL(); }
    if op == BINOP_GE() { return ITY_BOOL(); }
    if op == BINOP_AND() { return ITY_BOOL(); }
    if op == BINOP_OR() { return ITY_BOOL(); }
    if operand_ty == ITY_U64() { return ITY_U64(); }
    ITY_I64()
}

