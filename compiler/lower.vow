        ctx.loop_exit_blocks.push(exit_block);
        ctx.loop_header_blocks.push(header_block);
        let cpn: Vec<String> = Vec::new();
        let cpi: Vec<i64> = Vec::new();
        let mut ci: i64 = 0;
        while ci < nassigned {
