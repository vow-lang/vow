fn collect_assigned_vars(ctx: LowerCtx, eid: i64) -> Vec<String> {
    let result: Vec<String> = Vec::new();
    collect_assigned_in_expr(ctx, eid, result);
    result
}

fn collect_assigned_in_expr(ctx: LowerCtx, eid: i64, out: Vec<String>) {
    let a: AstArena = ctx.arena;
    let tag: i64 = expr_tag(a, eid);
    if tag == EXPR_ASSIGN() {
        let lhs_eid: i64 = expr_a(a, eid);
        let lhs_tag: i64 = expr_tag(a, lhs_eid);
        if lhs_tag == EXPR_IDENT() {
            let name_sid: i64 = expr_a(a, lhs_eid);
            let name: String = arena_str(a, name_sid);
            let already: bool = vec_contains_str(out, name);
            if !already {
                out.push(name);
            }
        }
    } else if tag == EXPR_BLOCK() {
        let bid: i64 = expr_a(a, eid);
        collect_assigned_in_block(ctx, bid, out);
    } else if tag == EXPR_IF() {
        let then_bid: i64 = expr_b(a, eid);
        let else_eid: i64 = expr_c(a, eid);
        collect_assigned_in_block(ctx, then_bid, out);
        if else_eid != -1 {
            collect_assigned_in_expr(ctx, else_eid, out);
        }
    } else if tag == EXPR_WHILE() {
        let body_bid: i64 = expr_b(a, eid);
        collect_assigned_in_block(ctx, body_bid, out);
    } else if tag == EXPR_LOOP() {
        let body_bid: i64 = expr_a(a, eid);
        collect_assigned_in_block(ctx, body_bid, out);
    } else if tag == EXPR_FOR() {
        let body_bid: i64 = expr_b(a, eid);
        collect_assigned_in_block(ctx, body_bid, out);
    } else if tag == EXPR_MATCH() {
        let arms_lid: i64 = expr_b(a, eid);
        let n_arms: i64 = list_len(a, arms_lid) / 2;
        let mut mai: i64 = 0;
        while mai < n_arms {
            let body_eid: i64 = list_get(a, arms_lid, mai * 2 + 1);
            collect_assigned_in_expr(ctx, body_eid, out);
            mai = mai + 1;
        }
    }
}

fn collect_assigned_in_block(ctx: LowerCtx, bid: i64, out: Vec<String>) {
    let a: AstArena = ctx.arena;
    let stmts_lid: i64 = blk_stmts(a, bid);
    let n: i64 = list_len(a, stmts_lid);
    let mut i: i64 = 0;
    while i < n {
        let sid: i64 = list_get(a, stmts_lid, i);
        let stag: i64 = stmt_tag(a, sid);
        if stag == STMT_EXPR() {
            let se_eid: i64 = stmt_a(a, sid);
            collect_assigned_in_expr(ctx, se_eid, out);
        }
        i = i + 1;
    }
}

fn vec_contains_str(v: Vec<String>, s: String) -> bool {
    let n: i64 = v.len();
    let mut i: i64 = 0;
    while i < n {
        if v[i] == s {
            return true;
        }
        i = i + 1;
    }
    false
}

fn backpatch_upsilon(ctx: LowerCtx, block_id: i64, upsilon_id: i64, phi_id: i64) {
    let blk: IrBlock = ctx.func.blocks[block_id];
    let n: i64 = blk.insts.len();
    let mut i: i64 = 0;
    while i < n {
        let inst: IrInst = blk.insts[i];
        if inst.id == upsilon_id {
            inst.dv = phi_id;
            return;
        }
        i = i + 1;
    }
}

fn collect_if_mutations(ctx: LowerCtx, then_bid: i64, else_eid: i64) -> Vec<String> {
    let result: Vec<String> = Vec::new();
    collect_assigned_in_block(ctx, then_bid, result);
    if else_eid != -1 {
        collect_assigned_in_expr(ctx, else_eid, result);
    }
    let filtered: Vec<String> = Vec::new();
    let n: i64 = result.len();
    let mut i: i64 = 0;
    while i < n {
        let name: String = result[i];
        let val: i64 = lctx_lookup(ctx, name);
        if val != -1 {
            filtered.push(name);
        }
        i = i + 1;
    }
    filtered
}

fn lower_expr(ctx: LowerCtx, eid: i64) -> i64 {
    let a: AstArena = ctx.arena;
    let tag: i64 = expr_tag(a, eid);

    if tag == EXPR_LIT_INT() {
        let val: i64 = expr_a(a, eid);
        let args: Vec<i64> = Vec::new();
        return lctx_emit(ctx, IOP_CONST_I64(), ITY_I64(), args, IDATA_CONST_I64(), val, 0, String::from(""));
    }

    if tag == EXPR_LIT_BOOL() {
        let val: i64 = expr_a(a, eid);
        let args: Vec<i64> = Vec::new();
        return lctx_emit(ctx, IOP_CONST_BOOL(), ITY_BOOL(), args, IDATA_CONST_BOOL(), val, 0, String::from(""));
    }

    if tag == EXPR_LIT_STR() {
        let sid: i64 = expr_a(a, eid);
        let s: String = arena_str(a, sid);
        let pool_idx: i64 = lctx_intern_str(ctx, s);
        let args: Vec<i64> = Vec::new();
        let str_id: i64 = lctx_emit(ctx, IOP_CONST_STR(), ITY_PTR(), args, IDATA_CONST_STR(), pool_idx, 0, String::from(""));
        let call_args: Vec<i64> = Vec::new();
        call_args.push(str_id);
        let result: i64 = lctx_emit(ctx, IOP_CALL(), ITY_PTR(), call_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_string_from_cstr"));
        lctx_tag(ctx, result, String::from("String"));
        lctx_track_alloc(ctx, result, String::from("String"), 0);
        return result;
    }

    if tag == EXPR_LIT_FLOAT() {
        let bits: i64 = expr_a(a, eid);
        let args: Vec<i64> = Vec::new();
        return lctx_emit(ctx, IOP_CONST_F64(), ITY_F64(), args, IDATA_CONST_F64(), bits, 0, String::from(""));
    }

    if tag == EXPR_IDENT() {
        let name_sid: i64 = expr_a(a, eid);
        let name: String = arena_str(a, name_sid);
        let ncnst: i64 = ctx.const_names.len();
        let mut ci: i64 = 0;
        while ci < ncnst {
            let cn: String = ctx.const_names[ci];
            if cn.eq(name) {
                let cv: i64 = ctx.const_values[ci];
                let ct: i64 = ctx.const_tids[ci];
                let args: Vec<i64> = Vec::new();
                if ct == ITY_BOOL() {
                    return lctx_emit(ctx, IOP_CONST_BOOL(), ITY_BOOL(), args, IDATA_CONST_BOOL(), cv, 0, String::from(""));
                }
                return lctx_emit(ctx, IOP_CONST_I64(), ITY_I64(), args, IDATA_CONST_I64(), cv, 0, String::from(""));
            }
            ci = ci + 1;
        }
        let val: i64 = lctx_lookup(ctx, name);
        if val != -1 {
            return val;
        }
        let args: Vec<i64> = Vec::new();
        return lctx_emit(ctx, IOP_CONST_UNIT(), ITY_UNIT(), args, IDATA_NONE(), 0, 0, String::from(""));
    }

    if tag == EXPR_RESULT() {
        let val: i64 = lctx_lookup(ctx, String::from("result"));
        if val != -1 {
            return val;
        }
        let args: Vec<i64> = Vec::new();
        return lctx_emit(ctx, IOP_CONST_UNIT(), ITY_UNIT(), args, IDATA_NONE(), 0, 0, String::from(""));
    }

    if tag == EXPR_BINOP() {
        let op: i64 = expr_a(a, eid);
        let lhs_eid: i64 = expr_b(a, eid);
        let rhs_eid: i64 = expr_c(a, eid);

        // Short-circuit evaluation for && and ||
        if op == BINOP_AND() || op == BINOP_OR() {
            let lhs_id: i64 = lower_expr(ctx, lhs_eid);
            let rhs_block: i64 = lctx_new_block(ctx);
            let short_block: i64 = lctx_new_block(ctx);
            let merge_block: i64 = lctx_new_block(ctx);

            // &&: if LHS true → evaluate RHS; else → short-circuit (false)
            // ||: if LHS true → short-circuit (true); else → evaluate RHS
            let then_target: i64 = if op == BINOP_AND() { rhs_block } else { short_block };
            let else_target: i64 = if op == BINOP_AND() { short_block } else { rhs_block };

            let br_args: Vec<i64> = Vec::new();
            br_args.push(lhs_id);
            lctx_emit(ctx, IOP_BRANCH(), ITY_UNIT(), br_args, IDATA_BRANCH_TARGETS(), then_target, else_target, String::from(""));

            // RHS block: evaluate RHS, Upsilon, Jump to merge
            lctx_switch_to_block(ctx, rhs_block);
            let rhs_id: i64 = lower_expr(ctx, rhs_eid);
            let rhs_up_args: Vec<i64> = Vec::new();
            rhs_up_args.push(rhs_id);
            let rhs_up_id: i64 = lctx_emit(ctx, IOP_UPSILON(), ITY_UNIT(), rhs_up_args, IDATA_PHI_TARGET(), 2147483647, 0, String::from(""));
            let rhs_up_block: i64 = ctx.current_block;
            let rhs_jmp_args: Vec<i64> = Vec::new();
            lctx_emit(ctx, IOP_JUMP(), ITY_UNIT(), rhs_jmp_args, IDATA_JUMP_TARGET(), merge_block, 0, String::from(""));

            // Short-circuit block: produce false (&&) or true (||), Upsilon, Jump
            lctx_switch_to_block(ctx, short_block);
            let short_val_i: i64 = if op == BINOP_OR() { 1 } else { 0 };
            let short_val_args: Vec<i64> = Vec::new();
            let short_val: i64 = lctx_emit(ctx, IOP_CONST_BOOL(), ITY_BOOL(), short_val_args, IDATA_CONST_BOOL(), short_val_i, 0, String::from(""));
            let short_up_args: Vec<i64> = Vec::new();
            short_up_args.push(short_val);
            let short_up_id: i64 = lctx_emit(ctx, IOP_UPSILON(), ITY_UNIT(), short_up_args, IDATA_PHI_TARGET(), 2147483647, 0, String::from(""));
            let short_up_block: i64 = ctx.current_block;
            let short_jmp_args: Vec<i64> = Vec::new();
            lctx_emit(ctx, IOP_JUMP(), ITY_UNIT(), short_jmp_args, IDATA_JUMP_TARGET(), merge_block, 0, String::from(""));

            // Merge block: Phi
            lctx_switch_to_block(ctx, merge_block);
            let phi_args: Vec<i64> = Vec::new();
            let phi_id: i64 = lctx_emit(ctx, IOP_PHI(), ITY_BOOL(), phi_args, IDATA_NONE(), 0, 0, String::from(""));
            backpatch_upsilon(ctx, rhs_up_block, rhs_up_id, phi_id);
            backpatch_upsilon(ctx, short_up_block, short_up_id, phi_id);
            return phi_id;
        }

        let lhs_id: i64 = lower_expr(ctx, lhs_eid);
        let rhs_id: i64 = lower_expr(ctx, rhs_eid);
        let lhs_is_str: bool = lctx_is_str_eid(ctx, lhs_eid);
        let rhs_is_str: bool = lctx_is_str_eid(ctx, rhs_eid);
        if (op == BINOP_EQ() || op == BINOP_NE()) && (lhs_is_str || rhs_is_str) {
            let call_args: Vec<i64> = Vec::new();
            call_args.push(lhs_id);
            call_args.push(rhs_id);
            let eq_id: i64 = lctx_emit(ctx, IOP_CALL(), ITY_BOOL(), call_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_string_eq"));
            let lhs_tag: i64 = expr_tag(a, lhs_eid);
            if lhs_tag == EXPR_LIT_STR() {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(lhs_id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_string_free"));
            }
            let rhs_tag: i64 = expr_tag(a, rhs_eid);
            if rhs_tag == EXPR_LIT_STR() {
                let free_args: Vec<i64> = Vec::new();
                free_args.push(rhs_id);
                lctx_emit(ctx, IOP_CALL(), ITY_UNIT(), free_args, IDATA_CALL_EXTERN(), 0, 0, String::from("__vow_string_free"));
            }
            if op == BINOP_NE() {
                let not_args: Vec<i64> = Vec::new();
                not_args.push(eq_id);
                return lctx_emit(ctx, IOP_NOT(), ITY_BOOL(), not_args, IDATA_NONE(), 0, 0, String::from(""));
            }
            return eq_id;
        }
        let lhs_ty: i64 = lctx_inst_ty(ctx, lhs_id);
        let iop: i64 = binop_opcode(op, lhs_ty);
        let rty: i64 = binop_result_ty(op, lhs_ty);
        let bin_args: Vec<i64> = Vec::new();
        bin_args.push(lhs_id);
        bin_args.push(rhs_id);
        return lctx_emit(ctx, iop, rty, bin_args, IDATA_NONE(), 0, 0, String::from(""));
    }

    if tag == EXPR_UNOP() {
        let op: i64 = expr_a(a, eid);
        let operand_eid: i64 = expr_b(a, eid);
        let operand_id: i64 = lower_expr(ctx, operand_eid);
        let un_args: Vec<i64> = Vec::new();
        un_args.push(operand_id);
        if op == UNOP_NOT() {
            return lctx_emit(ctx, IOP_NOT(), ITY_BOOL(), un_args, IDATA_NONE(), 0, 0, String::from(""));
        }
        let zero_args: Vec<i64> = Vec::new();
        let zero_id: i64 = lctx_emit(ctx, IOP_CONST_I64(), ITY_I64(), zero_args, IDATA_CONST_I64(), 0, 0, String::from(""));
        let neg_args: Vec<i64> = Vec::new();
        neg_args.push(zero_id);
        neg_args.push(operand_id);
        return lctx_emit(ctx, IOP_WSUB_I64(), ITY_I64(), neg_args, IDATA_NONE(), 0, 0, String::from(""));
