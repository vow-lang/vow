        let continue_block: i64 = lctx_new_block(ctx);
        let br_args: Vec<i64> = Vec::new();
        br_args.push(is_none);
        lctx_emit(ctx, IOP_BRANCH(), ITY_UNIT(), br_args, IDATA_BRANCH_TARGETS(), early_block, continue_block, String::from(""));

        lctx_switch_to_block(ctx, early_block);
        let alloc_args: Vec<i64> = Vec::new();
        let none_ptr: i64 = lctx_emit(ctx, IOP_REGION_ALLOC(), ITY_PTR(), alloc_args, IDATA_ALLOC_SIZE(), 16, 8, String::from(""));
        let none_tag_args: Vec<i64> = Vec::new();
        let none_tag: i64 = lctx_emit(ctx, IOP_CONST_I64(), ITY_I64(), none_tag_args, IDATA_CONST_I64(), 0, 0, String::from(""));
        let fs_args: Vec<i64> = Vec::new();
        fs_args.push(none_ptr);
        fs_args.push(none_tag);
        lctx_emit(ctx, IOP_FIELD_SET(), ITY_UNIT(), fs_args, IDATA_FIELD(), 0, 0, String::from(""));
        if ctx.cur_vow_lid != -1 {
            lower_ensures_clauses(ctx, ctx.cur_vow_lid, none_ptr);
        }
        lctx_emit_return_frees(ctx, none_ptr);
        let ret_args: Vec<i64> = Vec::new();
        ret_args.push(none_ptr);
        lctx_emit(ctx, IOP_RETURN(), ITY_UNIT(), ret_args, IDATA_NONE(), 0, 0, String::from(""));

        lctx_switch_to_block(ctx, continue_block);
        let payload_args: Vec<i64> = Vec::new();
        payload_args.push(inner_id);
        return lctx_emit(ctx, IOP_FIELD_GET(), ITY_I64(), payload_args, IDATA_FIELD(), 1, 0, String::from(""));
    }

    if tag == EXPR_BREAK() {
        let nle: i64 = ctx.loop_exit_blocks.len();
        if nle > 0 {
            let exit_block: i64 = ctx.loop_exit_blocks[nle - 1];
            let val_eid: i64 = expr_a(a, eid);
            let break_live_out: Vec<i64> = Vec::new();
            if val_eid != -1 {
                let val_id: i64 = lower_expr(ctx, val_eid);
                break_live_out.push(val_id);
                let is_loop_idx: i64 = ctx.loop_is_loop.len() - 1;
                let is_loop: i64 = ctx.loop_is_loop[is_loop_idx];
                if is_loop == 1 {
                    let val_ty: i64 = lctx_inst_ty(ctx, val_id);
                    let up_args: Vec<i64> = Vec::new();
                    up_args.push(val_id);
                    let up_id: i64 = lctx_emit(ctx, IOP_UPSILON(), val_ty, up_args, IDATA_PHI_TARGET(), 2147483647, 0, String::from(""));
                    let cur_block: i64 = ctx.current_block;
                    ctx.loop_break_up_ids.push(up_id);
                    ctx.loop_break_up_blocks.push(cur_block);
                    ctx.loop_break_up_tys.push(val_ty);
                    let cnt_idx: i64 = ctx.loop_break_counts.len() - 1;
                    let old_cnt: i64 = ctx.loop_break_counts[cnt_idx];
                    ctx.loop_break_counts[cnt_idx] = old_cnt + 1;
                }
            }
            // Free loop body allocations before jumping to exit.
            // Trace transitive sources of break value through Phi/Upsilon chains.
            let nlasd: i64 = ctx.loop_alloc_scope_depths.len();
            if nlasd > 0 {
                let depth: i64 = ctx.loop_alloc_scope_depths[nlasd - 1];
                if break_live_out.len() > 0 {
                    let bv: i64 = break_live_out[0];
                    let sources: Vec<i64> = lctx_collect_return_sources(ctx, bv);
                    let mut si: i64 = 0;
                    while si < sources.len() {
                        break_live_out.push(sources[si]);
                        si = si + 1;
                    }
                }
                lctx_emit_alloc_frees_to_depth(ctx, depth, break_live_out);
            }
            let jmp_args: Vec<i64> = Vec::new();
            return lctx_emit(ctx, IOP_JUMP(), ITY_UNIT(), jmp_args, IDATA_JUMP_TARGET(), exit_block, 0, String::from(""));
        }
        let u_args: Vec<i64> = Vec::new();
        return lctx_emit(ctx, IOP_CONST_UNIT(), ITY_UNIT(), u_args, IDATA_NONE(), 0, 0, String::from(""));
    }

    if tag == EXPR_CONTINUE() {
        let nlh: i64 = ctx.loop_header_blocks.len();
        if nlh > 0 {
            let hdr_block: i64 = ctx.loop_header_blocks[nlh - 1];
            let phi_names: Vec<String> = ctx.loop_continue_phi_names[nlh - 1];
            let phi_ids2: Vec<i64> = ctx.loop_continue_phi_ids[nlh - 1];
            let scope_depth: i64 = ctx.loop_continue_scope_depth[nlh - 1];
            let nphis: i64 = phi_names.len();

            // Free loop body allocations before jumping back to header.
            // Include transitive sources so Phi/Upsilon aliases aren't freed.
            let nlasd: i64 = ctx.loop_alloc_scope_depths.len();
            if nlasd > 0 {
                let depth: i64 = ctx.loop_alloc_scope_depths[nlasd - 1];
                let cont_live_out: Vec<i64> = Vec::new();
                let mut cli: i64 = 0;
                while cli < nphis {
                    let vname: String = phi_names[cli];
                    let cval: i64 = lctx_lookup(ctx, vname);
                    cont_live_out.push(cval);
                    let csources: Vec<i64> = lctx_collect_return_sources(ctx, cval);
                    let mut csi: i64 = 0;
                    while csi < csources.len() {
                        cont_live_out.push(csources[csi]);
                        csi = csi + 1;
                    }
                    cli = cli + 1;
                }
                lctx_emit_alloc_frees_to_depth(ctx, depth, cont_live_out);
            }

            let mut pi: i64 = 0;
            while pi < nphis {
                let vname: String = phi_names[pi];
                let cur_val: i64 = lctx_lookup_at_depth(ctx, vname, scope_depth);
                let val_ty: i64 = ITY_I64();
                let up_args: Vec<i64> = Vec::new();
                up_args.push(cur_val);
                lctx_emit(ctx, IOP_UPSILON(), val_ty, up_args, IDATA_PHI_TARGET(), phi_ids2[pi], 0, String::from(""));
                pi = pi + 1;
            }
            let idx_phi2: i64 = ctx.loop_continue_idx_phi[nlh - 1];
            if idx_phi2 != -1 {
                let one_args: Vec<i64> = Vec::new();
                let one: i64 = lctx_emit(ctx, IOP_CONST_I64(), ITY_I64(), one_args, IDATA_CONST_I64(), 1, 0, String::from(""));
                let add_args: Vec<i64> = Vec::new();
                add_args.push(idx_phi2);
                add_args.push(one);
                let idx_next: i64 = lctx_emit(ctx, IOP_WADD_I64(), ITY_I64(), add_args, IDATA_NONE(), 0, 0, String::from(""));
                let idx_up_args: Vec<i64> = Vec::new();
                idx_up_args.push(idx_next);
                lctx_emit(ctx, IOP_UPSILON(), ITY_I64(), idx_up_args, IDATA_PHI_TARGET(), idx_phi2, 0, String::from(""));
            }
            let jmp_args: Vec<i64> = Vec::new();
            return lctx_emit(ctx, IOP_JUMP(), ITY_UNIT(), jmp_args, IDATA_JUMP_TARGET(), hdr_block, 0, String::from(""));
        }
        let u_args: Vec<i64> = Vec::new();
        return lctx_emit(ctx, IOP_CONST_UNIT(), ITY_UNIT(), u_args, IDATA_NONE(), 0, 0, String::from(""));
    }

    if tag == EXPR_CAST() {
        let inner_eid: i64 = expr_a(a, eid);
        let target_ast_tid: i64 = expr_b(a, eid);
        let val_id: i64 = lower_expr(ctx, inner_eid);
        let src_ty: i64 = lctx_inst_ty(ctx, val_id);
        let tgt_ty: i64 = lower_ast_ty(a, target_ast_tid);
        if src_ty == ITY_I64() && tgt_ty == ITY_U64() {
            let inner_tag: i64 = expr_tag(a, inner_eid);
            if inner_tag == EXPR_LIT_INT() {
                let lit_val: i64 = expr_a(a, inner_eid);
                let const_args: Vec<i64> = Vec::new();
                return lctx_emit(ctx, IOP_CONST_U64(), ITY_U64(), const_args, IDATA_CONST_U64(), lit_val, 0, String::from(""));
            }
            let cast_args: Vec<i64> = Vec::new();
            cast_args.push(val_id);
            return lctx_emit(ctx, IOP_CAST_I64_TO_U64(), ITY_U64(), cast_args, IDATA_NONE(), 0, 0, String::from(""));
        }
        if src_ty == ITY_U64() && tgt_ty == ITY_I64() {
            let cast_args: Vec<i64> = Vec::new();
            cast_args.push(val_id);
            return lctx_emit(ctx, IOP_CAST_U64_TO_I64(), ITY_I64(), cast_args, IDATA_NONE(), 0, 0, String::from(""));
        }
        if src_ty == ITY_I32() && tgt_ty == ITY_U64() {
            let inner_tag: i64 = expr_tag(a, inner_eid);
            if inner_tag == EXPR_LIT_INT() {
                let lit_val: i64 = expr_a(a, inner_eid);
                let const_args: Vec<i64> = Vec::new();
                return lctx_emit(ctx, IOP_CONST_U64(), ITY_U64(), const_args, IDATA_CONST_U64(), lit_val, 0, String::from(""));
            }
            let cast_args: Vec<i64> = Vec::new();
            cast_args.push(val_id);
            return lctx_emit(ctx, IOP_CAST_I64_TO_U64(), ITY_U64(), cast_args, IDATA_NONE(), 0, 0, String::from(""));
        }
        return val_id;
    }

    let u_args: Vec<i64> = Vec::new();
    lctx_emit(ctx, IOP_CONST_UNIT(), ITY_UNIT(), u_args, IDATA_NONE(), 0, 0, String::from(""))
}

fn lower_stmt(ctx: LowerCtx, sid: i64) {
    let a: AstArena = ctx.arena;
    let tag: i64 = stmt_tag(a, sid);
    if tag == STMT_LET() {
        let pat_id: i64 = stmt_a(a, sid);
        let ann_tid: i64 = stmt_b(a, sid);
        let init_eid: i64 = stmt_c(a, sid);
        let mut val: i64 = lower_expr(ctx, init_eid);
        let ptag: i64 = pat_tag(a, pat_id);
        if ptag == PAT_IDENT() {
            let name_sid: i64 = pat_a(a, pat_id);
            let name: String = arena_str(a, name_sid);
            if ann_tid != -1 {
                let atag: i64 = type_tag(a, ann_tid);
                if atag == TY_NAMED() {
                    let type_name_sid: i64 = type_a(a, ann_tid);
                    let type_name: String = arena_str(a, type_name_sid);
                    if type_name == String::from("u64") && lctx_inst_ty(ctx, val) != ITY_U64() {
                        let cast_args: Vec<i64> = Vec::new();
                        cast_args.push(val);
                        val = lctx_emit(ctx, IOP_CAST_I64_TO_U64(), ITY_U64(), cast_args, IDATA_NONE(), 0, 0, String::from(""));
                    }
                    if type_name != String::from("i32") && type_name != String::from("i64") && type_name != String::from("u64") && type_name != String::from("f32") && type_name != String::from("f64") && type_name != String::from("bool") {
                        lctx_tag(ctx, val, type_name);
                    }
                } else if atag == TY_GENERIC() {
                    let type_name_sid: i64 = type_a(a, ann_tid);
                    let type_name: String = arena_str(a, type_name_sid);
                    lctx_tag(ctx, val, type_name);
                    if type_name == String::from("Vec") {
                        let args_lid: i64 = type_b(a, ann_tid);
                        if list_len(a, args_lid) > 0 {
                            let elem_tid: i64 = list_get(a, args_lid, 0);
                            let etag: i64 = type_tag(a, elem_tid);
                            if etag == TY_NAMED() {
                                let elem_name_sid: i64 = type_a(a, elem_tid);
                                let elem_name: String = arena_str(a, elem_name_sid);
                                lctx_tag_vec_elem(ctx, val, elem_name);
                            }
                        }
                    }
                }
            }
            ctx.func.local_names_ids.push(val);
            ctx.func.local_names_strs.push(name);
            lctx_define(ctx, name, val);
        }
    } else if tag == STMT_EXPR() {
        let expr_eid: i64 = stmt_a(a, sid);
        lower_expr(ctx, expr_eid);
    }
}

fn lower_block(ctx: LowerCtx, bid: i64) -> i64 {
    lctx_push_scope(ctx);
    let result: i64 = lower_block_inner(ctx, bid);
    lctx_pop_scope(ctx);
    result
}

fn lower_block_inner(ctx: LowerCtx, bid: i64) -> i64 {
    let a: AstArena = ctx.arena;
    let stmts_lid: i64 = blk_stmts(a, bid);
    let trail_eid: i64 = blk_trail(a, bid);
    let n: i64 = list_len(a, stmts_lid);
    let last_is_trail: bool = false;
    if n > 0 {
        let last_sid: i64 = list_get(a, stmts_lid, n - 1);
        let last_tag: i64 = stmt_tag(a, last_sid);
        if last_tag == STMT_EXPR() {
            let has_semi: i64 = stmt_b(a, last_sid);
            if has_semi == 0 {
                last_is_trail = true;
            }
        }
    }
    let limit: i64 = {
        if last_is_trail { n - 1 } else { n }
    };
    let mut i: i64 = 0;
    while i < limit && !lctx_is_terminated(ctx) {
        let sid: i64 = list_get(a, stmts_lid, i);
        lower_stmt(ctx, sid);
        i = i + 1;
    }
    if lctx_is_terminated(ctx) {
        return 2147483647;
    }
    if last_is_trail {
        let last_sid: i64 = list_get(a, stmts_lid, n - 1);
        let last_eid: i64 = stmt_a(a, last_sid);
        return lower_expr(ctx, last_eid);
    }
    if trail_eid != -1 {
        return lower_expr(ctx, trail_eid);
    }
    let u_args: Vec<i64> = Vec::new();
    lctx_emit(ctx, IOP_CONST_UNIT(), ITY_UNIT(), u_args, IDATA_NONE(), 0, 0, String::from(""))
}

fn lower_block_stmts(ctx: LowerCtx, bid: i64) {
    let a: AstArena = ctx.arena;
    let stmts_lid: i64 = blk_stmts(a, bid);
    let trail_eid: i64 = blk_trail(a, bid);
    let n: i64 = list_len(a, stmts_lid);
    let mut i: i64 = 0;
    while i < n && !lctx_is_terminated(ctx) {
        let sid: i64 = list_get(a, stmts_lid, i);
        lower_stmt(ctx, sid);
        i = i + 1;
    }
    if lctx_is_terminated(ctx) { return; }
    if trail_eid != -1 {
        lower_expr(ctx, trail_eid);
    }
}

fn stmt_is_last_no_semi(a: AstArena, bid: i64) -> bool {
    let stmts_lid: i64 = blk_stmts(a, bid);
    let n: i64 = list_len(a, stmts_lid);
    if n == 0 { return false; }
    let last_sid: i64 = list_get(a, stmts_lid, n - 1);
    let last_tag: i64 = stmt_tag(a, last_sid);
    if last_tag != STMT_EXPR() { return false; }
    let has_semi: i64 = stmt_b(a, last_sid);
    has_semi == 0
}

fn collect_free_vars_in_expr(ctx: LowerCtx, eid: i64, out_names: Vec<String>, out_ids: Vec<i64>) {
    let a: AstArena = ctx.arena;
    let tag: i64 = expr_tag(a, eid);
    if tag == EXPR_IDENT() {
        let name_sid: i64 = expr_a(a, eid);
        let name: String = arena_str(a, name_sid);
        let val: i64 = lctx_lookup(ctx, name);
        if val != -1 && !vec_contains_str(out_names, name) {
            out_names.push(name);
            out_ids.push(val);
        }
    } else if tag == EXPR_RESULT() {
        let val: i64 = lctx_lookup(ctx, String::from("result"));
        if val != -1 && !vec_contains_str(out_names, String::from("result")) {
            out_names.push(String::from("result"));
            out_ids.push(val);
        }
    } else if tag == EXPR_BINOP() {
        let lhs_eid: i64 = expr_b(a, eid);
        let rhs_eid: i64 = expr_c(a, eid);
        collect_free_vars_in_expr(ctx, lhs_eid, out_names, out_ids);
        collect_free_vars_in_expr(ctx, rhs_eid, out_names, out_ids);
    } else if tag == EXPR_UNOP() {
        let operand_eid: i64 = expr_b(a, eid);
        collect_free_vars_in_expr(ctx, operand_eid, out_names, out_ids);
    } else if tag == EXPR_CALL() {
        let callee_eid: i64 = expr_a(a, eid);
        let args_lid: i64 = expr_b(a, eid);
        collect_free_vars_in_expr(ctx, callee_eid, out_names, out_ids);
        let nargs: i64 = list_len(a, args_lid);
        let mut i: i64 = 0;
        while i < nargs {
            let arg_eid: i64 = list_get(a, args_lid, i);
            collect_free_vars_in_expr(ctx, arg_eid, out_names, out_ids);
            i = i + 1;
        }
    } else if tag == EXPR_CAST() {
        let inner_eid: i64 = expr_a(a, eid);
        collect_free_vars_in_expr(ctx, inner_eid, out_names, out_ids);
    } else if tag == EXPR_IF() {
        let cond_eid: i64 = expr_a(a, eid);
        collect_free_vars_in_expr(ctx, cond_eid, out_names, out_ids);
    }
}

fn print_expr_text(a: AstArena, eid: i64) -> String {
    let tag: i64 = expr_tag(a, eid);
    if tag == EXPR_LIT_INT() {
        let val: i64 = expr_a(a, eid);
        return i64_to_string(val);
    }
    if tag == EXPR_LIT_BOOL() {
        let val: i64 = expr_a(a, eid);
        if val != 0 { return String::from("true"); }
        return String::from("false");
    }
    if tag == EXPR_IDENT() {
        let name_sid: i64 = expr_a(a, eid);
        return arena_str(a, name_sid);
    }
    if tag == EXPR_RESULT() {
        return String::from("result");
    }
    if tag == EXPR_BINOP() {
        let op: i64 = expr_a(a, eid);
        let lhs_eid: i64 = expr_b(a, eid);
        let rhs_eid: i64 = expr_c(a, eid);
        let lhs_s: String = print_expr_text(a, lhs_eid);
        let rhs_s: String = print_expr_text(a, rhs_eid);
        let op_s: String = binop_str(op);
        let result: String = String::from("");
        result.push_str(lhs_s);
        result.push_str(String::from(" "));
        result.push_str(op_s);
        result.push_str(String::from(" "));
        result.push_str(rhs_s);
        return result;
    }
    if tag == EXPR_UNOP() {
        let op: i64 = expr_a(a, eid);
        let operand_eid: i64 = expr_b(a, eid);
        let inner_s: String = print_expr_text(a, operand_eid);
        if op == UNOP_NOT() {
            let result: String = String::from("!");
            result.push_str(inner_s);
            return result;
        }
        let result: String = String::from("-");
        result.push_str(inner_s);
        return result;
    }
    if tag == EXPR_CAST() {
        let inner_eid: i64 = expr_a(a, eid);
        let inner_s: String = print_expr_text(a, inner_eid);
        let result: String = String::from("");
        result.push_str(inner_s);
        result.push_str(String::from(" as <type>"));
        return result;
    }
    if tag == EXPR_CALL() {
        let callee_eid: i64 = expr_a(a, eid);
        let args_lid: i64 = expr_b(a, eid);
        let callee_s: String = print_expr_text(a, callee_eid);
        let result: String = String::from("");
        result.push_str(callee_s);
        result.push_str(String::from("("));
        let nargs: i64 = list_len(a, args_lid);
        let mut i: i64 = 0;
        while i < nargs {
            if i > 0 { result.push_str(String::from(", ")); }
            let arg_eid: i64 = list_get(a, args_lid, i);
            result.push_str(print_expr_text(a, arg_eid));
            i = i + 1;
        }
        result.push_str(String::from(")"));
        return result;
    }
    String::from("<expr>")
}

fn binop_str(op: i64) -> String {
    if op == BINOP_ADD() { return String::from("+"); }
    if op == BINOP_SUB() { return String::from("-"); }
    if op == BINOP_MUL() { return String::from("*"); }
    if op == BINOP_DIV() { return String::from("/"); }
    if op == BINOP_REM() { return String::from("%"); }
    if op == BINOP_EQ() { return String::from("=="); }
    if op == BINOP_NE() { return String::from("!="); }
    if op == BINOP_LT() { return String::from("<"); }
    if op == BINOP_LE() { return String::from("<="); }
    if op == BINOP_GT() { return String::from(">"); }
    if op == BINOP_GE() { return String::from(">="); }
    if op == BINOP_AND() { return String::from("&&"); }
    if op == BINOP_OR() { return String::from("||"); }
    if op == BINOP_BITAND() { return String::from("&"); }
    if op == BINOP_BITOR() { return String::from("|"); }
    if op == BINOP_ADD_CHK() { return String::from("+!"); }
    if op == BINOP_SUB_CHK() { return String::from("-!"); }
    if op == BINOP_MUL_CHK() { return String::from("*!"); }
    if op == BINOP_DIV_CHK() { return String::from("/!"); }
    if op == BINOP_REM_CHK() { return String::from("%!"); }
    if op == BINOP_XOR() { return String::from("^"); }
    if op == BINOP_SHL() { return String::from("<<"); }
    if op == BINOP_SHR() { return String::from(">>"); }
    String::from("?")
}

fn i64_to_string(v: i64) -> String {
    if v == 0 { return String::from("0"); }
    let neg: bool = v < 0;
    let mut n: i64 = v;
    if neg { n = 0 - n; }
    let digits: Vec<i64> = Vec::new();
    while n > 0 {
        digits.push(n - (n / 10) * 10);
        n = n / 10;
    }
    let result: String = String::from("");
    if neg { result.push_byte(45); }
    let nd: i64 = digits.len();
    let mut i: i64 = nd;
    while i > 0 {
        i = i - 1;
        result.push_byte(48 + digits[i]);
    }
    result
}

fn lower_requires_clauses(ctx: LowerCtx, vow_lid: i64) {
    let a: AstArena = ctx.arena;
    let n: i64 = list_len(a, vow_lid);
    let mut i: i64 = 0;
    while i < n {
        let cid: i64 = list_get(a, vow_lid, i);
        let kind: i64 = vow_clause_kind(a, cid);
        if kind == CLAUSE_REQUIRES() {
            let clause_eid: i64 = vow_clause_expr(a, cid);
            let desc: String = String::from("requires ");
            desc.push_str(print_expr_text(a, clause_eid));
            let binding_names: Vec<String> = Vec::new();
            let binding_ids: Vec<i64> = Vec::new();
            collect_free_vars_in_expr(ctx, clause_eid, binding_names, binding_ids);
            let clause_offset: i64 = span_unpack_start(expr_span(a, clause_eid));
            let vow_id: i64 = lctx_alloc_vow(ctx, desc, BLAME_CALLER(), binding_ids, binding_names, clause_offset);
            let pred_id: i64 = lower_expr(ctx, clause_eid);
            let vow_args: Vec<i64> = Vec::new();
            vow_args.push(pred_id);
            lctx_emit(ctx, IOP_VOW_REQ(), ITY_UNIT(), vow_args, IDATA_VOW_ID(), vow_id, 0, String::from(""));
        }
        i = i + 1;
    }
}

fn lower_ensures_clauses(ctx: LowerCtx, vow_lid: i64, result_id: i64) {
    let a: AstArena = ctx.arena;
    lctx_push_scope(ctx);
    lctx_define(ctx, String::from("result"), result_id);
    let n: i64 = list_len(a, vow_lid);
    let mut i: i64 = 0;
    while i < n {
        let cid: i64 = list_get(a, vow_lid, i);
        let kind: i64 = vow_clause_kind(a, cid);
        if kind == CLAUSE_ENSURES() {
            let clause_eid: i64 = vow_clause_expr(a, cid);
            let desc: String = String::from("ensures ");
            desc.push_str(print_expr_text(a, clause_eid));
            let binding_names: Vec<String> = Vec::new();
            let binding_ids: Vec<i64> = Vec::new();
            collect_free_vars_in_expr(ctx, clause_eid, binding_names, binding_ids);
            let clause_offset: i64 = span_unpack_start(expr_span(a, clause_eid));
            let vow_id: i64 = lctx_alloc_vow(ctx, desc, BLAME_CALLEE(), binding_ids, binding_names, clause_offset);
            let pred_id: i64 = lower_expr(ctx, clause_eid);
            let vow_args: Vec<i64> = Vec::new();
            vow_args.push(pred_id);
            lctx_emit(ctx, IOP_VOW_ENS(), ITY_UNIT(), vow_args, IDATA_VOW_ID(), vow_id, 0, String::from(""));
        }
        i = i + 1;
    }
    lctx_pop_scope(ctx);
}

fn lower_invariant_clauses(ctx: LowerCtx, vow_lid: i64) {
    let a: AstArena = ctx.arena;
    let n: i64 = list_len(a, vow_lid);
    let mut i: i64 = 0;
    while i < n {
        let cid: i64 = list_get(a, vow_lid, i);
        let kind: i64 = vow_clause_kind(a, cid);
        if kind == CLAUSE_INVARIANT() {
            let clause_eid: i64 = vow_clause_expr(a, cid);
            let desc: String = String::from("invariant ");
            desc.push_str(print_expr_text(a, clause_eid));
            let binding_names: Vec<String> = Vec::new();
            let binding_ids: Vec<i64> = Vec::new();
            collect_free_vars_in_expr(ctx, clause_eid, binding_names, binding_ids);
            let clause_offset: i64 = span_unpack_start(expr_span(a, clause_eid));
            let vow_id: i64 = lctx_alloc_vow(ctx, desc, BLAME_CALLEE(), binding_ids, binding_names, clause_offset);
            let pred_id: i64 = lower_expr(ctx, clause_eid);
            let vow_args: Vec<i64> = Vec::new();
            vow_args.push(pred_id);
            lctx_emit(ctx, IOP_VOW_INV(), ITY_UNIT(), vow_args, IDATA_VOW_ID(), vow_id, 0, String::from(""));
        }
        i = i + 1;
    }
}

fn lower_function_vow(ctx: LowerCtx, fid: i64) -> IrFunction {
    let a: AstArena = ctx.arena;
    let name_sid: i64 = fn_name_sid(a, fid);
    let name: String = arena_str(a, name_sid);
    let ret_tid: i64 = fn_ret_ast_tid(a, fid);
    let eff: i64 = fn_eff(a, fid);
    let body_bid: i64 = fn_body_bid(a, fid);
    let vow_lid: i64 = fn_vow_lid(a, fid);
    let params_lid: i64 = fn_params_lid(a, fid);

    let ir_ret: i64 = lower_ast_ty(a, ret_tid);
    let func: IrFunction = ir_function_new(0, name, ir_ret, eff);
    let entry: IrBlock = ir_block_new(0);
    func.blocks.push(entry);

    ctx.func = func;
    ctx.current_block = 0;
    ctx.next_inst_id = 0;
    ctx.scope_vars = Vec::new();
    ctx.scope_vals = Vec::new();
    ctx.scope_starts = Vec::new();
    ctx.tag_inst_ids = Vec::new();
    ctx.tag_names = Vec::new();
    ctx.vec_elem_inst_ids = Vec::new();
    ctx.vec_elem_names = Vec::new();
    ctx.alloc_ids = Vec::new();
    ctx.alloc_tags = Vec::new();
    ctx.alloc_sizes = Vec::new();
    ctx.escaped_ids = Vec::new();
    ctx.alloc_scope_starts = Vec::new();
    ctx.loop_alloc_scope_depths = Vec::new();

    if vow_lid != -1 {
        ctx.cur_vow_lid = vow_lid;
    } else {
        ctx.cur_vow_lid = -1;
    }

    let nparams: i64 = list_len(a, params_lid) / 3;
    let mut pi: i64 = 0;
    while pi < nparams {
        let pname_sid: i64 = list_get(a, params_lid, pi * 3);
        let ptid: i64 = list_get(a, params_lid, pi * 3 + 1);
        let pty: i64 = lower_ast_ty(a, ptid);
        func.params.push(pty);
        let arg_args: Vec<i64> = Vec::new();
        let arg_id: i64 = lctx_emit(ctx, IOP_GET_ARG(), pty, arg_args, IDATA_ARG_INDEX(), pi, 0, String::from(""));
        let pname: String = arena_str(a, pname_sid);
        func.param_names.push(pname);

        if ptid != -1 {
            let ptag: i64 = type_tag(a, ptid);
            if ptag == TY_NAMED() {
                let tn_sid: i64 = type_a(a, ptid);
                let tn: String = arena_str(a, tn_sid);
                if tn == String::from("String") || tn == String::from("str") {
                    lctx_tag(ctx, arg_id, String::from("String"));
                } else {
                    let sidx: i64 = lctx_find_struct(ctx, tn);
                    if sidx != -1 {
                        lctx_tag(ctx, arg_id, tn);
                    }
                }
            } else if ptag == TY_GENERIC() {
                let tn_sid: i64 = type_a(a, ptid);
                let tn: String = arena_str(a, tn_sid);
                if tn == String::from("HashMap") {
                    lctx_tag(ctx, arg_id, String::from("HashMap"));
                } else if tn == String::from("Vec") {
                    lctx_tag(ctx, arg_id, String::from("Vec"));
                    let pargs_lid: i64 = type_b(a, ptid);
                    if list_len(a, pargs_lid) > 0 {
                        let pelem_tid: i64 = list_get(a, pargs_lid, 0);
                        let petag: i64 = type_tag(a, pelem_tid);
                        if petag == TY_NAMED() {
                            let pelem_sid: i64 = type_a(a, pelem_tid);
                            let pelem_name: String = arena_str(a, pelem_sid);
                            lctx_tag_vec_elem(ctx, arg_id, pelem_name);
                        }
                    }
                }
            }
        }

        lctx_define(ctx, pname, arg_id);
        pi = pi + 1;
    }

    let mut ri: i64 = 0;
    while ri < nparams {
        let ref_eid: i64 = list_get(a, params_lid, ri * 3 + 2);
        if ref_eid != -1 {
            let rpname_sid: i64 = list_get(a, params_lid, ri * 3);
            let rpname: String = arena_str(a, rpname_sid);
            let desc: String = String::from("requires ");
            desc.push_str(print_expr_text(a, ref_eid));
            desc.push_str(String::from(" (where on parameter "));
            desc.push_str(rpname);
            desc.push_str(String::from(")"));
            let binding_names: Vec<String> = Vec::new();
            let binding_ids: Vec<i64> = Vec::new();
            collect_free_vars_in_expr(ctx, ref_eid, binding_names, binding_ids);
            let ref_offset: i64 = span_unpack_start(expr_span(a, ref_eid));
            let vow_id: i64 = lctx_alloc_vow(ctx, desc, BLAME_CALLER(), binding_ids, binding_names, ref_offset);
            let pred_id: i64 = lower_expr(ctx, ref_eid);
            let vow_args: Vec<i64> = Vec::new();
            vow_args.push(pred_id);
            lctx_emit(ctx, IOP_VOW_REQ(), ITY_UNIT(), vow_args, IDATA_VOW_ID(), vow_id, 0, String::from(""));
        }
        ri = ri + 1;
    }

    if vow_lid != -1 {
        lower_requires_clauses(ctx, vow_lid);
    }

    lctx_push_scope(ctx);
    let trailing: i64 = lower_block_inner(ctx, body_bid);
    lctx_pop_scope(ctx);

    let has_return: bool = lctx_is_terminated(ctx);

    if !has_return {
        if vow_lid != -1 {
            lower_ensures_clauses(ctx, vow_lid, trailing);
        }
        lctx_emit_return_frees(ctx, trailing);
        let ret_args: Vec<i64> = Vec::new();
        ret_args.push(trailing);
        lctx_emit(ctx, IOP_RETURN(), ITY_UNIT(), ret_args, IDATA_NONE(), 0, 0, String::from(""));
    }

    ctx.func
}

fn lower_module_vow(m: Module, str_eids: Vec<i64>, file_path: String) -> IrModule {
    let a: AstArena = m.arena;
    let mod_name_sid: i64 = m.name_sid;
    let mod_name: String = arena_str(a, mod_name_sid);
    let ir_mod: IrModule = ir_module_new(mod_name);

    let func_names: Vec<String> = Vec::new();
    let func_ret_tys: Vec<i64> = Vec::new();
    let struct_names: Vec<String> = Vec::new();
    let struct_field_lists: Vec<Vec<String>> = Vec::new();
    let struct_field_type_names: Vec<Vec<String>> = Vec::new();
    let struct_field_vec_elems: Vec<Vec<String>> = Vec::new();
    let enum_names: Vec<String> = Vec::new();
    let enum_variant_lists: Vec<Vec<String>> = Vec::new();

    let n_items: i64 = m.items.len();
    let mut ii: i64 = 0;
    while ii < n_items {
        let item: i64 = m.items[ii];
        let ik: i64 = item_kind(item);
        let iid: i64 = item_id(item);
        if ik == ITEM_FN() {
            let name_sid: i64 = fn_name_sid(a, iid);
            let name: String = arena_str(a, name_sid);
            let ret_tid: i64 = fn_ret_ast_tid(a, iid);
            let ir_ret: i64 = lower_ast_ty(a, ret_tid);
            func_names.push(name);
            func_ret_tys.push(ir_ret);
        } else if ik == ITEM_STRUCT() {
            let sname_sid: i64 = sdef_name_sid(a, iid);
            let sname: String = arena_str(a, sname_sid);
            let fields_lid: i64 = sdef_fields_lid(a, iid);
            let nf: i64 = list_len(a, fields_lid) / 2;
            let fnames: Vec<String> = Vec::new();
            let ftypes: Vec<String> = Vec::new();
            let fvec_elems: Vec<String> = Vec::new();
            let ir_fields: Vec<IrFieldLayout> = Vec::new();
            let mut fi: i64 = 0;
            while fi < nf {
                let fname_sid: i64 = list_get(a, fields_lid, fi * 2);
                let ftid: i64 = list_get(a, fields_lid, fi * 2 + 1);
                let fname: String = arena_str(a, fname_sid);
                fnames.push(fname);
                let ftype_name: String = {
                    if ftid != -1 {
                        let ftag: i64 = type_tag(a, ftid);
                        if ftag == TY_NAMED() || ftag == TY_GENERIC() {
                            let ftn_sid: i64 = type_a(a, ftid);
                            arena_str(a, ftn_sid)
                        } else {
                            String::from("")
                        }
                    } else {
                        String::from("")
                    }
                };
                ftypes.push(ftype_name);
                let fve: String = {
                    if ftid != -1 {
                        let ftag: i64 = type_tag(a, ftid);
                        if ftag == TY_GENERIC() {
                            let ftn_sid: i64 = type_a(a, ftid);
                            let ftn: String = arena_str(a, ftn_sid);
                            if ftn == String::from("Vec") {
                                let args_lid: i64 = type_b(a, ftid);
                                if list_len(a, args_lid) > 0 {
                                    let elem_tid: i64 = list_get(a, args_lid, 0);
                                    let etag: i64 = type_tag(a, elem_tid);
                                    if etag == TY_NAMED() {
                                        let en_sid: i64 = type_a(a, elem_tid);
                                        let en: String = arena_str(a, en_sid);
                                        if en != String::from("i32") && en != String::from("i64") && en != String::from("u64") && en != String::from("f32") && en != String::from("f64") && en != String::from("bool") {
                                            en
                                        } else {
                                            String::from("")
                                        }
                                    } else {
                                        String::from("")
                                    }
                                } else {
                                    String::from("")
                                }
                            } else {
                                String::from("")
                            }
                        } else {
                            String::from("")
                        }
                    } else {
                        String::from("")
                    }
                };
                fvec_elems.push(fve);
                let ir_ty: i64 = lower_ast_ty(a, ftid);
                let fl: IrFieldLayout = IrFieldLayout { name: fname, ty: ir_ty };
                ir_fields.push(fl);
                fi = fi + 1;
            }
            struct_names.push(sname);
            struct_field_lists.push(fnames);
            struct_field_type_names.push(ftypes);
            struct_field_vec_elems.push(fvec_elems);
            let is_linear: i64 = a.sdef_data[iid * 4 + 2];
            let sl: IrStructLayout = IrStructLayout { name: sname, fields: ir_fields, is_linear: is_linear };
            ir_mod.struct_layouts.push(sl);
        } else if ik == ITEM_ENUM() {
            let ename_sid: i64 = edef_name_sid(a, iid);
            let ename: String = arena_str(a, ename_sid);
            let variants_lid: i64 = edef_variants_lid(a, iid);
            let n_pairs: i64 = list_len(a, variants_lid);
            let nv: i64 = n_pairs / 2;
            let vnames: Vec<String> = Vec::new();
            let ir_variants: Vec<IrVariantLayout> = Vec::new();
            let mut vi: i64 = 0;
            while vi < nv {
                let vname_sid: i64 = list_get(a, variants_lid, vi * 2);
                let vname: String = arena_str(a, vname_sid);
                vnames.push(vname);
                let payload_lid: i64 = list_get(a, variants_lid, vi * 2 + 1);
                let n_payload: i64 = list_len(a, payload_lid);
                let payload: Vec<IrFieldLayout> = Vec::new();
                let mut pi: i64 = 0;
                while pi < n_payload {
                    let p_ast_tid: i64 = list_get(a, payload_lid, pi);
                    let p_ir_ty: i64 = lower_ast_ty(a, p_ast_tid);
                    let fl: IrFieldLayout = IrFieldLayout { name: String::from(""), ty: p_ir_ty };
                    payload.push(fl);
                    pi = pi + 1;
                }
                let vl: IrVariantLayout = IrVariantLayout { name: vname, tag: vi, payload: payload };
                ir_variants.push(vl);
                vi = vi + 1;
            }
            enum_names.push(ename);
            enum_variant_lists.push(vnames);
            let el: IrEnumLayout = IrEnumLayout { name: ename, variants: ir_variants };
            ir_mod.enum_layouts.push(el);
        }
        ii = ii + 1;
    }

    enum_names.push(String::from("Option"));
    let opt_variants: Vec<String> = Vec::new();
    opt_variants.push(String::from("None"));
    opt_variants.push(String::from("Some"));
    enum_variant_lists.push(opt_variants);

    enum_names.push(String::from("Result"));
    let res_variants: Vec<String> = Vec::new();
    res_variants.push(String::from("Ok"));
    res_variants.push(String::from("Err"));
    enum_variant_lists.push(res_variants);

    let cnames: Vec<String> = Vec::new();
    let cvals: Vec<i64> = Vec::new();
    let ctids: Vec<i64> = Vec::new();
    let mut ci: i64 = 0;
    while ci < n_items {
        let item: i64 = m.items[ci];
        let ik: i64 = item_kind(item);
        let iid: i64 = item_id(item);
        if ik == ITEM_CONST() {
            let cn_sid: i64 = cdef_name_sid(a, iid);
            let cn: String = arena_str(a, cn_sid);
            let cv_eid: i64 = cdef_value_eid(a, iid);
            let cv_tag: i64 = expr_tag(a, cv_eid);
            let cv: i64 = {
                if cv_tag == EXPR_LIT_INT() {
                    expr_a(a, cv_eid)
                } else if cv_tag == EXPR_LIT_BOOL() {
                    expr_a(a, cv_eid)
                } else if cv_tag == EXPR_UNOP() {
                    let inner_eid: i64 = expr_b(a, cv_eid);
                    let inner_tag: i64 = expr_tag(a, inner_eid);
                    if inner_tag == EXPR_LIT_INT() {
                        0 - expr_a(a, inner_eid)
                    } else {
                        0
                    }
                } else {
                    0
                }
            };
            let ct: i64 = {
                if cv_tag == EXPR_LIT_BOOL() {
                    ITY_BOOL()
                } else {
                    ITY_I64()
                }
            };
            cnames.push(cn);
            cvals.push(cv);
            ctids.push(ct);
        }
        ci = ci + 1;
    }

    let ctx: LowerCtx = lctx_new(String::from(""), ITY_UNIT(), 0, a, str_eids);
    ctx.file = file_path;
    ctx.func_names = func_names;
    ctx.func_ret_tys = func_ret_tys;
    ctx.struct_names = struct_names;
    ctx.struct_field_lists = struct_field_lists;
    ctx.struct_field_type_names = struct_field_type_names;
    ctx.struct_field_vec_elems = struct_field_vec_elems;
    ctx.enum_names = enum_names;
    ctx.enum_variant_lists = enum_variant_lists;
    ctx.const_names = cnames;
    ctx.const_values = cvals;
    ctx.const_tids = ctids;

    let all_strings: Vec<String> = Vec::new();
    let mut func_idx: i64 = 0;

    let mut ii2: i64 = 0;
    while ii2 < n_items {
        let item: i64 = m.items[ii2];
        let ik: i64 = item_kind(item);
        let iid: i64 = item_id(item);
        if ik == ITEM_FN() {
            let ir_func: IrFunction = lower_function_vow(ctx, iid);
            ir_func.id = func_idx;

            let base: i64 = all_strings.len();
            if base > 0 || ctx.string_pool.len() > 0 {
                let nb: i64 = ir_func.blocks.len();
                let mut bi: i64 = 0;
                while bi < nb {
                    let blk: IrBlock = ir_func.blocks[bi];
                    let ni: i64 = blk.insts.len();
                    let mut ii3: i64 = 0;
                    while ii3 < ni {
                        let inst: IrInst = blk.insts[ii3];
                        if inst.dk == IDATA_CONST_STR() {
                            inst.dv = inst.dv + base;
                        }
                        ii3 = ii3 + 1;
                    }
                    bi = bi + 1;
                }
            }

            let npool: i64 = ctx.string_pool.len();
            let mut si: i64 = 0;
            while si < npool {
                all_strings.push(ctx.string_pool[si]);
                si = si + 1;
            }
            ctx.string_pool = Vec::new();

            ir_mod.functions.push(ir_func);
            func_idx = func_idx + 1;
        }
        ii2 = ii2 + 1;
    }

    ir_mod.strings = all_strings;
    let nw: i64 = ctx.warnings.len();
    let mut wi: i64 = 0;
    while wi < nw {
        ir_mod.warnings.push(ctx.warnings[wi]);
        wi = wi + 1;
    }
    ir_mod
}
