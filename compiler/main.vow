    r.push_str(String::from("      }\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ],\n"));
    r.push_str(String::from("  \"message\": \"type error\",\n"));
    r.push_str(String::from("  \"counterexamples\": []\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VerifyFailed Example\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"status\": \"VerifyFailed\",\n"));
