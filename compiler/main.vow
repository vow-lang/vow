    r.push_str(String::from("          \"long\": \"--no-verify\",\n"));
    r.push_str(String::from("          \"value_kind\": \"flag\"\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        {\n"));
    r.push_str(String::from("          \"form\": \"--dump-ir\",\n"));
    r.push_str(String::from("          \"description\": \"Print IR text to stdout and exit (no JSON output, no codegen)\",\n"));
    r.push_str(String::from("          \"long\": \"--dump-ir\",\n"));
    r.push_str(String::from("          \"value_kind\": \"flag\"\n"));
    r.push_str(String::from("        },\n"));
