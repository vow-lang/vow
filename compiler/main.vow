    r.push_str(String::from("  \"usage\": \"vow <command> [OPTIONS] <source.vow>\",\n"));
    r.push_str(String::from("  \"legacy_usage\": \"vow [OPTIONS] <source.vow> (equivalent to vow build)\",\n"));
    r.push_str(String::from("  \"references\": {\n"));
    r.push_str(String::from("    \"grammar\": \"reference/grammar.md\",\n"));
    r.push_str(String::from("    \"cli\": \"reference/cli.md\",\n"));
    r.push_str(String::from("    \"contracts\": \"reference/contracts.md\",\n"));
    r.push_str(String::from("    \"errors\": \"reference/errors.md\",\n"));
    r.push_str(String::from("    \"examples\": \"examples/examples.md\",\n"));
    r.push_str(String::from("    \"schemas\": {\n"));
    r.push_str(String::from("      \"build_result\": \"schemas/build-result.schema.json\",\n"));
    r.push_str(String::from("      \"contracts_result\": \"schemas/contracts-result.schema.json\",\n"));
    r.push_str(String::from("      \"diagnostic\": \"schemas/diagnostic.schema.json\",\n"));
    r.push_str(String::from("      \"counterexample\": \"schemas/counterexample.schema.json\",\n"));
    r.push_str(String::from("      \"mutants_result\": \"schemas/mutants-result.schema.json\",\n"));
    r.push_str(String::from("      \"test_result\": \"schemas/test-result.schema.json\",\n"));
    r.push_str(String::from("      \"vow_violation\": \"schemas/vow-violation.schema.json\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"invocation\": {\n"));
    r.push_str(String::from("    \"canonical\": \"vow <command> [OPTIONS] <source.vow>\",\n"));
    r.push_str(String::from("    \"default_command\": \"build\",\n"));
    r.push_str(String::from("    \"legacy_equivalent\": \"vow [OPTIONS] <source.vow>\",\n"));
    r.push_str(String::from("    \"source_argument\": {\n"));
    r.push_str(String::from("      \"name\": \"source\",\n"));
    r.push_str(String::from("      \"kind\": \"path\",\n"));
    r.push_str(String::from("      \"required\": true,\n"));
    r.push_str(String::from("      \"suffix\": \".vow\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"commands\": {\n"));
    r.push_str(String::from("    \"build\": \"Compile source to native executable (verifies by default; use --no-verify to skip)\",\n"));
    r.push_str(String::from("    \"verify\": \"Verify contracts without producing an executable (use --no-cache to skip cache)\",\n"));
    r.push_str(String::from("    \"test\": \"Run tests: discover, compile, execute test_*.vow files with JSON results\",\n"));
    r.push_str(String::from("    \"decl\": \"Emit declaration file (.vow.d) with type signatures only\",\n"));
    r.push_str(String::from("    \"contracts\": \"List all contracts with optional verification status\",\n"));
    r.push_str(String::from("    \"skill\": \"Generate or install the Claude Code skill document for this compiler version\"\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"command_details\": {\n"));
    r.push_str(String::from("    \"build\": {\n"));
    r.push_str(String::from("      \"status\": \"implemented\",\n"));
    r.push_str(String::from("      \"usage\": \"vow build [OPTIONS] <source.vow>\",\n"));
    r.push_str(String::from("      \"default_when_command_omitted\": true,\n"));
    r.push_str(String::from("      \"arguments\": [\n"));
    r.push_str(String::from("        {\n"));
    r.push_str(String::from("          \"name\": \"source\",\n"));
    r.push_str(String::from("          \"kind\": \"path\",\n"));
    r.push_str(String::from("          \"required\": true,\n"));
    r.push_str(String::from("          \"suffix\": \".vow\"\n"));
