    r.push_str(String::from("  ]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Fields Reference\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Field              | Type                | When Present      | Description                               |\n"));
    r.push_str(String::from("|--------------------|---------------------|-------------------|-------------------------------------------|\n"));
    r.push_str(String::from("| `status`           | string              | Always            | One of the four status values             |\n"));
    r.push_str(String::from("| `executable`       | string \\| null      | Always            | Path to binary, null on compile failure or library module (no main) |\n"));
    r.push_str(String::from("| `diagnostics`      | array               | Always            | Compiler diagnostics (see schema)         |\n"));
    r.push_str(String::from("| `message`          | string              | CompileFailed     | Error category (\"parse error\", \"type error\", \"module load error\", or link error detail) |\n"));
    r.push_str(String::from("| `function`         | string              | VerifyFailed      | Function where verification failed        |\n"));
    r.push_str(String::from("| `counterexample`   | string              | VerifyFailed      | Legacy description string                 |\n"));
    r.push_str(String::from("| `counterexamples`  | array               | Always            | Structured counterexamples (see schema)   |\n"));
    r.push_str(String::from("| `verify_status`    | string              | On backend failure | `\"timeout\"`, `\"unknown\"`, `\"error\"`, `\"tool_not_found\"`, or `\"panicked\"` (verifier worker thread crashed -- no counterexample available) |\n"));
    r.push_str(String::from("| `verify_message`   | string              | On backend failure | ESBMC/backend error detail                |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Contracts Output JSON\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow contracts` emits a single JSON object to stdout. Schema: [`schemas/contracts-result.schema.json`](schemas/contracts-result.schema.json).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Example (without --verify)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"contracts\": [\n"));
    r.push_str(String::from("    {\n"));
    r.push_str(String::from("      \"vow_id\": 0,\n"));
    r.push_str(String::from("      \"function\": \"divide\",\n"));
    r.push_str(String::from("      \"kind\": \"requires\",\n"));
    r.push_str(String::from("      \"description\": \"requires y != 0\",\n"));
    r.push_str(String::from("      \"blame\": \"Caller\",\n"));
    r.push_str(String::from("      \"source\": { \"file\": \"divide.vow\", \"offset\": 42 },\n"));
    r.push_str(String::from("      \"status\": \"not_verified\",\n"));
    r.push_str(String::from("      \"quality\": \"substantive\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ],\n"));
    r.push_str(String::from("  \"summary\": { \"total\": 1, \"proven\": 0, \"failed\": 0, \"timeout\": 0, \"error\": 0, \"not_verified\": 1, \"skipped\": 0, \"vacuous\": 0, \"trivially_satisfiable\": 0, \"quality\": { \"weak\": 0, \"tautological\": 0, \"substantive\": 1 } }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Example (with --verify)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"contracts\": [\n"));
    r.push_str(String::from("    {\n"));
    r.push_str(String::from("      \"vow_id\": 0,\n"));
    r.push_str(String::from("      \"function\": \"divide\",\n"));
    r.push_str(String::from("      \"kind\": \"requires\",\n"));
    r.push_str(String::from("      \"description\": \"requires y != 0\",\n"));
    r.push_str(String::from("      \"blame\": \"Caller\",\n"));
    r.push_str(String::from("      \"source\": { \"file\": \"divide.vow\", \"offset\": 42 },\n"));
    r.push_str(String::from("      \"status\": \"proven\",\n"));
    r.push_str(String::from("      \"quality\": \"substantive\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ],\n"));
    r.push_str(String::from("  \"summary\": { \"total\": 1, \"proven\": 1, \"failed\": 0, \"timeout\": 0, \"error\": 0, \"not_verified\": 0, \"skipped\": 0, \"vacuous\": 0, \"trivially_satisfiable\": 0, \"quality\": { \"weak\": 0, \"tautological\": 0, \"substantive\": 1 } }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Contract Fields\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Field         | Type    | Description                                              |\n"));
    r.push_str(String::from("|---------------|---------|----------------------------------------------------------|\n"));
    r.push_str(String::from("| `vow_id`      | integer | Unique contract identifier within the program            |\n"));
    r.push_str(String::from("| `function`    | string  | Function containing this contract                        |\n"));
    r.push_str(String::from("| `kind`        | string  | `\"requires\"`, `\"ensures\"`, or `\"invariant\"`              |\n"));
    r.push_str(String::from("| `description` | string  | Full contract text                                       |\n"));
    r.push_str(String::from("| `blame`       | string  | `\"Caller\"` (requires) or `\"Callee\"` (ensures/invariant)  |\n"));
    r.push_str(String::from("| `source`      | object  | `{ \"file\": string, \"offset\": integer }`                  |\n"));
    r.push_str(String::from("| `status`      | string  | `\"proven\"`, `\"proven-ir\"`, `\"failed\"`, `\"unknown\"`, `\"timeout\"`, `\"error\"`, `\"not_verified\"`, `\"skipped\"`, or `\"vacuous\"` |\n"));
    r.push_str(String::from("| `quality`     | string  | Static clause-shape classification (no ESBMC): `\"weak\"`, `\"tautological\"`, or `\"substantive\"` |\n"));
    r.push_str(String::from("| `trivially_satisfiable` | bool | `--verify` only: true when a trivial `return <default>` body still satisfies this `ensures` (verification-confirmed weakness). Always false for `requires`/`invariant` and without `--verify`. Informational -- never affects the exit code. See `docs/spec/contracts-methodology.md`. |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Status Values\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Status          | Meaning                                              |\n"));
    r.push_str(String::from("|-----------------|------------------------------------------------------|\n"));
    r.push_str(String::from("| `not_verified`  | Verification not requested (no `--verify` flag)      |\n"));
    r.push_str(String::from("| `proven`        | ESBMC proved this contract holds for all inputs (bit-vector encoding, overflow modeled) |\n"));
    r.push_str(String::from("| `proven-ir`     | ESBMC proved this contract under integer-arithmetic encoding after BV timed out; overflow is not modeled by IR, but the BV caller preconditions still guard against it |\n"));
    r.push_str(String::from("| `failed`        | ESBMC found a counterexample violating this contract |\n"));
    r.push_str(String::from("| `unknown`       | ESBMC could not conclude for this contract -- either `VERIFICATION UNKNOWN` was reported for the containing function (k-induction's forward condition unable to prove or falsify), or the function's verification failed overall and ESBMC's per-clause `--multi-property` run returned no individual verdict for this clause |\n"));
    r.push_str(String::from("| `timeout`       | ESBMC timed out on the containing function (BV and -- when applicable -- IR fallback both timed out) |\n"));
    r.push_str(String::from("| `error`         | ESBMC error or tool not found                        |\n"));
    r.push_str(String::from("| `skipped`       | The containing function's body uses opcodes the verifier cannot model (e.g. `RegionAlloc` from struct construction). Contract is documentary; runtime checks still apply under `--mode debug`. Surfaces as a `VerificationSkipped` Warning in the build JSON's `diagnostics[]` and lifts the overall build/verify status to `Skipped` (fail-closed, exit 1) -- use `--no-verify` if you want a non-failing path that does not invoke ESBMC at all. |\n"));
    r.push_str(String::from("| `vacuous`       | The containing function's `requires` clauses are contradictory, so every `ensures` is satisfied vacuously -- ESBMC proved nothing of substance (antecedent failure). Detected by a second ESBMC run with `--error-label`: a `vow_reach` label planted after the `requires` assumes is unreachable. All of the function's clauses are reported `vacuous` (fail-closed, exit 1). See `docs/spec/contracts-methodology.md`. |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Quality Values\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`quality` is a static classification of each clause's *shape*, computed without ESBMC and independent of `status`. It surfaces the \"proven but trivial\" problem: a `weak` contract can be `proven` while constraining almost nothing. See `docs/spec/contracts-methodology.md` for the full taxonomy.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Quality        | Meaning                                                                                      |\n"));
    r.push_str(String::from("|----------------|----------------------------------------------------------------------------------------------|\n"));
    r.push_str(String::from("| `weak`         | An `ensures` that only bounds `result` by an integer literal (e.g. `result >= 0`). Satisfied by almost any implementation. |\n"));
    r.push_str(String::from("| `tautological` | A constant clause that references no program value (e.g. `true`, `0 >= 0`). Constrains nothing. |\n"));
    r.push_str(String::from("| `substantive`  | Everything else -- equality, relational, inverse/round-trip, dispatch-totality, or function-call shapes. The classifier is conservative: anything not provably weak/tautological is reported `substantive`. |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Trace Output (stderr, --debug-trace)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("When `--debug-trace=calls` or `--debug-trace=full` is used, the compiled binary emits JSON lines to stderr:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### calls mode\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"event\":\"enter\",\"fn\":\"main\"}\n"));
    r.push_str(String::from("{\"event\":\"enter\",\"fn\":\"divide\"}\n"));
    r.push_str(String::from("{\"event\":\"exit\",\"fn\":\"divide\"}\n"));
    r.push_str(String::from("{\"event\":\"exit\",\"fn\":\"main\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### full mode (adds vow check results)\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"event\":\"enter\",\"fn\":\"divide\"}\n"));
    r.push_str(String::from("{\"event\":\"vow\",\"fn\":\"divide\",\"vow_id\":0,\"passed\":true}\n"));
    r.push_str(String::from("{\"event\":\"exit\",\"fn\":\"divide\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Profile Output (stderr, profile mode)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("When `--mode profile` is used, the compiled binary prints a call-count report to stderr on normal exit (via `atexit`). The report is not printed if the program is killed by a signal or calls `abort()`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("--- vow profile report ---\n"));
    r.push_str(String::from("function                                        calls       %\n"));
    r.push_str(String::from("-------------------------------------------------------------\n"));
    r.push_str(String::from("infer                                         4812399   48.2%\n"));
    r.push_str(String::from("is_def_eq_core                                3201882   32.1%\n"));
    r.push_str(String::from("whnf                                           984201    9.9%\n"));
    r.push_str(String::from("main                                                1    0.0%\n"));
    r.push_str(String::from("-------------------------------------------------------------\n"));
    r.push_str(String::from("total calls: 9998483, unique functions: 12\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The report lists the top 20 most-called functions sorted by call count. No vow checks are emitted in profile mode.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Runtime Error JSON (stderr, debug/sanitize mode)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("When a compiled program runs in debug mode (`--mode debug`) or sanitize mode (`--mode sanitize`) and violates a vow at runtime, it emits JSON to stderr before aborting.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VowViolation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"VowViolation\",\"vow_id\":0,\"blame\":\"Caller\",\"description\":\"y != 0\",\"file\":\"divide.vow\",\"offset\":42,\"values\":{\"y\":0}}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Schema: [`schemas/vow-violation.schema.json`](schemas/vow-violation.schema.json).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### ArithmeticOverflow\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"ArithmeticOverflow\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emitted when a checked arithmetic operator (`+!`, `-!`, etc.) overflows at runtime.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### UnwrapOnNone\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"UnwrapOnNone\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emitted when `.unwrap()` is called on `Option::None`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### IndexOutOfBounds\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"IndexOutOfBounds\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emitted when a `Vec` index is out of bounds.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### UseAfterFree (sanitize mode only)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"UseAfterFree\",\"op\":\"push\",\"vec\":\"0x55a1b2c3d4e0\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emitted when a Vec operation is attempted on a Vec that has already been freed.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### DoubleFree (sanitize mode only)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"DoubleFree\",\"vec\":\"0x55a1b2c3d4e0\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emitted when a Vec is freed twice.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### StaleIndex (sanitize mode only)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"StaleIndex\",\"index\":5,\"expected_gen\":3,\"actual_gen\":7,\"vec\":\"0x55a1b2c3d4e0\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emitted when `__vow_sanitize_check_generation` detects that a Vec slot's generation counter does not match the expected value, indicating the slot was overwritten since the index was recorded.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Agent Decision Tree\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("Parse JSON from stdout\n"));
    r.push_str(String::from("├── status == \"Verified\"       → Success. Binary at `executable`.\n"));
    r.push_str(String::from("├── status == \"Unverified\"     → Compiled but unverified. ESBMC missing or --no-verify.\n"));
    r.push_str(String::from("├── status == \"CompileFailed\"  → Read `diagnostics[]` for error details.\n"));
    r.push_str(String::from("│   ├── error_code is parse error  → Fix syntax (see grammar.md)\n"));
    r.push_str(String::from("│   └── error_code is type error   → Fix types (see errors.md)\n"));
    r.push_str(String::from("└── status == \"VerifyFailed\"   → Read `counterexamples[]`.\n"));
    r.push_str(String::from("    ├── Check `inputs` for the violating values\n"));
    r.push_str(String::from("    ├── Check `violation` for which contract failed\n"));
    r.push_str(String::from("    ├── Check `source` for the location\n"));
    r.push_str(String::from("    └── Fix the contract or the implementation, then rebuild\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Always check stderr for human-readable diagnostics alongside the JSON on stdout.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("# Contract Authoring and Verification\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Vow uses ESBMC (bounded model checker) for static contract verification. This document covers contract patterns, verification behavior, and common pitfalls.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Verification Pipeline\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Codegen (Cranelift) and verification run in parallel:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("Vow Source → Parse → Type Check → IR Lower ─┬─→ Cranelift → executable\n"));
    r.push_str(String::from("                                              └─→ C Emit → ESBMC → proof / counterexample\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Contract clauses become IR opcodes. The C emitter translates `requires` to `__ESBMC_assume()` (the verifier assumes preconditions hold) and `ensures`/`invariant` to `__ESBMC_assert()` (the verifier checks postconditions).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### ESBMC Configuration\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("- Verification strategy: **k-induction-parallel** (incremental BMC + k-induction proof)\n"));
    r.push_str(String::from("- Incremental BMC with `--max-k-step` (default: **50**) -- loops are verified incrementally up to N iterations\n"));
    r.push_str(String::from("- Architecture: 64-bit\n"));
    r.push_str(String::from("- Array bounds / pointer checks disabled (Vow handles these in its own model)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Collection Models for Verification\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("ESBMC is a *bounded* model checker, so it models collection types as\n"));
    r.push_str(String::from("fixed-size arrays and reasons about them up to a finite capacity. These\n"));
    r.push_str(String::from("capacities are an internal property of the verifier, not of the language:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Type              | Model Capacity | Supported Operations |\n"));
    r.push_str(String::from("|-------------------|----------------|----------------------------------------------|\n"));
    r.push_str(String::from("| `Vec<T>`          | 128            | `new`, `push`, `pop`, `len`, `get`, `set`    |\n"));
    r.push_str(String::from("| `String`          | 256            | `from`, `len`, `push_byte`, `push_str`, `byte_at`, `matches_literal_at` |\n"));
    r.push_str(String::from("| `HashMap<K, V>`   | 64             | `new`, `insert`, `get`, `contains_key`, `len`|\n"));
    r.push_str(String::from("| `BTreeMap<K, V>`  | 64             | `new`, `insert`, `get`, `contains_key`, `len`|\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**These bounds are not a language feature and are not user-tunable.** A `Vec`\n"));
    r.push_str(String::from("in a Vow program grows dynamically on the heap with no fixed maximum; the\n"));
    r.push_str(String::from("capacity above only describes how far the *bounded* model checker reasons. The\n"));
    r.push_str(String::from("language and its contracts are deliberately decoupled from what any particular\n"));
    r.push_str(String::from("prover can prove: replace ESBMC with a stronger (or unbounded) checker and the\n"));
    r.push_str(String::from("same source, the same contracts, and the same CLI keep working -- the only\n"));
    r.push_str(String::from("difference is that proof covers more (or all) of the state space. For this\n"));
    r.push_str(String::from("reason a `requires`/`ensures` clause must never encode a verifier bound (e.g.\n"));
    r.push_str(String::from("`requires: v.len() <= 128`); see \"Verification-Driven Bounds (Anti-Pattern)\"\n"));
    r.push_str(String::from("below and `docs/design/verifier-model-bounds.md`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("These models support the same operations as the runtime but with bounded\n"));
    r.push_str(String::from("storage. String literals carry their concrete length and bytes in verification,\n"));
    r.push_str(String::from("and `String::from` copies that model from its source value. The effective string\n"));
    r.push_str(String::from("model capacity is automatically at least the longest static string literal, so\n"));
    r.push_str(String::from("literal byte initializers always fit the model array. Operations whose bytes are\n"));
    r.push_str(String::from("not statically known, such as `String::from_cstr`, produce a nondeterministic\n"));
    r.push_str(String::from("length (0 to max-1). `string_matches_literal_at` is modeled against the\n"));
    r.push_str(String::from("literal's concrete bytes and byte length; the third argument must be a string\n"));
    r.push_str(String::from("literal so the verifier never has to infer static text from a dynamic `String`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Blame Model\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Clause      | Blame  | Who is at fault                                    |\n"));
    r.push_str(String::from("|-------------|--------|----------------------------------------------------|\n"));
    r.push_str(String::from("| `requires`  | Caller | The caller passed invalid arguments                |\n"));
    r.push_str(String::from("| `ensures`   | Callee | The function body doesn't satisfy the postcondition|\n"));
    r.push_str(String::from("| `invariant` | Callee | The loop body breaks the invariant                 |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Integer Contracts\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Non-zero Guard\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn divide(x: i64, y: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: y != 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    x / y\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Range Bounds\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Use range bounds only when they reflect genuine semantic constraints (e.g., overflow prevention), not to appease the verifier:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn safe_add(a: i64, b: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: a >= 0,\n"));
    r.push_str(String::from("    requires: b >= 0,\n"));
    r.push_str(String::from("    requires: a <= 4611686018427387903,\n"));
    r.push_str(String::from("    requires: b <= 4611686018427387903,\n"));
    r.push_str(String::from("    ensures: result >= a,\n"));
    r.push_str(String::from("    ensures: result >= b\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    a + b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The bounds here prevent `a + b` from overflowing `i64` -- a legitimate semantic concern, not a verifier limitation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Equality Postcondition\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn twice(x: i64) -> i64 vow {\n"));
    r.push_str(String::from("    ensures: result == x + x\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    x + x\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Negation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn negate(x: i64) -> i64 vow {\n"));
    r.push_str(String::from("    ensures: result + x == 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    0 - x\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Warning:** Fails for `x = -9223372036854775808` (i64 min) due to wrapping overflow. Add `requires: x > -9223372036854775808` if needed.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Vec Contracts\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Bounds Check\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn get_element(v: Vec<i64>, i: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: i >= 0,\n"));
    r.push_str(String::from("    requires: i < v.len()\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    v[i]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Fill Pattern with Loop Invariant\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("See the worked CEGIS example in [examples.md](examples.md#3-vec-fill--loop-invariant).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## String Contracts\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Non-empty String\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn make_greeting() -> String vow {\n"));
    r.push_str(String::from("    ensures: result.len() > 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    let s: String = String::from(\"\");\n"));
    r.push_str(String::from("    s.push_byte(72);\n"));
    r.push_str(String::from("    s\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## HashMap Contracts\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Contains Key After Insert\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn insert_and_check() -> HashMap<i64, i64> vow {\n"));
    r.push_str(String::from("    ensures: result.contains_key(42)\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    let m: HashMap<i64, i64> = HashMap::new();\n"));
    r.push_str(String::from("    m.insert(42, 100);\n"));
    r.push_str(String::from("    m\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Loop Invariants\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Counter Bounds\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The most common loop invariant pattern bounds the loop counter:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("while i < n vow {\n"));
    r.push_str(String::from("    invariant: i >= 0,\n"));
    r.push_str(String::from("    invariant: i <= n\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    i = i + 1;\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Search Range\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn bisect(lo: i64, hi: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: hi >= lo\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    let mut lo: i64 = lo;\n"));
    r.push_str(String::from("    let mut hi: i64 = hi;\n"));
    r.push_str(String::from("    while lo + 1 < hi vow {\n"));
    r.push_str(String::from("        invariant: hi - lo >= 0\n"));
    r.push_str(String::from("    } {\n"));
    r.push_str(String::from("        let mid: i64 = lo + (hi - lo) / 2;\n"));
    r.push_str(String::from("        lo = mid;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("    lo\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Where Clause Patterns\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Where clauses on parameters become refinement types (additional `requires` for verification):\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn bounded_add(a: i64 where a >= 0, b: i64 where b >= 0) -> i64 vow {\n"));
    r.push_str(String::from("    requires: a <= 4611686018427387903,\n"));
    r.push_str(String::from("    requires: b <= 4611686018427387903,\n"));
    r.push_str(String::from("    ensures: result >= a,\n"));
    r.push_str(String::from("    ensures: result >= b\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    a + b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Each `where` clause can only reference its own parameter.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Anti-Patterns\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Over-Specifying\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn add(x: i64, y: i64) -> i64 vow {\n"));
    r.push_str(String::from("    ensures: result == x + y\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    x + y\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Fails when `x + y` overflows. The contract mirrors the implementation exactly -- it verifies nothing useful and breaks on edge cases.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add bounds (`requires: x >= 0, ...`) or verify a weaker property.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Wrapping Arithmetic Overflow\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Default arithmetic (`+`, `-`, `*`) wraps on overflow. Contracts that assume no overflow will be violated:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn double(x: i64) -> i64 vow {\n"));
    r.push_str(String::from("    ensures: result > x\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    x + x\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("ESBMC finds: `x = 4611686018427387904` → `result = -9223372036854775808` (wraps negative).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Bound the input or use checked arithmetic (`+!`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Non-Inductive Loop Invariant\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("An invariant must hold at the **start** of every iteration, not just at the end:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("while i < n vow {\n"));
    r.push_str(String::from("    invariant: v.len() == n\n"));
    r.push_str(String::from("} { ... }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("This is not inductive -- `v.len() == n` is only true after the loop.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Use `invariant: i >= 0, invariant: i <= n`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Unbound Loop Iterations\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Without a bound on loop iterations, ESBMC may timeout (default max-k-step is 50):\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn fill(n: i64) -> Vec<i64> vow {\n"));
    r.push_str(String::from("    requires: n >= 0,\n"));
    r.push_str(String::from("    ensures: result.len() == n\n"));
    r.push_str(String::from("} { ... }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("ESBMC will only verify this for small `n` values. **Do not** add `requires: n <= 8` to the contract -- that would distort the semantic specification. The contract is correct as-is; ESBMC's bounded verification provides partial assurance.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Verification-Driven Bounds (Anti-Pattern)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Never** add artificial bounds to contracts solely to help ESBMC verify them:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("// WRONG: bounds exist only to appease the verifier\n"));
    r.push_str(String::from("fn gcd(a: i64, b: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: a >= 0,\n"));
    r.push_str(String::from("    requires: b >= 0,\n"));
    r.push_str(String::from("    requires: a + b > 0,\n"));
    r.push_str(String::from("    requires: a <= 15,   // <-- verifier artifact, not semantic\n"));
    r.push_str(String::from("    requires: b <= 15,   // <-- verifier artifact, not semantic\n"));
    r.push_str(String::from("    ensures: result > 0\n"));
    r.push_str(String::from("} { ... }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("// CORRECT: only genuine semantic constraints\n"));
    r.push_str(String::from("fn gcd(a: i64, b: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: a >= 0,\n"));
    r.push_str(String::from("    requires: b >= 0,\n"));
    r.push_str(String::from("    requires: a + b > 0,\n"));
    r.push_str(String::from("    ensures: result > 0\n"));
    r.push_str(String::from("} { ... }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Contracts express what is mathematically required for correctness. ESBMC verifies within its capabilities (bounded loops, bounded arithmetic, bounded collection models) -- if it cannot fully prove a correct contract, that is acceptable. Partial verification is better than a distorted specification. The same rule is why the verifier's collection model capacities (see \"Collection Models for Verification\") are internal defaults rather than CLI flags or contract clauses: a bound that belongs to the prover must never leak into the language.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Interpreting Counterexamples\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("A counterexample in the JSON output:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"function\": \"safe_sub\",\n"));
    r.push_str(String::from("  \"inputs\": { \"a\": \"-9223372036854775808\", \"b\": \"0\" },\n"));
    r.push_str(String::from("  \"violation\": \"ensures result >= 0\",\n"));
    r.push_str(String::from("  \"vow_id\": 1,\n"));
    r.push_str(String::from("  \"source\": { \"file\": \"cegis_broken.vow\", \"offset\": 76, \"length\": 20 }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Field       | Meaning                                                |\n"));
    r.push_str(String::from("|-------------|--------------------------------------------------------|\n"));
    r.push_str(String::from("| `function`  | Which function failed                                  |\n"));
    r.push_str(String::from("| `inputs`    | Parameter values that trigger the violation            |\n"));
    r.push_str(String::from("| `violation` | Which contract clause was violated                     |\n"));
    r.push_str(String::from("| `vow_id`    | Internal ID linking to the specific vow clause         |\n"));
    r.push_str(String::from("| `source`    | Byte offset in the source file of the violated clause  |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Variable names prefixed with `_esbmc_` are ESBMC internal variables; named inputs map directly to function parameters.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Unsigned Integer Contracts\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `u64` type works naturally in contracts. Use `as u64` to cast literal values in contract expressions:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn safe_add(a: u64, b: u64) -> u64\n"));
    r.push_str(String::from("vow {\n"));
    r.push_str(String::from("    requires: a <= 1000 as u64\n"));
    r.push_str(String::from("    requires: b <= 1000 as u64\n"));
    r.push_str(String::from("    ensures: result >= a\n"));
    r.push_str(String::from("    ensures: result >= b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("    a + b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("ESBMC verifies `u64` contracts using `uint64_t` and unsigned nondet values.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Extern Block Contracts\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Every `extern \"C\"` block **must** include a `vow { ... }` contract specifying the expected behavior of foreign functions. Omitting the contract is a `MissingContract` error.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("extern \"C\" vow {\n"));
    r.push_str(String::from("    requires: fd >= 0\n"));
    r.push_str(String::from("    ensures: return >= 0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("    fn write(fd: i32, ptr: i64, len: i64) -> i64 [io]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The contract applies to all functions declared in the block. ESBMC uses `requires` as assumptions and `ensures` as assertions when verifying callers of extern functions.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("# Contract Methodology: What to Verify\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("This document answers a question that `contracts.md` does not: given a function,\n"));
    r.push_str(String::from("**which** properties are worth proving, how do you tell a strong contract from a\n"));
    r.push_str(String::from("hollow one, and how do you express the strong shapes within ESBMC's reach.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`contracts.md` is the *reference* (syntax, blame, the verification pipeline,\n"));
    r.push_str(String::from("anti-patterns). This is the *methodology* (judgement). Read that first.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## The core principle: strength, not volume\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("A proven contract is worth nothing if it would also hold for an incorrect\n"));
    r.push_str(String::from("implementation. The number of contracts a codebase proves is not a quality\n"));
    r.push_str(String::from("signal -- the *discriminating power* of each contract is.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("This is measurable. Polikarpova, Furia, Pei, Wei, and Meyer (the originator of\n"));
    r.push_str(String::from("Design by Contract), *\"What Good Are Strong Specifications?\"* (ICSE 2013), found\n"));
    r.push_str(String::from("that testing implementations against **strong** specifications -- comprehensive\n"));
    r.push_str(String::from("functional pre/post/invariants -- detected roughly **twice as many bugs** as\n"));
    r.push_str(String::from("testing against standard/weak contracts. Their conclusion: *\"the quality of\n"));
    r.push_str(String::from("specifications limits the value of verification.\"*\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("A concrete Vow example of the trap. Many tag constants in the self-hosted\n"));
    r.push_str(String::from("compiler carry this contract:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn EFF_IO() -> i64 vow { ensures: result > 0 } { 1 }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("ESBMC proves `1 > 0` in milliseconds. But `ensures: result > 0` also holds for\n"));
    r.push_str(String::from("`{ 2 }`, `{ 99 }`, and every other positive constant -- it does not pin the value\n"));
    r.push_str(String::from("this function is *supposed* to return. It is a real postcondition, but a **weak**\n"));
    r.push_str(String::from("one: it constrains the output to a half-line, not to a point. Proving 354 of\n"));
    r.push_str(String::from("these does not make the compiler more correct; it makes the verification report\n"));
    r.push_str(String::from("longer.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The fix is not \"delete contracts\" -- it is \"make each contract say something only\n"));
    r.push_str(String::from("the correct implementation satisfies.\"\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## A taxonomy of contract shapes\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Each shape below lists its *intent*, *when it applies*, a *real Vow example*, and\n"));
    r.push_str(String::from("*strength notes*. The expressibility/verifiability status of every shape is\n"));
    r.push_str(String::from("collected in the matrix at the end.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### 1. Domain precondition (range / validity bound)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Intent:** restrict the inputs the function promises to handle correctly. Blame\n"));
    r.push_str(String::from("falls on the caller (`requires`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** the function is only correct on a subset of its parameter types -- a byte\n"));
    r.push_str(String::from("in `0..=255`, a non-zero divisor, an in-bounds index.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn write_u8(out: Vec<i64>, v: i64) vow {\n"));
    r.push_str(String::from("    requires: v >= 0,\n"));
    r.push_str(String::from("    requires: v <= 255\n"));
    r.push_str(String::from("} { out.push(v); }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Strength:** a precondition is strong when it is the *true* domain of the\n"));
    r.push_str(String::from("function -- no wider (which would admit miscompilation) and no narrower (a\n"));
    r.push_str(String::from("verifier-driven bound like `requires: n <= 8`, forbidden by `contracts.md`).\n"));
    r.push_str(String::from("A bounds-check precondition such as `requires: i >= 0, requires: i < v.len()` is\n"));
    r.push_str(String::from("the standard guard for every indexing operation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### 2. Output-range postcondition (the weak default -- use sparingly)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Intent:** constrain the result to a range.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** the range *is* the full functional spec -- e.g. a function whose only\n"));
    r.push_str(String::from("guarantee is non-negativity. This is rare. Most uses are the weak trap above.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn item_kind(v: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: v >= 0,\n"));
    r.push_str(String::from("    ensures: result >= 0          // weak: any non-negative value satisfies this\n"));
    r.push_str(String::from("} { v / 4294967296 }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Strength:** weak by default. Reach for shape 3, 4, or 5 instead whenever the\n"));
    r.push_str(String::from("function actually computes a *specific* value. If you find yourself writing\n"));
    r.push_str(String::from("`ensures: result >= 0` on a function that returns a computed quantity, ask what\n"));
    r.push_str(String::from("the result *equals* or *inverts*, and assert that.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### 3. Exact functional postcondition (equality)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Intent:** pin the result to the value the function is defined to produce.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** the output is a closed-form function of the inputs (arithmetic,\n"));
    r.push_str(String::from("bit-packing, encodings).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn region_pack(kind: i64, val: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: kind >= 0,\n"));
    r.push_str(String::from("    requires: kind <= 3,\n"));
    r.push_str(String::from("    requires: val >= 0,\n"));
    r.push_str(String::from("    requires: val <= 4294967295,\n"));
    r.push_str(String::from("    ensures: result == val * 4 + kind     // exact: only the right answer passes\n"));
    r.push_str(String::from("} { val * 4 + kind }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Strength:** strong -- a wrong shift or offset is caught immediately. Note the\n"));
    r.push_str(String::from("preconditions are not verifier appeasement: they bound `val` and `kind` so the\n"));
    r.push_str(String::from("packed result cannot overflow `i64` (a genuine semantic constraint). Contrast\n"));
    r.push_str(String::from("`region_pack` (exact) with `item_pack`/`item_kind` (shape 2, only `>= 0`): the\n"));
    r.push_str(String::from("same bit-packing pattern, one specified strongly and one weakly.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### 4. Round-trip / inverse\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Intent:** prove that an encode/decode (or pack/unpack, serialize/deserialize)\n"));
    r.push_str(String::from("pair compose to the identity on the valid domain.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** two functions are defined as inverses -- `pack`/`unpack`,\n"));
    r.push_str(String::from("`encode`/`decode`, `to_bytes`/`from_bytes`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Specify each direction with an exact closed-form postcondition -- shape 3 applied\n"));
    r.push_str(String::from("to the extractor as well as the encoder, so the decoder is pinned to the exact\n"));
    r.push_str(String::from("arithmetic that inverts the pack:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn region_kind(r: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: r >= 0,\n"));
    r.push_str(String::from("    ensures: result == r - (r / 4) * 4,   // exact extractor\n"));
    r.push_str(String::from("    ensures: result <= 3\n"));
    r.push_str(String::from("} { r - (r / 4) * 4 }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Because both directions are pinned to closed forms -- `region_pack`'s exact\n"));
    r.push_str(String::from("`ensures: result == val * 4 + kind` (shape 3 above) and the matching\n"));
    r.push_str(String::from("`region_kind`/`region_val` extractors -- a `region_pack` then\n"));
    r.push_str(String::from("`region_kind`/`region_val` round-trip recovers `(kind, val)` exactly, and ESBMC\n"));
    r.push_str(String::from("discharges that composition with no separate assertion. The inverse can also be\n"));
    r.push_str(String::from("asserted directly: Vow allows pure-function calls in postconditions, so an\n"));
    r.push_str(String::from("`ensures: region_kind(result) == kind` on `region_pack` is expressible and\n"));
    r.push_str(String::from("modelable when the partner is pure (matrix shape 4). **Strength:** very strong --\n"));
    r.push_str(String::from("round-trip is the property a serialization layer must have, and it catches the\n"));
    r.push_str(String::from("entire class of \"encoder and decoder drifted apart\" bugs that output-range\n"));
    r.push_str(String::from("contracts miss completely.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### 5. Dispatch totality (fail-closed decoders)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Intent:** prove that a decoder/dispatcher maps **every** valid input to a\n"));
    r.push_str(String::from("defined output and **never** silently falls through to a default.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** a function switches over a tag/opcode/discriminator. This is the\n"));
    r.push_str(String::from("single highest-value shape for Vow, because silent-fallback normalization\n"));
    r.push_str(String::from("(mapping an unknown tag to a valid-looking default) is the bug class issue #81\n"));
    r.push_str(String::from("was filed over.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The pattern has two halves -- a validity precondition and an explicit error\n"));
    r.push_str(String::from("sentinel for the unreachable tail:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn is_valid_binop(op: i64) -> bool { op >= 0 && op <= 22 }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn binop_opcode(op: i64, operand_ty: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: is_valid_binop(op)\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    if op == BINOP_ADD() { return ...; }\n"));
    r.push_str(String::from("    // ... one arm per valid op ...\n"));
    r.push_str(String::from("    -1                                    // unreachable under the precondition\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Strength -- and a live hardening gap.** The precondition pins the domain, but\n"));
    r.push_str(String::from("this contract does **not yet prove totality**: nothing asserts the function never\n"));
    r.push_str(String::from("returns the `-1` sentinel. The strong form adds a postcondition that rules out\n"));
    r.push_str(String::from("the fallthrough:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn binop_opcode(op: i64, operand_ty: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: is_valid_binop(op),\n"));
    r.push_str(String::from("    ensures: result != -1                 // proves every valid op is handled\n"));
    r.push_str(String::from("} { ... }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("With `ensures: result != -1`, ESBMC must show that on every `op` in `0..=22` some\n"));
    r.push_str(String::from("arm returns before the sentinel -- i.e. the dispatch is exhaustive. If an agent\n"));
    r.push_str(String::from("later adds opcode 23 to `is_valid_binop` but forgets the matching arm,\n"));
    r.push_str(String::from("verification fails instead of miscompiling. This is the contract that converts a\n"));
    r.push_str(String::from("silent fallback into a caught error.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The static classifier rates this clause `substantive`, and `vow contracts --verify`'s\n"));
    r.push_str(String::from("body-replace probe reports it `trivially_satisfiable: true` -- both are correct, because\n"));
    r.push_str(String::from("they measure different things. The probe replaces the body with `return 0` (the `i64`\n"));
    r.push_str(String::from("default); `0 != -1` holds, so by the definition in **Weakness** (below) this is a *true*\n"));
    r.push_str(String::from("positive: `ensures: result != -1` does not constrain the op→opcode *mapping* -- a constant\n"));
    r.push_str(String::from("non-sentinel body (`return 5`) satisfies it for every valid `op`. What the clause *does*\n"));
    r.push_str(String::from("prove is dispatch **totality**: every valid `op` reaches an arm before the `-1` fallthrough\n"));
    r.push_str(String::from("(delete an arm and verification fails). Totality is the silent-fallback property #81\n"));
    r.push_str(String::from("targets, and -- absent a quantifier to say \"result is the correct opcode for `op`\" -- it is\n"));
    r.push_str(String::from("the strongest property a `!= sentinel` postcondition can express. So read the\n"));
    r.push_str(String::from("`trivially_satisfiable: true` as accurate (the clause pins totality, not the mapping), not\n"));
    r.push_str(String::from("as a probe artifact to dismiss. This is *not* the constant-result false positive noted in\n"));
    r.push_str(String::from("**Weakness**: `binop_opcode`'s correct result varies per `op`, so it is not genuinely the\n"));
    r.push_str(String::from("type default.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("> Vow has no surface quantifier (`forall i in 0..n`) today, so \"covers all valid\n"));
    r.push_str(String::from("> inputs\" is expressed as `requires` (pin the finite domain) + a postcondition\n"));
    r.push_str(String::from("> that excludes the failure value, letting ESBMC enumerate the finite branch\n"));
    r.push_str(String::from("> structure. Bounded quantifiers are tracked as a roadmap item (#467/#470).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### 6. Relational / cross-function (uniqueness, agreement)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Intent:** state a property that spans more than one function or more than one\n"));
    r.push_str(String::from("argument.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** tags in a family must be distinct; two collections must have equal\n"));
    r.push_str(String::from("length; a result must relate two inputs.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The argument-relational form is directly expressible:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn build_pairs(ids: Vec<i64>, names: Vec<i64>) -> Vec<Pair> vow {\n"));
    r.push_str(String::from("    requires: ids.len() == names.len()\n"));
    r.push_str(String::from("} { ... }\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The *cross-function uniqueness* form -- \"`tok_kw_fn() != tok_kw_let()` for every\n"));
    r.push_str(String::from("pair in the family\" -- is expressible only as O(n²) pairwise inequalities, which\n"));
    r.push_str(String::from("does not scale to dozens of tag constants. **The better fix is structural, not\n"));
    r.push_str(String::from("contractual:** encode each family as a base+offset range or a generated table so\n"));
    r.push_str(String::from("uniqueness is a property of the *encoding* rather than something every function\n"));
    r.push_str(String::from("must restate. Treat a wall of zero-argument tag constants as an API smell that\n"));
    r.push_str(String::from("shape-6 contracts cannot economically repair.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### 7. Loop invariant / frame\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Covered in `contracts.md` (counter bounds, search-range invariants, the\n"));
    r.push_str(String::from("inductiveness requirement). The methodology point: an invariant is strong when it\n"));
    r.push_str(String::from("is the property the loop *maintains toward its postcondition*, not merely\n"));
    r.push_str(String::from("`i >= 0`. See `contracts.md` §Loop Invariants and the worked CEGIS cycle in\n"));
    r.push_str(String::from("`examples.md`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Hollow contracts: three failure modes to detect\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("A contract can pass verification while proving nothing. There are three distinct\n"));
    r.push_str(String::from("ways this happens; a contract-quality tool should distinguish them.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Weakness\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The clause is satisfiable and true, but so loose that an incorrect\n"));
    r.push_str(String::from("implementation also satisfies it (`ensures: result >= 0` on a computed value).\n"));
    r.push_str(String::from("This is the 354-contract problem.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Detection (the body-replace probe).** `vow contracts --verify` ships this check\n"));
    r.push_str(String::from("(#81). It mutates the implementation in the strongest possible way -- replaces the\n"));
    r.push_str(String::from("whole body with a trivial `return <type-default>` -- and re-verifies the\n"));
    r.push_str(String::from("`ensures`. If the contract still proves against that body, a constant-returning\n"));
    r.push_str(String::from("implementation satisfies it, so it does not constrain the real computation: each\n"));
    r.push_str(String::from("such `ensures` is reported `trivially_satisfiable: true`. This is exactly the\n"));
    r.push_str(String::from("`body-replace` mutation of `vowc mutants` with ESBMC as the oracle.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The signal is **one-sided (sound, not complete)**: a `true` verdict is a proof of\n"));
    r.push_str(String::from("weakness (a specific trivial body satisfies the contract), but a `false` verdict\n"));
    r.push_str(String::from("does not prove strength -- the probe uses a single default value and skips\n"));
    r.push_str(String::from("non-scalar returns, returned parameters, and φ-merged/branchy results, so it can\n"));
    r.push_str(String::from("miss weak contracts it cannot witness this way. It is informational and never\n"));
    r.push_str(String::from("changes the exit code; pair it with the static `quality` field. The one known\n"));
    r.push_str(String::from("false positive is a function whose correct result genuinely *is* the type default\n"));
    r.push_str(String::from("(e.g. a constant `ensures result == 0` on a `{ 0 }` body) -- an equivalent mutant,\n"));
    r.push_str(String::from("the standard caveat of mutation testing.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Tautology\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The clause is true independent of the program -- `ensures: true`,\n"));
    r.push_str(String::from("`ensures: result == result`, `ensures: x >= 0 || x < 0`. **Detection:** the clause\n"));
    r.push_str(String::from("is valid (provable) with the function body removed; a cheap check folds constant\n"));
    r.push_str(String::from("clauses and flags any clause with no dependence on parameters or `result`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Vacuity (antecedent failure)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The clause is proved only because its **preconditions are unsatisfiable**, so the\n"));
    r.push_str(String::from("path it guards is dead and the postcondition never has to hold. Because Vow\n"));
    r.push_str(String::from("lowers `requires` to `__ESBMC_assume`, a contradictory or over-strong precondition\n"));
    r.push_str(String::from("makes *any* `ensures` provable -- an assume-false / dead-path proof.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("This is the classic vacuity of Beer, Ben-David, Eisner, and Rodeh, *\"Efficient\n"));
    r.push_str(String::from("Detection of Vacuity in Temporal Model Checking\"* (Formal Methods in System\n"));
    r.push_str(String::from("Design, 2001): a subformula is vacuous when replacing it changes nothing about\n"));
    r.push_str(String::from("the result. Their industrial data is the reason to take it seriously -- across\n"));
    r.push_str(String::from("years of hardware verification at IBM, ~20% of formulas were trivially valid on\n"));
    r.push_str(String::from("first runs, and trivial validity *always* indicated a real defect in the design,\n"));
    r.push_str(String::from("spec, or environment.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Detection (the reachability probe).** `vow contracts --verify` ships this check\n"));
    r.push_str(String::from("(#81). For any function carrying a `requires`, it re-runs ESBMC over the same\n"));
    r.push_str(String::from("model with a `vow_reach` label planted immediately after the `requires` assumes,\n"));
    r.push_str(String::from("under `--error-label vow_reach`. If ESBMC reports the label **unreachable**\n"));
    r.push_str(String::from("(`VERIFICATION SUCCESSFUL`), the conjoined preconditions are contradictory and\n"));
    r.push_str(String::from("every `ensures` held only vacuously -- all of the function's clauses are reported\n"));
    r.push_str(String::from("`status: \"vacuous\"` and the command fails closed. If the label is **reachable**\n"));
    r.push_str(String::from("(`VERIFICATION FAILED`), the precondition domain is non-empty and the proof is\n"));
    r.push_str(String::from("live. This is operationally the dual of the classic `ensures: false` re-check --\n"));
    r.push_str(String::from("asking \"is the post-`requires` point reachable?\" instead of \"does `assert(false)`\n"));
    r.push_str(String::from("still pass?\" -- but it needs only one extra run per function and is unaffected by\n"));
    r.push_str(String::from("body divergence, since the label precedes the body. The label sits after the\n"));
    r.push_str(String::from("requires prefix rather than at the function end precisely so an unbounded loop or\n"));
    r.push_str(String::from("an `assume(0)` deeper in the body cannot make it spuriously unreachable.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Interesting witnesses.** Beer et al. also propose the dual of a counterexample:\n"));
    r.push_str(String::from("for a proof that holds, emit a non-trivial *witness* -- concrete inputs that\n"));
    r.push_str(String::from("exercise the property for a substantive reason -- so the author can confirm the\n"));
    r.push_str(String::from("proof is not hollow. Vow's structured output is well-suited to carrying a witness\n"));
    r.push_str(String::from("alongside each `Verified` result.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## When to write contracts\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Builtins and `extern` blocks\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Runtime functions (`Vec.push`, `String.from`, `HashMap.insert`) are implemented in\n"));
    r.push_str(String::from("Rust/C and cannot be verified by ESBMC. Their behavior enters verification through\n"));
    r.push_str(String::from("the `vow` contract on the `extern \"C\"` block, which becomes an **assumed**\n"));
    r.push_str(String::from("(`__ESBMC_assume`) surface for callers. Because these contracts are *assumed, not\n"));
    r.push_str(String::from("checked*, they are the most dangerous place for an error: a wrong `ensures` on an\n"));
    r.push_str(String::from("extern block silently weakens every proof that depends on it. Extern contracts\n"));
    r.push_str(String::from("must be reviewed as assumptions, audited against the runtime implementation, and\n"));
    r.push_str(String::from("kept minimal. (Omitting the block is a `MissingContract` error -- see `errors.md`.)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Library functions (written in Vow)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Public Vow functions are fully within verification reach. Give each one its true\n"));
    r.push_str(String::from("domain precondition and the strongest postcondition shape that applies (3–6, not\n"));
    r.push_str(String::from("2). Add contracts when the function's contract is *known*, which is usually at\n"));
    r.push_str(String::from("definition time for pure utilities and after the signature stabilizes for APIs.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Application code (including agent-generated)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Vow's target author is an AI agent, and the failure mode to design against is\n"));
    r.push_str(String::from("*volume over substance* -- an agent emitting many `ensures: result >= 0` clauses\n"));
    r.push_str(String::from("because the prompt said \"add contracts.\" Skill guidance should push the opposite:\n"));
    r.push_str(String::from("for each function, identify which shape applies (equality, round-trip, dispatch\n"));
    r.push_str(String::from("totality, relational) and write that one; prefer one discriminating contract to\n"));
    r.push_str(String::from("five weak ones. The Specification Pattern System of Dwyer, Avrunin, and Corbett\n"));
    r.push_str(String::from("(ICSE 1999) -- a survey-validated catalog built specifically to turn imprecise\n"));
    r.push_str(String::from("intent into precise specifications -- is the model for guiding an author from \"this\n"));
    r.push_str(String::from("should be valid\" to a postcondition that says what *valid* means.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Expressibility and verifiability matrix\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Whether a shape is usable depends on five independent axes, not just \"can the\n"));
    r.push_str(String::from("syntax say it\":\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("- **expressible** -- surface Vow has the syntax\n"));
    r.push_str(String::from("- **typechecked** -- the checker validates the clause to `bool` (added in #81 Phase 0)\n"));
    r.push_str(String::from("- **lowerable** -- the lowerer emits IR for the clause\n"));
    r.push_str(String::from("- **modelable** -- the C emitter / ESBMC model supports the operations used\n"));
    r.push_str(String::from("  (pure, non-effectful helpers only; see `is_modelable` in the C emitter)\n"));
    r.push_str(String::from("- **backend** -- ESBMC actually discharges it within bounds\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Shape | expressible | typechecked | lowerable | modelable | backend |\n"));
    r.push_str(String::from("|-------|:-----------:|:-----------:|:---------:|:---------:|:-------:|\n"));
    r.push_str(String::from("| 1. Domain precondition | ✓ | ✓ | ✓ | ✓ | ✓ |\n"));
    r.push_str(String::from("| 2. Output-range postcond. | ✓ | ✓ | ✓ | ✓ | ✓ (but weak) |\n"));
    r.push_str(String::from("| 3. Exact equality | ✓ | ✓ | ✓ | ✓ | ✓ within overflow bounds |\n"));
    r.push_str(String::from("| 4. Round-trip / inverse | ✓ | ✓ | ✓ | ✓ if partner is pure & modelable | ✓ for arithmetic |\n"));
    r.push_str(String::from("| 5. Dispatch totality | ✓ | ✓ | ✓ | ✓ (pure dispatch) | ✓ over finite domain |\n"));
    r.push_str(String::from("| 6a. Argument-relational | ✓ | ✓ | ✓ | ✓ | ✓ |\n"));
    r.push_str(String::from("| 6b. Cross-fn uniqueness | ✓ (O(n²)) | ✓ | ✓ | ✓ | ✓ but unscalable → prefer structural encoding |\n"));
    r.push_str(String::from("| 7. Loop invariant | ✓ | ✓ | ✓ | ✓ | partial (bounded / k-induction) |\n"));
    r.push_str(String::from("| Bounded quantifier (`forall i in 0..n`) | ✗ (no surface syntax) | -- | -- | -- | -- (roadmap #467/#470) |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Contract expressions must be **pure** -- they cannot call effectful functions\n"));
    r.push_str(String::from("(`grammar.md` §Contract Purity). A property that needs an effectful helper is\n"));
    r.push_str(String::from("blocked at the *modelable* axis, not the expressible one; classify such gaps as\n"));
    r.push_str(String::from("model limitations, not contract-language limitations.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Tooling\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow contracts --verify` performs the **per-obligation** quality analysis tracked\n"));
    r.push_str(String::from("in #81 / roadmap WS-3.2. Each clause gets an individual verification verdict (via\n"));
    r.push_str(String::from("ESBMC `--multi-property`), plus the three quality signals above:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("- **Tautology** -- the static `quality` field flags constant clauses (no ESBMC).\n"));
    r.push_str(String::from("- **Vacuity** -- a contradictory `requires` is caught by the `--error-label`\n"));
    r.push_str(String::from("  reachability probe and reported `status: \"vacuous\"` (fail-closed).\n"));
    r.push_str(String::from("- **Weakness** -- the body-replace probe reports `trivially_satisfiable: true` for\n"));
    r.push_str(String::from("  an `ensures` a trivial `return <default>` body satisfies (informational).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `summary` carries `vacuous` and `trivially_satisfiable` counts alongside the\n"));
    r.push_str(String::from("status and quality tallies, so an author or CI can gate on hollow proofs.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**CI weak-gate.** `scripts/check_contract_quality.py` ratchets on the static\n"));
    r.push_str(String::from("quality of the self-hosted compiler's own contracts: it reads\n"));
    r.push_str(String::from("`vow contracts compiler/main.vow` and fails if the `weak` or `tautological` count\n"));
    r.push_str(String::from("exceeds a committed baseline, so a new `ensures result >= 0` cannot slip in\n"));
    r.push_str(String::from("unnoticed. It runs in `scripts/full_test.sh`. The baseline is an upper bound to\n"));
    r.push_str(String::from("ratchet down as contracts harden. The dispatch-totality example above\n"));
    r.push_str(String::from("(`binop_opcode`, `ensures: result != -1`) and `binop_result_ty`\n"));
    r.push_str(String::from("(`ensures: result == ITY_BOOL() || result == ITY_U64() || result == ITY_I64()`)\n"));
    r.push_str(String::from("are enforced in `compiler/lower.vow` today.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Tag families are structural, not contracted.** The bulk of the old `weak`\n"));
    r.push_str(String::from("count was nullary tag constants -- `fn IOP_VOW_REQ() -> i64 { 73 }`, the `ITY_*`,\n"));
    r.push_str(String::from("`EXPR_*`, `BINOP_*`, `RSUM_KIND_*`, … enum families. A per-constant `ensures\n"));
    r.push_str(String::from("result >= 0` proves nothing: a constant's value is the only fact about it, and\n"));
    r.push_str(String::from("that fact is structural (each is a distinct literal). So these carry **no**\n"));
    r.push_str(String::from("contract. Their correctness is established where it matters -- at use sites: the\n"));
    r.push_str(String::from("dispatch-totality contracts above prove every valid tag is handled, the IR\n"));
    r.push_str(String::from("validator and serializer round-trips exercise every kind, and the binary\n"));
    r.push_str(String::from("fixed-point bootstrap miscompiles if any two tags collide. Removing the\n"));
    r.push_str(String::from("contracts cut the compiler's `weak` count from 408 to 11 (#81). The remaining 11\n"));
    r.push_str(String::from("are genuine parametric functions (the region/span bit-packers and friends) whose\n"));
    r.push_str(String::from("right contract is a round-trip or enumerated postcondition -- the next hardening\n"));
    r.push_str(String::from("target, not noise.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## References\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("- N. Polikarpova, C. A. Furia, Y. Pei, Y. Wei, B. Meyer. *What Good Are Strong\n"));
    r.push_str(String::from("  Specifications?* ICSE 2013. https://arxiv.org/abs/1208.3337\n"));
    r.push_str(String::from("- I. Beer, S. Ben-David, C. Eisner, Y. Rodeh. *Efficient Detection of Vacuity in\n"));
    r.push_str(String::from("  Temporal Model Checking.* Formal Methods in System Design 18:141–163, 2001.\n"));
    r.push_str(String::from("- M. Dwyer, G. Avrunin, J. Corbett. *Property Specification Patterns for\n"));
    r.push_str(String::from("  Finite-State Verification.* ICSE 1999.\n"));
    r.push_str(String::from("- B. Meyer. *Object-Oriented Software Construction* (Design by Contract).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("# Vow Error Catalog\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Every Vow error has a machine-readable `error_code` in the JSON output. This document lists all error codes, their phase, meaning, an example trigger, and how to fix them.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Compile-Time Errors\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("These appear in the `diagnostics` array of the build output JSON.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### UnterminatedString\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Lexer\n"));
    r.push_str(String::from("**Meaning:** A string literal was opened with `\"` but never closed.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f() -> () [io] {\n"));
    r.push_str(String::from("    print_str(\"hello);\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Close the string with a matching `\"`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### InvalidCharacter\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Lexer\n"));
    r.push_str(String::from("**Meaning:** The source contains a character the lexer does not recognize.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f() -> i64 {\n"));
    r.push_str(String::from("    x @ y\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Remove the invalid character. Vow has no `@` operator.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### UnexpectedToken\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Parser\n"));
    r.push_str(String::from("**Meaning:** The parser encountered a token it did not expect at that position.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module M 123\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Check the syntax around the reported span. Common causes: missing `{`, `}`, `(`, `)`, or a keyword in the wrong position.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### MissingDelimiter\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Parser\n"));
    r.push_str(String::from("**Meaning:** A matching delimiter (`}`, `)`, `]`) is missing.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f() -> i64 {\n"));
    r.push_str(String::from("    42\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add the missing closing delimiter.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### TypeMismatch\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** An expression has a different type than expected.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f() -> i32 {\n"));
    r.push_str(String::from("    true\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `function body has type 'bool' but declared return type is 'i32'`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Change the expression or the declared type to match.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### LiteralOutOfRange\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** An integer literal appears in a typed context (annotated `let`, function argument, struct field, or const declaration) whose target type cannot hold the literal's value. The check runs after context coercion, so the offending literal is the one written in the source, not a widened intermediate.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let x: u8 = 300;\n"));
    r.push_str(String::from("const NEG: u16 = -1;\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `literal 300 does not fit in u8 (range 0..=255)`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Use a value within the target type's range, change the target type, or write an explicit narrowing intrinsic (`i64_to_u8_try`, `i64_to_u8_wrap`, `i64_to_u8_sat`) if you intend to convert a wider value at runtime.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### NarrowingCastNotAllowed\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** The `as` operator was used to convert a wider integer type to a narrower one. `as` is widening-only; narrowing must use a named intrinsic so the agent chooses an explicit semantics (range-checked vs. truncating vs. saturating). See `grammar.md` §Type Cast.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f(big: i64) -> u8 {\n"));
    r.push_str(String::from("    big as u8\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `cannot cast 'i64' to 'u8' via 'as'; use 'i64_to_u8_try', 'i64_to_u8_wrap', or 'i64_to_u8_sat' to choose the narrowing semantics`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Replace the cast with the narrowing intrinsic that matches your intent:\n"));
    r.push_str(String::from("- `i64_to_u8_try(big) -> Option<u8>` -- reject out-of-range with `None`\n"));
    r.push_str(String::from("- `i64_to_u8_wrap(big) -> u8` -- truncate (keep low bits)\n"));
    r.push_str(String::from("- `i64_to_u8_sat(big) -> u8` -- clamp to `0..=255`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### ShiftCountOutOfRange\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A constant-expression shift count is greater than or equal to the bit-width of the left operand. Shifting an `N`-bit value by `>= N` bits is undefined in the underlying C model and is rejected at compile time when the count is statically known. Dynamic shift counts (non-const expressions) get a Vow contract on the operation and are checked by ESBMC and at runtime in debug mode.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f(x: u8) -> u8 {\n"));
    r.push_str(String::from("    x << 8\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `shift count 8 is out of range for u8 (max 7)`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Use a count less than the LHS bit-width. To shift a narrow value by a larger amount, widen first: `(x as u32) << 8` is legal (it shifts the widened `u32` value by 8), but the result is `u32`; to get back to `u8`, use a narrowing intrinsic such as `u32_to_u8_wrap`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### StaticLiteralRequired\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A compiler intrinsic requires a string literal operand so it can be lowered without allocation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f(s: String, key: String) -> i64 {\n"));
    r.push_str(String::from("    string_matches_literal_at(s, 0, key)\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `string_matches_literal_at requires a string literal as its third argument`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Pass a literal directly, for example `string_matches_literal_at(s, 0, \"name\")`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### EffectViolation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A function calls another function with effects not declared in its own signature.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f() -> () {\n"));
    r.push_str(String::from("    print_str(\"hi\");\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add the required effect to the function signature: `fn f() -> () [io]`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### LinearTypeViolation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A value of a `linear struct` type is used in a way that is immediately invalid before region inference runs, such as consuming it twice, consuming it inside a loop that may execute more than once, or consuming it after only some control-flow paths already consumed it.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("linear struct Handle { fd: i64 }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn f(h: Handle) -> Handle {\n"));
    r.push_str(String::from("    let h2: Handle = h;\n"));
    r.push_str(String::from("    let h3: Handle = h;  // h was already consumed\n"));
    r.push_str(String::from("    h2\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Restructure ownership so each path uses a consumed linear value at most once. Obligations that are simply left live at scope exit are reported later as `RegionLinear`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### RegionLinear\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Region Inference\n"));
    r.push_str(String::from("**Meaning:** A `linear struct` value can remain live when its owning region closes. Returning the value transfers the linear obligation to the caller; consuming it before the close satisfies the obligation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("linear struct Handle { fd: i64 }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn f() -> i64 {\n"));
    r.push_str(String::from("    let h: Handle = Handle { fd: 1 };\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Consume the value before the region closes, or return it so the caller receives the obligation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### NonExhaustiveMatch\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A `match` expression does not cover all possible variants.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f(o: Option<i64>) -> i64 {\n"));
    r.push_str(String::from("    match o {\n"));
    r.push_str(String::from("        Option::Some(x) => x,\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add a `_ => ...` wildcard arm or cover all variants (`Option::None => ...`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### UnknownMethod\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A method call uses a name that does not exist on the receiver type.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f() -> () {\n"));
    r.push_str(String::from("    let v: Vec<i64> = Vec::new();\n"));
    r.push_str(String::from("    v.psh(42);\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `unknown method 'psh' on type 'Vec<i64>'`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Check the method name for typos. Use `--help` to see available methods for each type.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### UnsupportedFeature\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A language feature that is not supported in Vow was used.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("trait Foo {\n"));
    r.push_str(String::from("    fn bar() -> i64;\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `trait blocks are not supported in Vow`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Remove the unsupported construct. Vow does not support traits or impl blocks.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### BTreeMapKeyTypeMustBeI64\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A `BTreeMap<K, V>` was instantiated with `K` not equal to `i64`. Phase 1 of the BTreeMap stdlib only supports `i64` keys; the runtime helpers and ESBMC C model are hard-coded to i64.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn f() -> () {\n"));
    r.push_str(String::from("    let m: BTreeMap<bool, i64> = BTreeMap::new();\n"));
    r.push_str(String::from("    m.insert(true, 1);\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `BTreeMap key type must be i64; found 'bool'`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Use `BTreeMap<i64, V>`. If you need string or struct keys, hash or intern them to `i64` at the call site and keep a side-table for the originals.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### BTreeMapValueMustBeNonLinear\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A `BTreeMap<K, V>` was instantiated with a `V` that is or transitively contains a `linear struct`. Non-linear containers like `BTreeMap`, `Vec`, and `HashMap` cannot hold linear values because their internal shift/copy operations are bitwise and would silently duplicate the linear ownership obligation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("linear struct Token { id: i64 }\n"));
    r.push_str(String::from("fn f() -> () {\n"));
    r.push_str(String::from("    let m: BTreeMap<i64, Token> = BTreeMap::new();\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `BTreeMap value type must be non-linear; found 'Token'`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Either drop the `linear` qualifier on the struct, or keep handles in a `Vec<i64>` indirection and consume the linear values via direct function calls outside the map.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### MissingContract\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** An `extern \"C\"` block was declared without a `vow { ... }` contract. Every foreign function call requires a mandatory contract specifying expected behavior.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("extern \"C\" {\n"));
    r.push_str(String::from("    fn write(fd: i32, ptr: i64, len: i64) -> i64 [io];\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `extern block requires a vow contract`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add a `vow { ... }` block to the extern declaration with `requires` and/or `ensures` clauses.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### ContractTypeMismatch\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Type Checker\n"));
    r.push_str(String::from("**Meaning:** A `requires`, `ensures`, or `invariant` clause expression does not have type `bool`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn add(a: i64, b: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: a + b\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    a + b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Output:** `` `requires` clause has type `i64` but must be `bool` ``\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Ensure every contract clause is a boolean expression (comparison, logical operator, or a call to a predicate function returning `bool`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VowRequiresViolated\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Verification (ESBMC)\n"));
    r.push_str(String::from("**Meaning:** ESBMC found inputs that violate a `requires` precondition. This is a **static** verification error -- it means the function's callers can reach it with invalid arguments.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Strengthen the `requires` clause, or fix the callers to pass valid arguments.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VowEnsuresViolated\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Verification (ESBMC)\n"));
    r.push_str(String::from("**Meaning:** ESBMC found inputs where the function's return value does not satisfy the `ensures` postcondition.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Fix the function body to satisfy the postcondition, or weaken the `ensures` clause.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VowInvariantViolated\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Verification (ESBMC)\n"));
    r.push_str(String::from("**Meaning:** ESBMC found a loop iteration where the `invariant` does not hold.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Strengthen the invariant or fix the loop body.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### EsbmcNotFound\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Verification\n"));
    r.push_str(String::from("**Meaning:** ESBMC is not installed or not on `$PATH`. When verification is enabled (the default for `vowc build`, always for `vowc verify`), the compiler checks for ESBMC upfront before compilation. If ESBMC is not found, the build aborts immediately with exit code 1.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Install ESBMC, or use `--no-verify` to skip verification: `vowc build --no-verify <file>`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### RegionConflict\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Region Inference (arena-per-scope, Phase 3)\n"));
    r.push_str(String::from("**Meaning:** A heap-typed value's required lifetime cannot be satisfied by the regions the surrounding code provides. This fires when an interprocedural store-effect constraint is unsatisfiable against the **inferred** region -- that is, the value's `region(I) = LUB(must_outlive(I))` resolves to a concrete block strictly narrower than the target container's region.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("> **Coverage note (as of issue #314):** the check is now semantic, consulting\n"));
    r.push_str(String::from("> the inferred region populated by §4.1 step 3's LUB pass rather than the\n"));
    r.push_str(String::from("> raw IR opcode. A fresh allocation routed through a callee's store-effect\n"));
    r.push_str(String::from("> chain into a parameter container has its inferred region widened to\n"));
    r.push_str(String::from("> `Caller(HiddenRegionIdx(N))` by §4.1 step 2's must-outlive marker\n"));
    r.push_str(String::from("> propagation, where `N` is the precise slot index implied by the\n"));
    r.push_str(String::from("> destination (issue #317 slot-aware inference). Such single-slot routings\n"));
    r.push_str(String::from("> satisfy the constraint and are accepted. Allocations whose caller-region\n"));
    r.push_str(String::from("> markers require more than one hidden caller-arena slot resolve to\n"));
    r.push_str(String::from("> `Caller(HiddenRegionIdx::AMBIGUOUS)` and are rejected when the directly\n"));
    r.push_str(String::from("> fresh heap value is stored into a parameter-rooted target; allocations\n"));
    r.push_str(String::from("> whose inferred region is a strictly narrower block also fire\n"));
    r.push_str(String::from("> `RegionConflict`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn store_into(out: Vec<String>, prefix: String) [io] {\n"));
    r.push_str(String::from("    let s: String = String::from(prefix);\n"));
    r.push_str(String::from("    s.push_str(String::from(\" world\"));\n"));
    r.push_str(String::from("    out.push(s);  // s is allocated in this function's scope but escapes into out's region\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Move the allocation to a wider scope, or copy the value into the target region (e.g., `String::from(s)` into the outer arena). For routings that compile cleanly but you'd like to know about (root-region placement), see `RegionRootEscape` below. See `docs/design/arena_memory.md` §4.4 for the full rejection vs. visibility distinction.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### RegionRootEscape\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Region Inference (arena-per-scope, Phase 3)\n"));
    r.push_str(String::from("**Severity:** Note (informational -- does not fail the build)\n"));
    r.push_str(String::from("**Meaning:** A heap allocation's inferred region is `Caller`, and the surrounding function publishes a `FreshInCaller` return summary or store effect -- so the allocation may flow up the caller chain to `main` and ultimately land in the root region (`__vow_root_arena`, never freed). This is a memory-cost decision the compiler surfaces visibly per `docs/design/arena_memory.md` §4.4: silent root-region placement caused growth-with-no-signal in earlier compiler versions, and the note restores that signal without conflating it with unsoundness (`RegionConflict`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The note is conservative -- it fires for any `Caller`-region allocation in a function that could route to a caller, even if the actual concrete chain in this program doesn't reach `main`. False positives are tolerated because the diagnostic is non-blocking.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"error_code\": \"RegionRootEscape\",\n"));
    r.push_str(String::from("  \"severity\": \"note\",\n"));
    r.push_str(String::from("  \"message\": \"allocation may live in the root region: routed via store-effect chain to a caller whose target_region ultimately resolves to root\",\n"));
    r.push_str(String::from("  \"hints\": [\n"));
    r.push_str(String::from("    \"if intentional (e.g. program-lifetime data), no action needed; if you want this allocation freed earlier, restructure so the value is returned rather than stored into a parameter container\"\n"));
    r.push_str(String::from("  ]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Often none -- if the program is short-lived (a checker, a CLI tool) or the values are genuinely program-lifetime, the note is informational. To free the allocation earlier, restructure so the value is **returned** from the constructing function rather than stored into a parameter container; the canonical `FreshInCaller` return path (`fn make_X() -> X`) does not trigger the note for the returned value or any allocation installed as a field of the returned struct (e.g. `Item { name: String::from(\"hi\") }`). The exemption applies only to the *currently-installed* field initializers -- a field overwritten before the return (`x.f = A; x.f = B; return x`) does not suppress the dead allocation `A`, which fires the note as expected (per-block last-write dedup, issue #326).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VerificationSkipped\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** Verification (Warning surfaced alongside `BuildStatus::Skipped`)\n"));
    r.push_str(String::from("**Meaning:** The function carries a `vow {}` block but its body uses opcodes the verifier's C model cannot represent -- most commonly `RegionAlloc` and `FieldSet` produced by struct construction, also `Load`/`Store`, `RemF*`, and the `Linear*` family. The function is skipped before any C is emitted or ESBMC is invoked. The contract becomes documentary: runtime checks still apply in `--mode debug`, but no static proof is attempted.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"error_code\": \"VerificationSkipped\",\n"));
    r.push_str(String::from("  \"severity\": \"warning\",\n"));
    r.push_str(String::from("  \"message\": \"skipped verification of `ir_inst_set_region`: function `ir_inst_set_region` is not modelable in the verifier (contains unsupported opcode `RegionAlloc`)\",\n"));
    r.push_str(String::from("  \"hints\": [\n"));
    r.push_str(String::from("    \"the contract is documentary; runtime checks still apply in --mode debug\"\n"));
    r.push_str(String::from("  ]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Why the build fails closed.** Per `CLAUDE.md`'s \"Contract Authoring\" guidance, contracts express semantic correctness and must not be weakened to fit the verifier. When the verifier's bounded model checker cannot represent a function's body, the function is skipped with a structured warning instead of tripping the defense-in-depth `__ESBMC_assert(0, \"vow:UNSUPPORTED_OP_VOW_ID\")` that historically broke the bootstrap on every vowed struct-builder. But a skipped contract is still an unproved contract, so the build lifts its overall status to `Skipped` (exit 1). Use `--no-verify` if you explicitly want a non-failing path that does not invoke ESBMC at all (`Unverified`, exit 0).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Refactor the function so its body uses only modelable opcodes -- typically by splitting allocation/initialisation away from the contract-bearing computation. Alternatively, run with `--no-verify` if the contract is intentionally documentary.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Runtime Errors\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("These are emitted to stderr as JSON when a compiled program runs (debug mode for VowViolation).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VowViolation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** Debug mode only (`--mode debug`). A `requires`, `ensures`, or `invariant` predicate evaluates to false at runtime.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"VowViolation\",\"vow_id\":0,\"blame\":\"Caller\",\"description\":\"y != 0\",\"file\":\"divide.vow\",\"offset\":42,\"values\":{\"y\":0}}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `blame` field indicates who is at fault:\n"));
    r.push_str(String::from("- `Caller` -- a `requires` was violated (the caller passed bad arguments)\n"));
    r.push_str(String::from("- `Callee` -- an `ensures` or `invariant` was violated (the function has a bug)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** See the `description` and `values` fields to understand which predicate failed and with what runtime values.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### ArithmeticOverflow\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** A checked arithmetic operator (`+!`, `-!`, `*!`, `/!`, `%!`) overflows at runtime.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"ArithmeticOverflow\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Use wrapping arithmetic (`+`, `-`, etc.) if overflow is acceptable, or add bounds contracts to prevent overflow.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### UnwrapOnNone\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** `.unwrap()` is called on `Option::None`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"UnwrapOnNone\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Use `match` to handle `None`, or add contracts that guarantee the value is `Some`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### IndexOutOfBounds\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** A `Vec` index access (`v[i]` or `v[i] = val`) uses an index outside `0..v.len()`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"IndexOutOfBounds\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add a bounds check before indexing, or add contracts: `requires: i >= 0, requires: i < v.len()`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### RegionLiteralMutation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** A `Vec`, `String`, or `HashMap` mutation is attempted on a literal-backed container -- one whose descriptor carries the `VOW_CAP_RODATA` sentinel (backing lives in `.rodata` or was pinned to the root region). Calls that statically trace a mutating target to a literal are rejected during compilation with this code; a runtime fallback emits the JSON shape below if an unchecked mutation reaches a `VOW_CAP_RODATA` descriptor. See `docs/design/arena_memory.md` §6.1, §7.3.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"RegionLiteralMutation\",\"operation\":\"String::push_str\",\"origin\":\"rodata\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("A plain-text hint follows on the next line (not a JSON field). The hint text is dispatched on the operation's type prefix:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("hint: make an explicit mutable copy with String::from(value) before mutating  # for String::* operations\n"));
    r.push_str(String::from("hint: construct a mutable Vec and copy entries before mutating                # for Vec::*    operations\n"));
    r.push_str(String::from("hint: construct a mutable HashMap and copy entries before mutating  # for HashMap::* operations\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `operation` field identifies the source-level method that trapped (e.g., `Vec::push`, `Vec::pop`, `HashMap::insert`, `String::clear`). The `origin` field identifies the storage class of the immutable backing; today only `rodata` is emitted.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Obtain an explicit mutable copy before mutation: `String::from(value)`, or construct a fresh mutable container and copy the entries you need before mutating.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### StackOverflow\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** The native call stack is exhausted, typically due to unbounded recursion.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"StackOverflow\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("In debug or sanitize mode, the diagnostic includes call depth and the function that was executing when the overflow occurred:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"StackOverflow\",\"depth\":10693,\"function\":\"recurse\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The signal handler is installed in **all** build modes. The `depth` and `function` fields are only available in debug/sanitize mode where call-depth instrumentation is emitted.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add a base case to recursive functions, or restructure the algorithm to use iteration instead of recursion.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### OutOfMemory\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**When:** A runtime arena operation (`__vow_arena_open` or `__vow_arena_alloc`) failed because the underlying `malloc` returned null. Non-recoverable from within Vow (`docs/design/arena_memory.md` §3.3, §16).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"OutOfMemory\",\"operation\":\"arena_alloc\"}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `operation` field is `arena_open` for the initial chunk allocation or `arena_alloc` for a later fallback chunk allocation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Reduce working-set size, raise the process memory limit, or run on a machine with more memory. This is not a Vow program error.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Warnings\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### LoweringWarning\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Phase:** IR Lowering\n"));
    r.push_str(String::from("**Meaning:** The IR lowerer could not resolve a struct type tag or field name, defaulting to index 0. This usually indicates a missing type annotation on a `let` binding, causing the compiler to lose track of which struct type a pointer refers to.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Fix:** Add an explicit type annotation: `let x: MyStruct = ...;` so the compiler can track struct type tags through the IR.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("# Worked Examples\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Verification workflow examples. The first three demonstrate Counterexample-Guided Inductive Synthesis (CEGIS) cycles: write spec, build, read JSON, diagnose, fix, verify. The fourth shows break-with-value in loop expressions. The fifth shows an EOF-safe interactive command loop using `stdin_read_line()`. The sixth shows bounded-memory streaming file input.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## 1. Safe Division -- Requires Pattern\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Goal\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Write a division function that is safe (cannot divide by zero).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 1: Write the spec\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module Divide\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn divide(x: i64, y: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: y != 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    x / y\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    divide(10, 0);\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 2: Build and verify\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ vow build examples/divide.vow\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"status\":\"Verified\",\"executable\":\"examples/divide\",\"diagnostics\":[],\"counterexamples\":[]}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("ESBMC proves the contract: whenever `y != 0` holds, the division is safe.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 3: Runtime behavior (debug mode)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `main()` calls `divide(10, 0)` which violates `requires: y != 0`. In debug mode:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ vow build --mode debug --no-verify examples/divide.vow -o /tmp/divide_debug\n"));
    r.push_str(String::from("$ /tmp/divide_debug\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Stderr:\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"error\":\"VowViolation\",\"vow_id\":0,\"blame\":\"Caller\",\"description\":\"y != 0\",\"file\":\"examples/divide.vow\",\"offset\":56,\"values\":{\"y\":0}}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `blame: \"Caller\"` tells you: `main()` passed `y=0`, which violates the precondition.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## 2. CEGIS Broken → Fixed -- The Core Workflow\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Goal\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Write `safe_sub(a, b)` that always returns a non-negative result.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 1: Initial attempt (broken)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module CegisBroken\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn safe_sub(a: i64, b: i64 where b >= 0) -> i64 vow {\n"));
    r.push_str(String::from("    ensures: result >= 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    a - b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    print_i64(safe_sub(10, 3));\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 2: Build\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ vow build examples/cegis_broken.vow\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"status\": \"VerifyFailed\",\n"));
    r.push_str(String::from("  \"executable\": \"examples/cegis_broken\",\n"));
    r.push_str(String::from("  \"diagnostics\": [],\n"));
    r.push_str(String::from("  \"function\": \"safe_sub\",\n"));
    r.push_str(String::from("  \"counterexample\": \"[Counterexample]\",\n"));
    r.push_str(String::from("  \"counterexamples\": [\n"));
    r.push_str(String::from("    {\n"));
    r.push_str(String::from("      \"function\": \"safe_sub\",\n"));
    r.push_str(String::from("      \"inputs\": { \"a\": \"-9223372036854775808\", \"b\": \"0\" },\n"));
    r.push_str(String::from("      \"violation\": \"ensures result >= 0\",\n"));
    r.push_str(String::from("      \"vow_id\": 1,\n"));
    r.push_str(String::from("      \"source\": { \"file\": \"examples/cegis_broken.vow\", \"offset\": 76, \"length\": 20 }\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 3: Diagnose\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The counterexample shows `a = -9223372036854775808` (i64 min), `b = 0`. Then `a - b = a`, which is negative. The `ensures: result >= 0` is violated.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Root cause:** We need `a >= b` to guarantee a non-negative result, and `a >= 0` to prevent negative inputs.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 4: Fix\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module CegisFixed\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn safe_sub(a: i64 where a >= 0, b: i64 where b >= 0) -> i64 vow {\n"));
    r.push_str(String::from("    requires: a >= b,\n"));
    r.push_str(String::from("    ensures: result >= 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    a - b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    print_i64(safe_sub(10, 3));\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 5: Verify\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ vow build examples/cegis_fixed.vow\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"status\":\"Verified\",\"executable\":\"examples/cegis_fixed\",\"diagnostics\":[],\"counterexamples\":[]}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Verified. With `a >= 0`, `b >= 0`, and `a >= b`, ESBMC proves `result >= 0`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## 3. Vec Fill -- Loop Invariant\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Goal\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Fill a vector with `n` elements and prove its length equals `n`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 1: Write the spec\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module VecFill\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn fill_vec(n: i64) -> Vec<i64> vow {\n"));
    r.push_str(String::from("    requires: n >= 0,\n"));
    r.push_str(String::from("    requires: n <= 8,\n"));
    r.push_str(String::from("    ensures: result.len() == n\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    let v: Vec<i64> = Vec::new();\n"));
    r.push_str(String::from("    let mut i: i64 = 0;\n"));
    r.push_str(String::from("    while i < n vow {\n"));
    r.push_str(String::from("        invariant: i >= 0,\n"));
    r.push_str(String::from("        invariant: i <= n\n"));
    r.push_str(String::from("    } {\n"));
    r.push_str(String::from("        v.push(i);\n"));
    r.push_str(String::from("        i = i + 1;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("    v\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    let v: Vec<i64> = fill_vec(5);\n"));
    r.push_str(String::from("    print_i64(v.len());\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 2: Build and verify\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ vow build examples/vec_fill.vow\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"status\":\"Verified\",\"executable\":\"examples/vec_fill\",\"diagnostics\":[],\"counterexamples\":[]}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Key points:**\n"));
    r.push_str(String::from("- `requires: n <= 8` keeps iterations tractable for verification\n"));
    r.push_str(String::from("- `invariant: i >= 0, invariant: i <= n` is inductive: true on entry, preserved by the loop body\n"));
    r.push_str(String::from("- The Vec model tracks `len`, so ESBMC can reason about `result.len() == n`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## 4. Linear Search -- Break-with-Value\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Goal\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Search a vector for a target value and return its index, or `-1` if not found. Uses `loop` with `break <value>` to produce a result directly from the loop expression.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 1: Write the spec\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module Search\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn linear_search(data: Vec<i64>, target: i64) -> i64\n"));
    r.push_str(String::from("    vow { requires: data.len() > 0 }\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("    let mut i: i64 = 0;\n"));
    r.push_str(String::from("    let n: i64 = data.len();\n"));
    r.push_str(String::from("    let result: i64 = loop {\n"));
    r.push_str(String::from("        if i >= n {\n"));
    r.push_str(String::from("            break -1;\n"));
    r.push_str(String::from("        }\n"));
    r.push_str(String::from("        if data[i] == target {\n"));
    r.push_str(String::from("            break i;\n"));
    r.push_str(String::from("        }\n"));
    r.push_str(String::from("        i = i + 1;\n"));
    r.push_str(String::from("    };\n"));
    r.push_str(String::from("    result\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    let data: Vec<i64> = Vec::new();\n"));
    r.push_str(String::from("    data.push(10);\n"));
    r.push_str(String::from("    data.push(20);\n"));
    r.push_str(String::from("    data.push(30);\n"));
    r.push_str(String::from("    data.push(40);\n"));
    r.push_str(String::from("    data.push(50);\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("    let idx: i64 = linear_search(data, 30);\n"));
    r.push_str(String::from("    print_i64(idx);\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("    let idx2: i64 = linear_search(data, 99);\n"));
    r.push_str(String::from("    print_i64(idx2);\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 2: Build and verify\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ vow build examples/search.vow\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"status\":\"Verified\",\"executable\":\"examples/search\",\"diagnostics\":[],\"counterexamples\":[]}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Key points:**\n"));
    r.push_str(String::from("- `loop { ... break <value>; ... }` is an expression that evaluates to the break value\n"));
    r.push_str(String::from("- All `break` expressions in a `loop` must produce the same type (`i64` here)\n"));
    r.push_str(String::from("- `break <value>` is only allowed in `loop`, not in `while` (which always evaluates to `()`)\n"));
    r.push_str(String::from("- The result is bound with `let result: i64 = loop { ... };`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## 5. Command Loop -- EOF-Safe `stdin_read_line`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Goal\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Write a line-oriented command interpreter that reads from stdin, dispatches commands, skips empty lines, and exits cleanly on EOF. This is the canonical pattern for CI-safe interactive programs.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 1: Write the program\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module CmdLoop\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn trim_newline(s: String) -> String {\n"));
    r.push_str(String::from("    let n: i64 = s.len();\n"));
    r.push_str(String::from("    if n == 0 { return s; }\n"));
    r.push_str(String::from("    let last: i64 = s.byte_at(n - 1);\n"));
    r.push_str(String::from("    if last == 10 {\n"));
    r.push_str(String::from("        if n >= 2 {\n"));
    r.push_str(String::from("            let prev: i64 = s.byte_at(n - 2);\n"));
    r.push_str(String::from("            if prev == 13 {\n"));
    r.push_str(String::from("                return s.substring(0, n - 2);\n"));
    r.push_str(String::from("            }\n"));
    r.push_str(String::from("        }\n"));
    r.push_str(String::from("        return s.substring(0, n - 1);\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("    s\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn skip_spaces(s: String, start: i64) -> i64 {\n"));
    r.push_str(String::from("    let mut i: i64 = start;\n"));
    r.push_str(String::from("    let n: i64 = s.len();\n"));
    r.push_str(String::from("    while i < n {\n"));
    r.push_str(String::from("        if s.byte_at(i) != 32 { return i; }\n"));
    r.push_str(String::from("        i = i + 1;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("    i\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [read, io] {\n"));
    r.push_str(String::from("    let mut line: String = stdin_read_line();\n"));
    r.push_str(String::from("    while line.len() > 0 {\n"));
    r.push_str(String::from("        let cmd: String = trim_newline(line);\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("        if cmd.len() > 0 {\n"));
    r.push_str(String::from("            if cmd.eq(String::from(\"quit\")) {\n"));
    r.push_str(String::from("                return 0;\n"));
    r.push_str(String::from("            }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("            if cmd.eq(String::from(\"hello\")) {\n"));
    r.push_str(String::from("                print_str(String::from(\"Hello, world!\\n\"));\n"));
    r.push_str(String::from("            } else {\n"));
    r.push_str(String::from("                if cmd.len() >= 5 {\n"));
    r.push_str(String::from("                    let prefix: String = cmd.substring(0, 5);\n"));
    r.push_str(String::from("                    if prefix.eq(String::from(\"echo \")) {\n"));
    r.push_str(String::from("                        let start: i64 = skip_spaces(cmd, 5);\n"));
    r.push_str(String::from("                        let text: String = cmd.substring(start, cmd.len());\n"));
    r.push_str(String::from("                        print_str(text);\n"));
    r.push_str(String::from("                        print_str(String::from(\"\\n\"));\n"));
    r.push_str(String::from("                    } else {\n"));
    r.push_str(String::from("                        print_str(String::from(\"unknown: \"));\n"));
    r.push_str(String::from("                        print_str(cmd);\n"));
    r.push_str(String::from("                        print_str(String::from(\"\\n\"));\n"));
    r.push_str(String::from("                    }\n"));
    r.push_str(String::from("                } else {\n"));
    r.push_str(String::from("                    print_str(String::from(\"unknown: \"));\n"));
    r.push_str(String::from("                    print_str(cmd);\n"));
    r.push_str(String::from("                    print_str(String::from(\"\\n\"));\n"));
    r.push_str(String::from("                }\n"));
    r.push_str(String::from("            }\n"));
    r.push_str(String::from("        }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("        line = stdin_read_line();\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 2: Build\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ vow build --no-verify examples/cmdloop.vow -o /tmp/cmdloop\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\"status\":\"Unverified\",\"executable\":\"/tmp/cmdloop\",\"diagnostics\":[],\"counterexamples\":[]}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("No contracts here -- this example focuses on the I/O pattern, not verification.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 3: Run with piped input\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ printf 'hello\\necho Vow is great\\n\\nbogus\\nquit\\n' | /tmp/cmdloop\n"));
    r.push_str(String::from("Hello, world!\n"));
    r.push_str(String::from("Vow is great\n"));
    r.push_str(String::from("unknown: bogus\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `quit` command causes an early `return 0`. Empty lines are silently skipped.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Step 4: Run with EOF (no quit)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("$ printf 'hello\\necho test\\n' | /tmp/cmdloop\n"));
    r.push_str(String::from("Hello, world!\n"));
    r.push_str(String::from("test\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("When stdin is exhausted, `stdin_read_line()` returns `\"\"` (length 0), the `while` condition fails, and the program exits cleanly with code 0.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Key points\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("- **EOF detection:** `stdin_read_line()` returns `\"\"` at EOF. Check `.len() > 0` to exit the loop.\n"));
    r.push_str(String::from("- **Newline stripping:** `stdin_read_line()` includes the trailing `\\n` (or `\\r\\n`). Strip it with `byte_at` + `substring` before comparing commands.\n"));
    r.push_str(String::from("- **Empty line handling:** After trimming, `cmd.len() == 0` means the line was blank -- skip it.\n"));
    r.push_str(String::from("- **Effects:** `stdin_read_line()` requires `[read]`; `print_str()` requires `[io]`. The `main` function declares both.\n"));
    r.push_str(String::from("- **CI-safe:** No blocking reads, no prompts -- the program processes whatever stdin provides and exits at EOF. Safe to run in pipelines and test harnesses.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## 6. Streaming File Input\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`fs_read(path)` materializes the entire file as one `String`. Use `fs_open` plus `fs_read_line` for newline-delimited files that may be large.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module StreamingFile\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [read, io] {\n"));
    r.push_str(String::from("    let argv: Vec<String> = args();\n"));
    r.push_str(String::from("    if argv.len() < 2 {\n"));
    r.push_str(String::from("        eprintln_str(String::from(\"usage: streaming_file <path>\"));\n"));
    r.push_str(String::from("        return 1;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("    let h: i64 = fs_open(argv[1]);\n"));
    r.push_str(String::from("    if h < 0 {\n"));
    r.push_str(String::from("        eprintln_str(String::from(\"could not open input\"));\n"));
    r.push_str(String::from("        return 1;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("    let mut lines: i64 = 0;\n"));
    r.push_str(String::from("    let mut bytes: i64 = 0;\n"));
    r.push_str(String::from("    let mut line: String = fs_read_line(h);\n"));
    r.push_str(String::from("    while line.len() > 0 {\n"));
    r.push_str(String::from("        lines = lines + 1;\n"));
    r.push_str(String::from("        bytes = bytes + line.len();\n"));
    r.push_str(String::from("        line = fs_read_line(h);\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("    if fs_status(h) != 1 {\n"));
    r.push_str(String::from("        fs_close(h);\n"));
    r.push_str(String::from("        eprintln_str(String::from(\"read error\"));\n"));
    r.push_str(String::from("        return 1;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("    if fs_close(h) != 0 {\n"));
    r.push_str(String::from("        eprintln_str(String::from(\"close error\"));\n"));
    r.push_str(String::from("        return 1;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("    print_i64(lines);\n"));
    r.push_str(String::from("    print_str(String::from(\"\\n\"));\n"));
    r.push_str(String::from("    print_i64(bytes);\n"));
    r.push_str(String::from("    print_str(String::from(\"\\n\"));\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Key points:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("- `fs_read_line(handle)` includes the trailing newline when present.\n"));
    r.push_str(String::from("- Blank lines are returned as `\"\\n\"`; EOF returns `\"\"`.\n"));
    r.push_str(String::from("- Check `fs_status(handle)` after `fs_read_line(handle)` returns `\"\"`: `1` means EOF, `-1` means invalid handle or read error.\n"));
    r.push_str(String::from("- Close each successful handle with `fs_close(handle)` and check for a non-zero close result.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## 7. BTreeMap basic usage\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`BTreeMap<i64, V>` is the deterministic alternative to `HashMap` -- sorted ascending by key, binary-search lookup. Use it when iteration order affects program output (codegen, serialization, or any reproducible build).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("module BTreeMapExample\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn fetch(m: BTreeMap<i64, i64>) -> Option<i64> [io] {\n"));
    r.push_str(String::from("    let r: Option<i64> = m.get(7);\n"));
    r.push_str(String::from("    let v: i64 = r?;\n"));
    r.push_str(String::from("    print_i64(v);\n"));
    r.push_str(String::from("    print_str(String::from(\"\\n\"));\n"));
    r.push_str(String::from("    Option::Some(v)\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    let m: BTreeMap<i64, i64> = BTreeMap::new();\n"));
    r.push_str(String::from("    m.insert(7, 42);\n"));
    r.push_str(String::from("    let prev: Option<i64> = m.insert(7, 99);\n"));
    r.push_str(String::from("    // prev is Some(42); the second insert overwrote the first.\n"));
    r.push_str(String::from("    fetch(m);\n"));
    r.push_str(String::from("    print_i64(m.len());\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Note that `.insert` returns `Option<V>` (the previous value, if any), and `.get` returns `Option<V>`. Use `?` to short-circuit on `None`. Phase 1 only supports `i64` keys; using any other key type raises `BTreeMapKeyTypeMustBeI64`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Why BTreeMap and not HashMap\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`HashMap.insert` returns `()` and its iteration order is unspecified. For maps whose iteration is observable in the output binary, the byte-identical bootstrap requirement (`stage1 == stage2` sha256) demands deterministic order. `BTreeMap` provides it; `HashMap` does not.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("---\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("# JSON Schemas\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## build-result\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n"));
    r.push_str(String::from("  \"$id\": \"https://vow-lang.dev/schemas/build-result.schema.json\",\n"));
    r.push_str(String::from("  \"title\": \"BuildResult\",\n"));
    r.push_str(String::from("  \"description\": \"JSON output from `vow build` on stdout\",\n"));
    r.push_str(String::from("  \"type\": \"object\",\n"));
    r.push_str(String::from("  \"required\": [\"status\", \"executable\", \"diagnostics\", \"counterexamples\"],\n"));
    r.push_str(String::from("  \"properties\": {\n"));
    r.push_str(String::from("    \"status\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"enum\": [\"Verified\", \"Unverified\", \"Skipped\", \"CompileFailed\", \"VerifyFailed\"],\n"));
    r.push_str(String::from("      \"description\": \"Build outcome. `Skipped` means ESBMC was invoked but at least one vowed function could not be modelled; the build fails closed with exit 1 (distinct from `Unverified`, which means ESBMC was not invoked, e.g. `--no-verify`/`--dump-ir`, exit 0).\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"executable\": {\n"));
    r.push_str(String::from("      \"type\": [\"string\", \"null\"],\n"));
    r.push_str(String::from("      \"description\": \"Path to compiled binary, or null on failure or when source has no main function (library module)\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"diagnostics\": {\n"));
    r.push_str(String::from("      \"type\": \"array\",\n"));
    r.push_str(String::from("      \"items\": { \"$ref\": \"diagnostic.schema.json\" },\n"));
    r.push_str(String::from("      \"description\": \"Compiler diagnostics (parse errors, type errors, vow violations)\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"message\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Error detail (present only when status is CompileFailed)\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"function\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Function name (present only when status is VerifyFailed)\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"counterexample\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Legacy counterexample description (present only when status is VerifyFailed)\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"counterexamples\": {\n"));
    r.push_str(String::from("      \"type\": \"array\",\n"));
    r.push_str(String::from("      \"items\": { \"$ref\": \"counterexample.schema.json\" },\n"));
    r.push_str(String::from("      \"description\": \"Structured counterexamples from ESBMC verification\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"verify_status\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"enum\": [\"timeout\", \"unknown\", \"error\", \"tool_not_found\", \"panicked\"],\n"));
    r.push_str(String::from("      \"description\": \"Verification sub-status (present only when the verification backend did not produce a proof or counterexample; \\\"panicked\\\" signals the verifier worker thread crashed and the build fails closed)\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"verify_message\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Verification backend error detail (present only when verify_status is set)\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"allOf\": [\n"));
    r.push_str(String::from("    {\n"));
    r.push_str(String::from("      \"if\": { \"properties\": { \"status\": { \"const\": \"CompileFailed\" } } },\n"));
    r.push_str(String::from("      \"then\": { \"required\": [\"message\"] }\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    {\n"));
    r.push_str(String::from("      \"if\": { \"properties\": { \"status\": { \"const\": \"VerifyFailed\" } } },\n"));
    r.push_str(String::from("      \"then\": { \"required\": [\"function\", \"counterexample\"] }\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ],\n"));
    r.push_str(String::from("  \"additionalProperties\": false\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## contracts-result\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n"));
    r.push_str(String::from("  \"$id\": \"https://vow-lang.dev/schemas/contracts-result.schema.json\",\n"));
    r.push_str(String::from("  \"title\": \"ContractsResult\",\n"));
    r.push_str(String::from("  \"description\": \"JSON output from `vow contracts` on stdout\",\n"));
    r.push_str(String::from("  \"type\": \"object\",\n"));
    r.push_str(String::from("  \"required\": [\"contracts\", \"summary\"],\n"));
    r.push_str(String::from("  \"properties\": {\n"));
    r.push_str(String::from("    \"contracts\": {\n"));
    r.push_str(String::from("      \"type\": \"array\",\n"));
    r.push_str(String::from("      \"items\": {\n"));
    r.push_str(String::from("        \"type\": \"object\",\n"));
    r.push_str(String::from("        \"required\": [\"vow_id\", \"function\", \"kind\", \"description\", \"blame\", \"source\", \"status\", \"quality\"],\n"));
    r.push_str(String::from("        \"properties\": {\n"));
    r.push_str(String::from("          \"vow_id\": {\n"));
    r.push_str(String::from("            \"type\": \"integer\",\n"));
    r.push_str(String::from("            \"description\": \"Unique contract identifier within the program\"\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"function\": {\n"));
    r.push_str(String::from("            \"type\": \"string\",\n"));
    r.push_str(String::from("            \"description\": \"Function containing this contract\"\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"kind\": {\n"));
    r.push_str(String::from("            \"type\": \"string\",\n"));
    r.push_str(String::from("            \"enum\": [\"requires\", \"ensures\", \"invariant\"],\n"));
    r.push_str(String::from("            \"description\": \"Contract kind\"\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"description\": {\n"));
    r.push_str(String::from("            \"type\": \"string\",\n"));
    r.push_str(String::from("            \"description\": \"Full contract text\"\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"blame\": {\n"));
    r.push_str(String::from("            \"type\": \"string\",\n"));
    r.push_str(String::from("            \"enum\": [\"Caller\", \"Callee\"],\n"));
    r.push_str(String::from("            \"description\": \"Blame assignment: Caller for requires, Callee for ensures/invariant\"\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"source\": {\n"));
    r.push_str(String::from("            \"type\": \"object\",\n"));
    r.push_str(String::from("            \"required\": [\"file\", \"offset\"],\n"));
    r.push_str(String::from("            \"properties\": {\n"));
    r.push_str(String::from("              \"file\": {\n"));
    r.push_str(String::from("                \"type\": \"string\",\n"));
    r.push_str(String::from("                \"description\": \"Source file path\"\n"));
    r.push_str(String::from("              },\n"));
    r.push_str(String::from("              \"offset\": {\n"));
    r.push_str(String::from("                \"type\": \"integer\",\n"));
    r.push_str(String::from("                \"description\": \"Byte offset in source file\"\n"));
    r.push_str(String::from("              }\n"));
    r.push_str(String::from("            },\n"));
    r.push_str(String::from("            \"additionalProperties\": false\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"status\": {\n"));
    r.push_str(String::from("            \"type\": \"string\",\n"));
    r.push_str(String::from("            \"enum\": [\"proven\", \"proven-ir\", \"failed\", \"unknown\", \"timeout\", \"error\", \"not_verified\", \"skipped\", \"vacuous\"],\n"));
    r.push_str(String::from("            \"description\": \"Verification status\"\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"quality\": {\n"));
    r.push_str(String::from("            \"type\": \"string\",\n"));
    r.push_str(String::from("            \"enum\": [\"weak\", \"tautological\", \"substantive\"],\n"));
    r.push_str(String::from("            \"description\": \"Static, no-ESBMC classification of the clause shape: weak (an ensures that only bounds result by a constant), tautological (constant clause that says nothing), or substantive (equality/relational/inverse/call). See contracts-methodology.md\"\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"trivially_satisfiable\": {\n"));
    r.push_str(String::from("            \"type\": \"boolean\",\n"));
    r.push_str(String::from("            \"description\": \"`--verify` only: true when a trivial `return <default>` body still satisfies this `ensures` (verification-confirmed weakness). Always false for `requires`/`invariant` and without `--verify`. Informational; never affects the exit code. See contracts-methodology.md\"\n"));
    r.push_str(String::from("          }\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        \"additionalProperties\": false\n"));
    r.push_str(String::from("      }\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"summary\": {\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"total\", \"proven\", \"failed\", \"unknown\", \"timeout\", \"error\", \"not_verified\", \"skipped\", \"quality\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"total\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"proven\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"failed\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"unknown\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"timeout\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"error\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"not_verified\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"skipped\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"vacuous\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"trivially_satisfiable\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("        \"quality\": {\n"));
    r.push_str(String::from("          \"type\": \"object\",\n"));
    r.push_str(String::from("          \"description\": \"Static contract-quality tallies independent of verification status\",\n"));
    r.push_str(String::from("          \"required\": [\"weak\", \"tautological\", \"substantive\"],\n"));
    r.push_str(String::from("          \"properties\": {\n"));
    r.push_str(String::from("            \"weak\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("            \"tautological\": { \"type\": \"integer\" },\n"));
    r.push_str(String::from("            \"substantive\": { \"type\": \"integer\" }\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"additionalProperties\": false\n"));
    r.push_str(String::from("        }\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"additionalProperties\": false\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"additionalProperties\": false\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## counterexample\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n"));
    r.push_str(String::from("  \"$id\": \"https://vow-lang.dev/schemas/counterexample.schema.json\",\n"));
    r.push_str(String::from("  \"title\": \"Counterexample\",\n"));
    r.push_str(String::from("  \"description\": \"A structured counterexample from ESBMC verification failure\",\n"));
    r.push_str(String::from("  \"type\": \"object\",\n"));
    r.push_str(String::from("  \"required\": [\"function\", \"inputs\", \"violation\", \"vow_id\", \"source\"],\n"));
    r.push_str(String::from("  \"properties\": {\n"));
    r.push_str(String::from("    \"function\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Name of the function where verification failed\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"inputs\": {\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"additionalProperties\": { \"type\": \"string\" },\n"));
    r.push_str(String::from("      \"description\": \"Map of parameter names to counterexample values\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"violation\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Description of the violated contract\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"vow_id\": {\n"));
    r.push_str(String::from("      \"type\": \"integer\",\n"));
    r.push_str(String::from("      \"minimum\": 0,\n"));
    r.push_str(String::from("      \"description\": \"Numeric ID of the violated vow (matches vow_id in VowViolation)\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"source\": {\n"));
    r.push_str(String::from("      \"oneOf\": [\n"));
    r.push_str(String::from("        {\n"));
    r.push_str(String::from("          \"type\": \"object\",\n"));
    r.push_str(String::from("          \"required\": [\"file\", \"offset\", \"length\"],\n"));
    r.push_str(String::from("          \"properties\": {\n"));
    r.push_str(String::from("            \"file\": { \"type\": \"string\", \"description\": \"Source file path\" },\n"));
    r.push_str(String::from("            \"offset\": { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Byte offset of the vow clause\" },\n"));
    r.push_str(String::from("            \"length\": { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Byte length of the vow clause\" }\n"));
    r.push_str(String::from("          },\n"));
    r.push_str(String::from("          \"additionalProperties\": false\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        { \"type\": \"null\" }\n"));
    r.push_str(String::from("      ],\n"));
    r.push_str(String::from("      \"description\": \"Source location of the violated vow clause, or null\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"additionalProperties\": false\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## diagnostic\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n"));
    r.push_str(String::from("  \"$id\": \"https://vow-lang.dev/schemas/diagnostic.schema.json\",\n"));
    r.push_str(String::from("  \"title\": \"Diagnostic\",\n"));
    r.push_str(String::from("  \"description\": \"A single compiler diagnostic (error, warning, or note)\",\n"));
    r.push_str(String::from("  \"type\": \"object\",\n"));
    r.push_str(String::from("  \"required\": [\"error_code\", \"message\", \"severity\", \"span\"],\n"));
    r.push_str(String::from("  \"properties\": {\n"));
    r.push_str(String::from("    \"error_code\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"enum\": [\n"));
    r.push_str(String::from("        \"UnterminatedString\",\n"));
    r.push_str(String::from("        \"InvalidCharacter\",\n"));
    r.push_str(String::from("        \"UnexpectedToken\",\n"));
    r.push_str(String::from("        \"MissingDelimiter\",\n"));
    r.push_str(String::from("        \"TypeMismatch\",\n"));
    r.push_str(String::from("        \"StaticLiteralRequired\",\n"));
    r.push_str(String::from("        \"EffectViolation\",\n"));
    r.push_str(String::from("        \"LinearTypeViolation\",\n"));
    r.push_str(String::from("        \"NonExhaustiveMatch\",\n"));
    r.push_str(String::from("        \"VowRequiresViolated\",\n"));
    r.push_str(String::from("        \"VowEnsuresViolated\",\n"));
    r.push_str(String::from("        \"VowInvariantViolated\",\n"));
    r.push_str(String::from("        \"UnknownMethod\",\n"));
    r.push_str(String::from("        \"UnsupportedFeature\",\n"));
    r.push_str(String::from("        \"LoweringWarning\",\n"));
    r.push_str(String::from("        \"MissingContract\",\n"));
    r.push_str(String::from("        \"ContractTypeMismatch\",\n"));
    r.push_str(String::from("        \"EsbmcNotFound\",\n"));
    r.push_str(String::from("        \"IoError\",\n"));
    r.push_str(String::from("        \"RegionConflict\",\n"));
    r.push_str(String::from("        \"RegionLinear\",\n"));
    r.push_str(String::from("        \"RegionRootEscape\"\n"));
    r.push_str(String::from("      ],\n"));
    r.push_str(String::from("      \"description\": \"Machine-readable error code\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"message\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Human-readable error message\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"severity\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"enum\": [\"error\", \"warning\", \"note\"],\n"));
    r.push_str(String::from("      \"description\": \"Diagnostic severity\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"span\": {\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"file\", \"offset\", \"length\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"file\": { \"type\": \"string\", \"description\": \"Source file path\" },\n"));
    r.push_str(String::from("        \"offset\": { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Byte offset from start of file\" },\n"));
    r.push_str(String::from("        \"length\": { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Byte length of the span\" }\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"additionalProperties\": false\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"additionalProperties\": false\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## mutants-result\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n"));
    r.push_str(String::from("  \"$id\": \"https://vow-lang.org/schemas/mutants-result.schema.json\",\n"));
    r.push_str(String::from("  \"title\": \"MutantsOutput\",\n"));
    r.push_str(String::from("  \"description\": \"Output of `vow-mutants run` populates a directory (default `mutants.out/`). Each file has its own schema; the union is documented here.\",\n"));
    r.push_str(String::from("  \"$defs\": {\n"));
    r.push_str(String::from("    \"Mutant\": {\n"));
    r.push_str(String::from("      \"description\": \"Per-mutant catalog record (in mutants.json).\",\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"name\", \"file\", \"line\", \"col\", \"off\", \"len\", \"kind\", \"from\", \"to\", \"label\", \"clause_index\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"name\":         { \"type\": \"string\", \"description\": \"Stable cargo-mutants-style name: `file:line:col: <label>`.\" },\n"));
    r.push_str(String::from("        \"file\":         { \"type\": \"string\", \"description\": \"Repo-relative source path. Independent of --workdir.\" },\n"));
    r.push_str(String::from("        \"line\":         { \"type\": \"integer\", \"minimum\": 1, \"description\": \"1-based source line of `off`.\" },\n"));
    r.push_str(String::from("        \"col\":          { \"type\": \"integer\", \"minimum\": 1, \"description\": \"1-based source column of `off`.\" },\n"));
    r.push_str(String::from("        \"off\":          { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Byte offset of the mutation site.\" },\n"));
    r.push_str(String::from("        \"len\":          { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Byte length of the mutation span.\" },\n"));
    r.push_str(String::from("        \"kind\":         { \"enum\": [\"op-flip\", \"const-flip\", \"body-replace\", \"contract-weaken\"] },\n"));
    r.push_str(String::from("        \"from\":         { \"type\": \"string\", \"description\": \"Original source text at the site (empty for body-replace).\" },\n"));
    r.push_str(String::from("        \"to\":           { \"type\": \"string\", \"description\": \"Replacement text spliced in for this mutation.\" },\n"));
    r.push_str(String::from("        \"label\":        { \"type\": \"string\", \"description\": \"Human-readable summary of the mutation.\" },\n"));
    r.push_str(String::from("        \"clause_index\": { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Disambiguates sibling contract clauses on the same function. 0 for non-contract sites.\" }\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"additionalProperties\": false\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"Outcome\": {\n"));
    r.push_str(String::from("      \"description\": \"Per-mutant verdict (in outcomes.json).\",\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"id\", \"name\", \"status\", \"tier\", \"oracle_ms\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"id\":         { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Position of this mutant within the shard's `mutants.json` array.\" },\n"));
    r.push_str(String::from("        \"name\":       { \"type\": \"string\", \"description\": \"Same name as the corresponding Mutant record.\" },\n"));
    r.push_str(String::from("        \"status\":     { \"enum\": [\"caught\", \"missed\", \"timeout\", \"unviable\", \"unrun\"] },\n"));
    r.push_str(String::from("        \"tier\":       { \"enum\": [1, 2], \"description\": \"Oracle tier that produced the verdict.\" },\n"));
    r.push_str(String::from("        \"oracle_ms\":  { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Per-mutant oracle wall-clock in milliseconds. Non-deterministic -- excluded from the determinism guarantee.\" }\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"additionalProperties\": false\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"Summary\": {\n"));
    r.push_str(String::from("      \"description\": \"Aggregate counts across all of this shard's mutants. Same shape as the stdout summary line.\",\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"total\", \"caught\", \"missed\", \"timeout\", \"unviable\", \"unrun\", \"shard\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"total\":     { \"type\": \"integer\", \"minimum\": 0 },\n"));
    r.push_str(String::from("        \"caught\":    { \"type\": \"integer\", \"minimum\": 0 },\n"));
    r.push_str(String::from("        \"missed\":    { \"type\": \"integer\", \"minimum\": 0 },\n"));
    r.push_str(String::from("        \"timeout\":   { \"type\": \"integer\", \"minimum\": 0 },\n"));
    r.push_str(String::from("        \"unviable\":  { \"type\": \"integer\", \"minimum\": 0 },\n"));
    r.push_str(String::from("        \"unrun\":     { \"type\": \"integer\", \"minimum\": 0, \"description\": \"Tier-1 survivors not run because the Tier-2 budget was exhausted.\" },\n"));
    r.push_str(String::from("        \"shard\":     { \"type\": \"string\", \"pattern\": \"^[0-9]+/[1-9][0-9]*$\" }\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"additionalProperties\": false\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"MutantsJson\": {\n"));
    r.push_str(String::from("      \"description\": \"Format of `mutants.out/mutants.json`. Written before testing begins.\",\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"version\", \"tool\", \"shard\", \"mutants\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"version\":  { \"const\": 1 },\n"));
    r.push_str(String::from("        \"tool\":     { \"const\": \"vow-mutants\" },\n"));
    r.push_str(String::from("        \"shard\":    { \"type\": \"string\", \"pattern\": \"^[0-9]+/[1-9][0-9]*$\" },\n"));
    r.push_str(String::from("        \"mutants\":  { \"type\": \"array\", \"items\": { \"$ref\": \"#/$defs/Mutant\" } }\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"additionalProperties\": false\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"OutcomesJson\": {\n"));
    r.push_str(String::from("      \"description\": \"Format of `mutants.out/outcomes.json`. Written after all mutants in this shard have been classified.\",\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"version\", \"summary\", \"outcomes\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"version\":  { \"const\": 1 },\n"));
    r.push_str(String::from("        \"summary\":  { \"$ref\": \"#/$defs/Summary\" },\n"));
    r.push_str(String::from("        \"outcomes\": { \"type\": \"array\", \"items\": { \"$ref\": \"#/$defs/Outcome\" } }\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"additionalProperties\": false\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## test-result\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n"));
    r.push_str(String::from("  \"$id\": \"https://vow-lang.dev/schemas/test-result.schema.json\",\n"));
    r.push_str(String::from("  \"title\": \"TestResult\",\n"));
    r.push_str(String::from("  \"description\": \"JSON output from `vow test` on stdout\",\n"));
    r.push_str(String::from("  \"type\": \"object\",\n"));
    r.push_str(String::from("  \"required\": [\"status\", \"total\", \"passed\", \"failed\", \"skipped\", \"tests\", \"contract_density\"],\n"));
    r.push_str(String::from("  \"properties\": {\n"));
    r.push_str(String::from("    \"status\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"enum\": [\"TestsPassed\", \"TestsFailed\"],\n"));
    r.push_str(String::from("      \"description\": \"Overall test outcome\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"total\": {\n"));
    r.push_str(String::from("      \"type\": \"integer\",\n"));
    r.push_str(String::from("      \"description\": \"Total number of tests discovered\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"passed\": {\n"));
    r.push_str(String::from("      \"type\": \"integer\",\n"));
    r.push_str(String::from("      \"description\": \"Number of tests that passed\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"failed\": {\n"));
    r.push_str(String::from("      \"type\": \"integer\",\n"));
    r.push_str(String::from("      \"description\": \"Number of tests that failed\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"skipped\": {\n"));
    r.push_str(String::from("      \"type\": \"integer\",\n"));
    r.push_str(String::from("      \"description\": \"Number of tests that were skipped\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"tests\": {\n"));
    r.push_str(String::from("      \"type\": \"array\",\n"));
    r.push_str(String::from("      \"items\": { \"$ref\": \"#/$defs/TestEntry\" },\n"));
    r.push_str(String::from("      \"description\": \"Per-test results\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"contract_density\": {\n"));
    r.push_str(String::from("      \"$ref\": \"#/$defs/ContractDensity\",\n"));
    r.push_str(String::from("      \"description\": \"Contract density across tested modules\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"$defs\": {\n"));
    r.push_str(String::from("    \"TestEntry\": {\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"file\", \"name\", \"status\", \"stdout\", \"stderr\", \"duration_ms\", \"diagnostics\", \"counterexamples\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"file\": { \"type\": \"string\", \"description\": \"Path to the test .vow file\" },\n"));
    r.push_str(String::from("        \"name\": { \"type\": \"string\", \"description\": \"Test name (file stem)\" },\n"));
    r.push_str(String::from("        \"status\": {\n"));
    r.push_str(String::from("          \"type\": \"string\",\n"));
    r.push_str(String::from("          \"enum\": [\"passed\", \"failed\", \"timeout\", \"skipped\", \"compile_error\", \"verify_failed\", \"contract_skipped\"],\n"));
    r.push_str(String::from("          \"description\": \"Per-test outcome\"\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        \"exit_code\": {\n"));
    r.push_str(String::from("          \"type\": [\"integer\", \"null\"],\n"));
    r.push_str(String::from("          \"description\": \"Process exit code, null on compile/verify failure or timeout\"\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        \"stdout\": { \"type\": \"string\", \"description\": \"Captured stdout from test binary\" },\n"));
    r.push_str(String::from("        \"stderr\": { \"type\": \"string\", \"description\": \"Captured stderr from test binary\" },\n"));
    r.push_str(String::from("        \"duration_ms\": { \"type\": \"integer\", \"description\": \"Wall-clock duration in milliseconds\" },\n"));
    r.push_str(String::from("        \"diagnostics\": {\n"));
    r.push_str(String::from("          \"type\": \"array\",\n"));
    r.push_str(String::from("          \"items\": { \"$ref\": \"diagnostic.schema.json\" },\n"));
    r.push_str(String::from("          \"description\": \"Compiler diagnostics (on compile_error)\"\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        \"counterexamples\": {\n"));
    r.push_str(String::from("          \"type\": \"array\",\n"));
    r.push_str(String::from("          \"items\": { \"$ref\": \"counterexample.schema.json\" },\n"));
    r.push_str(String::from("          \"description\": \"ESBMC counterexamples (on verify_failed)\"\n"));
    r.push_str(String::from("        }\n"));
    r.push_str(String::from("      }\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"ContractDensity\": {\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"required\": [\"functions_total\", \"functions_with_vows\", \"density_pct\"],\n"));
    r.push_str(String::from("      \"properties\": {\n"));
    r.push_str(String::from("        \"functions_total\": { \"type\": \"integer\", \"description\": \"Total non-main functions across tested modules\" },\n"));
    r.push_str(String::from("        \"functions_with_vows\": { \"type\": \"integer\", \"description\": \"Functions with at least one vow block\" },\n"));
    r.push_str(String::from("        \"density_pct\": { \"type\": \"number\", \"description\": \"Percentage of functions with vow contracts\" }\n"));
    r.push_str(String::from("      }\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## vow-violation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n"));
    r.push_str(String::from("  \"$id\": \"https://vow-lang.dev/schemas/vow-violation.schema.json\",\n"));
    r.push_str(String::from("  \"title\": \"VowViolation\",\n"));
    r.push_str(String::from("  \"description\": \"Runtime vow violation emitted to stderr (debug mode only). This is emitted by the vow-runtime C code, not by serde.\",\n"));
    r.push_str(String::from("  \"type\": \"object\",\n"));
    r.push_str(String::from("  \"required\": [\"error\", \"vow_id\", \"blame\", \"description\", \"file\", \"offset\"],\n"));
    r.push_str(String::from("  \"properties\": {\n"));
    r.push_str(String::from("    \"error\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"const\": \"VowViolation\",\n"));
    r.push_str(String::from("      \"description\": \"Always the string VowViolation\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"vow_id\": {\n"));
    r.push_str(String::from("      \"type\": \"integer\",\n"));
    r.push_str(String::from("      \"minimum\": 0,\n"));
    r.push_str(String::from("      \"description\": \"Numeric ID of the violated vow\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"blame\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"enum\": [\"Caller\", \"Callee\"],\n"));
    r.push_str(String::from("      \"description\": \"Who is blamed: Caller for requires violations, Callee for ensures/invariant\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"description\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"The contract predicate text\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"file\": {\n"));
    r.push_str(String::from("      \"type\": \"string\",\n"));
    r.push_str(String::from("      \"description\": \"Source file path\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"offset\": {\n"));
    r.push_str(String::from("      \"type\": \"integer\",\n"));
    r.push_str(String::from("      \"minimum\": 0,\n"));
    r.push_str(String::from("      \"description\": \"Byte offset of the vow in the source file\"\n"));
    r.push_str(String::from("    },\n"));
    r.push_str(String::from("    \"values\": {\n"));
    r.push_str(String::from("      \"type\": \"object\",\n"));
    r.push_str(String::from("      \"additionalProperties\": {\n"));
    r.push_str(String::from("        \"type\": [\"integer\", \"number\", \"boolean\"]\n"));
    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"description\": \"Runtime values of free variables in the predicate (optional, present when bindings exist)\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
    r.push_str(String::from("  \"additionalProperties\": false\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r
}
