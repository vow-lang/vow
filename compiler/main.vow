    r.push_str(String::from("          \"value_kind\": \"path\",\n"));
    r.push_str(String::from("          \"default\": \"source without .vow extension\"\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        {\n"));
    r.push_str(String::from("          \"form\": \"--mode <debug|release|profile|sanitize>\",\n"));
    r.push_str(String::from("          \"description\": \"Build mode: debug inserts runtime vow checks, profile inserts call counters and prints report on normal exit, sanitize adds debug checks + Vec provenance tracking (default: release)\",\n"));
    r.push_str(String::from("          \"long\": \"--mode\",\n"));
