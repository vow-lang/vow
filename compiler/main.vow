fn skill_support_content_0() -> String {
    let r: String = String::from("# Vow Grammar Reference\n");
    r.push_str(String::from("\n"));
    r.push_str(String::from("Complete grammar for the Vow programming language. Vow source files use the `.vow` extension.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Line comments.** `//` starts a line comment extending to end of line. Comments are stripped during lexing and never enter the token stream. Block comments (`/* */`) are not supported. Machine-relevant intent belongs in contracts; comments are for non-semantic rationale.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Module Declaration\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Every file begins with a module declaration:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("module <Name>\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`<Name>` is a PascalCase identifier. There is no semicolon.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Use Declarations\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Import other modules with dot-separated paths:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("use foo.bar\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("This resolves to `<rootdir>/foo/bar.vow` relative to the main source file.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Const Declarations\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Named constants with compile-time values:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("const MAX_SIZE: i64 = 1024;\n"));
    r.push_str(String::from("const NEG_ONE: i64 = -1;\n"));
    r.push_str(String::from("const DEBUG: bool = true;\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Supported value forms: integer literals, boolean literals, negated integer literals. Constants are inlined at every use site (zero runtime cost). The type must be any of the 10 integer types (`i8`, `i16`, `i32`, `i64`, `i128`, `u8`, `u16`, `u32`, `u64`, `u128`) or `bool`. Integer constants are subject to the same compile-time range check as integer literals. Constants are referenced by name in expressions like any other identifier.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Functions\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Pure Function\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn add(x: i64, y: i64) -> i64 {\n"));
    r.push_str(String::from("    x + y\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Function with Effects\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    print_str(\"hello\");\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Effects appear in brackets after the return type: `[io]`, `[read, write]`, `[io, panic]`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Function with Vow Block\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn divide(x: i64, y: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: y != 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    x / y\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `vow` block sits between the signature and the body. Clauses:\n"));
    r.push_str(String::from("- `requires: <expr>` -- precondition (blame: Caller)\n"));
    r.push_str(String::from("- `ensures: <expr>` -- postcondition (blame: Callee); use `result` for the return value\n"));
    r.push_str(String::from("- `invariant: <expr>` -- loop invariant (blame: Callee)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Multiple clauses are separated by commas:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn clamp(x: i64, lo: i64, hi: i64) -> i64 vow {\n"));
    r.push_str(String::from("    requires: lo <= hi,\n"));
    r.push_str(String::from("    ensures: result >= lo,\n"));
    r.push_str(String::from("    ensures: result <= hi\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    if x < lo { lo } else { if x > hi { hi } else { x } }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Where Clauses (Refinement Types on Parameters)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn safe_sub(a: i64 where a >= 0, b: i64 where b >= 0) -> i64 vow {\n"));
    r.push_str(String::from("    requires: a >= b,\n"));
    r.push_str(String::from("    ensures: result >= 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    a - b\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`where` constraints on parameters become additional `requires` in verification. Each `where` clause can only reference its own parameter -- it cannot reference other parameters.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Public Functions\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("pub fn api_function(x: i64) -> i64 {\n"));
    r.push_str(String::from("    x\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Types\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Primitive Types\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Type   | Description              |\n"));
    r.push_str(String::from("|--------|--------------------------|\n"));
    r.push_str(String::from("| `i8`   | 8-bit signed integer     |\n"));
    r.push_str(String::from("| `i16`  | 16-bit signed integer    |\n"));
    r.push_str(String::from("| `i32`  | 32-bit signed integer    |\n"));
    r.push_str(String::from("| `i64`  | 64-bit signed integer    |\n"));
    r.push_str(String::from("| `i128` | 128-bit signed integer (verifier may time out; see below) |\n"));
    r.push_str(String::from("| `u8`   | 8-bit unsigned integer   |\n"));
    r.push_str(String::from("| `u16`  | 16-bit unsigned integer  |\n"));
    r.push_str(String::from("| `u32`  | 32-bit unsigned integer  |\n"));
    r.push_str(String::from("| `u64`  | 64-bit unsigned integer  |\n"));
    r.push_str(String::from("| `u128` | 128-bit unsigned integer (verifier may time out; see below) |\n"));
    r.push_str(String::from("| `f32`  | 32-bit float (limited support -- avoid in contracts) |\n"));
    r.push_str(String::from("| `f64`  | 64-bit float (limited support -- avoid in contracts) |\n"));
    r.push_str(String::from("| `bool` | Boolean                  |\n"));
    r.push_str(String::from("| `()`   | Unit type                |\n"));
    r.push_str(String::from("| `!`    | Never type (diverges)    |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("There is no `isize`/`usize`. Vow targets 64-bit only; `Vec::len()` returns `i64`,\n"));
    r.push_str(String::from("indices are `i64`. This is deliberate -- it preserves binary fixed point\n"));
    r.push_str(String::from("reproducibility across compilations. See [ADR 0001](../adr/0001-numeric-tower-narrow-ints.md).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**128-bit verification:** `i128`/`u128` arithmetic codegens via Cranelift's\n"));
    r.push_str(String::from("`I128` and verifies via ESBMC's `__int128`. Predicates over 128-bit values may\n"));
    r.push_str(String::from("exceed reasonable SMT solver timeouts; the `--no-128-verify` flag skips\n"));
    r.push_str(String::from("verification for functions whose contracts mention 128-bit values while still\n"));
    r.push_str(String::from("generating native code for them.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Struct field layout:** every struct field up to 64 bits wide occupies one\n"));
    r.push_str(String::from("8-byte slot regardless of declared type (narrow ints are padded); `i128`/`u128`\n"));
    r.push_str(String::from("fields occupy two consecutive 8-byte slots (16 bytes). There is no packing or\n"));
    r.push_str(String::from("natural-alignment layout today; FFI structs that need a specific C layout must\n"));
    r.push_str(String::from("shim through `Vec<u8>` or extern wrappers.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Built-in Parameterized Types\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Type               | Description                     |\n"));
    r.push_str(String::from("|--------------------|---------------------------------|\n"));
    r.push_str(String::from("| `Vec<T>`           | Growable array                  |\n"));
    r.push_str(String::from("| `Option<T>`        | Optional value (Some/None)      |\n"));
    r.push_str(String::from("| `Result<T, E>`     | Success or error                |\n"));
    r.push_str(String::from("| `String`           | UTF-8 string (backed by Vec<u8>)|\n"));
    r.push_str(String::from("| `HashMap<K, V>`    | Key-value map (linear scan)     |\n"));
    r.push_str(String::from("| `BTreeMap<K, V>`   | Sorted key-value map (binary search; ascending iteration). `K` must be `i64`; `V` may be any non-linear type |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### User-Defined Types\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Structs and enums (see below).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Literals\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Integer Literals\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("42\n"));
    r.push_str(String::from("-1\n"));
    r.push_str(String::from("0\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Unsuffixed integer literals default to `i64` in expression position, and\n"));
    r.push_str(String::from("**context-coerce** to any of the 10 integer types when the\n"));
    r.push_str(String::from("surrounding context fixes one -- `let` bindings, function arguments, struct\n"));
    r.push_str(String::from("fields, and the typed operand of an arithmetic, bitwise, or comparison\n"));
    r.push_str(String::from("operator. The same coercion applies to constant expressions composed entirely\n"));
    r.push_str(String::from("of unsuffixed integer literals (e.g. `1 + 2`, `1 << 3`, `-5`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Out-of-range literals in a typed context are a compile-time error:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let x: u8 = 300;   // error: LiteralOutOfRange -- 300 does not fit in u8\n"));
    r.push_str(String::from("let y: i8 = 200;   // error: LiteralOutOfRange -- i8 range is -128..=127\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Suffixed integer literals** force the type at the literal:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("42u8     42u16     42u32     42u64     42u128\n"));
    r.push_str(String::from("42i8     42i16     42i32     42i64     42i128\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Suffixed forms are supported for all 10 integer widths. They override context\n"));
    r.push_str(String::from("coercion and are still subject to the same compile-time range check.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Float Literals\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("3.14\n"));
    r.push_str(String::from("-0.5\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Boolean Literals\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("true\n"));
    r.push_str(String::from("false\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### String Literals\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("\"hello, world\"\n"));
    r.push_str(String::from("\"line one\\nline two\"\n"));
    r.push_str(String::from("\"tab\\there\"\n"));
    r.push_str(String::from("\"null\\0byte\"\n"));
    r.push_str(String::from("\"escaped\\\\backslash\"\n"));
    r.push_str(String::from("\"escaped\\\"quote\"\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Supported escape sequences: `\\n`, `\\t`, `\\r`, `\\\\`, `\\\"`, `\\0`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("String literals have type `String` and are backed by a read-only static\n"));
    r.push_str(String::from("descriptor. Passing or returning a literal does not allocate. To obtain a\n"));
    r.push_str(String::from("mutable, arena-owned copy, use `String::from(\"...\")`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Operators\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Wrapping Arithmetic (default)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Operator | Meaning        |\n"));
    r.push_str(String::from("|----------|----------------|\n"));
    r.push_str(String::from("| `+`      | Add (wrapping) |\n"));
    r.push_str(String::from("| `-`      | Sub (wrapping) |\n"));
    r.push_str(String::from("| `*`      | Mul (wrapping) |\n"));
    r.push_str(String::from("| `/`      | Div (wrapping) |\n"));
    r.push_str(String::from("| `%`      | Rem (wrapping) |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Wrapping operators silently wrap on overflow. For `u64` operands, division and remainder use unsigned semantics.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Checked Arithmetic\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Operator | Meaning           |\n"));
    r.push_str(String::from("|----------|-------------------|\n"));
    r.push_str(String::from("| `+!`     | Add (checked)     |\n"));
    r.push_str(String::from("| `-!`     | Sub (checked)     |\n"));
    r.push_str(String::from("| `*!`     | Mul (checked)     |\n"));
    r.push_str(String::from("| `/!`     | Div (checked)     |\n"));
    r.push_str(String::from("| `%!`     | Rem (checked)     |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Checked operators abort with `ArithmeticOverflow` on overflow.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Comparison Operators\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Operator | Meaning                |\n"));
    r.push_str(String::from("|----------|------------------------|\n"));
    r.push_str(String::from("| `==`     | Equal                  |\n"));
    r.push_str(String::from("| `!=`     | Not equal              |\n"));
    r.push_str(String::from("| `<`      | Less than              |\n"));
    r.push_str(String::from("| `<=`     | Less than or equal     |\n"));
    r.push_str(String::from("| `>`      | Greater than           |\n"));
    r.push_str(String::from("| `>=`     | Greater than or equal  |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Bitwise Operators\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Operator | Meaning      |\n"));
    r.push_str(String::from("|----------|--------------|\n"));
    r.push_str(String::from("| `&`      | Bitwise AND  |\n"));
    r.push_str(String::from("| `\\|`     | Bitwise OR   |\n"));
    r.push_str(String::from("| `^`      | Bitwise XOR  |\n"));
    r.push_str(String::from("| `<<`     | Left shift   |\n"));
    r.push_str(String::from("| `>>`     | Right shift  |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Bitwise `& | ^` require integer operands of the same type and work on all 10\n"));
    r.push_str(String::from("integer widths. `>>` is **arithmetic** (sign-extending) for signed types\n"));
    r.push_str(String::from("(`i8`..`i128`) and **logical** (zero-extending) for unsigned types\n"));
    r.push_str(String::from("(`u8`..`u128`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Shift count type.** The right operand of `<<` and `>>` is `u32`. Unsuffixed\n"));
    r.push_str(String::from("integer literals on the right side context-coerce to `u32`: given\n"));
    r.push_str(String::from("`let x: u8 = ...`, `x << 3` is well-typed (`3` coerces to `u32`). The left\n"));
    r.push_str(String::from("operand keeps its own integer type; the shift result has the left operand's\n"));
    r.push_str(String::from("type.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Shift count range.** A const-expression shift count `>= bit-width(LHS)` is a\n"));
    r.push_str(String::from("compile-time error (`ShiftCountOutOfRange`). For example, `(x: u8) << 8` does\n"));
    r.push_str(String::from("not compile. Dynamic shift counts (`x << n` where `n` is not a const\n"));
    r.push_str(String::from("expression) get a contract on the operation that ESBMC checks: the count must\n"));
    r.push_str(String::from("be less than the LHS width at the point of the shift.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Unsuffixed literal coercion still applies for `&`, `|`, `^` operands: with\n"));
    r.push_str(String::from("`let x: u64 = ...`, `3 & x` and `x | 0xff` type-check because the literal\n"));
    r.push_str(String::from("side coerces to `u64`. Use a suffix to force a different type explicitly.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Logical Operators\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Operator | Meaning    |\n"));
    r.push_str(String::from("|----------|------------|\n"));
    r.push_str(String::from("| `&&`     | Logical AND (short-circuit) |\n"));
    r.push_str(String::from("| `\\|\\|`   | Logical OR (short-circuit) |\n"));
    r.push_str(String::from("| `!`      | Logical NOT|\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`&&` and `||` use short-circuit evaluation: for `a && b`, `b` is only evaluated if `a` is true; for `a || b`, `b` is only evaluated if `a` is false.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Operator Precedence\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("From loosest to tightest, Vow follows the usual C/Rust precedence for logical and bitwise operators:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`||`, `&&`, comparisons (`== != < <= > >=`), `|`, `^`, `&`, `<< >>`, `+ -`, `* / %`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Unary `-`, `!`, `&`, and `?` bind tighter than every binary operator.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Single `&` is overloaded by position: prefix `&expr` is borrow, while infix `lhs & rhs` is bitwise AND.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Unary Operators\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Operator | Meaning    |\n"));
    r.push_str(String::from("|----------|------------|\n"));
    r.push_str(String::from("| `-`      | Negation (not allowed on `u64`) |\n"));
    r.push_str(String::from("| `!`      | Logical NOT|\n"));
    r.push_str(String::from("| `&`      | Borrow     |\n"));
    r.push_str(String::from("| `?`      | Unwrap (propagate error) |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Type Cast\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`as` is **widening-only** across integer types. Any narrower integer can be\n"));
    r.push_str(String::from("cast to any wider integer; signed sources sign-extend, unsigned sources\n"));
    r.push_str(String::from("zero-extend:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let a: i32 = -1;\n"));
    r.push_str(String::from("let b: i64 = a as i64;     // sign-extend: -1_i64\n"));
    r.push_str(String::from("let c: u8  = 200;\n"));
    r.push_str(String::from("let d: u64 = c as u64;     // zero-extend: 200_u64\n"));
    r.push_str(String::from("let e: u32 = 1;\n"));
    r.push_str(String::from("let f: i64 = e as i64;     // unsigned-to-signed widening, value preserved\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`as` between signed and unsigned of **the same width** is also allowed\n"));
    r.push_str(String::from("(machine-level bit reinterpretation): `i64 as u64`, `u64 as i64`, `i32 as u32`,\n"));
    r.push_str(String::from("etc.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Narrowing via `as` is a compile-time error** (`NarrowingCastNotAllowed`):\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let big: i64 = 300;\n"));
    r.push_str(String::from("let small: u8 = big as u8;     // error -- narrowing not allowed via `as`\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("To narrow, use a named intrinsic that makes the intent explicit. For every\n"));
    r.push_str(String::from("narrowing pair `(src, tgt)` the compiler exposes three free functions:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Intrinsic                         | Behavior on out-of-range input          |\n"));
    r.push_str(String::from("|-----------------------------------|-----------------------------------------|\n"));
    r.push_str(String::from("| `<src>_to_<tgt>_try(x) -> Option<tgt>` | returns `Option::None`             |\n"));
    r.push_str(String::from("| `<src>_to_<tgt>_wrap(x) -> tgt`   | truncates (low bits, two's-complement)  |\n"));
    r.push_str(String::from("| `<src>_to_<tgt>_sat(x) -> tgt`    | clamps to the target type's range       |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Example:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let big: i64 = 300;\n"));
    r.push_str(String::from("match i64_to_u8_try(big) {\n"));
    r.push_str(String::from("    Option::Some(b) => use_byte(b),\n"));
    r.push_str(String::from("    Option::None    => fallback(),\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("These intrinsics are emitted by the compiler so ESBMC sees their semantics\n"));
    r.push_str(String::from("directly in the verification C model.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("No implicit conversions: `i64 + u64` and `u8 + i32` are type errors. The\n"));
    r.push_str(String::from("operands must already have the same type. The compiler does not coerce\n"));
    r.push_str(String::from("across integer types at operator sites -- only literals coerce, per the\n"));
    r.push_str(String::from("[Integer Literals](#integer-literals) rules.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Let Bindings\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Immutable\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let x: i64 = 42;\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Mutable\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let mut i: i64 = 0;\n"));
    r.push_str(String::from("i = i + 1;\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Pattern Destructuring\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let (a, b): (i64, i64) = (1, 2);\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Control Flow\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### If / Else\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("if x > 0 {\n"));
    r.push_str(String::from("    x\n"));
    r.push_str(String::from("} else {\n"));
    r.push_str(String::from("    0 - x\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`if`/`else` is an expression -- both branches must have the same type. There is no `else if` keyword; nest `if` inside `else`:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("if x < lo {\n"));
    r.push_str(String::from("    lo\n"));
    r.push_str(String::from("} else {\n"));
    r.push_str(String::from("    if x > hi {\n"));
    r.push_str(String::from("        hi\n"));
    r.push_str(String::from("    } else {\n"));
    r.push_str(String::from("        x\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### While Loop\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("while i > 0 {\n"));
    r.push_str(String::from("    i = i - 1;\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### While Loop with Invariant\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("while i < n vow {\n"));
    r.push_str(String::from("    invariant: i >= 0,\n"));
    r.push_str(String::from("    invariant: i <= n\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    v.push(i);\n"));
    r.push_str(String::from("    i = i + 1;\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### For-Each Loop\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("for x in vec {\n"));
    r.push_str(String::from("    print_i64(x);\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Iterates over each element of a `Vec<T>`. The loop variable `x` is bound to each element in turn. Desugars to a `while` loop with index arithmetic -- zero verification overhead.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### For-Each Loop with Invariant\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("for x in vec vow {\n"));
    r.push_str(String::from("    invariant: total >= 0\n"));
    r.push_str(String::from("} {\n"));
    r.push_str(String::from("    total = total + x;\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Loop (Infinite)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`loop` creates an infinite loop. The expression returns the type of the `break` value:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let idx: i64 = loop {\n"));
    r.push_str(String::from("    if data[i] == target {\n"));
    r.push_str(String::from("        break i;\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("    i = i + 1;\n"));
    r.push_str(String::from("    if i >= n { break -1; }\n"));
    r.push_str(String::from("};\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("ESBMC cannot verify unbounded `loop` constructs -- use `while` with invariants for verifiable loops.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Break\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`break` exits the innermost loop. Inside `loop`, `break value` sets the loop's result:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("break;           // exit while or loop (loop returns Unit)\n"));
    r.push_str(String::from("break value;     // exit loop with a value (only inside loop, not while)\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Continue\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`continue` skips the remaining statements in the current loop iteration and jumps back to the loop header:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("continue;        // skip to next iteration of while, loop, or for\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Inside `while` and `loop`, `continue` emits back-edge values for any mutated variables. Inside `for`, it also advances the loop index.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Return\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("return;\n"));
    r.push_str(String::from("return value;\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Struct Definitions\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("struct Point {\n"));
    r.push_str(String::from("    x: i64,\n"));
    r.push_str(String::from("    y: i64,\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Linear Structs\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("linear struct FileHandle {\n"));
    r.push_str(String::from("    fd: i64,\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Linear struct values carry a linear obligation. The obligation must either be consumed before the value's owning region closes or transferred to the caller by returning the value.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Struct Literals\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Struct literal names must be PascalCase:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let p: Point = Point { x: 1, y: 2 };\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Field Access\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("p.x\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Field Assignment\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("p.x = 10;\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Passing Semantics\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Structs are heap-allocated. A struct value is a pointer to a heap region, so passing a struct to a function passes the pointer -- the function operates on the same heap data, not a copy. Field assignments inside the called function are visible to the caller:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn shift_right(p: Point, dx: i64) {\n"));
    r.push_str(String::from("    p.x = p.x + dx;\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn main() -> i32 [io] {\n"));
    r.push_str(String::from("    let p: Point = Point { x: 0, y: 0 };\n"));
    r.push_str(String::from("    shift_right(p, 5);\n"));
    r.push_str(String::from("    print_i64(p.x);  // 5 -- mutation visible to caller\n"));
    r.push_str(String::from("    0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("This enables in-place mutation patterns (e.g., make/unmake in search trees) without cloning. The same aliasing semantics apply when structs are stored in containers -- see [Indexing](#indexing). To avoid aliasing, construct a fresh struct literal with the desired field values.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Note:** For `linear struct` types, passing the value to a function consumes it; the caller cannot access it afterward. Returning a linear value transfers the obligation to the caller, so this is the normal way to hand an updated linear value back out of a function.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Enum Definitions\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("enum Shape {\n"));
    r.push_str(String::from("    Circle(i64),\n"));
    r.push_str(String::from("    Rect(i64, i64),\n"));
    r.push_str(String::from("    Empty,\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Variant kinds: unit (`Empty`), tuple (`Circle(i64)`), struct (`Named { x: i64 }`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Enum Construction\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let s: Shape = Shape::Circle(5);\n"));
    r.push_str(String::from("let none: Option<i64> = Option::None;\n"));
    r.push_str(String::from("let some: Option<i64> = Option::Some(42);\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Built-in Enums\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`Option<T>` has variants `Some(T)` and `None`.\n"));
    r.push_str(String::from("`Result<T, E>` has variants `Ok(T)` and `Err(E)`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Pattern Matching\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("match value {\n"));
    r.push_str(String::from("    Pattern1 => expr1,\n"));
    r.push_str(String::from("    Pattern2 => expr2,\n"));
    r.push_str(String::from("    _ => default_expr,\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Match is an expression. All arms must return the same type. Patterns must be exhaustive.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Pattern Kinds\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Pattern                      | Example                          |\n"));
    r.push_str(String::from("|------------------------------|----------------------------------|\n"));
    r.push_str(String::from("| Wildcard                     | `_`                              |\n"));
    r.push_str(String::from("| Identifier binding           | `x`                              |\n"));
    r.push_str(String::from("| Mutable identifier           | `mut x`                          |\n"));
    r.push_str(String::from("| Literal                      | `0`, `true`, `\"hello\"`           |\n"));
    r.push_str(String::from("| Tuple                        | `(a, b)`                         |\n"));
    r.push_str(String::from("| Enum variant (unit)          | `Option::None`                   |\n"));
    r.push_str(String::from("| Enum variant (tuple)         | `Option::Some(x)`                |\n"));
    r.push_str(String::from("| Enum variant (struct)        | `Shape::Named { x, y }`         |\n"));
    r.push_str(String::from("| Or pattern                   | `0 \\| 1 \\| 2`                   |\n"));
    r.push_str(String::from("| Struct pattern               | `Point { x, y }`                |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Method Calls\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("v.push(42);\n"));
    r.push_str(String::from("v.len()\n"));
    r.push_str(String::from("s.byte_at(0)\n"));
    r.push_str(String::from("m.contains_key(k)\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Vec<T> Methods\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Method         | Signature                        |\n"));
    r.push_str(String::from("|----------------|----------------------------------|\n"));
    r.push_str(String::from("| `Vec::new()`   | `() -> Vec<T>`                   |\n"));
    r.push_str(String::from("| `Vec::from_raw_parts_copy(ptr, len)` | `(i64, i64) -> Vec<T>` for flat scalar `T` |\n"));
    r.push_str(String::from("| `.push(val)`   | `(T) -> ()`                      |\n"));
    r.push_str(String::from("| `.pop()`       | `() -> ()`                       |\n"));
    r.push_str(String::from("| `.len()`       | `() -> i64`                      |\n"));
    r.push_str(String::from("| `.clear()`     | `() -> ()` -- frees buffer, resets to empty |\n"));
    r.push_str(String::from("| `.truncate(n)` | `(i64) -> ()` -- shrinks to n elements, frees excess memory |\n"));
    r.push_str(String::from("| `v[i]`         | Index read -- copies slot value; aliases heap types (panics if out of bounds) |\n"));
    r.push_str(String::from("| `v[i] = val`   | Index write -- copies value into slot |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### String Methods\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Method              | Signature                   |\n"));
    r.push_str(String::from("|---------------------|-----------------------------|\n"));
    r.push_str(String::from("| `String::from(s)`   | `(String) -> String` -- mutable copy |\n"));
    r.push_str(String::from("| `String::new()`     | `() -> String`              |\n"));
    r.push_str(String::from("| `String::from_raw_parts_copy(ptr, len)` | `(i64, i64) -> String` |\n"));
    r.push_str(String::from("| `.len()`            | `() -> i64`                 |\n"));
    r.push_str(String::from("| `.byte_at(i)`       | `(i64) -> i64`              |\n"));
    r.push_str(String::from("| `.push_byte(b)`     | `(i64) -> ()`               |\n"));
    r.push_str(String::from("| `.push_str(s)`      | `(String) -> ()`            |\n"));
    r.push_str(String::from("| `.clear()`          | `() -> ()` -- frees buffer, resets to empty |\n"));
    r.push_str(String::from("| `.contains(s)`      | `(String) -> bool`          |\n"));
    r.push_str(String::from("| `.eq(s)`            | `(String) -> bool`          |\n"));
    r.push_str(String::from("| `.substring(start, end)` | `(i64, i64) -> String` |\n"));
    r.push_str(String::from("| `.parse_i64()`      | `() -> Option<i64>`         |\n"));
    r.push_str(String::from("| `.parse_u64()`      | `() -> Option<u64>`         |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### HashMap<K, V> Methods\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Method              | Signature                   |\n"));
    r.push_str(String::from("|---------------------|-----------------------------|\n"));
    r.push_str(String::from("| `HashMap::new()`    | `() -> HashMap<K, V>`       |\n"));
    r.push_str(String::from("| `.insert(k, v)`     | `(K, V) -> ()`              |\n"));
    r.push_str(String::from("| `.get(k)`           | `(K) -> V`                  |\n"));
    r.push_str(String::from("| `.contains_key(k)`  | `(K) -> bool`               |\n"));
    r.push_str(String::from("| `.remove(k)`        | `(K) -> ()`                 |\n"));
    r.push_str(String::from("| `.len()`            | `() -> i64`                 |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### BTreeMap<K, V> Methods\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Keys must be `i64` (K violations raise `BTreeMapKeyTypeMustBeI64`). Values may be any\n"));
    r.push_str(String::from("non-linear type -- primitives, structs, `Vec<T>`, `Option<T>`, or nested combinations.\n"));
    r.push_str(String::from("A `V` that is or transitively contains a `linear struct` is rejected with\n"));
    r.push_str(String::from("`BTreeMapValueMustBeNonLinear`, because the runtime/verifier shift values bitwise and\n"));
    r.push_str(String::from("would silently duplicate a linear obligation.\n"));
    r.push_str(String::from("Storage is two parallel sorted arrays (binary-search lookup, sorted-insert writes).\n"));
    r.push_str(String::from("Iteration order is ascending by key and is **deterministic across runs and compilers** --\n"));
    r.push_str(String::from("prefer `BTreeMap` over `HashMap` for any map whose iteration affects compiler output.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Method              | Signature                   |\n"));
    r.push_str(String::from("|---------------------|-----------------------------|\n"));
    r.push_str(String::from("| `BTreeMap::new()`   | `() -> BTreeMap<K, V>`      |\n"));
    r.push_str(String::from("| `.insert(k, v)`     | `(K, V) -> Option<V>` (returns the previous value bound to `k`, if any) |\n"));
    r.push_str(String::from("| `.get(k)`           | `(K) -> Option<V>` (returns the value bound to `k`, or `None`)          |\n"));
    r.push_str(String::from("| `.contains(k)`      | `(K) -> bool`               |\n"));
    r.push_str(String::from("| `.len()`            | `() -> i64`                 |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Option<T> Methods\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Method      | Signature                              |\n"));
    r.push_str(String::from("|-------------|----------------------------------------|\n"));
    r.push_str(String::from("| `.unwrap()` | `() -> T` (panics on None; requires `[panic]` effect) |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The `?` operator on `Option<T>` or `Result<T, E>` propagates `None`/`Err` to the caller (the calling function must return `Option` or `Result`).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Indexing\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let val: i64 = v[0];\n"));
    r.push_str(String::from("v[i] = new_val;\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Indexing uses **copy semantics**: `v[i]` copies the 8-byte slot value and `v[i] = val` copies a value into the slot. The base container is not consumed.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("For primitive types (`i64`, `bool`), this is a genuine value copy -- the result is independent of the container. For heap types (`Vec<T>`, `String`, structs, enums), the 8-byte slot holds a pointer, so indexing copies the pointer, creating an **alias**. Both the container slot and the local variable point to the same heap data:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let buckets: Vec<Vec<i64>> = Vec::new();\n"));
    r.push_str(String::from("buckets.push(Vec::new());\n"));
    r.push_str(String::from("let b: Vec<i64> = buckets[0];  // b aliases buckets[0]\n"));
    r.push_str(String::from("b.push(42);                     // visible through buckets[0]\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("This aliasing is the intended behavior for arena and hash-table patterns where bucket contents are read and mutated repeatedly through index access.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Extern Blocks\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Declare external C functions (a `vow` contract block is required):\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("extern \"C\" vow {\n"));
    r.push_str(String::from("    requires: fd >= 0\n"));
    r.push_str(String::from("    ensures: return >= 0\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("    fn write(fd: i32, ptr: i64, len: i64) -> i64 [io]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Omitting the `vow` block produces a `MissingContract` error (see [errors.md](errors.md)).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Type Aliases\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("type Score = i64\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Effect System\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Effects are explicit. Every function declares which side effects it may perform. Pure functions (no effects) need no annotation.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Effect Types\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Effect   | Meaning                              |\n"));
    r.push_str(String::from("|----------|--------------------------------------|\n"));
    r.push_str(String::from("| `io`     | Standard I/O (print, stdin, network) |\n"));
    r.push_str(String::from("| `read`   | File system reads                    |\n"));
    r.push_str(String::from("| `write`  | File system writes                   |\n"));
    r.push_str(String::from("| `panic`  | May panic (unwrap, etc.)             |\n"));
    r.push_str(String::from("| `unsafe` | Unsafe operations (FFI, raw memory)  |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Each effect is independent -- `io` is not a superset of `read` or `write`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Propagation\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("A function must declare every effect that any function it calls may produce:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("fn do_io() -> () [io] {\n"));
    r.push_str(String::from("    print_str(\"hi\");\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("fn caller() -> () [io] {\n"));
    r.push_str(String::from("    do_io();\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("If `caller` omitted `[io]`, the type checker would emit `EffectViolation`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Contract Purity\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Contract expressions (`requires`, `ensures`, `invariant`) must be pure -- they cannot call effectful functions.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Builtin Function Signatures\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### FFI Wrapper Intrinsics\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `pin_to_root`    | `fn(value: String) -> String` and `fn<T>(value: Vec<T>) -> Vec<T>` for flat scalar `T` | `[]` |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`pin_to_root` is a compiler intrinsic, not a user-defined generic. Each call site is monomorphised from the argument type. It always deep-copies the supported heap value into root storage; it does not inspect descriptor tags and does not claim idempotency. The current supported forms are `String` and `Vec<T>` where `T` is a flat scalar slot type (`i*`, `u*`, `f32`, `f64`, `bool`). Pointer-containing payloads, user structs, enums, and maps require hand-written deep-copy wrappers at the FFI boundary.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`String::from_raw_parts_copy(ptr: i64, len: i64)` copies `len` bytes from a raw C pointer into a fresh `String`. `Vec::from_raw_parts_copy(ptr: i64, len: i64)` copies `len` flat scalar slots into a fresh `Vec<T>`. The surface length type is `i64`; the code generator converts pointer and length values to the platform pointer-sized ABI type at the FFI boundary. Both helpers have a `FreshInCaller` return summary.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("For pointer-containing C payloads, a wrapper must be written per type: call the extern, recursively copy every Vow-owned heap subobject into the target region, free every C-owned pointer according to the extern's ownership contract, then return the Vow-placed value. A bytewise copy of a pointer-containing payload is unsound because it preserves stale pointers into C-owned storage.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Print / IO\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `print_str`      | `fn(s: String) -> ()`                      | `[io]`     |\n"));
    r.push_str(String::from("| `print_i64`      | `fn(v: i64) -> ()`                         | `[io]`     |\n"));
    r.push_str(String::from("| `print_u64`      | `fn(v: u64) -> ()`                         | `[io]`     |\n"));
    r.push_str(String::from("| `eprintln_str`   | `fn(s: String) -> ()`                      | `[io]`     |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Debug\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `debug_str`      | `fn(s: String) -> ()`                      | `[]`       |\n"));
    r.push_str(String::from("| `debug_i64`      | `fn(v: i64) -> ()`                         | `[]`       |\n"));
    r.push_str(String::from("| `debug_u64`      | `fn(v: u64) -> ()`                         | `[]`       |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Debug print semantics:** Debug prints are effect-free and callable from pure functions. In debug and sanitize modes (`--mode debug`, `--mode sanitize`), they write to stderr. In release and profile modes, the debug call itself is not emitted -- no function call occurs. However, argument expressions are still evaluated (a direct literal such as `\"label\"` is static, while `String::from(\"label\")` still allocates a mutable copy). They are also no-ops during verification. Use them to trace values inside pure kernel code without restructuring the effect hierarchy.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Filesystem\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `fs_read`        | `fn(path: String) -> String`               | `[read]`   |\n"));
    r.push_str(String::from("| `fs_open`        | `fn(path: String) -> i64`                  | `[read]`   |\n"));
    r.push_str(String::from("| `fs_read_line`   | `fn(handle: i64) -> String`                | `[read]`   |\n"));
    r.push_str(String::from("| `fs_status`      | `fn(handle: i64) -> i64`                   | `[read]`   |\n"));
    r.push_str(String::from("| `fs_close`       | `fn(handle: i64) -> i64`                   | `[read]`   |\n"));
    r.push_str(String::from("| `fs_write`       | `fn(path: String, data: String) -> i64`    | `[write]`  |\n"));
    r.push_str(String::from("| `fs_exists`      | `fn(path: String) -> i64`                  | `[read]`   |\n"));
    r.push_str(String::from("| `fs_mkdir`       | `fn(path: String) -> i64`                  | `[io]`     |\n"));
    r.push_str(String::from("| `fs_listdir`     | `fn(path: String) -> Vec<String>`          | `[read]`   |\n"));
    r.push_str(String::from("| `fs_remove`      | `fn(path: String) -> i64`                  | `[io]`     |\n"));
    r.push_str(String::from("| `fs_remove_dir`  | `fn(path: String) -> i64`                  | `[io]`     |\n"));
    r.push_str(String::from("| `fs_is_dir`      | `fn(path: String) -> i64`                  | `[read]`   |\n"));
    r.push_str(String::from("| `fs_is_symlink`  | `fn(path: String) -> i64`                  | `[read]`   |\n"));
    r.push_str(String::from("| `fs_rename`      | `fn(old: String, new: String) -> i64`      | `[io]`     |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### String Operations\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function              | Signature                                        | Effects |\n"));
    r.push_str(String::from("|-----------------------|--------------------------------------------------|---------|\n"));
    r.push_str(String::from("| `string_substr`       | `fn(s: String, start: i64, len: i64) -> String`  | `[]`    |\n"));
    r.push_str(String::from("| `string_split`        | `fn(s: String, delim: String) -> Vec<String>`    | `[]`    |\n"));
    r.push_str(String::from("| `string_starts_with`  | `fn(s: String, prefix: String) -> i64`           | `[]`    |\n"));
    r.push_str(String::from("| `string_ends_with`    | `fn(s: String, suffix: String) -> i64`           | `[]`    |\n"));
    r.push_str(String::from("| `string_matches_literal_at` | `fn(s: String, pos: i64, literal: String literal) -> i64` | `[]` |\n"));
    r.push_str(String::from("| `string_trim`         | `fn(s: String) -> String`                        | `[]`    |\n"));
    r.push_str(String::from("| `string_to_upper`     | `fn(s: String) -> String`                        | `[]`    |\n"));
    r.push_str(String::from("| `string_to_lower`     | `fn(s: String) -> String`                        | `[]`    |\n"));
    r.push_str(String::from("| `string_replace`      | `fn(s: String, from: String, to: String) -> String` | `[]` |\n"));
    r.push_str(String::from("| `string_join`         | `fn(parts: Vec<String>, sep: String) -> String`  | `[]`    |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Conversion\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Formatting** uses two baselines; widen via `as` for narrower types:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `int_to_string`  | `fn(v: i64) -> String`                     | `[]`       |\n"));
    r.push_str(String::from("| `uint_to_string` | `fn(v: u64) -> String`                     | `[]`       |\n"));
    r.push_str(String::from("| `i64_to_string`  | `fn(v: i64) -> String` (alias of `int_to_string`) | `[]` |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let small: u8 = 42;\n"));
    r.push_str(String::from("print_str(uint_to_string(small as u64));  // widen then format\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Parsing** exposes a try-form for every integer width:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function       | Signature                                |\n"));
    r.push_str(String::from("|----------------|------------------------------------------|\n"));
    r.push_str(String::from("| `parse_i8`     | `fn(s: String) -> Option<i8>`            |\n"));
    r.push_str(String::from("| `parse_i16`    | `fn(s: String) -> Option<i16>`           |\n"));
    r.push_str(String::from("| `parse_i32`    | `fn(s: String) -> Option<i32>`           |\n"));
    r.push_str(String::from("| `parse_i64`    | `fn(s: String) -> Option<i64>` (also see `String.parse_i64()`) |\n"));
    r.push_str(String::from("| `parse_i128`   | `fn(s: String) -> Option<i128>`          |\n"));
    r.push_str(String::from("| `parse_u8`     | `fn(s: String) -> Option<u8>`            |\n"));
    r.push_str(String::from("| `parse_u16`    | `fn(s: String) -> Option<u16>`           |\n"));
    r.push_str(String::from("| `parse_u32`    | `fn(s: String) -> Option<u32>`           |\n"));
    r.push_str(String::from("| `parse_u64`    | `fn(s: String) -> Option<u64>` (also see `String.parse_u64()`) |\n"));
    r.push_str(String::from("| `parse_u128`   | `fn(s: String) -> Option<u128>`          |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Each `parse_X` returns `Option::None` for malformed input, empty strings, or\n"));
    r.push_str(String::from("values outside the target type's range.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Narrowing intrinsics** (per [Type Cast](#type-cast)): for every narrowing\n"));
    r.push_str(String::from("pair the compiler emits `<src>_to_<tgt>_try`, `<src>_to_<tgt>_wrap`, and\n"));
    r.push_str(String::from("`<src>_to_<tgt>_sat` free functions with the semantics described in that\n"));
    r.push_str(String::from("section.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Collections\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `vec_sort`       | `fn(v: Vec<i64>) -> Vec<i64>`              | `[]`       |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Time\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `time_unix`      | `fn() -> i64`                              | `[io]`     |\n"));
    r.push_str(String::from("| `time_unix_ms`   | `fn() -> i64`                              | `[io]`     |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### System\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `num_cpus`       | `fn() -> i64`                              | `[io]`     |\n"));
    r.push_str(String::from("| `memory_root_arena_bytes` | `fn() -> u64`                    | `[io]`     |\n"));
    r.push_str(String::from("| `memory_peak_bytes` | `fn() -> u64`                           | `[io]`     |\n"));
    r.push_str(String::from("| `memory_alloc_count_since_start` | `fn() -> u64`              | `[io]`     |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`num_cpus()` returns the number of available logical CPUs (from `std::thread::available_parallelism`), or `1` if the query fails. Used to size worker pools (e.g. the default `--verify-jobs` value).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`memory_root_arena_bytes()` returns the current bytes retained by root-region arena chunks. `memory_peak_bytes()` returns the peak live bytes retained by all open arena chunks since process start. `memory_alloc_count_since_start()` returns the number of successful Vow arena allocation requests since process start. These queries do not allocate; they are effectful because they observe runtime process state.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Encoding\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `hex_encode`     | `fn(data: Vec<u8>) -> String`              | `[]`       |\n"));
    r.push_str(String::from("| `hex_decode`     | `fn(s: String) -> Vec<u8>`                 | `[]`       |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Input\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function         | Signature                                  | Effects    |\n"));
    r.push_str(String::from("|------------------|--------------------------------------------|------------|\n"));
    r.push_str(String::from("| `args`           | `fn() -> Vec<String>`                      | `[read]`   |\n"));
    r.push_str(String::from("| `stdin_read`     | `fn() -> String`                           | `[read]`   |\n"));
    r.push_str(String::from("| `stdin_read_line`| `fn() -> String`                           | `[read]`   |\n"));
    r.push_str(String::from("| `stdin_ready`    | `fn() -> bool`                             | `[read]`   |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("#### Process Management\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Function              | Signature                                        | Effects |\n"));
    r.push_str(String::from("|-----------------------|--------------------------------------------------|---------|\n"));
    r.push_str(String::from("| `process_exit`        | `fn(code: i64) -> !`                             | `[io]`  |\n"));
    r.push_str(String::from("| `process_run`         | `fn(cmd: String, args: Vec<String>) -> i64`      | `[io]`  |\n"));
    r.push_str(String::from("| `process_get_stdout`  | `fn() -> String`                                 | `[io]`  |\n"));
    r.push_str(String::from("| `process_get_stderr`  | `fn() -> String`                                 | `[io]`  |\n"));
    r.push_str(String::from("| `process_start`       | `fn(cmd: String, args: Vec<String>) -> i64`      | `[io]`  |\n"));
    r.push_str(String::from("| `process_wait`        | `fn(pid: i64) -> i64`                            | `[io]`  |\n"));
    r.push_str(String::from("| `process_wait_timeout`| `fn(pid: i64, timeout_ms: i64) -> i64`           | `[io]`  |\n"));
    r.push_str(String::from("| `process_kill`        | `fn(pid: i64) -> i64`                             | `[io]`  |\n"));
    r.push_str(String::from("| `process_stdout_for`  | `fn(pid: i64) -> String`                         | `[io]`  |\n"));
    r.push_str(String::from("| `process_stderr_for`  | `fn(pid: i64) -> String`                         | `[io]`  |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`args` semantics:** `args()` returns all process arguments including the program name at index 0 (matching C `argv` and Rust `std::env::args()` conventions). For `./my_program foo bar`, `args()` returns `[\"./my_program\", \"foo\", \"bar\"]`. Use `args[1]` onward for user-supplied arguments. The Vec is empty only if the OS provides no arguments (unusual). Returns an empty String element if an argument is empty (`\"\"`). Non-UTF-8 arguments are included as-is (byte content preserved).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`fs_read` semantics:** `fs_read(path)` opens the file at `path`, reads its entire contents, and returns a String. Returns `\"\"` (empty String) on any error (file not found, permission denied, I/O error, non-UTF-8 path). Does not block on regular files. Callers should check `result.len() == 0` to detect failure.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Streaming file input:** `fs_open(path)` opens a file for incremental reading and returns a positive handle, or `-1` on path/open error. `fs_read_line(handle)` reads one line from the current cursor and returns it as a String, including the trailing newline when present. It returns `\"\"` at EOF, for an invalid handle, or after a read error. A blank line is returned as `\"\\n\"`, so newline-delimited callers can distinguish a real blank line from EOF by content. After `fs_read_line(handle)` returns `\"\"`, call `fs_status(handle)` to distinguish EOF from error: `0` means the handle is open with no EOF/error state, `1` means EOF, and `-1` means invalid handle or read error. `fs_status(handle)` reports the result of the most recent `fs_read_line(handle)` call on that open handle; read it immediately after a `\"\"` return because later reads may update it. `fs_close(handle)` releases the handle and returns `0` on success or `-1` for an invalid/already-closed handle. Long-running programs must close handles they no longer need. All streaming handle operations use the `[read]` effect, including `fs_close`, because closing a read handle releases read-stream state and does not mutate filesystem contents. The current runtime stores streaming handles in one process-global table, and `fs_read_line` holds that table lock while it reads the next line. This keeps the API simple for single-stream file processing, but it is not intended for latency-sensitive concurrent reads from multiple slow handles.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Filesystem return values:** `fs_write`, `fs_mkdir`, `fs_remove`, `fs_remove_dir`, and `fs_rename` return `i64`: 0 on success, non-zero on failure. `fs_open`, `fs_status`, and `fs_close` use the streaming status codes above. `fs_exists`, `fs_is_dir`, and `fs_is_symlink` are predicates: they return 1 for true, 0 for false. Errors (null pointer, invalid UTF-8) also return 0, so callers cannot distinguish \"false\" from \"error\". `fs_is_symlink` uses `lstat`-equivalent semantics: a symlink reports 1 even when its target is a regular file or directory.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`string_starts_with` / `string_ends_with` / `string_matches_literal_at` return values:** Return `i64`: 1 if true, 0 if false.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`string_matches_literal_at` literal operand:** The third argument must be written as a string literal at the call site. The compiler lowers that literal to static bytes plus an explicit byte length, so no temporary `String` allocation is created and embedded NUL bytes are preserved. Passing a variable or computed `String` as the third argument is a type-check error (`StaticLiteralRequired`). Use `string_starts_with`, `string_ends_with`, or `String` methods when the needle must be dynamic.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`process_run` vs `process_start`:** `process_run(cmd, args)` runs a subprocess synchronously and returns its exit code. After it returns, `process_get_stdout()` and `process_get_stderr()` retrieve the captured output of the most recent `process_run` call. `process_start(cmd, args)` launches a subprocess asynchronously and returns a process ID. Use `process_wait(pid)` to wait for completion and get the exit code, and `process_stdout_for(pid)` / `process_stderr_for(pid)` to retrieve output.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`process_wait_timeout`:** `process_wait_timeout(pid, timeout_ms)` polls a process started with `process_start` until it exits or the timeout (in milliseconds) elapses. Returns the exit code on completion, `-1` on error, or `-2` on timeout. After a timeout, the process is still running; use `process_kill(pid)` to terminate it.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`process_kill`:** `process_kill(pid)` sends a kill signal to a running process and waits for it to exit. Returns 0 on success, -1 on error. No-op (returns 0) if the process has already completed.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`stdin_read` vs `stdin_read_line`:** `stdin_read()` reads the entire stdin stream into a single String (unbounded memory). `stdin_read_line()` reads one line at a time, including the trailing newline. Returns `\"\"` (empty string) at EOF. The returned String is runtime scratch storage valid until the next `stdin_read_line()` call. Process each line before reading the next one for bounded memory; use `pin_to_root(line)` before the next read when a line must be stored, returned, passed to a function that may store it, mutated, or otherwise retained. The direct scratch line is read-only. The scratch buffer keeps the largest line capacity seen so far, so memory is bounded by maximum line length rather than total input, but one very large line can retain that capacity for the process lifetime.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let lines: Vec<String> = Vec::new();\n"));
    r.push_str(String::from("let mut line: String = stdin_read_line();\n"));
    r.push_str(String::from("while str_len(line) > 0 {\n"));
    r.push_str(String::from("    // Without pin_to_root, lines.push(line) would store the scratch alias, not a copy.\n"));
    r.push_str(String::from("    lines.push(pin_to_root(line));\n"));
    r.push_str(String::from("    line = stdin_read_line();\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("let mut line: String = stdin_read_line();\n"));
    r.push_str(String::from("while str_len(line) > 0 {\n"));
    r.push_str(String::from("    // process line (has trailing \\n)\n"));
    r.push_str(String::from("    line = stdin_read_line();\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**`stdin_ready`:** `stdin_ready()` returns `true` if `stdin_read_line()` would return immediately without blocking, `false` otherwise. Uses a non-blocking poll with zero timeout. Use this in computation loops that must remain responsive to external input:\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```vow\n"));
    r.push_str(String::from("while !stdin_ready() && depth < max_depth {\n"));
    r.push_str(String::from("    // continue searching\n"));
    r.push_str(String::from("    depth = depth + 1;\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("if stdin_ready() {\n"));
    r.push_str(String::from("    let cmd: String = stdin_read_line();\n"));
    r.push_str(String::from("    // handle command\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Canonical Form\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("The canonical printer normalizes source: `parse → print → parse` is idempotent. Effects are sorted alphabetically, indentation uses 4 spaces, trailing expressions omit semicolons.\n"));
    r.push_str(String::from("\n"));
    r
}

fn skill_support_content_1() -> String {
    let r: String = String::from("# Vow CLI Reference\n");
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Commands\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow build` (default)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Compile source to native executable. Verifies contracts by default.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow build [OPTIONS] <source.vow>\n"));
    r.push_str(String::from("vow [OPTIONS] <source.vow>          # legacy (equivalent)\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Options:**\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag              | Default     | Description                                |\n"));
    r.push_str(String::from("|-------------------|-------------|--------------------------------------------|\n"));
    r.push_str(String::from("| `-o, --output`    | `build/<stem>` | Output executable path                  |\n"));
    r.push_str(String::from("| `--mode <debug\\|release\\|profile\\|sanitize>` | `release` | Build mode: debug inserts runtime vow checks, profile inserts call counters and prints report on normal exit, sanitize adds debug checks + Vec provenance tracking |\n"));
    r.push_str(String::from("| `--no-verify`     | (off)       | Skip ESBMC static verification            |\n"));
    r.push_str(String::from("| `--dump-ir`       | (off)       | Print IR text to stdout and exit (no JSON output, no codegen) |\n"));
    r.push_str(String::from("| `--debug-trace <off\\|calls\\|full>` | `off` | Emit JSON trace lines to stderr at runtime |\n"));
    r.push_str(String::from("| `--no-cache`    | (off)       | Disable verification result caching, and (for `--no-verify` builds) the compile-object cache. See \"Compile-object cache behavior\" below |\n"));
    r.push_str(String::from("| `--max-k-step <N>` | `50`     | ESBMC incremental BMC max iterations          |\n"));
    r.push_str(String::from("| `--solver <boolector\\|z3\\|bitwuzla\\|auto>` | `auto` | ESBMC SMT solver; auto selects per-function via heuristic |\n"));
    r.push_str(String::from("| `--encoding <bv\\|ir\\|auto>` | `auto` | ESBMC encoding mode: bv (bit-vector) or ir (integer/real arithmetic); ir requires z3 |\n"));
    r.push_str(String::from("| `--timeout <N>` | `300` (or `30` when `--encoding` is `auto`) | ESBMC per-function timeout in seconds. Under `--encoding auto`, a 30s default is applied so the BV-timeout fallback to `--encoding ir --solver z3` can trigger when bit-vector solving takes too long. With explicit encodings, a 300s safety watchdog bounds the run; explicit `--timeout` overrides both. `--timeout 0` is honoured as an immediate watchdog kill |\n"));
    r.push_str(String::from("| `--verify-jobs <N>` | `num_cpus/2` | Max concurrent ESBMC verification jobs |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Compile-object cache behavior.** The on-disk compile-object cache (`$VOW_CACHE_DIR` or `~/.cache/vow/`, where each entry is a `<key>.o` artifact keyed by a content hash of all dependencies, mode, and trace settings) is automatically disabled whenever ESBMC verification is active. This guarantees the linked binary always comes from the same codegen run whose IR was verified, closing the integrity gap where a stale or attacker-supplied `.o` could be linked against freshly-verified IR. Concretely the cache only activates on `vow build --no-verify` invocations; it is bypassed on the default `vow build` path. `--no-cache` additionally disables the cache for `--no-verify` builds.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow verify`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Verify contracts only -- no executable output. Emits the same JSON format as `vow build` but `executable` is always `null`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow verify [OPTIONS] <source.vow>\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Options:**\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag              | Default     | Description                                |\n"));
    r.push_str(String::from("|-------------------|-------------|--------------------------------------------|\n"));
    r.push_str(String::from("| `--no-cache`      | (off)       | Disable verification result caching        |\n"));
    r.push_str(String::from("| `--max-k-step <N>` | `50`       | ESBMC incremental BMC max iterations       |\n"));
    r.push_str(String::from("| `--solver <boolector\\|z3\\|bitwuzla\\|auto>` | `auto` | ESBMC SMT solver; auto selects per-function via heuristic |\n"));
    r.push_str(String::from("| `--encoding <bv\\|ir\\|auto>` | `auto` | ESBMC encoding mode: bv (bit-vector) or ir (integer/real arithmetic); ir requires z3 |\n"));
    r.push_str(String::from("| `--timeout <N>` | `300` (or `30` when `--encoding` is `auto`) | ESBMC per-function timeout in seconds. Under `--encoding auto`, a 30s default is applied so the BV-timeout fallback to `--encoding ir --solver z3` can trigger when bit-vector solving takes too long. With explicit encodings, a 300s safety watchdog bounds the run; explicit `--timeout` overrides both. `--timeout 0` is honoured as an immediate watchdog kill |\n"));
    r.push_str(String::from("| `--verify-jobs <N>` | `num_cpus/2` | Max concurrent ESBMC verification jobs |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow contracts`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("List all contracts (requires, ensures, invariant) in a program. Runs frontend only by default (no codegen, no verification).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow contracts [OPTIONS] <source.vow>\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Options:**\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag              | Default     | Description                                |\n"));
    r.push_str(String::from("|-------------------|-------------|--------------------------------------------|\n"));
    r.push_str(String::from("| `--verify`        | (off)       | Run ESBMC verification and report per-contract status |\n"));
    r.push_str(String::from("| `--no-cache`      | (off)       | Disable verification result caching        |\n"));
    r.push_str(String::from("| `--max-k-step <N>` | `50`       | ESBMC incremental BMC max iterations       |\n"));
    r.push_str(String::from("| `--solver <boolector\\|z3\\|bitwuzla\\|auto>` | `auto` | ESBMC SMT solver (with --verify)           |\n"));
    r.push_str(String::from("| `--encoding <bv\\|ir\\|auto>` | `auto` | ESBMC encoding mode (with --verify); ir requires z3 |\n"));
    r.push_str(String::from("| `--verify-jobs <N>` | `num_cpus/2` | Accepted for CLI parity with build/verify/test; currently a no-op (the contracts verifier is serial) |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Exit code.** With `--verify`, `vow contracts` fails closed exactly like `vow build --verify` and `vow verify`: it exits **1** if any contract's `status` is not proven -- i.e. any `failed`, `timeout`, `unknown`, `error`, `skipped`, or `vacuous` -- and **0** only when every contract is `proven`/`proven-ir`. Without `--verify` every contract is `not_verified` and the command exits 0. (This is independent of the static `quality` classification, which never affects the exit code.)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("When `--verify` is requested but ESBMC is not installed, the command still emits the full contracts-result JSON schema with every entry's `status` set to `error` and exits with code 1 (fail-closed). Install ESBMC, or omit `--verify`, to obtain proven/failed/unknown statuses.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow skill`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Generate or install the Claude Code skill document for the current compiler version. The skill is embedded in the compiler binary, ensuring the documentation always matches the installed toolchain.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow skill              # print skill document to stdout (default: print)\n"));
    r.push_str(String::from("vow skill print        # print concise Claude Code SKILL.md entrypoint\n"));
    r.push_str(String::from("vow skill print --bundle  # print self-contained bundle for raw API harnesses\n"));
    r.push_str(String::from("vow skill install      # prompt for local or global install target\n"));
    r.push_str(String::from("vow skill install --local   # install to ./.claude/skills/vow/\n"));
    r.push_str(String::from("vow skill install --global  # install to $HOME/.claude/skills/vow/ on Linux\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`print` writes the concise installed `SKILL.md` entrypoint (with YAML frontmatter) to stdout. `print --bundle` writes a complete self-contained skill document to stdout for non–Claude Code harnesses that cannot load supporting files.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`install` writes `SKILL.md` plus supporting files under `reference/`, `examples/`, and `schemas/`. Claude Code discovers the skill from the `.claude/skills/` directory and uses the frontmatter description/`when_to_use` metadata to load it for `.vow` file work as well as creation and verification-debugging prompts before a `.vow` file exists.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("When no scope flag is provided, `install` prompts on stderr for local (`./.claude`) or global (`$HOME/.claude`) installation. Scripts and agents should pass `--local` or `--global` explicitly. `--local` requires the current directory to contain both `.git` and `.claude/`; otherwise it exits with an error and writes nothing. `--global` installs under `$HOME/.claude/skills/vow/` and fails if `$HOME` is unset or empty.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Auto-install on build.** The first time `vow build` (or the legacy `vow <source.vow>` form) runs in a directory that already contains a `.claude/` subtree but no `.claude/skills/vow/SKILL.md`, the compiler installs the skill silently. This bootstraps Claude Code projects without requiring an explicit `vow skill install`. Unlike explicit `--local`, auto-install only requires `.claude/`; it does not require the directory to be a git checkout. Auto-install is skipped when `.claude/` does not exist (so it never pollutes non–Claude Code projects) and when the skill file is already present (so user edits are never overwritten). Auto-install never fails the build.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow test`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Discover, compile, run, and report on Vow test files. Tests are normal `.vow` programs with `main() -> i32` -- no test-specific syntax.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow test [OPTIONS] [<path>]\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Options:**\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag              | Default     | Description                                |\n"));
    r.push_str(String::from("|-------------------|-------------|--------------------------------------------|\n"));
    r.push_str(String::from("| `<path>`          | `.`         | Directory to scan or single `.vow` file    |\n"));
    r.push_str(String::from("| `--verify`        | (off)       | Run ESBMC verification on test files       |\n"));
    r.push_str(String::from("| `--filter <pat>`  | (none)      | Only run tests whose file stem contains pat |\n"));
    r.push_str(String::from("| `--module-root <path>` | (auto)  | Resolve `use` declarations against `<path>`. Defaults to the scan path when it's a directory, otherwise the entry file's parent directory. |\n"));
    r.push_str(String::from("| `--mode debug`    | (default)   | Insert runtime vow checks                 |\n"));
    r.push_str(String::from("| `--mode release`  | `debug`     | Omit all vow checks for performance       |\n"));
    r.push_str(String::from("| `--timeout <ms>`  | `30000`     | Per-test execution timeout in milliseconds |\n"));
    r.push_str(String::from("| `--max-k-step <N>` | `50`       | ESBMC incremental BMC max iterations (with --verify) |\n"));
    r.push_str(String::from("| `--verify-jobs <N>` | `num_cpus/2` | Max concurrent ESBMC verification jobs (with --verify) |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Test discovery: files matching `test_*.vow` or `*_test.vow` under the given directory **and its subdirectories**, sorted alphabetically. Each test must contain `main() -> i32` returning 0 on success.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Module resolution for directory scans.** When `<path>` is a directory, every discovered test resolves its `use` declarations against `<path>` rather than the test file's own parent directory. This lets internal-unit tests live in a subdirectory like `compiler/tests/test_region.vow` and still `use region;` to import the module under test (which lives at `compiler/region.vow`). Single-file invocations (`vow test path/to/test_foo.vow`) keep the default behaviour of resolving `use` against the file's parent directory.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Test Output JSON:**\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"status\": \"TestsPassed\",\n"));
    r.push_str(String::from("  \"total\": 3,\n"));
    r.push_str(String::from("  \"passed\": 3,\n"));
    r.push_str(String::from("  \"failed\": 0,\n"));
    r.push_str(String::from("  \"skipped\": 0,\n"));
    r.push_str(String::from("  \"tests\": [\n"));
    r.push_str(String::from("    {\n"));
    r.push_str(String::from("      \"file\": \"compiler/test_arith.vow\",\n"));
    r.push_str(String::from("      \"name\": \"test_arith\",\n"));
    r.push_str(String::from("      \"status\": \"passed\",\n"));
    r.push_str(String::from("      \"exit_code\": 0,\n"));
    r.push_str(String::from("      \"stdout\": \"7\",\n"));
    r.push_str(String::from("      \"stderr\": \"\",\n"));
    r.push_str(String::from("      \"duration_ms\": 72,\n"));
    r.push_str(String::from("      \"diagnostics\": [],\n"));
    r.push_str(String::from("      \"counterexamples\": []\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ],\n"));
    r.push_str(String::from("  \"contract_density\": {\n"));
    r.push_str(String::from("    \"functions_total\": 1,\n"));
    r.push_str(String::from("    \"functions_with_vows\": 0,\n"));
    r.push_str(String::from("    \"density_pct\": 0.0\n"));
    r.push_str(String::from("  }\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Status Field   | Meaning                                           |\n"));
    r.push_str(String::from("|----------------|---------------------------------------------------|\n"));
    r.push_str(String::from("| `TestsPassed`  | All tests passed                                  |\n"));
    r.push_str(String::from("| `TestsFailed`  | One or more tests failed                          |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Per-test status: `passed`, `failed`, `timeout`, `compile_error`, `verify_failed`, `contract_skipped`, `skipped`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow decl`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emit declaration file output only.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow decl [OPTIONS] <source.vow>\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Options:**\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag              | Default     | Description                                |\n"));
    r.push_str(String::from("|-------------------|-------------|--------------------------------------------|\n"));
    r.push_str(String::from("| `-o, --output`    | `<source>.vow.d` | Output declaration file path          |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow mutants` (self-hosted only)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Run mutation testing on a Vow source tree. Implemented in the self-hosted compiler only; the Rust bootstrap compiler emits an error pointing the user to `build/vowc`. See `docs/mutants.md` for full details on output schema, mutation kinds, skip-list, and known limitations.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vowc mutants version\n"));
    r.push_str(String::from("vowc mutants list  [--root DIR] [--shard X/Y]\n"));
    r.push_str(String::from("vowc mutants run   [--root DIR] [--shard X/Y]\n"));
    r.push_str(String::from("                   [--tier1-cmd 'cmd'] [--tier2-cmd 'cmd']\n"));
    r.push_str(String::from("                   [--tier1-timeout-secs N] [--tier2-timeout-secs N]\n"));
    r.push_str(String::from("                   [--tier2-budget-secs N]\n"));
    r.push_str(String::from("                   [--workdir DIR] [--output-dir DIR] [--force-unlock]\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag | Default | Notes |\n"));
    r.push_str(String::from("|---|---|---|\n"));
    r.push_str(String::from("| `--root` | `compiler` | Directory whose `*.vow` files are mutated. `test_*.vow` files are excluded. |\n"));
    r.push_str(String::from("| `--shard X/Y` | `0/1` | Round-robin split of the deterministic mutant ID space. Mutant `id` is selected iff `id % Y == X`. |\n"));
    r.push_str(String::from("| `--tier1-cmd` | `scripts/bootstrap.sh --skip-cargo` | Fast oracle. Anything but exit 0 = caught at Tier 1. |\n"));
    r.push_str(String::from("| `--tier2-cmd` | `scripts/full_test.sh` | Full oracle. Only run on Tier-1 survivors. |\n"));
    r.push_str(String::from("| `--tier1-timeout-secs` | `180` | Per-mutant Tier-1 wall-clock cap. |\n"));
    r.push_str(String::from("| `--tier2-timeout-secs` | `3600` | Per-mutant Tier-2 wall-clock cap. |\n"));
    r.push_str(String::from("| `--tier2-budget-secs` | `7200` | Per-shard total Tier-2 budget. Once exhausted, surviving Tier-1 mutants are emitted with `status:\"unrun\"`. |\n"));
    r.push_str(String::from("| `--workdir` | `/tmp/vow-mutants-<ms>` | Path of the throwaway `git worktree` used for all mutations. |\n"));
    r.push_str(String::from("| `--output-dir` | `mutants.out` | Directory for `mutants.json`, `outcomes.json`, status text files, `diff/`, `logs/`. |\n"));
    r.push_str(String::from("| `--force-unlock` | off | Remove a stale `output_dir/.lock` before starting. |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Output schemas: see `docs/spec/schemas/mutants-result.schema.json`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow --help`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow --help` is agent-first. It emits versioned JSON capability data for the tool, command set,\n"));
    r.push_str(String::from("language surface, result schemas, and implementation status. `--help --human` exists only as a\n"));
    r.push_str(String::from("legacy compatibility mode and is not the canonical interface.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow --help               # versioned JSON tool-help protocol\n"));
    r.push_str(String::from("vow --help --human       # legacy compatibility text\n"));
    r.push_str(String::from("vow build --help         # same JSON (works on all subcommands)\n"));
    r.push_str(String::from("vow verify --help --human  # same legacy text (works on all subcommands)\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Exit Codes\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Code | Meaning                                                                            |\n"));
    r.push_str(String::from("|------|------------------------------------------------------------------------------------|\n"));
    r.push_str(String::from("| `0`  | Success (`Verified` or `Unverified`)                                               |\n"));
    r.push_str(String::from("| `1`  | Failure (`CompileFailed`, `VerifyFailed`, or `Skipped`)                            |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow build` and `vow verify` both fail closed on `Skipped`: if ESBMC was asked to verify a vowed\n"));
    r.push_str(String::from("function but the verifier could not model the function body, the contract was not statically\n"));
    r.push_str(String::from("proved, so the run exits non-zero. Use `--no-verify` if you genuinely want to skip verification --\n"));
    r.push_str(String::from("that path produces `Unverified` (exit 0).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Build Output JSON\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow build` and `vow verify` emit a single JSON object to stdout. Schema: [`schemas/build-result.schema.json`](schemas/build-result.schema.json).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Note:** `--dump-ir` suppresses JSON output -- only IR text is printed.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Status Values\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Status          | Meaning                                     |\n"));
    r.push_str(String::from("|-----------------|---------------------------------------------|\n"));
    r.push_str(String::from("| `Verified`      | Compiled + every vowed function's contract was statically proved by ESBMC. |\n"));
    r.push_str(String::from("| `Unverified`    | Compiled but ESBMC was not invoked (e.g. `--no-verify`, `--dump-ir`). Exit 0. |\n"));
    r.push_str(String::from("| `Skipped`       | ESBMC was invoked but at least one vowed function could not be modelled (e.g. body uses `RegionAlloc`, `FieldSet`, `Linear*`, `Load`/`Store`, `RemF*`, or has effects). Each such function appears as a `VerificationSkipped` *Warning* in `diagnostics[]`. Their contracts are runtime-checked under `--mode debug` but were not statically proved; the run fails closed with exit 1. |\n"));
    r.push_str(String::from("| `CompileFailed` | Parse error, type error, module load error, or link failure |\n"));
    r.push_str(String::from("| `VerifyFailed`  | ESBMC produced a non-Verified outcome: a counterexample, timeout, `VERIFICATION UNKNOWN` (`verify_status: \"unknown\"`), tool error, the tool was not found, or the verifier worker thread crashed (`verify_status: \"panicked\"`). Inspect `counterexamples[]` (definitive failures) and `verify_status`/`verify_message` (soft failures) to distinguish. |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Verified Example\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"status\": \"Verified\",\n"));
    r.push_str(String::from("  \"executable\": \"examples/divide\",\n"));
    r.push_str(String::from("  \"diagnostics\": [],\n"));
    r.push_str(String::from("  \"counterexamples\": []\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### CompileFailed Example\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"status\": \"CompileFailed\",\n"));
    r.push_str(String::from("  \"executable\": null,\n"));
    r.push_str(String::from("  \"diagnostics\": [\n"));
    r.push_str(String::from("    {\n"));
