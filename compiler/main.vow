    r.push_str(String::from("\n"));
    r.push_str(String::from("Per-test status: `passed`, `failed`, `timeout`, `compile_error`, `verify_failed`, `contract_skipped`, `skipped`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow decl`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Emit declaration file output only.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow decl [OPTIONS] <source.vow>\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Options:**\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag              | Default     | Description                                |\n"));
    r.push_str(String::from("|-------------------|-------------|--------------------------------------------|\n"));
    r.push_str(String::from("| `-o, --output`    | `<source>.vow.d` | Output declaration file path          |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow mutants` (self-hosted only)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Run mutation testing on a Vow source tree. Implemented in the self-hosted compiler only; the Rust bootstrap compiler emits an error pointing the user to `build/vowc`. See `docs/mutants.md` for full details on output schema, mutation kinds, skip-list, and known limitations.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vowc mutants version\n"));
    r.push_str(String::from("vowc mutants list  [--root DIR] [--shard X/Y]\n"));
    r.push_str(String::from("vowc mutants run   [--root DIR] [--shard X/Y]\n"));
    r.push_str(String::from("                   [--tier1-cmd 'cmd'] [--tier2-cmd 'cmd']\n"));
    r.push_str(String::from("                   [--tier1-timeout-secs N] [--tier2-timeout-secs N]\n"));
    r.push_str(String::from("                   [--tier2-budget-secs N]\n"));
    r.push_str(String::from("                   [--workdir DIR] [--output-dir DIR] [--force-unlock]\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Flag | Default | Notes |\n"));
    r.push_str(String::from("|---|---|---|\n"));
    r.push_str(String::from("| `--root` | `compiler` | Directory whose `*.vow` files are mutated. `test_*.vow` files are excluded. |\n"));
    r.push_str(String::from("| `--shard X/Y` | `0/1` | Round-robin split of the deterministic mutant ID space. Mutant `id` is selected iff `id % Y == X`. |\n"));
    r.push_str(String::from("| `--tier1-cmd` | `scripts/bootstrap.sh --skip-cargo` | Fast oracle. Anything but exit 0 = caught at Tier 1. |\n"));
    r.push_str(String::from("| `--tier2-cmd` | `scripts/full_test.sh` | Full oracle. Only run on Tier-1 survivors. |\n"));
    r.push_str(String::from("| `--tier1-timeout-secs` | `180` | Per-mutant Tier-1 wall-clock cap. |\n"));
    r.push_str(String::from("| `--tier2-timeout-secs` | `3600` | Per-mutant Tier-2 wall-clock cap. |\n"));
    r.push_str(String::from("| `--tier2-budget-secs` | `7200` | Per-shard total Tier-2 budget. Once exhausted, surviving Tier-1 mutants are emitted with `status:\"unrun\"`. |\n"));
    r.push_str(String::from("| `--workdir` | `/tmp/vow-mutants-<ms>` | Path of the throwaway `git worktree` used for all mutations. |\n"));
    r.push_str(String::from("| `--output-dir` | `mutants.out` | Directory for `mutants.json`, `outcomes.json`, status text files, `diff/`, `logs/`. |\n"));
    r.push_str(String::from("| `--force-unlock` | off | Remove a stale `output_dir/.lock` before starting. |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("Output schemas: see `docs/spec/schemas/mutants-result.schema.json`.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### `vow --help`\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow --help` is agent-first. It emits versioned JSON capability data for the tool, command set,\n"));
    r.push_str(String::from("language surface, result schemas, and implementation status. `--help --human` exists only as a\n"));
    r.push_str(String::from("legacy compatibility mode and is not the canonical interface.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("vow --help               # versioned JSON tool-help protocol\n"));
    r.push_str(String::from("vow --help --human       # legacy compatibility text\n"));
    r.push_str(String::from("vow build --help         # same JSON (works on all subcommands)\n"));
    r.push_str(String::from("vow verify --help --human  # same legacy text (works on all subcommands)\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Exit Codes\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Code | Meaning                                                                            |\n"));
    r.push_str(String::from("|------|------------------------------------------------------------------------------------|\n"));
    r.push_str(String::from("| `0`  | Success (`Verified` or `Unverified`)                                               |\n"));
    r.push_str(String::from("| `1`  | Failure (`CompileFailed`, `VerifyFailed`, or `Skipped`)                            |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow build` and `vow verify` both fail closed on `Skipped`: if ESBMC was asked to verify a vowed\n"));
    r.push_str(String::from("function but the verifier could not model the function body, the contract was not statically\n"));
    r.push_str(String::from("proved, so the run exits non-zero. Use `--no-verify` if you genuinely want to skip verification --\n"));
    r.push_str(String::from("that path produces `Unverified` (exit 0).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Build Output JSON\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow build` and `vow verify` emit a single JSON object to stdout. Schema: [`schemas/build-result.schema.json`](schemas/build-result.schema.json).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("**Note:** `--dump-ir` suppresses JSON output -- only IR text is printed.\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Status Values\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Status          | Meaning                                     |\n"));
    r.push_str(String::from("|-----------------|---------------------------------------------|\n"));
    r.push_str(String::from("| `Verified`      | Compiled + every vowed function's contract was statically proved by ESBMC. |\n"));
    r.push_str(String::from("| `Unverified`    | Compiled but ESBMC was not invoked (e.g. `--no-verify`, `--dump-ir`). Exit 0. |\n"));
    r.push_str(String::from("| `Skipped`       | ESBMC was invoked but at least one vowed function could not be modelled (e.g. body uses `RegionAlloc`, `FieldSet`, `Linear*`, `Load`/`Store`, `RemF*`, or has effects). Each such function appears as a `VerificationSkipped` *Warning* in `diagnostics[]`. Their contracts are runtime-checked under `--mode debug` but were not statically proved; the run fails closed with exit 1. |\n"));
    r.push_str(String::from("| `CompileFailed` | Parse error, type error, module load error, or link failure |\n"));
    r.push_str(String::from("| `VerifyFailed`  | ESBMC produced a non-Verified outcome: a counterexample, timeout, `VERIFICATION UNKNOWN` (`verify_status: \"unknown\"`), tool error, the tool was not found, or the verifier worker thread crashed (`verify_status: \"panicked\"`). Inspect `counterexamples[]` (definitive failures) and `verify_status`/`verify_message` (soft failures) to distinguish. |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Verified Example\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"status\": \"Verified\",\n"));
    r.push_str(String::from("  \"executable\": \"examples/divide\",\n"));
    r.push_str(String::from("  \"diagnostics\": [],\n"));
    r.push_str(String::from("  \"counterexamples\": []\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### CompileFailed Example\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
