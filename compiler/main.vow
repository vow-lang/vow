    r.push_str(String::from("          \"description\": \"Emit JSON trace lines to stderr at runtime (default: off)\",\n"));
    r.push_str(String::from("          \"long\": \"--debug-trace\",\n"));
    r.push_str(String::from("          \"value_name\": \"trace\",\n"));
    r.push_str(String::from("          \"value_kind\": \"enum\",\n"));
    r.push_str(String::from("          \"values\": [\n"));
    r.push_str(String::from("            \"off\",\n"));
    r.push_str(String::from("            \"calls\",\n"));
    r.push_str(String::from("            \"full\"\n"));
    r.push_str(String::from("          ],\n"));
    r.push_str(String::from("          \"default\": \"off\"\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        {\n"));
    r.push_str(String::from("          \"form\": \"--no-cache\",\n"));
    r.push_str(String::from("          \"description\": \"Disable verification result caching, and (for --no-verify builds) the compile-object cache. See \\\"Compile-object cache behavior\\\" below\",\n"));
    r.push_str(String::from("          \"long\": \"--no-cache\",\n"));
    r.push_str(String::from("          \"value_kind\": \"flag\"\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        {\n"));
    r.push_str(String::from("          \"form\": \"--max-k-step <N>\",\n"));
    r.push_str(String::from("          \"description\": \"ESBMC incremental BMC max iterations (default: 50)\",\n"));
    r.push_str(String::from("          \"long\": \"--max-k-step\",\n"));
    r.push_str(String::from("          \"value_name\": \"N\",\n"));
    r.push_str(String::from("          \"value_kind\": \"integer\",\n"));
    r.push_str(String::from("          \"default\": 50\n"));
    r.push_str(String::from("        },\n"));
    r.push_str(String::from("        {\n"));
    r.push_str(String::from("          \"form\": \"--solver <boolector|z3|bitwuzla|auto>\",\n"));
    r.push_str(String::from("          \"description\": \"ESBMC SMT solver; auto selects per-function via heuristic (default: auto)\",\n"));
    r.push_str(String::from("          \"long\": \"--solver\",\n"));
    r.push_str(String::from("          \"value_name\": \"boolector|z3|bitwuzla|auto\",\n"));
    r.push_str(String::from("          \"value_kind\": \"enum\",\n"));
    r.push_str(String::from("          \"values\": [\n"));
    r.push_str(String::from("            \"boolector\",\n"));
    r.push_str(String::from("            \"z3\",\n"));
    r.push_str(String::from("            \"bitwuzla\",\n"));
    r.push_str(String::from("            \"auto\"\n"));
    r.push_str(String::from("          ],\n"));
    r.push_str(String::from("          \"default\": \"auto\"\n"));
    r.push_str(String::from("        },\n"));
