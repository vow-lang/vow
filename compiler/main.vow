    r.push_str(String::from("        \"length\": 20\n"));
    r.push_str(String::from("      }\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ]\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Fields Reference\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("| Field              | Type                | When Present      | Description                               |\n"));
    r.push_str(String::from("|--------------------|---------------------|-------------------|-------------------------------------------|\n"));
    r.push_str(String::from("| `status`           | string              | Always            | One of the four status values             |\n"));
    r.push_str(String::from("| `executable`       | string \\| null      | Always            | Path to binary, null on compile failure or library module (no main) |\n"));
    r.push_str(String::from("| `diagnostics`      | array               | Always            | Compiler diagnostics (see schema)         |\n"));
    r.push_str(String::from("| `message`          | string              | CompileFailed     | Error category (\"parse error\", \"type error\", \"module load error\", or link error detail) |\n"));
    r.push_str(String::from("| `function`         | string              | VerifyFailed      | Function where verification failed        |\n"));
    r.push_str(String::from("| `counterexample`   | string              | VerifyFailed      | Legacy description string                 |\n"));
    r.push_str(String::from("| `counterexamples`  | array               | Always            | Structured counterexamples (see schema)   |\n"));
    r.push_str(String::from("| `verify_status`    | string              | On backend failure | `\"timeout\"`, `\"unknown\"`, `\"error\"`, `\"tool_not_found\"`, or `\"panicked\"` (verifier worker thread crashed -- no counterexample available) |\n"));
    r.push_str(String::from("| `verify_message`   | string              | On backend failure | ESBMC/backend error detail                |\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("## Contracts Output JSON\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("`vow contracts` emits a single JSON object to stdout. Schema: [`schemas/contracts-result.schema.json`](schemas/contracts-result.schema.json).\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Example (without --verify)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"contracts\": [\n"));
    r.push_str(String::from("    {\n"));
    r.push_str(String::from("      \"vow_id\": 0,\n"));
    r.push_str(String::from("      \"function\": \"divide\",\n"));
    r.push_str(String::from("      \"kind\": \"requires\",\n"));
    r.push_str(String::from("      \"description\": \"requires y != 0\",\n"));
    r.push_str(String::from("      \"blame\": \"Caller\",\n"));
    r.push_str(String::from("      \"source\": { \"file\": \"divide.vow\", \"offset\": 42 },\n"));
