    r.push_str(String::from("      },\n"));
    r.push_str(String::from("      \"description\": \"Runtime values of free variables in the predicate (optional, present when bindings exist)\"\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  },\n"));
