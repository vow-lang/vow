    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### Example (with --verify)\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"contracts\": [\n"));
    r.push_str(String::from("    {\n"));
