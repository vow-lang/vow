    r.push_str(String::from("      \"message\": \"function body has type `bool` but declared return type is `i32`\",\n"));
    r.push_str(String::from("      \"severity\": \"error\",\n"));
    r.push_str(String::from("      \"span\": {\n"));
    r.push_str(String::from("        \"file\": \"bad.vow\",\n"));
    r.push_str(String::from("        \"offset\": 25,\n"));
    r.push_str(String::from("        \"length\": 8\n"));
    r.push_str(String::from("      }\n"));
    r.push_str(String::from("    }\n"));
    r.push_str(String::from("  ],\n"));
    r.push_str(String::from("  \"message\": \"type error\",\n"));
    r.push_str(String::from("  \"counterexamples\": []\n"));
    r.push_str(String::from("}\n"));
    r.push_str(String::from("```\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("### VerifyFailed Example\n"));
    r.push_str(String::from("\n"));
    r.push_str(String::from("```json\n"));
    r.push_str(String::from("{\n"));
    r.push_str(String::from("  \"status\": \"VerifyFailed\",\n"));
    r.push_str(String::from("  \"executable\": \"examples/cegis_broken\",\n"));
    r.push_str(String::from("  \"diagnostics\": [],\n"));
    r.push_str(String::from("  \"function\": \"safe_sub\",\n"));
    r.push_str(String::from("  \"counterexample\": \"[Counterexample]\",\n"));
