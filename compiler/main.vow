    v.push(skill_support_content_11());
    v.push(skill_support_content_12());
    v
}
// GENERATE:SKILL_FULL:END

fn skill_install_dir(root: String) -> String {
    if root.len() == 0 {
        return String::from(".claude/skills/vow");
    }
    str3(root, String::from("/"), String::from(".claude/skills/vow"))
}

fn skill_parent_dir(path: String) -> String {
    let n: i64 = path.len();
    let mut last_slash: i64 = -1;
    let mut i: i64 = 0;
    while i < n {
        if path.byte_at(i) == 47 {
            last_slash = i;
        }
        i = i + 1;
    }
    if last_slash < 0 {
        return String::from("");
    }
    let parent: String = String::new();
    i = 0;
    while i < last_slash {
        parent.push_byte(path.byte_at(i));
        i = i + 1;
    }
    parent
}

fn install_skill_tree(root: String, emit_errors: bool) -> String [io, write] {
    let dir: String = skill_install_dir(root);
    let mk: i64 = fs_mkdir(dir);
    if mk < 0 {
        if emit_errors {
            eprintln_str(str2(String::from("vow skill install: cannot create "), dir));
        }
        return String::from("");
    }

    let path: String = str3(dir, String::from("/"), String::from("SKILL.md"));
    let wr: i64 = fs_write(path, skill_entrypoint());
    if wr < 0 {
        if emit_errors {
            eprintln_str(str2(String::from("vow skill install: cannot write "), path));
        }
        return String::from("");
    }

    let paths: Vec<String> = skill_support_paths();
    let contents: Vec<String> = skill_support_contents();
    let mut i: i64 = 0;
    while i < paths.len() {
        let support_path: String = str3(dir, String::from("/"), paths[i]);
        let support_parent: String = skill_parent_dir(support_path);
        if support_parent.len() > 0 {
            let parent_mk: i64 = fs_mkdir(support_parent);
            if parent_mk < 0 {
                if emit_errors {
                    eprintln_str(str2(String::from("vow skill install: cannot create "), support_parent));
                }
                return String::from("");
            }
        }
        let support_wr: i64 = fs_write(support_path, contents[i]);
        if support_wr < 0 {
            if emit_errors {
                eprintln_str(str2(String::from("vow skill install: cannot write "), support_path));
            }
            return String::from("");
        }
        i = i + 1;
    }

    path
}

// Self-hosted Vow has no getenv builtin, so read $HOME through sh.
// A shell failure is reported like an unset or empty HOME by the caller.
fn skill_home_dir() -> String [io] {
    let pargs: Vec<String> = Vec::new();
    pargs.push(String::from("-c"));
    pargs.push(String::from("printf %s \"$HOME\""));
    let rc: i64 = process_run(String::from("sh"), pargs);
    if rc != 0 {
        return String::from("");
    }
    process_get_stdout()
}

fn skill_install_root(local: bool, global: bool) -> String [io, read] {
    let use_local: bool = local;
    let use_global: bool = global;
    if use_local && use_global {
        eprintln_str("vow skill install: --local and --global are mutually exclusive");
        return String::from("");
    }
    if !use_local && !use_global {
        eprintln_str("Install Vow skill locally (./.claude) or globally (~/.claude)? [l/g]: ");
        let answer: String = string_to_lower(string_trim(stdin_read_line()));
        if answer == String::from("l") || answer == String::from("local") {
            use_local = true;
        } else if answer == String::from("g") || answer == String::from("global") {
            use_global = true;
        } else {
            eprintln_str("vow skill install: stdin closed or unrecognised answer; pass --local or --global");
            return String::from("");
        }
    }
    if use_local {
        if fs_is_dir(String::from(".claude")) != 1 {
            eprintln_str("vow skill install: --local requires a .claude/ directory in the current project");
            return String::from("");
        }
        if fs_exists(String::from(".git")) != 1 {
            eprintln_str("vow skill install: --local requires the current project to be a git checkout");
            return String::from("");
        }
        return String::from(".");
    }
    let home: String = skill_home_dir();
    if home.len() == 0 {
        eprintln_str("vow skill install: --global requires $HOME");
        return String::from("");
    }
    home
}

fn run_skill(argv: Vec<String>) -> i32 [io, read, write] {
    let do_install: bool = false;
    let do_bundle: bool = has_flag(argv, String::from("--bundle"));
    if argv.len() >= 3 {
        let action: String = argv[2];
        if action == String::from("install") {
            do_install = true;
        } else if action == String::from("print") {
            do_install = false;
        } else {
            eprintln_str(str3(String::from("vow skill: unknown action '"), action, String::from("' (expected 'print' or 'install')")));
            return 1;
        }
    }
    if do_install {
        if do_bundle {
            eprintln_str("vow skill install: --bundle is only valid with print");
            return 1;
        }
        let root: String = skill_install_root(has_flag(argv, String::from("--local")), has_flag(argv, String::from("--global")));
        if root.len() == 0 {
            return 1;
        }
        let path: String = install_skill_tree(root, true);
        if path.len() == 0 {
            return 1;
        }
        eprintln_str(str2(String::from("installed skill to "), path));
        return 0;
    }
    if do_bundle {
        print_str(skill_bundle());
    } else {
        print_str(skill_entrypoint());
    }
    0
}

fn maybe_auto_install_skill() [io, write] {
    if fs_is_dir(".claude") != 1 {
        return;
    }
    let target: String = ".claude/skills/vow/SKILL.md";
    if fs_exists(target) == 1 {
        return;
    }
    install_skill_tree(String::from(""), false);
}

fn vow_kind_from_desc(desc: String) -> String {
    if str_starts_with(desc, String::from("requires")) {
        return String::from("requires");
    }
    if str_starts_with(desc, String::from("ensures")) {
        return String::from("ensures");
    }
    if str_starts_with(desc, String::from("invariant")) {
        return String::from("invariant");
    }
    String::from("unknown")
}

// Static contract-quality classification of a clause by shape (no ESBMC).
// Mirrors classify_contract_quality in vow/src/main.rs. See
// docs/spec/contracts-methodology.md for the methodology.

fn cq_byte_is_alpha(b: i64) -> bool {
    (b >= 65 && b <= 90) || (b >= 97 && b <= 122)
}

fn cq_has_alpha(s: String) -> bool {
    let n: i64 = s.len();
    let mut i: i64 = 0;
    while i < n {
        if cq_byte_is_alpha(s.byte_at(i)) {
            return true;
        }
        i = i + 1;
    }
    false
}

fn cq_is_int_literal(s: String) -> bool {
    let t: String = str_trim(s);
    let n: i64 = t.len();
    if n == 0 {
        return false;
    }
    let mut i: i64 = 0;
    if t.byte_at(0) == 45 {
        if n == 1 {
            return false;
        }
        i = 1;
    }
    while i < n {
        let b: i64 = t.byte_at(i);
        if b < 48 || b > 57 {
            return false;
        }
        i = i + 1;
    }
    true
}

// Strip the leading requires/ensures/invariant keyword, leaving the predicate.
// clause descriptions are formatted as "{kind} {printed_expr}".
fn cq_predicate(desc: String) -> String {
    let sp: i64 = str_find_byte(desc, 32);
    if sp < 0 {
        return String::from("");
    }
    str_trim(str_substring(desc, sp + 1, desc.len()))
}

fn cq_side_has_ordering(s: String) -> bool {
    str_contains_byte(s, 60) || str_contains_byte(s, 62)
}

fn cq_weak_sides(lhs: String, rhs: String) -> bool {
    let l: String = str_trim(lhs);
    let r: String = str_trim(rhs);
    if cq_side_has_ordering(l) || cq_side_has_ordering(r) {
        return false;
    }
    let result_s: String = String::from("result");
    (l == result_s && cq_is_int_literal(r)) || (r == result_s && cq_is_int_literal(l))
}

// True for a single ordering comparison between `result` and an integer literal.
fn cq_is_weak_result_bound(pred: String) -> bool {
    if str_find_str(pred, String::from("&&")) >= 0 {
        return false;
    }
    if str_find_str(pred, String::from("||")) >= 0 {
        return false;
    }
    if str_find_str(pred, String::from("==")) >= 0 {
        return false;
    }
    if str_find_str(pred, String::from("!=")) >= 0 {
        return false;
    }
    if str_contains_byte(pred, 40) {
        return false;
    }
    let n: i64 = pred.len();
    let p_le: i64 = str_find_str(pred, String::from("<="));
    if p_le >= 0 {
        return cq_weak_sides(str_substring(pred, 0, p_le), str_substring(pred, p_le + 2, n));
    }
    let p_ge: i64 = str_find_str(pred, String::from(">="));
    if p_ge >= 0 {
        return cq_weak_sides(str_substring(pred, 0, p_ge), str_substring(pred, p_ge + 2, n));
    }
    let p_lt: i64 = str_find_byte(pred, 60);
    if p_lt >= 0 {
        return cq_weak_sides(str_substring(pred, 0, p_lt), str_substring(pred, p_lt + 1, n));
    }
    let p_gt: i64 = str_find_byte(pred, 62);
    if p_gt >= 0 {
        return cq_weak_sides(str_substring(pred, 0, p_gt), str_substring(pred, p_gt + 1, n));
    }
    false
}

fn cq_classify(kind: String, desc: String) -> String {
    let pred: String = cq_predicate(desc);
    if pred.len() == 0 {
        return String::from("tautological");
    }
    if pred == String::from("true") {
        return String::from("tautological");
    }
    if !cq_has_alpha(pred) {
        return String::from("tautological");
    }
    if kind == String::from("ensures") && cq_is_weak_result_bound(pred) {
        return String::from("weak");
    }
    String::from("substantive")
}

fn run_contracts(argv: Vec<String>) -> i32 [io] {
    let path: String = frontend_path_from_argv(argv, true);
    let fr: LoweredFrontend = frontend_lower_path(path);
    let checked: CheckedFrontend = fr.checked;
    let dctx: DiagCtx = checked.dctx;
    let n_errors: i64 = checked.n_errors;
    diag_ctx_print_all(dctx);
    if n_errors > 0 {
        diag_emit_verify_json(String::from("CompileFailed"), dctx, Vec::new());
        return 1;
    }
    let ir_mod: IrModule = fr.ir_mod;

    let do_verify: bool = has_flag(argv, "--verify");
    let use_cache: bool = !has_flag(argv, "--no-cache");
    let mks_str: String = get_flag_arg(argv, "--max-k-step");
    let max_k_step: String = {
        if mks_str.len() > 0 { mks_str }
        else { String::from("50") }
    };
    let mut solver: String = get_flag_arg(argv, "--solver");
    let encoding: String = get_flag_arg(argv, "--encoding");
    let timeout_secs: String = get_flag_arg(argv, "--timeout");
    if encoding == String::from("ir") {
        if solver == String::from("boolector") || solver == String::from("bitwuzla") {
            eprintln_str(String::from("error: --encoding ir requires --solver z3"));
            return 1;
        }
        if solver.len() == 0 || solver == String::from("auto") {
            solver = String::from("z3");
        }
    }
    let vec_max_c: i64 = VOW_VEC_MAX();
    let string_max_c: i64 = VOW_STRING_MAX();
    let hashmap_max_c: i64 = VOW_HASHMAP_MAX();
    let btreemap_max_c: i64 = VOW_BTREEMAP_MAX();
    // Accepted for CLI parity with build/verify/test; resolved via the same
    // path, then discarded because the contracts verify loop is serial.
    let _cjobs: i64 = resolve_verify_jobs(argv);

    // Collect per-contract entries into parallel arrays
    let e_vow_ids: Vec<i64> = Vec::new();
    let e_func_ids: Vec<i64> = Vec::new();
    let e_func_names: Vec<String> = Vec::new();
    let e_kinds: Vec<String> = Vec::new();
    let e_descs: Vec<String> = Vec::new();
    let e_blames: Vec<String> = Vec::new();
    let e_files: Vec<String> = Vec::new();
    let e_offsets: Vec<i64> = Vec::new();
    let e_statuses: Vec<String> = Vec::new();
    let e_qualities: Vec<String> = Vec::new();
    // 1 when a trivial `return <default>` body satisfies this ensures (#81 PR-C).
    let e_trivial: Vec<i64> = Vec::new();

    let nf: i64 = ir_mod.functions.len();
    let mut fi: i64 = 0;
    while fi < nf {
        let func: IrFunction = ir_mod.functions[fi];
        let nv: i64 = func.vows.len();
        let mut vi: i64 = 0;
        while vi < nv {
            let ve: IrVowEntry = func.vows[vi];
            let ve_desc: String = ve.description;
            let ve_kind: String = vow_kind_from_desc(ve_desc);
            e_vow_ids.push(ve.id);
            e_func_ids.push(func.id);
            e_func_names.push(func.name);
            e_kinds.push(ve_kind);
            e_descs.push(ve_desc);
            e_qualities.push(cq_classify(ve_kind, ve_desc));
            if ve.blame == BLAME_CALLER() {
                e_blames.push(String::from("Caller"));
            } else {
                e_blames.push(String::from("Callee"));
            }
            e_files.push(ve.file);
            e_offsets.push(ve.offset);
            e_statuses.push(String::from("not_verified"));
            e_trivial.push(0);
            vi = vi + 1;
        }
        fi = fi + 1;
    }

    // If --verify, run verification per function and update statuses
    let mut exit_code: i32 = 0;
    if do_verify {
        if !esbmc_exists() {
            let mut ei_missing: i64 = 0;
            while ei_missing < e_statuses.len() {
                e_statuses[ei_missing] = String::from("error");
                ei_missing = ei_missing + 1;
            }
            exit_code = 1;
        } else {
            let const_fn_indices_c: Vec<i64> = detect_const_fns(ir_mod);
            fi = 0;
            while fi < nf {
                let func: IrFunction = ir_mod.functions[fi];
                if func.vows.len() > 0 {
                    let skip_reason: String = non_modelable_reason(func, ir_mod, const_fn_indices_c);
                    if skip_reason.len() > 0 {
                        let mut ei: i64 = 0;
                        while ei < e_func_ids.len() {
                            if e_func_ids[ei] == func.id {
                                e_statuses[ei] = String::from("skipped");
                            }
                            ei = ei + 1;
                        }
                    } else {
                        // Per-clause status via ESBMC `--multi-property`: every
                        // `vow:N` claim is reported individually, so each clause
                        // gets a precise verdict instead of the siblings of a
                        // failed clause collapsing to `unknown` (#81 PR-A).
                        let mpr: MultiPropertyResult = verify_function_multi_property(func, ir_mod, max_k_step, solver, encoding, timeout_secs, vec_max_c, string_max_c, hashmap_max_c, btreemap_max_c);
                        let overall: i64 = mpr.status;
                        let v_ids: Vec<i64> = mpr.verdict_ids;
                        let v_proven: Vec<i64> = mpr.verdict_proven;
                        let mut ei: i64 = 0;
                        while ei < e_func_ids.len() {
                            if e_func_ids[ei] == func.id {
                                let mut verdict: i64 = -1;
                                let mut k: i64 = 0;
                                while k < v_ids.len() {
                                    if v_ids[k] == e_vow_ids[ei] {
                                        verdict = v_proven[k];
                                        k = v_ids.len();
                                    } else {
                                        k = k + 1;
                                    }
                                }
                                if verdict == 1 {
                                    e_statuses[ei] = String::from("proven");
                                } else if verdict == 0 {
                                    e_statuses[ei] = String::from("failed");
                                } else if overall == VERIFY_PROVEN() || overall == VERIFY_PROVEN_IR() {
                                    e_statuses[ei] = String::from("proven");
                                } else if overall == VERIFY_TIMEOUT() {
                                    e_statuses[ei] = String::from("timeout");
                                } else if overall == VERIFY_UNKNOWN() {
                                    e_statuses[ei] = String::from("unknown");
                                } else if overall == VERIFY_FAILED() {
                                    e_statuses[ei] = String::from("unknown");
                                } else {
                                    e_statuses[ei] = String::from("error");
                                }
                            }
                            ei = ei + 1;
                        }

                        // Vacuity probe (#81 PR-B): if the function's `requires`
                        // are contradictory, the `ensures` above all passed
                        // vacuously. Re-run with a `vow_reach` label after the
                        // requires; if that point is unreachable, override the
                        // whole contract's clauses with `vacuous`. Only functions
                        // with a `requires` are eligible.
                        let vac: i64 = verify_function_vacuity(func, ir_mod, max_k_step, solver, encoding, timeout_secs, vec_max_c, string_max_c, hashmap_max_c, btreemap_max_c);
                        if vac == 1 {
                            let mut vi2: i64 = 0;
                            while vi2 < e_func_ids.len() {
                                if e_func_ids[vi2] == func.id {
                                    e_statuses[vi2] = String::from("vacuous");
                                }
                                vi2 = vi2 + 1;
                            }
                        }

                        // Weakness probe (#81 PR-C): if a trivial `return
                        // <default>` body still satisfies the ensures, mark each
                        // ensures clause trivially_satisfiable (informational).
                        let triv: i64 = verify_function_trivial(func, ir_mod, max_k_step, solver, encoding, timeout_secs, vec_max_c, string_max_c, hashmap_max_c, btreemap_max_c);
                        if triv == 1 {
                            let mut ti: i64 = 0;
                            while ti < e_func_ids.len() {
                                if e_func_ids[ti] == func.id && e_kinds[ti] == String::from("ensures") {
                                    e_trivial[ti] = 1;
                                }
                                ti = ti + 1;
                            }
                        }
                    }
                }
                fi = fi + 1;
            }
        }
    }

    // Build JSON output
    let total: i64 = e_vow_ids.len();
    let json: String = String::from("{\"contracts\":[");
    let mut ci: i64 = 0;
    while ci < total {
        if ci > 0 {
            json.push_str(String::from(","));
        }
        json.push_str(String::from("{\"vow_id\":"));
        json.push_str(i64_to_str(e_vow_ids[ci]));
        json.push_str(String::from(",\"function\":\""));
        json.push_str(diag_json_escape_str(e_func_names[ci]));
        json.push_str(String::from("\",\"kind\":\""));
        json.push_str(e_kinds[ci]);
        json.push_str(String::from("\",\"description\":\""));
        json.push_str(diag_json_escape_str(e_descs[ci]));
        json.push_str(String::from("\",\"blame\":\""));
        json.push_str(e_blames[ci]);
        json.push_str(String::from("\",\"source\":{\"file\":\""));
        json.push_str(diag_json_escape_str(e_files[ci]));
        json.push_str(String::from("\",\"offset\":"));
        json.push_str(i64_to_str(e_offsets[ci]));
        json.push_str(String::from("},\"status\":\""));
        json.push_str(e_statuses[ci]);
        json.push_str(String::from("\",\"quality\":\""));
        json.push_str(e_qualities[ci]);
        json.push_str(String::from("\",\"trivially_satisfiable\":"));
        if e_trivial[ci] == 1 {
            json.push_str(String::from("true"));
        } else {
            json.push_str(String::from("false"));
        }
        json.push_str(String::from("}"));
        ci = ci + 1;
    }

    // Compute summary counts
    let n_proven: i64 = 0;
    let n_failed: i64 = 0;
    let n_unknown: i64 = 0;
    let n_timeout: i64 = 0;
    let n_error: i64 = 0;
    let n_not_verified: i64 = 0;
    let n_skipped: i64 = 0;
    let n_vacuous: i64 = 0;
    let n_trivial: i64 = 0;
    let mut si: i64 = 0;
    while si < total {
        let s: String = e_statuses[si];
        if e_trivial[si] == 1 {
            n_trivial = n_trivial + 1;
        }
        if s == String::from("proven") || s == String::from("proven-ir") {
            n_proven = n_proven + 1;
        } else if s == String::from("failed") {
            n_failed = n_failed + 1;
        } else if s == String::from("unknown") {
            n_unknown = n_unknown + 1;
        } else if s == String::from("timeout") {
            n_timeout = n_timeout + 1;
        } else if s == String::from("error") {
            n_error = n_error + 1;
        } else if s == String::from("skipped") {
            n_skipped = n_skipped + 1;
        } else if s == String::from("vacuous") {
            n_vacuous = n_vacuous + 1;
        } else {
            n_not_verified = n_not_verified + 1;
        }
        si = si + 1;
    }

    // Fail closed: `vow contracts --verify` exits non-zero when any contract is
    // not proven, matching `vow build --verify` / `vow verify` (#479). A vacuous
    // contract is a hollow proof, so it fails closed too (#81 PR-B).
    if n_failed > 0 || n_timeout > 0 || n_unknown > 0 || n_error > 0 || n_skipped > 0 || n_vacuous > 0 {
        exit_code = 1;
    }

    // Static contract-quality tallies (independent of verification status).
    let n_weak: i64 = 0;
    let n_taut: i64 = 0;
    let n_subst: i64 = 0;
    let mut qi: i64 = 0;
    while qi < total {
        let q: String = e_qualities[qi];
        if q == String::from("weak") {
            n_weak = n_weak + 1;
        } else if q == String::from("tautological") {
            n_taut = n_taut + 1;
        } else {
            n_subst = n_subst + 1;
        }
        qi = qi + 1;
    }

    json.push_str(String::from("],\"summary\":{\"total\":"));
    json.push_str(i64_to_str(total));
    json.push_str(String::from(",\"proven\":"));
    json.push_str(i64_to_str(n_proven));
    json.push_str(String::from(",\"failed\":"));
    json.push_str(i64_to_str(n_failed));
    json.push_str(String::from(",\"unknown\":"));
    json.push_str(i64_to_str(n_unknown));
    json.push_str(String::from(",\"timeout\":"));
    json.push_str(i64_to_str(n_timeout));
    json.push_str(String::from(",\"error\":"));
    json.push_str(i64_to_str(n_error));
    json.push_str(String::from(",\"not_verified\":"));
    json.push_str(i64_to_str(n_not_verified));
    json.push_str(String::from(",\"skipped\":"));
    json.push_str(i64_to_str(n_skipped));
    json.push_str(String::from(",\"vacuous\":"));
    json.push_str(i64_to_str(n_vacuous));
    json.push_str(String::from(",\"trivially_satisfiable\":"));
    json.push_str(i64_to_str(n_trivial));
    json.push_str(String::from(",\"quality\":{\"weak\":"));
    json.push_str(i64_to_str(n_weak));
    json.push_str(String::from(",\"tautological\":"));
    json.push_str(i64_to_str(n_taut));
    json.push_str(String::from(",\"substantive\":"));
    json.push_str(i64_to_str(n_subst));
    json.push_str(String::from("}}}"));
    print_str(json);
    exit_code
}

fn main() -> i32 [io, read, write] {
    let argv: Vec<String> = args();
    if has_flag(argv, "--help") {
        if has_flag(argv, "--human") {
            print_str(skill_human());
        } else {
            print_str(skill_json());
        }
        return 0;
    }
    if argv.len() <= 1 {
        eprintln_str("usage: vowc <command> [options] <file.vow>");
        return 1;
    }
    let cmd: i64 = get_subcommand(argv);
    if cmd == CMD_TEST() {
        return run_test(argv);
    }
    if cmd == CMD_SKILL() {
        return run_skill(argv);
    }
    if cmd == CMD_BUILD() {
        maybe_auto_install_skill();
        return run_build(argv);
    }
    if cmd == CMD_VERIFY() {
        return run_verify(argv);
    }
    if cmd == CMD_CONTRACTS() {
        return run_contracts(argv);
    }
    if cmd == CMD_MUTANTS() {
        return run_mutants(argv);
    }
    maybe_auto_install_skill();
    run_legacy(argv)
}
