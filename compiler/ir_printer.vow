module IrPrinter

use ir

fn i64_to_str(v: i64) -> String {
    if v == 0 { return String::from("0"); }
    let out: String = String::from("");
    let mut n: i64 = v;
    if n < 0 {
        out.push_byte(45);
        n = 0 - n;
    }
    let digits: Vec<i64> = Vec::new();
    while n > 0 {
        digits.push(n % 10);
        n = n / 10;
    }
    let mut i: i64 = digits.len() - 1;
    while i >= 0 {
        out.push_byte(48 + digits[i]);
        i = i - 1;
    }
    out
}

fn pad_right(s: String, width: i64) -> String {
    let out: String = String::from("");
    out.push_str(s);
    let mut i: i64 = s.len();
    while i < width {
        out.push_byte(32);
        i = i + 1;
    }
    out
}

fn debug_escape_str(s: String) -> String {
    let out: String = String::from("");
    out.push_byte(34);
    let n: i64 = s.len();
    let mut i: i64 = 0;
    while i < n {
        let b: i64 = s.byte_at(i);
        if b == 34 {
            out.push_byte(92);
            out.push_byte(34);
        } else if b == 92 {
            out.push_byte(92);
            out.push_byte(92);
        } else if b == 10 {
            out.push_byte(92);
            out.push_byte(110);
        } else if b == 13 {
            out.push_byte(92);
            out.push_byte(114);
        } else if b == 9 {
            out.push_byte(92);
            out.push_byte(116);
        } else if b == 0 {
            out.push_byte(92);
            out.push_byte(48);
        } else {
            out.push_byte(b);
        }
        i = i + 1;
    }
    out.push_byte(34);
    out
}

fn ir_ty_str(ty: i64) -> String {
    if ty == ITY_I32() { return String::from("i32"); }
    if ty == ITY_I64() { return String::from("i64"); }
    if ty == ITY_F32() { return String::from("f32"); }
    if ty == ITY_F64() { return String::from("f64"); }
    if ty == ITY_BOOL() { return String::from("Bool"); }
    if ty == ITY_UNIT() { return String::from("Void"); }
    if ty == ITY_PTR() { return String::from("ptr"); }
    if ty == ITY_LPTR() { return String::from("linear_ptr"); }
    if ty == ITY_U64() { return String::from("u64"); }
    String::from("???")
}

