    if op == IOP_DEBUG_CALL() { return String::from("DebugCall"); }
    String::from("???")
}

fn effects_str(eff: i64) -> String {
    let out: String = String::from("");
    let mut first: i64 = 1;
    if eff % 2 == 1 {
        out.push_str(String::from("IO"));
        first = 0;
    }
    if (eff / 2) % 2 == 1 {
        if first == 0 { out.push_str(String::from(", ")); }
        out.push_str(String::from("Panic"));
        first = 0;
    }
    if (eff / 4) % 2 == 1 {
        if first == 0 { out.push_str(String::from(", ")); }
        out.push_str(String::from("Read"));
        first = 0;
    }
    if (eff / 8) % 2 == 1 {
        if first == 0 { out.push_str(String::from(", ")); }
        out.push_str(String::from("Unsafe"));
        first = 0;
    }
    if (eff / 16) % 2 == 1 {
        if first == 0 { out.push_str(String::from(", ")); }
        out.push_str(String::from("Write"));
        first = 0;
    }
    out
}

fn format_data(inst: IrInst) -> String {
    let dk: i64 = inst.dk;
    if dk == IDATA_NONE() { return String::from(""); }
    if dk == IDATA_CONST_I32() { return i64_to_str(inst.dv); }
    if dk == IDATA_CONST_I64() { return i64_to_str(inst.dv); }
    if dk == IDATA_CONST_F32() { return i64_to_str(inst.dv); }
    if dk == IDATA_CONST_F64() { return i64_to_str(inst.dv); }
    if dk == IDATA_CONST_BOOL() {
        if inst.dv == 0 { return String::from("false"); }
        return String::from("true");
    }
    if dk == IDATA_ARG_INDEX() { return i64_to_str(inst.dv); }
    if dk == IDATA_PHI_TARGET() {
        let out: String = String::from("%");
        out.push_str(i64_to_str(inst.dv));
        return out;
    }
    if dk == IDATA_CONST_STR() {
        let out: String = String::from("@");
        out.push_str(i64_to_str(inst.dv));
        return out;
    }
    if dk == IDATA_CALL_TARGET() {
        let out: String = String::from("func");
        out.push_str(i64_to_str(inst.dv));
        return out;
    }
    if dk == IDATA_CALL_EXTERN() {
        let out: String = String::from("extern:");
        out.push_str(inst.ds);
        return out;
    }
    if dk == IDATA_BRANCH_TARGETS() {
        let out: String = String::from("block_");
        out.push_str(i64_to_str(inst.dv));
        out.push_str(String::from(", block_"));
        out.push_str(i64_to_str(inst.dv2));
        return out;
    }
    if dk == IDATA_JUMP_TARGET() {
        let out: String = String::from("block_");
        out.push_str(i64_to_str(inst.dv));
        return out;
    }
    if dk == IDATA_REGION_ID() {
        let out: String = String::from("region_");
        out.push_str(i64_to_str(inst.dv));
        return out;
    }
    if dk == IDATA_VOW_ID() {
        let out: String = String::from("vow_");
        out.push_str(i64_to_str(inst.dv));
        return out;
    }
    if dk == IDATA_ALLOC_SIZE() {
        let out: String = String::from("size=");
        out.push_str(i64_to_str(inst.dv));
        out.push_str(String::from(",align="));
        out.push_str(i64_to_str(inst.dv2));
        return out;
    }
    if dk == IDATA_FIELD() {
        let out: String = String::from("field_");
        out.push_str(i64_to_str(inst.dv));
        return out;
    }
    if dk == IDATA_CONST_U64() {
        let out: String = i64_to_str(inst.dv);
        out.push_str(String::from("u64"));
        return out;
    }
    String::from("")
}

fn format_args(args: Vec<i64>) -> String {
    let out: String = String::from("");
    let n: i64 = args.len();
    let mut i: i64 = 0;
    while i < n {
        if i > 0 { out.push_str(String::from(", ")); }
        out.push_byte(37);
        out.push_str(i64_to_str(args[i]));
        i = i + 1;
    }
    out
}

fn print_inst(inst: IrInst) -> String {
    let out: String = String::from("    ");
    out.push_str(pad_right(ir_ty_str(inst.ty), 10));
    out.push_str(String::from("  %"));
    out.push_str(i64_to_str(inst.id));
    out.push_str(String::from(" = "));
    let dstr: String = format_data(inst);
    out.push_str(opcode_name(inst.op));
    if dstr.len() > 0 {
        out.push_byte(91);
        out.push_str(dstr);
        out.push_byte(93);
    }
    out.push_byte(40);
    out.push_str(format_args(inst.args));
    out.push_byte(41);
    // Region suffix: only for RegionAlloc and only when non-Root, so
    // existing golden output stays byte-identical in Phase 2. Matches
    // vow-ir/src/printer.rs region_suffix().
    if inst.op == IOP_REGION_ALLOC() {
        let rgn: i64 = inst.rgn;
        let kind: i64 = region_kind(rgn);
        if kind != REGION_KIND_ROOT() {
            out.push_str(String::from("<region="));
            if kind == REGION_KIND_RODATA() {
                out.push_str(String::from("rodata"));
            } else if kind == REGION_KIND_BLOCK() {
                out.push_str(String::from("block_"));
                out.push_str(i64_to_str(region_val(rgn)));
            } else if kind == REGION_KIND_CALLER() {
                out.push_str(String::from("caller_"));
                out.push_str(i64_to_str(region_val(rgn)));
            } else {
                // Defensive: a packed i64 outside 0..=3 indicates a bug in
                // whoever assigned `inst.rgn`. Emit the raw kind so the slip
                // is visible in golden output instead of silently producing
                // an empty `<region=>`.
                out.push_str(String::from("unknown_"));
                out.push_str(i64_to_str(kind));
            }
            out.push_byte(62);
        }
    }
    out
}

fn print_block(blk: IrBlock, is_entry: i64) -> String {
    let out: String = String::from("");
    if is_entry == 1 {
        out.push_str(String::from("  entry (block "));
        out.push_str(i64_to_str(blk.id));
        out.push_str(String::from("):"));
    } else {
        out.push_str(String::from("  block_"));
        out.push_str(i64_to_str(blk.id));
        out.push_byte(58);
    }
    let n: i64 = blk.insts.len();
    let mut i: i64 = 0;
    while i < n {
        out.push_byte(10);
        let inst: IrInst = blk.insts[i];
        out.push_str(print_inst(inst));
        i = i + 1;
    }
    out
}

fn print_function(f: IrFunction) -> String {
    let out: String = String::from("fn ");
    out.push_str(f.name);
    out.push_byte(40);
    let np: i64 = f.params.len();
    let mut i: i64 = 0;
    while i < np {
        if i > 0 { out.push_str(String::from(", ")); }
        out.push_str(ir_ty_str(f.params[i]));
        i = i + 1;
    }
    out.push_str(String::from(") -> "));
    out.push_str(ir_ty_str(f.return_ty));
    out.push_str(String::from(" ["));
    out.push_str(effects_str(f.effects));
    out.push_str(String::from("]:"));
    let nb: i64 = f.blocks.len();
    i = 0;
    while i < nb {
        out.push_byte(10);
        let blk: IrBlock = f.blocks[i];
        let is_entry: i64 = if i == 0 { 1 } else { 0 };
        out.push_str(print_block(blk, is_entry));
        i = i + 1;
    }
    out
}

fn print_module(m: IrModule) -> String {
    let out: String = String::from("");
    let ns: i64 = m.strings.len();
    if ns > 0 {
        out.push_str(String::from("strings:"));
        let mut i: i64 = 0;
        while i < ns {
            out.push_str(String::from("\n  @"));
            out.push_str(i64_to_str(i));
            out.push_str(String::from(" = "));
            out.push_str(debug_escape_str(m.strings[i]));
            i = i + 1;
        }
    }

    let nsl: i64 = m.struct_layouts.len();
    let mut si: i64 = 0;
    while si < nsl {
        if out.len() > 0 { out.push_str(String::from("\n\n")); }
        let sl: IrStructLayout = m.struct_layouts[si];
        out.push_str(String::from("struct "));
        out.push_str(sl.name);
        out.push_str(String::from(" { "));
        let nf: i64 = sl.fields.len();
        let mut fi: i64 = 0;
        while fi < nf {
            if fi > 0 { out.push_str(String::from(", ")); }
            let fld: IrFieldLayout = sl.fields[fi];
            out.push_str(fld.name);
            out.push_str(String::from(": "));
            out.push_str(ir_ty_str(fld.ty));
            fi = fi + 1;
        }
        out.push_str(String::from(" }"));
        si = si + 1;
    }

    let nel: i64 = m.enum_layouts.len();
    let mut ei: i64 = 0;
    while ei < nel {
        if out.len() > 0 { out.push_str(String::from("\n\n")); }
        let el: IrEnumLayout = m.enum_layouts[ei];
        out.push_str(String::from("enum "));
        out.push_str(el.name);
        out.push_str(String::from(" { "));
        let nv: i64 = el.variants.len();
        let mut vi: i64 = 0;
        while vi < nv {
            if vi > 0 { out.push_str(String::from(", ")); }
            let vr: IrVariantLayout = el.variants[vi];
            out.push_str(vr.name);
            out.push_str(String::from("(tag="));
            out.push_str(i64_to_str(vr.tag));
            let npay: i64 = vr.payload.len();
            if npay > 0 {
                out.push_str(String::from(", "));
                let mut pi: i64 = 0;
                while pi < npay {
                    if pi > 0 { out.push_str(String::from(", ")); }
                    let pf: IrFieldLayout = vr.payload[pi];
                    out.push_str(ir_ty_str(pf.ty));
                    pi = pi + 1;
                }
            }
            out.push_byte(41);
            vi = vi + 1;
        }
        out.push_str(String::from(" }"));
        ei = ei + 1;
    }

    let nfn: i64 = m.functions.len();
    let mut fi: i64 = 0;
    while fi < nfn {
        if out.len() > 0 { out.push_str(String::from("\n\n")); }
        let func: IrFunction = m.functions[fi];
        out.push_str(print_function(func));
        fi = fi + 1;
    }
    out
}
