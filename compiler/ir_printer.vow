    if op == IOP_CONST_UNIT() { return String::from("ConstUnit"); }
    if op == IOP_GET_ARG() { return String::from("GetArg"); }
    if op == IOP_WADD_I32() { return String::from("WrappingAddI32"); }
    if op == IOP_WSUB_I32() { return String::from("WrappingSubI32"); }
    if op == IOP_WMUL_I32() { return String::from("WrappingMulI32"); }
    if op == IOP_WDIV_I32() { return String::from("WrappingDivI32"); }
    if op == IOP_WREM_I32() { return String::from("WrappingRemI32"); }
    if op == IOP_CADD_I32() { return String::from("CheckedAddI32"); }
    if op == IOP_CSUB_I32() { return String::from("CheckedSubI32"); }
    if op == IOP_CMUL_I32() { return String::from("CheckedMulI32"); }
    if op == IOP_CDIV_I32() { return String::from("CheckedDivI32"); }
    if op == IOP_CREM_I32() { return String::from("CheckedRemI32"); }
    if op == IOP_EQ_I32() { return String::from("EqI32"); }
    if op == IOP_NE_I32() { return String::from("NeI32"); }
    if op == IOP_LT_I32() { return String::from("LtI32"); }
    if op == IOP_LE_I32() { return String::from("LeI32"); }
    if op == IOP_GT_I32() { return String::from("GtI32"); }
    if op == IOP_GE_I32() { return String::from("GeI32"); }
    if op == IOP_WADD_I64() { return String::from("WrappingAddI64"); }
    if op == IOP_WSUB_I64() { return String::from("WrappingSubI64"); }
    if op == IOP_WMUL_I64() { return String::from("WrappingMulI64"); }
    if op == IOP_WDIV_I64() { return String::from("WrappingDivI64"); }
    if op == IOP_WREM_I64() { return String::from("WrappingRemI64"); }
    if op == IOP_CADD_I64() { return String::from("CheckedAddI64"); }
