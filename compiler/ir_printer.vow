    if op == IOP_CREM_U64() { return String::from("CheckedRemU64"); }
    if op == IOP_EQ_U64() { return String::from("EqU64"); }
    if op == IOP_NE_U64() { return String::from("NeU64"); }
    if op == IOP_LT_U64() { return String::from("LtU64"); }
    if op == IOP_LE_U64() { return String::from("LeU64"); }
    if op == IOP_GT_U64() { return String::from("GtU64"); }
    if op == IOP_GE_U64() { return String::from("GeU64"); }
    if op == IOP_XOR_U64() { return String::from("XorU64"); }
    if op == IOP_BITAND_U64() { return String::from("BitAndU64"); }
    if op == IOP_BITOR_U64() { return String::from("BitOrU64"); }
    if op == IOP_SHL_U64() { return String::from("ShlU64"); }
    if op == IOP_SHR_U64() { return String::from("ShrU64"); }
