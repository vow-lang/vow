module CEmitter

use clif
use ir
use ir_printer

fn VOW_VEC_MAX() -> i64 vow { ensures: result >= 0 } { 128 }
fn VOW_STRING_MAX() -> i64 vow { ensures: result >= 0 } { 256 }
fn VOW_HASHMAP_MAX() -> i64 vow { ensures: result >= 0 } { 64 }
fn VOW_BTREEMAP_MAX() -> i64 vow { ensures: result >= 0 } { 64 }

fn str3(a: String, b: String, c: String) -> String {
    let r: String = String::from("");
    r.push_str(a);
    r.push_str(b);
    r.push_str(c);
    r
}

fn str4(a: String, b: String, c: String, d: String) -> String {
    let r: String = String::from("");
    r.push_str(a);
    r.push_str(b);
    r.push_str(c);
    r.push_str(d);
    r
}

fn str5(a: String, b: String, c: String, d: String, e: String) -> String {
    let r: String = String::from("");
    r.push_str(a);
    r.push_str(b);
    r.push_str(c);
    r.push_str(d);
    r.push_str(e);
    r
}

fn str6(a: String, b: String, c: String, d: String, e: String, f: String) -> String {
    let r: String = String::from("");
    r.push_str(a);
    r.push_str(b);
    r.push_str(c);
    r.push_str(d);
    r.push_str(e);
    r.push_str(f);
    r
}

fn str7(a: String, b: String, c: String, d: String, e: String, f: String, g: String) -> String {
    let r: String = String::from("");
    r.push_str(a);
    r.push_str(b);
    r.push_str(c);
    r.push_str(d);
    r.push_str(e);
    r.push_str(f);
    r.push_str(g);
    r
}

fn vid(id: i64) -> String {
    str2(String::from("v"), i64_to_str(id))
}

fn str_starts_with(s: String, prefix: String) -> bool {
    let plen: i64 = prefix.len();
    if s.len() < plen { return false; }
    let mut i: i64 = 0;
    while i < plen {
        if s.byte_at(i) != prefix.byte_at(i) { return false; }
        i = i + 1;
    }
    true
}

fn vec_contains_i64(v: Vec<i64>, val: i64) -> bool {
    let n: i64 = v.len();
    let mut i: i64 = 0;
    while i < n {
        if v[i] == val { return true; }
        i = i + 1;
    }
    false
}

fn vec_insert_i64(v: Vec<i64>, val: i64) -> bool {
    if vec_contains_i64(v, val) { return false; }
    v.push(val);
    true
}

fn is_string_fresh_helper(name: String) -> bool {
    name == String::from("__vow_string_trim")
    || name == String::from("__vow_string_trim_in_arena")
    || name == String::from("__vow_string_to_upper")
    || name == String::from("__vow_string_to_upper_in_arena")
    || name == String::from("__vow_string_to_lower")
    || name == String::from("__vow_string_to_lower_in_arena")
    || name == String::from("__vow_string_replace")
    || name == String::from("__vow_string_replace_in_arena")
    || name == String::from("__vow_string_join")
    || name == String::from("__vow_string_join_in_arena")
}

fn is_known_builtin(name: String) -> bool {
    if is_string_fresh_helper(name) { return true; }
    name == String::from("__vow_vec_new")
    || name == String::from("__vow_vec_new_val")
    || name == String::from("__vow_vec_new_in_arena")
    || name == String::from("__vow_vec_new_val_in_arena")
    || name == String::from("__vow_vec_from_raw_parts_copy_val")
    || name == String::from("__vow_vec_pin_to_root_val")
    || name == String::from("__vow_vec_push_val")
    || name == String::from("__vow_vec_push_in_arena")
    || name == String::from("__vow_vec_push_val_in_arena")
    || name == String::from("__vow_vec_reserve_in_arena")
    || name == String::from("__vow_vec_get_val")
    || name == String::from("__vow_vec_len")
    || name == String::from("__vow_vec_pop")
    || name == String::from("__vow_vec_set_val")
    || name == String::from("__vow_string_split")
    || name == String::from("__vow_string_split_in_arena")
    || name == String::from("__vow_string_new")
    || name == String::from("__vow_string_new_in_arena")
    || name == String::from("__vow_string_literal")
    || name == String::from("__vow_string_from_cstr")
    || name == String::from("__vow_string_from_cstr_in_arena")
    || name == String::from("__vow_string_clone")
    || name == String::from("__vow_string_clone_in_arena")
    || name == String::from("__vow_string_from_raw_parts_copy")
    || name == String::from("__vow_string_pin_to_root")
    || name == String::from("__vow_string_len")
    || name == String::from("__vow_string_push_str")
    || name == String::from("__vow_string_push_str_in_arena")
    || name == String::from("__vow_string_push_byte")
    || name == String::from("__vow_string_push_byte_in_arena")
    || name == String::from("__vow_string_clear")
    || name == String::from("__vow_string_byte_at")
    || name == String::from("__vow_string_eq")
    || name == String::from("__vow_string_contains")
    || name == String::from("__vow_string_matches_literal_at")
    || name == String::from("__vow_string_substr")
    || name == String::from("__vow_string_substr_in_arena")
    || name == String::from("__vow_string_substring")
    || name == String::from("__vow_string_substring_in_arena")
    || name == String::from("__vow_string_from_i64")
    || name == String::from("__vow_string_from_i64_in_arena")
    || name == String::from("__vow_string_print")
    || name == String::from("__vow_map_new")
    || name == String::from("__vow_map_new_in_arena")
    || name == String::from("__vow_map_len")
    || name == String::from("__vow_map_insert")
    || name == String::from("__vow_map_insert_in_arena")
    || name == String::from("__vow_map_get")
    || name == String::from("__vow_map_contains")
    || name == String::from("__vow_map_remove")
    || name == String::from("__vow_map_remove_in_arena")
    || name == String::from("__vow_btreemap_new")
    || name == String::from("__vow_btreemap_len")
    || name == String::from("__vow_btreemap_insert")
    || name == String::from("__vow_btreemap_get")
    || name == String::from("__vow_btreemap_contains")
}

fn is_reserved_verifier_symbol(name: String) -> bool {
    str_starts_with(name, String::from("__ESBMC_"))
    || str_starts_with(name, String::from("__VERIFIER_"))
}

fn is_modelable(f: IrFunction, m: IrModule, const_fn_indices: Vec<i64>, modelable_cache_ids: Vec<i64>, modelable_cache_vals: Vec<i64>) -> bool {
    if is_reserved_verifier_symbol(f.name) {
        return false;
    }

    let fid: i64 = f.id;
    let nc: i64 = modelable_cache_ids.len();
    let mut ci: i64 = 0;
    while ci < nc {
        if modelable_cache_ids[ci] == fid {
            return modelable_cache_vals[ci] != 0;
        }
        ci = ci + 1;
    }
    modelable_cache_ids.push(fid);
    modelable_cache_vals.push(0);

    if f.effects != 0 {
        return false;
    }

    let vec_vars: Vec<i64> = collect_vec_vars(f);
    let string_vars: Vec<i64> = collect_string_vars(f);
    let hashmap_vars: Vec<i64> = collect_hashmap_vars(f);
    let btreemap_vars: Vec<i64> = collect_btreemap_vars(f);
    let option_vars: Vec<i64> = collect_option_vars(f);

    let blocks: Vec<IrBlock> = f.blocks;
    let mut bi: i64 = 0;
    while bi < blocks.len() {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            let op: i64 = inst.op;
            let ok: bool = {
                if op == IOP_CONST_I32() || op == IOP_CONST_I64() || op == IOP_CONST_F32()
                   || op == IOP_CONST_F64() || op == IOP_CONST_BOOL() || op == IOP_CONST_UNIT()
                   || op == IOP_CONST_STR() || op == IOP_GET_ARG()
                   || op == IOP_WADD_I32() || op == IOP_WADD_I64() || op == IOP_CADD_I32() || op == IOP_CADD_I64()
                   || op == IOP_WSUB_I32() || op == IOP_WSUB_I64() || op == IOP_CSUB_I32() || op == IOP_CSUB_I64()
                   || op == IOP_WMUL_I32() || op == IOP_WMUL_I64() || op == IOP_CMUL_I32() || op == IOP_CMUL_I64()
                   || op == IOP_WDIV_I32() || op == IOP_WDIV_I64() || op == IOP_CDIV_I32() || op == IOP_CDIV_I64()
                   || op == IOP_WREM_I32() || op == IOP_WREM_I64() || op == IOP_CREM_I32() || op == IOP_CREM_I64()
                   || op == IOP_ADD_F32() || op == IOP_ADD_F64() || op == IOP_SUB_F32() || op == IOP_SUB_F64()
                   || op == IOP_MUL_F32() || op == IOP_MUL_F64() || op == IOP_DIV_F32() || op == IOP_DIV_F64()
                   || op == IOP_EQ_I32() || op == IOP_EQ_I64() || op == IOP_EQ_F32() || op == IOP_EQ_F64()
                   || op == IOP_NE_I32() || op == IOP_NE_I64() || op == IOP_NE_F32() || op == IOP_NE_F64()
                   || op == IOP_LT_I32() || op == IOP_LT_I64() || op == IOP_LT_F32() || op == IOP_LT_F64()
                   || op == IOP_LE_I32() || op == IOP_LE_I64() || op == IOP_LE_F32() || op == IOP_LE_F64()
                   || op == IOP_GT_I32() || op == IOP_GT_I64() || op == IOP_GT_F32() || op == IOP_GT_F64()
                   || op == IOP_GE_I32() || op == IOP_GE_I64() || op == IOP_GE_F32() || op == IOP_GE_F64()
                   || op == IOP_NOT() || op == IOP_AND() || op == IOP_OR()
                   || op == IOP_BITAND_I64() || op == IOP_BITOR_I64()
                   || op == IOP_XOR_I32() || op == IOP_XOR_I64()
                   || op == IOP_SHL_I64() || op == IOP_SHR_I64()
                   || op == IOP_WADD_U64() || op == IOP_WSUB_U64() || op == IOP_WMUL_U64() || op == IOP_WDIV_U64() || op == IOP_WREM_U64()
                   || op == IOP_CADD_U64() || op == IOP_CSUB_U64() || op == IOP_CMUL_U64() || op == IOP_CDIV_U64() || op == IOP_CREM_U64()
                   || op == IOP_EQ_U64() || op == IOP_NE_U64() || op == IOP_LT_U64() || op == IOP_LE_U64() || op == IOP_GT_U64() || op == IOP_GE_U64()
                   || op == IOP_BITAND_U64() || op == IOP_BITOR_U64() || op == IOP_XOR_U64() || op == IOP_SHL_U64() || op == IOP_SHR_U64()
                   || op == IOP_CONST_U64() || op == IOP_CAST_I64_TO_U64() || op == IOP_CAST_U64_TO_I64()
                   || op == IOP_VOW_REQ() || op == IOP_VOW_ENS() || op == IOP_VOW_INV()
                   || op == IOP_BRANCH() || op == IOP_JUMP() || op == IOP_RETURN() || op == IOP_UNREACHABLE()
                   || op == IOP_PHI() || op == IOP_UPSILON()
                   || op == IOP_REGION_OPEN() || op == IOP_REGION_CLOSE()
                   || op == IOP_DEBUG_CALL() {
                    true
                } else if op == IOP_CALL() {
                    if inst.dk == IDATA_CALL_EXTERN() {
                        is_known_builtin(inst.ds)
                    } else if inst.dk == IDATA_CALL_TARGET() {
                        let target_fi: i64 = inst.dv;
                        if vec_contains_i64(const_fn_indices, target_fi) {
                            true
                        } else {
                            let fns: Vec<IrFunction> = m.functions;
                            let mut found: bool = false;
                            let mut fi: i64 = 0;
                            while fi < fns.len() {
                                let callee: IrFunction = fns[fi];
                                if callee.id == target_fi {
                                    found = is_modelable(callee, m, const_fn_indices, modelable_cache_ids, modelable_cache_vals);
                                    fi = fns.len();
                                }
                                fi = fi + 1;
                            }
                            found
                        }
                    } else {
                        false
                    }
                } else if op == IOP_FIELD_GET() {
                    let iid: i64 = inst.id;
                    let iargs: Vec<i64> = inst.args;
                    vec_contains_i64(vec_vars, iid)
                    || vec_contains_i64(string_vars, iid)
                    || vec_contains_i64(hashmap_vars, iid)
                    || vec_contains_i64(btreemap_vars, iid)
                    || (iargs.len() > 0 && vec_contains_i64(option_vars, iargs[0]))
                } else if op == IOP_REM_F32() || op == IOP_REM_F64()
                   || op == IOP_LOAD() || op == IOP_STORE()
                   || op == IOP_REGION_ALLOC()
                   || op == IOP_LINEAR_CONSUME() || op == IOP_LINEAR_BORROW()
                   || op == IOP_FIELD_SET() {
                    false
                } else {
                    false
                }
            };
            if !ok {
                return false;
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    let nc2: i64 = modelable_cache_ids.len();
    let mut ci2: i64 = 0;
    while ci2 < nc2 {
        if modelable_cache_ids[ci2] == fid {
            modelable_cache_vals[ci2] = 1;
        }
        ci2 = ci2 + 1;
    }
    true
}

// Mirror of `vow_verify::c_emitter::non_modelable_reason`. Returns a
// human-readable explanation for why the verifier cannot model this
// function (used as a Warning diagnostic + skip-the-function gate).
// Empty string means the function IS modelable.
fn iop_unsupported_name(op: i64) -> String {
    if op == IOP_REM_F32() { return String::from("RemF32"); }
    if op == IOP_REM_F64() { return String::from("RemF64"); }
    if op == IOP_LOAD() { return String::from("Load"); }
    if op == IOP_STORE() { return String::from("Store"); }
    if op == IOP_REGION_ALLOC() { return String::from("RegionAlloc"); }
    if op == IOP_REGION_OPEN() { return String::from("RegionOpen"); }
    if op == IOP_REGION_CLOSE() { return String::from("RegionClose"); }
    if op == IOP_LINEAR_CONSUME() { return String::from("LinearConsume"); }
    if op == IOP_LINEAR_BORROW() { return String::from("LinearBorrow"); }
    if op == IOP_FIELD_SET() { return String::from("FieldSet"); }
    String::from("")
}

fn first_unsupported_opcode_name(f: IrFunction, m: IrModule, const_fn_indices: Vec<i64>) -> String {
    let blocks: Vec<IrBlock> = f.blocks;
    let mut bi: i64 = 0;
    while bi < blocks.len() {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            let op: i64 = inst.op;
            let name: String = iop_unsupported_name(op);
            if name.len() > 0 {
                return name;
            }
            if op == IOP_CALL() {
                if inst.dk == IDATA_CALL_EXTERN() {
                    if !is_known_builtin(inst.ds) {
                        return str3(String::from("Call extern `"), inst.ds, String::from("`"));
                    }
                } else if inst.dk == IDATA_CALL_TARGET() {
                    let target_fi: i64 = inst.dv;
                    if !vec_contains_i64(const_fn_indices, target_fi) {
                        let fns: Vec<IrFunction> = m.functions;
                        let mut found_modelable: bool = false;
                        let mut callee_name: String = String::from("");
                        let mut fi: i64 = 0;
                        while fi < fns.len() {
                            let callee: IrFunction = fns[fi];
                            if callee.id == target_fi {
                                callee_name = callee.name;
                                let cache_ids: Vec<i64> = Vec::new();
                                let cache_vals: Vec<i64> = Vec::new();
                                found_modelable = is_modelable(callee, m, const_fn_indices, cache_ids, cache_vals);
                                fi = fns.len();
                            }
                            fi = fi + 1;
                        }
                        if !found_modelable {
                            if callee_name.len() == 0 {
                                callee_name = str2(String::from("FuncId("), str2(i64_to_str(target_fi), String::from(")")));
                            }
                            return str3(String::from("Call target `"), callee_name, String::from("`"));
                        }
                    }
                } else {
                    return str3(String::from("Call (dk="), i64_to_str(inst.dk), String::from(")"));
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    String::from("")
}

fn non_modelable_reason(f: IrFunction, m: IrModule, const_fn_indices: Vec<i64>) -> String {
    if is_reserved_verifier_symbol(f.name) {
        return str3(String::from("function `"), f.name, String::from("` shadows a reserved verifier symbol"));
    }
    if f.effects != 0 {
        return str3(
            String::from("function `"),
            f.name,
            String::from("` has effects; the verifier model is restricted to pure functions"),
        );
    }
    let cache_ids: Vec<i64> = Vec::new();
    let cache_vals: Vec<i64> = Vec::new();
    if is_modelable(f, m, const_fn_indices, cache_ids, cache_vals) {
        return String::from("");
    }
    let offender: String = first_unsupported_opcode_name(f, m, const_fn_indices);
    let detail: String = {
        if offender.len() > 0 {
            str3(String::from("contains unsupported opcode `"), offender, String::from("`"))
        } else {
            String::from("calls a non-modelable callee")
        }
    };
    str5(
        String::from("function `"),
        f.name,
        String::from("` is not modelable in the verifier ("),
        detail,
        String::from(")"),
    )
}

fn collect_callees_dfs(f: IrFunction, m: IrModule, const_fn_indices: Vec<i64>,
                       modelable_cache_ids: Vec<i64>, modelable_cache_vals: Vec<i64>,
                       visited: Vec<i64>, order: Vec<i64>) {
    let blocks: Vec<IrBlock> = f.blocks;
    let mut bi: i64 = 0;
    while bi < blocks.len() {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_CALL() && inst.dk == IDATA_CALL_TARGET() {
                let target_fi: i64 = inst.dv;
                if !vec_contains_i64(const_fn_indices, target_fi) && !vec_contains_i64(visited, target_fi) {
                    let fns: Vec<IrFunction> = m.functions;
                    let mut fi: i64 = 0;
                    while fi < fns.len() {
                        let callee: IrFunction = fns[fi];
                        if callee.id == target_fi {
                            if is_modelable(callee, m, const_fn_indices, modelable_cache_ids, modelable_cache_vals) {
                                visited.push(target_fi);
                                collect_callees_dfs(callee, m, const_fn_indices, modelable_cache_ids, modelable_cache_vals, visited, order);
                                order.push(target_fi);
                            }
                            fi = fns.len();
                        }
                        fi = fi + 1;
                    }
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
}

fn collect_modelable_callees(f: IrFunction, m: IrModule, const_fn_indices: Vec<i64>) -> Vec<i64> {
    let modelable_cache_ids: Vec<i64> = Vec::new();
    let modelable_cache_vals: Vec<i64> = Vec::new();
    let visited: Vec<i64> = Vec::new();
    let order: Vec<i64> = Vec::new();
    collect_callees_dfs(f, m, const_fn_indices, modelable_cache_ids, modelable_cache_vals, visited, order);
    order
}

fn ir_ty_to_c(ty: i64) -> String {
    if ty == ITY_I32() { return String::from("int32_t"); }
    if ty == ITY_I64() { return String::from("int64_t"); }
    if ty == ITY_F32() { return String::from("float"); }
    if ty == ITY_F64() { return String::from("double"); }
    if ty == ITY_BOOL() { return String::from("_Bool"); }
    if ty == ITY_UNIT() { return String::from("int32_t"); }
    if ty == ITY_PTR() { return String::from("void*"); }
    if ty == ITY_LPTR() { return String::from("void*"); }
    if ty == ITY_U64() { return String::from("uint64_t"); }
    String::from("int64_t")
}

fn c_nondet_suffix(ty: i64) -> String {
    if ty == ITY_I32() { return String::from("int"); }
    if ty == ITY_I64() { return String::from("long"); }
    if ty == ITY_F32() { return String::from("float"); }
    if ty == ITY_F64() { return String::from("double"); }
    if ty == ITY_BOOL() { return String::from("bool"); }
    if ty == ITY_PTR() { return String::from("long"); }
    if ty == ITY_LPTR() { return String::from("long"); }
    if ty == ITY_U64() { return String::from("unsigned_long"); }
    String::from("int")
}

fn is_vec_model_constructor(name: String) -> bool {
    name == String::from("__vow_vec_new")
    || name == String::from("__vow_vec_new_val")
    || name == String::from("__vow_vec_new_in_arena")
    || name == String::from("__vow_vec_new_val_in_arena")
    || name == String::from("__vow_vec_from_raw_parts_copy_val")
    || name == String::from("__vow_vec_pin_to_root_val")
    || name == String::from("__vow_string_split")
    || name == String::from("__vow_string_split_in_arena")
}

fn is_string_model_constructor(name: String) -> bool {
    if is_string_fresh_helper(name) { return true; }
    name == String::from("__vow_string_new")
    || name == String::from("__vow_string_new_in_arena")
    || name == String::from("__vow_string_literal")
    || name == String::from("__vow_string_from_cstr")
    || name == String::from("__vow_string_from_cstr_in_arena")
    || name == String::from("__vow_string_clone")
    || name == String::from("__vow_string_clone_in_arena")
    || name == String::from("__vow_string_from_raw_parts_copy")
    || name == String::from("__vow_string_pin_to_root")
    || name == String::from("__vow_string_substr")
    || name == String::from("__vow_string_substr_in_arena")
    || name == String::from("__vow_string_substring")
    || name == String::from("__vow_string_substring_in_arena")
    || name == String::from("__vow_string_from_i64")
    || name == String::from("__vow_string_from_i64_in_arena")
}

fn is_map_model_constructor(name: String) -> bool {
    name == String::from("__vow_map_new")
    || name == String::from("__vow_map_new_in_arena")
}

fn map_model_receiver_arg(name: String) -> i64 {
    if name == String::from("__vow_map_insert_in_arena") { return 1; }
    if name == String::from("__vow_map_remove_in_arena") { return 1; }
    if name == String::from("__vow_map_insert") { return 0; }
    if name == String::from("__vow_map_remove") { return 0; }
    if name == String::from("__vow_map_get") { return 0; }
    if name == String::from("__vow_map_contains") { return 0; }
    if name == String::from("__vow_map_len") { return 0; }
    -1
}

fn vec_model_receiver_arg(name: String) -> i64 {
    if name == String::from("__vow_vec_push_val") { return 0; }
    if name == String::from("__vow_vec_get_val") { return 0; }
    if name == String::from("__vow_vec_len") { return 0; }
    if name == String::from("__vow_vec_pop") { return 0; }
    if name == String::from("__vow_vec_set_val") { return 0; }
    if name == String::from("__vow_vec_push_in_arena") { return 1; }
    if name == String::from("__vow_vec_push_val_in_arena") { return 1; }
    if name == String::from("__vow_vec_reserve_in_arena") { return 1; }
    -1
}

fn string_model_receiver_arg(name: String) -> i64 {
    if name == String::from("__vow_string_push_str_in_arena") { return 1; }
    if name == String::from("__vow_string_push_byte_in_arena") { return 1; }
    if name == String::from("__vow_string_substr_in_arena") { return 1; }
    if name == String::from("__vow_string_substring_in_arena") { return 1; }
    if name == String::from("__vow_string_push_str") { return 0; }
    if name == String::from("__vow_string_push_byte") { return 0; }
    if name == String::from("__vow_string_substr") { return 0; }
    if name == String::from("__vow_string_substring") { return 0; }
    if name == String::from("__vow_string_clone") { return 0; }
    if name == String::from("__vow_string_clone_in_arena") { return 1; }
    if name == String::from("__vow_string_pin_to_root") { return 0; }
    if name == String::from("__vow_string_len") { return 0; }
    if name == String::from("__vow_string_clear") { return 0; }
    if name == String::from("__vow_string_byte_at") { return 0; }
    if name == String::from("__vow_string_eq") { return 0; }
    if name == String::from("__vow_string_contains") { return 0; }
    if name == String::from("__vow_string_matches_literal_at") { return 0; }
    if name == String::from("__vow_string_print") { return 0; }
    -1
}

fn string_model_extra_arg(name: String) -> i64 {
    if name == String::from("__vow_string_push_str_in_arena") { return 2; }
    if name == String::from("__vow_string_push_str") { return 1; }
    if name == String::from("__vow_string_eq") { return 1; }
    if name == String::from("__vow_string_contains") { return 1; }
    -1
}

fn detect_const_fns(m: IrModule) -> Vec<i64> {
    let result: Vec<i64> = Vec::new();
    let fns: Vec<IrFunction> = m.functions;
    let mut fi: i64 = 0;
    while fi < fns.len() {
        let f: IrFunction = fns[fi];
        let blocks: Vec<IrBlock> = f.blocks;
        if blocks.len() == 1 {
            let blk: IrBlock = blocks[0];
            let insts: Vec<IrInst> = blk.insts;
            let non_arg: Vec<i64> = Vec::new();
            let mut ii: i64 = 0;
            while ii < insts.len() {
                let inst: IrInst = insts[ii];
                if inst.op != IOP_GET_ARG() {
                    non_arg.push(ii);
                }
                ii = ii + 1;
            }
            if non_arg.len() == 2 {
                let ci: IrInst = insts[non_arg[0]];
                let ri: IrInst = insts[non_arg[1]];
                if ri.op == IOP_RETURN() {
                    let ri_args: Vec<i64> = ri.args;
                    if ri_args.len() > 0 {
                        if ri_args[0] == ci.id {
                            if ci.op == IOP_CONST_I32() || ci.op == IOP_CONST_I64() || ci.op == IOP_CONST_U64() || ci.op == IOP_CONST_BOOL() {
                                result.push(fi);
                            }
                        }
                    }
                }
            }
        }
        fi = fi + 1;
    }
    result
}

fn const_fn_value_str(m: IrModule, fi: i64) -> String {
    let f: IrFunction = m.functions[fi];
    let blk: IrBlock = f.blocks[0];
    let insts: Vec<IrInst> = blk.insts;
    let mut ii: i64 = 0;
    while ii < insts.len() {
        let inst: IrInst = insts[ii];
        if inst.op == IOP_CONST_I32() {
            return i64_to_str(inst.dv);
        }
        if inst.op == IOP_CONST_I64() {
            return str2(i64_to_str(inst.dv), String::from("LL"));
        }
        if inst.op == IOP_CONST_U64() {
            return str2(i64_to_str(inst.dv), String::from("ULL"));
        }
        if inst.op == IOP_CONST_BOOL() {
            if inst.dv != 0 { return String::from("1"); }
            return String::from("0");
        }
        ii = ii + 1;
    }
    String::from("0")
}

fn const_fn_type_str(m: IrModule, fi: i64) -> String {
    let f: IrFunction = m.functions[fi];
    let blk: IrBlock = f.blocks[0];
    let insts: Vec<IrInst> = blk.insts;
    let mut ii: i64 = 0;
    while ii < insts.len() {
        let inst: IrInst = insts[ii];
        if inst.op == IOP_CONST_I32() { return String::from("int32_t"); }
        if inst.op == IOP_CONST_I64() { return String::from("int64_t"); }
        if inst.op == IOP_CONST_U64() { return String::from("uint64_t"); }
        if inst.op == IOP_CONST_BOOL() { return String::from("_Bool"); }
        ii = ii + 1;
    }
    String::from("int64_t")
}

fn collect_modelled_vars(f: IrFunction, constructor: String, prefix: String) -> Vec<i64> {
    let vars: Vec<i64> = Vec::new();
    let blocks: Vec<IrBlock> = f.blocks;
    let mut bi: i64 = 0;
    while bi < blocks.len() {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_CALL() && inst.dk == IDATA_CALL_EXTERN() {
                let ds: String = inst.ds;
                let alt_creator: bool = (prefix == String::from("__vow_vec_")
                    && is_vec_model_constructor(ds))
                    || (prefix == String::from("__vow_string_")
                        && is_string_model_constructor(ds))
                    || (prefix == String::from("__vow_map_")
                        && is_map_model_constructor(ds));
                let is_creator: bool = ds == constructor || alt_creator;
                if is_creator {
                    vec_insert_i64(vars, inst.id);
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    bi = 0;
    while bi < blocks.len() {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_CALL() && inst.dk == IDATA_CALL_EXTERN() {
                let ds: String = inst.ds;
                if str_starts_with(ds, prefix) {
                    let iargs: Vec<i64> = inst.args;
                    let receiver_arg: i64 = {
                        if prefix == String::from("__vow_vec_") {
                            vec_model_receiver_arg(ds)
                        } else if prefix == String::from("__vow_string_") {
                            string_model_receiver_arg(ds)
                        } else if prefix == String::from("__vow_map_") {
                            map_model_receiver_arg(ds)
                        } else {
                            0
                        }
                    };
                    if receiver_arg >= 0 && iargs.len() > receiver_arg {
                        vec_insert_i64(vars, iargs[receiver_arg]);
                    }
                    if prefix == String::from("__vow_string_") {
                        let extra_arg: i64 = string_model_extra_arg(ds);
                        if extra_arg >= 0 && iargs.len() > extra_arg {
                            vec_insert_i64(vars, iargs[extra_arg]);
                        }
                    }
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    let mut changed: bool = true;
    while changed {
        changed = false;
        bi = 0;
        while bi < blocks.len() {
            let blk: IrBlock = blocks[bi];
            let insts: Vec<IrInst> = blk.insts;
            let mut ii: i64 = 0;
            while ii < insts.len() {
                let inst: IrInst = insts[ii];
                if inst.op == IOP_UPSILON() && inst.dk == IDATA_PHI_TARGET() {
                    let iargs: Vec<i64> = inst.args;
                    if iargs.len() > 0 {
                        let phi_id: i64 = inst.dv;
                        let src_id: i64 = iargs[0];
                        if vec_contains_i64(vars, src_id) {
                            if vec_insert_i64(vars, phi_id) { changed = true; }
                        }
                        if vec_contains_i64(vars, phi_id) {
                            if vec_insert_i64(vars, src_id) { changed = true; }
                        }
                    }
                }
                ii = ii + 1;
            }
            bi = bi + 1;
        }
    }
    vars
}

fn collect_vec_vars(f: IrFunction) -> Vec<i64> {
    collect_modelled_vars(f, String::from("__vow_vec_new"), String::from("__vow_vec_"))
}

fn collect_string_vars(f: IrFunction) -> Vec<i64> {
    collect_modelled_vars(f, String::from("__vow_string_new"), String::from("__vow_string_"))
}

fn collect_hashmap_vars(f: IrFunction) -> Vec<i64> {
    collect_modelled_vars(f, String::from("__vow_map_new"), String::from("__vow_map_"))
}

fn collect_btreemap_vars(f: IrFunction) -> Vec<i64> {
    collect_modelled_vars(f, String::from("__vow_btreemap_new"), String::from("__vow_btreemap_"))
}

fn is_option_returning_extern(name: String) -> bool {
    name == String::from("__vow_string_parse_i64_opt")
    || name == String::from("__vow_string_parse_u64_opt")
    || name == String::from("__vow_btreemap_insert")
    || name == String::from("__vow_btreemap_get")
}

fn collect_option_vars(f: IrFunction) -> Vec<i64> {
    let result: Vec<i64> = Vec::new();
    let blocks: Vec<IrBlock> = f.blocks;
    let mut bi: i64 = 0;
    while bi < blocks.len() {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_CALL() && inst.dk == IDATA_CALL_EXTERN() && is_option_returning_extern(inst.ds) {
                result.push(inst.id);
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    // Propagate Option tag through Upsilon/Phi pairs so downstream FieldGet is modelled.
    let mut changed: bool = true;
    while changed {
        changed = false;
        bi = 0;
        while bi < blocks.len() {
            let blk: IrBlock = blocks[bi];
            let insts: Vec<IrInst> = blk.insts;
            let mut ii: i64 = 0;
            while ii < insts.len() {
                let inst: IrInst = insts[ii];
                if inst.op == IOP_UPSILON() && inst.dk == IDATA_PHI_TARGET() {
                    let iargs: Vec<i64> = inst.args;
                    if iargs.len() > 0 {
                        let phi_id: i64 = inst.dv;
                        let src_id: i64 = iargs[0];
                        if vec_contains_i64(result, src_id) {
                            if vec_insert_i64(result, phi_id) { changed = true; }
                        }
                        if vec_contains_i64(result, phi_id) {
                            if vec_insert_i64(result, src_id) { changed = true; }
                        }
                    }
                }
                ii = ii + 1;
            }
            bi = bi + 1;
        }
    }
    result
}

fn emit_unmodelled(out: String, inst: IrInst) {
    let id: i64 = inst.id;
    out.push_str(str3(String::from("  /* opcode "), opcode_name(inst.op), String::from(" not modelled */\n")));
    if inst.ty != ITY_UNIT() {
        out.push_str(str4(
            String::from("  v"), i64_to_str(id),
            String::from(" = __VERIFIER_nondet_"), str2(c_nondet_suffix(inst.ty), String::from("();\n"))
        ));
    }
}

// Sentinel vow_id paired with `emit_unsupported_for_verification`.
// Mirrors `vow_verify::c_emitter::UNSUPPORTED_OP_VOW_ID = u32::MAX`. Reserved so
// the diagnostic pipeline can distinguish a verifier-limitation failure from
// a real vow violation. Single source of truth for the self-hosted side; the
// stringified form is derived via `i64_to_str` so the two cannot drift.
fn unsupported_op_vow_id() -> i64 {
    4294967295
}

fn unsupported_op_vow_id_str() -> String {
    i64_to_str(unsupported_op_vow_id())
}

// Fail-closed marker for opcodes that have side effects but no verifier model.
// The assertion text must be exactly `vow:<id>` — `parse_vow_id` (and the Rust
// `extract_vow_id`) accept only pure digits after `vow:`, so any trailing text
// would defeat the sentinel. Descriptive context lives in a separate C comment.
fn emit_unsupported_for_verification(out: String, inst: IrInst) {
    let id: i64 = inst.id;
    out.push_str(str3(
        String::from("  /* unsupported opcode in verifier model: "),
        opcode_name(inst.op), String::from(" */\n")
    ));
    out.push_str(str3(
        String::from("  __ESBMC_assert(0, \"vow:"),
        unsupported_op_vow_id_str(), String::from("\");\n")
    ));
    if inst.ty != ITY_UNIT() {
        out.push_str(str4(
            String::from("  v"), i64_to_str(id),
            String::from(" = __VERIFIER_nondet_"), str2(c_nondet_suffix(inst.ty), String::from("();\n"))
        ));
    }
}

fn emit_binop(out: String, ty: i64, id: i64, a: i64, b: i64, op: String) {
    out.push_str(str7(
        String::from("  v"),
        i64_to_str(id), String::from(" = v"), i64_to_str(a),
        str2(String::from(" "), op),
        str2(String::from(" v"), i64_to_str(b)),
        String::from(";\n")
    ));
}

fn emit_cmp(out: String, id: i64, a: i64, b: i64, op: String) {
    out.push_str(str7(
        String::from("  v"), i64_to_str(id),
        String::from(" = (v"), i64_to_str(a),
        str2(String::from(" "), op),
        str2(String::from(" v"), i64_to_str(b)),
        String::from(");\n")
    ));
}

fn emit_inst(out: String, inst: IrInst, f: IrFunction, vec_vars: Vec<i64>, string_vars: Vec<i64>,
             hashmap_vars: Vec<i64>, btreemap_vars: Vec<i64>, option_vars: Vec<i64>,
             const_fn_indices: Vec<i64>, modelable_fi_set: Vec<i64>, m: IrModule,
             const_str_ids: Vec<i64>, const_str_idxs: Vec<i64>,
             eq_lo: Vec<i64>, eq_hi: Vec<i64>,
             vec_max: i64, string_max: i64, hashmap_max: i64, btreemap_max: i64) {
    let id: i64 = inst.id;
    let op: i64 = inst.op;
    let ty: i64 = inst.ty;
    let iargs: Vec<i64> = inst.args;

    if op == IOP_CONST_I32() {
        out.push_str(str3(String::from("  v"), i64_to_str(id),
            str3(String::from(" = "), i64_to_str(inst.dv), String::from(";\n"))));
        return;
    }
    if op == IOP_CONST_I64() {
        out.push_str(str3(String::from("  v"), i64_to_str(id),
            str3(String::from(" = "), i64_to_str(inst.dv), String::from("LL;\n"))));
        return;
    }
    if op == IOP_CONST_F32() {
        out.push_str(str4(String::from("  v"), i64_to_str(id), String::from(" = "),
            str2(i64_to_str(inst.dv), String::from("f;\n"))));
        return;
    }
    if op == IOP_CONST_F64() {
        out.push_str(str4(String::from("  v"), i64_to_str(id), String::from(" = "),
            str2(i64_to_str(inst.dv), String::from(";\n"))));
        return;
    }
    if op == IOP_CONST_BOOL() {
        let bval: String = if inst.dv != 0 { String::from("1") } else { String::from("0") };
        out.push_str(str4(String::from("  v"), i64_to_str(id), String::from(" = "),
            str2(bval, String::from(";\n"))));
        return;
    }
    if op == IOP_CONST_UNIT() {
        out.push_str(str3(String::from("  v"), i64_to_str(id), String::from(" = 0;\n")));
        return;
    }
    if op == IOP_CONST_U64() {
        out.push_str(str3(String::from("  v"), i64_to_str(id),
            str3(String::from(" = "), i64_to_str(inst.dv), String::from("ULL;\n"))));
        return;
    }
    if op == IOP_CONST_STR() {
        out.push_str(str3(String::from("  v"), i64_to_str(id), String::from(" = 0; /* string not modelled */\n")));
        return;
    }

    if op == IOP_GET_ARG() { return; }

    if op == IOP_WADD_I32() || op == IOP_WADD_I64() || op == IOP_CADD_I32() || op == IOP_CADD_I64() || op == IOP_WADD_U64() || op == IOP_CADD_U64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("+"));
        return;
    }
    if op == IOP_WSUB_I32() || op == IOP_WSUB_I64() || op == IOP_CSUB_I32() || op == IOP_CSUB_I64() || op == IOP_WSUB_U64() || op == IOP_CSUB_U64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("-"));
        return;
    }
    if op == IOP_WMUL_I32() || op == IOP_WMUL_I64() || op == IOP_CMUL_I32() || op == IOP_CMUL_I64() || op == IOP_WMUL_U64() || op == IOP_CMUL_U64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("*"));
        return;
    }
    if op == IOP_WDIV_I32() || op == IOP_WDIV_I64() || op == IOP_CDIV_I32() || op == IOP_CDIV_I64() || op == IOP_WDIV_U64() || op == IOP_CDIV_U64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("/"));
        return;
    }
    if op == IOP_WREM_I32() || op == IOP_WREM_I64() || op == IOP_CREM_I32() || op == IOP_CREM_I64() || op == IOP_WREM_U64() || op == IOP_CREM_U64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("%"));
        return;
    }

    if op == IOP_ADD_F32() || op == IOP_ADD_F64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("+"));
        return;
    }
    if op == IOP_SUB_F32() || op == IOP_SUB_F64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("-"));
        return;
    }
    if op == IOP_MUL_F32() || op == IOP_MUL_F64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("*"));
        return;
    }
    if op == IOP_DIV_F32() || op == IOP_DIV_F64() {
        emit_binop(out, ty, id, iargs[0], iargs[1], String::from("/"));
        return;
    }
    if op == IOP_REM_F32() || op == IOP_REM_F64() {
        out.push_str(str3(String::from("  /* float rem not modelled */ v"), i64_to_str(id), String::from(" = 0;\n")));
        return;
    }

    if op == IOP_EQ_I32() || op == IOP_EQ_I64() || op == IOP_EQ_F32() || op == IOP_EQ_F64() || op == IOP_EQ_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("=="));
        return;
    }
    if op == IOP_NE_I32() || op == IOP_NE_I64() || op == IOP_NE_F32() || op == IOP_NE_F64() || op == IOP_NE_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("!="));
        return;
    }
    if op == IOP_LT_I32() || op == IOP_LT_I64() || op == IOP_LT_F32() || op == IOP_LT_F64() || op == IOP_LT_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("<"));
        return;
    }
    if op == IOP_LE_I32() || op == IOP_LE_I64() || op == IOP_LE_F32() || op == IOP_LE_F64() || op == IOP_LE_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("<="));
        return;
    }
    if op == IOP_GT_I32() || op == IOP_GT_I64() || op == IOP_GT_F32() || op == IOP_GT_F64() || op == IOP_GT_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from(">"));
        return;
    }
    if op == IOP_GE_I32() || op == IOP_GE_I64() || op == IOP_GE_F32() || op == IOP_GE_F64() || op == IOP_GE_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from(">="));
        return;
    }

    if op == IOP_NOT() {
        out.push_str(str4(String::from("  v"), i64_to_str(id), String::from(" = !v"),
            str2(i64_to_str(iargs[0]), String::from(";\n"))));
        return;
    }
    if op == IOP_AND() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("&&"));
        return;
    }
    if op == IOP_OR() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("||"));
        return;
    }
    if op == IOP_BITAND_I64() || op == IOP_BITAND_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("&"));
        return;
    }
    if op == IOP_BITOR_I64() || op == IOP_BITOR_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("|"));
        return;
    }
    if op == IOP_XOR_I32() || op == IOP_XOR_I64() || op == IOP_XOR_U64() {
        emit_cmp(out, id, iargs[0], iargs[1], String::from("^"));
        return;
    }
    if op == IOP_SHL_I64() || op == IOP_SHL_U64() {
        if op == IOP_SHL_I64() {
            out.push_str(str7(
                String::from("  v"), i64_to_str(id), String::from(" = __vow_shl_i64(v"),
                i64_to_str(iargs[0]), String::from(", v"), i64_to_str(iargs[1]),
                String::from(");\n")
            ));
        } else {
            out.push_str(str7(
                String::from("  v"), i64_to_str(id), String::from(" = __vow_shl_u64(v"),
                i64_to_str(iargs[0]), String::from(", v"), i64_to_str(iargs[1]),
                String::from(");\n")
            ));
        }
        return;
    }
    if op == IOP_SHR_I64() || op == IOP_SHR_U64() {
        if op == IOP_SHR_I64() {
            out.push_str(str7(
                String::from("  v"), i64_to_str(id), String::from(" = __vow_shr_i64(v"),
                i64_to_str(iargs[0]), String::from(", v"), i64_to_str(iargs[1]),
                String::from(");\n")
            ));
        } else {
            out.push_str(str7(
                String::from("  v"), i64_to_str(id), String::from(" = __vow_shr_u64(v"),
                i64_to_str(iargs[0]), String::from(", v"), i64_to_str(iargs[1]),
                String::from(");\n")
            ));
        }
        return;
    }

    if op == IOP_CAST_I64_TO_U64() {
        out.push_str(str4(String::from("  v"), i64_to_str(id), String::from(" = (uint64_t)v"),
            str2(i64_to_str(iargs[0]), String::from(";\n"))));
        return;
    }
    if op == IOP_CAST_U64_TO_I64() {
        out.push_str(str4(String::from("  v"), i64_to_str(id), String::from(" = (int64_t)v"),
            str2(i64_to_str(iargs[0]), String::from(";\n"))));
        return;
    }

    if op == IOP_VOW_REQ() {
        out.push_str(str3(String::from("  __ESBMC_assume(v"), i64_to_str(iargs[0]), String::from(");\n")));
        return;
    }
    if op == IOP_VOW_ENS() || op == IOP_VOW_INV() {
        let vow_id: i64 = inst.dv;
        out.push_str(str5(String::from("  __ESBMC_assert(v"), i64_to_str(iargs[0]),
            String::from(", \"vow:"), i64_to_str(vow_id), String::from("\");\n")));
        return;
    }

    if op == IOP_BRANCH() {
        let cond: i64 = iargs[0];
        let then_b: i64 = inst.dv;
        let else_b: i64 = inst.dv2;
        out.push_str(str6(String::from("  if (v"), i64_to_str(cond),
            String::from(") goto block"), i64_to_str(then_b),
            String::from("; else goto block"), str2(i64_to_str(else_b), String::from(";\n"))));
        return;
    }
    if op == IOP_JUMP() {
        let target: i64 = inst.dv;
        out.push_str(str3(String::from("  goto block"), i64_to_str(target), String::from(";\n")));
        return;
    }
    if op == IOP_RETURN() {
        if iargs.len() > 0 {
            let val_id: i64 = iargs[0];
            if vec_contains_i64(vec_vars, val_id) || vec_contains_i64(string_vars, val_id) || vec_contains_i64(hashmap_vars, val_id) || vec_contains_i64(btreemap_vars, val_id) || vec_contains_i64(option_vars, val_id) {
                out.push_str(String::from("  return 0; /* modelled type return */\n"));
            } else {
                out.push_str(str3(String::from("  return v"), i64_to_str(val_id), String::from(";\n")));
            }
        } else {
            out.push_str(String::from("  return 0;\n"));
        }
        return;
    }
    if op == IOP_UNREACHABLE() {
        out.push_str(String::from("  __ESBMC_assume(0); /* unreachable */\n"));
        return;
    }

    if op == IOP_PHI() { return; }
    if op == IOP_UPSILON() { return; }
    if op == IOP_DEBUG_CALL() { return; }

    if op == IOP_CALL() {
        if inst.dk == IDATA_CALL_EXTERN() {
            let ds: String = inst.ds;
            if str_starts_with(ds, String::from("__vow_vec_")) {
                emit_vec_op(out, inst, vec_max);
                return;
            }
            if str_starts_with(ds, String::from("__vow_string_")) {
                emit_string_op(out, inst, f, m, vec_max, string_max, const_str_ids, const_str_idxs, eq_lo, eq_hi);
                return;
            }
            if str_starts_with(ds, String::from("__vow_map_")) {
                emit_map_op(out, inst, hashmap_max);
                return;
            }
            if str_starts_with(ds, String::from("__vow_btreemap_")) {
                emit_btreemap_op(out, inst, btreemap_max);
                return;
            }
            emit_unsupported_for_verification(out, inst);
            return;
        }
        if inst.dk == IDATA_CALL_TARGET() {
            let func_idx: i64 = inst.dv;
            if vec_contains_i64(const_fn_indices, func_idx) {
                let val_s: String = const_fn_value_str(m, func_idx);
                out.push_str(str4(String::from("  v"),
                    i64_to_str(id), String::from(" = "), str2(val_s, String::from(";\n"))));
                return;
            }
            if vec_contains_i64(modelable_fi_set, func_idx) {
                let fns: Vec<IrFunction> = m.functions;
                let mut fi: i64 = 0;
                while fi < fns.len() {
                    let callee: IrFunction = fns[fi];
                    if callee.id == func_idx {
                        let args_str: String = String::from("");
                        let callee_params: Vec<i64> = callee.params;
                        let mut arg_count: i64 = 0;
                        let mut ai: i64 = 0;
                        while ai < iargs.len() {
                            if ai < callee_params.len() && callee_params[ai] != ITY_UNIT() {
                                if arg_count > 0 {
                                    args_str.push_str(String::from(", "));
                                }
                                args_str.push_str(vid(iargs[ai]));
                                arg_count = arg_count + 1;
                            }
                            ai = ai + 1;
                        }
                        if ty != ITY_UNIT() {
                            out.push_str(str6(String::from("  v"), i64_to_str(id),
                                String::from(" = "), callee.name,
                                String::from("("), str2(args_str, String::from(");\n"))));
                        } else {
                            out.push_str(str4(String::from("  "), callee.name,
                                String::from("("), str2(args_str, String::from(");\n"))));
                        }
                        fi = fns.len();
                    }
                    fi = fi + 1;
                }
                return;
            }
        }
        emit_unsupported_for_verification(out, inst);
        return;
    }

    if op == IOP_FIELD_GET() {
        if vec_contains_i64(vec_vars, id) {
            let ids: String = i64_to_str(id);
            out.push_str(str3(String::from("  /* FieldGet -> vec */ v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
            out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
            out.push_str(str4(ids, String::from(".len <= "), i64_to_str(vec_max), String::from(");\n")));
            return;
        }
        if vec_contains_i64(string_vars, id) {
            let ids: String = i64_to_str(id);
            out.push_str(str3(String::from("  /* FieldGet -> string */ v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
            out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
            out.push_str(str4(ids, String::from(".len <= "), i64_to_str(string_max), String::from(");\n")));
            return;
        }
        if vec_contains_i64(hashmap_vars, id) {
            let ids: String = i64_to_str(id);
            out.push_str(str3(String::from("  /* FieldGet -> hashmap */ v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
            out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
            out.push_str(str4(ids, String::from(".len <= "), i64_to_str(hashmap_max), String::from(");\n")));
            return;
        }
        if vec_contains_i64(btreemap_vars, id) {
            let ids: String = i64_to_str(id);
            out.push_str(str3(String::from("  /* FieldGet -> btreemap */ v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
            out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
            out.push_str(str4(ids, String::from(".len <= "), i64_to_str(btreemap_max), String::from(");\n")));
            // Sorted-keys assume: get/contains/insert C model requires ascending-key state.
            out.push_str(str3(String::from("  for (int64_t __si = 0; __si + 1 < v"), ids, String::from(".len; __si++)\n")));
            out.push_str(str3(String::from("    __ESBMC_assume(v"), ids, String::from(".keys[__si] < v")));
            out.push_str(str3(ids, String::from(".keys[__si + 1]);\n"), String::from("")));
            return;
        }
        // Option projection: FieldGet[0] -> .tag, FieldGet[1+] -> .payload.
        // Triggered by `?`, `match Option::Some(x) => ...`, and explicit field reads
        // on Option-returning calls (parse_i64_opt, btreemap_insert, btreemap_get).
        if iargs.len() > 0 && vec_contains_i64(option_vars, iargs[0]) && inst.dk == IDATA_FIELD() {
            let ids: String = i64_to_str(id);
            let srcs: String = i64_to_str(iargs[0]);
            if inst.dv == 0 {
                out.push_str(str5(String::from("  v"), ids, String::from(" = v"), srcs, String::from(".tag;\n")));
            } else {
                out.push_str(str5(String::from("  v"), ids, String::from(" = v"), srcs, String::from(".payload;\n")));
            }
            return;
        }
        emit_unmodelled(out, inst);
        return;
    }

    if op == IOP_REGION_OPEN() || op == IOP_REGION_CLOSE() {
        out.push_str(String::from("  /* verifier no-op: region scope marker */\n"));
        return;
    }

    if op == IOP_LOAD() || op == IOP_STORE() || op == IOP_REGION_ALLOC()
       || op == IOP_LINEAR_CONSUME() || op == IOP_LINEAR_BORROW() || op == IOP_FIELD_SET() {
        emit_unsupported_for_verification(out, inst);
        return;
    }

    emit_unsupported_for_verification(out, inst);
}

fn emit_vec_op(out: String, inst: IrInst, vec_max: i64) {
    let id: i64 = inst.id;
    let ds: String = inst.ds;
    let iargs: Vec<i64> = inst.args;

    if ds == String::from("__vow_vec_new")
       || ds == String::from("__vow_vec_new_val")
       || ds == String::from("__vow_vec_new_in_arena")
       || ds == String::from("__vow_vec_new_val_in_arena") {
        let ids: String = i64_to_str(id);
        out.push_str(str3(String::from("  v"), ids, String::from(".len = 0;\n")));
        return;
    }
    if ds == String::from("__vow_vec_from_raw_parts_copy_val") {
        let len_arg: i64 = iargs[1];
        let ids: String = i64_to_str(id);
        let ls: String = i64_to_str(len_arg);
        out.push_str(str5(String::from("  __ESBMC_assume(v"), ls,
            String::from(" >= 0 && v"), ls,
            str3(String::from(" < "), i64_to_str(vec_max), String::from(");\n"))));
        out.push_str(str5(String::from("  v"), ids, String::from(".len = v"), ls, String::from(";\n")));
        return;
    }
    if ds == String::from("__vow_vec_pin_to_root_val") {
        let src: i64 = iargs[0];
        out.push_str(str5(String::from("  v"), i64_to_str(id),
            String::from(" = v"), i64_to_str(src), String::from(";\n")));
        return;
    }
    if ds == String::from("__vow_vec_push_val")
       || ds == String::from("__vow_vec_push_val_in_arena") {
        let vec_arg: i64 = { if ds == String::from("__vow_vec_push_val_in_arena") { 1 } else { 0 } };
        let val_arg: i64 = { if ds == String::from("__vow_vec_push_val_in_arena") { 2 } else { 1 } };
        let vec: i64 = iargs[vec_arg];
        let val: i64 = iargs[val_arg];
        let vs: String = i64_to_str(vec);
        let vas: String = i64_to_str(val);
        out.push_str(str5(String::from("  __ESBMC_assert(v"), vs,
            String::from(".len < "), i64_to_str(vec_max), String::from(", \"vec capacity\");\n")));
        out.push_str(str6(String::from("  v"), vs, String::from(".data[v"), vs,
            String::from(".len] = v"), str2(vas, String::from(";\n"))));
        out.push_str(str3(String::from("  v"), vs, String::from(".len++;\n")));
        return;
    }
    if ds == String::from("__vow_vec_push_in_arena") {
        let vec: i64 = iargs[1];
        let vs: String = i64_to_str(vec);
        out.push_str(str5(String::from("  __ESBMC_assert(v"), vs,
            String::from(".len < "), i64_to_str(vec_max), String::from(", \"vec capacity\");\n")));
        out.push_str(str5(String::from("  v"), vs, String::from(".data[v"), vs,
            String::from(".len] = __VERIFIER_nondet_long();\n")));
        out.push_str(str3(String::from("  v"), vs, String::from(".len++;\n")));
        return;
    }
    if ds == String::from("__vow_vec_reserve_in_arena") {
        return;
    }
    if ds == String::from("__vow_vec_get_val") {
        let vec: i64 = iargs[0];
        let idx: i64 = iargs[1];
        let vs: String = i64_to_str(vec);
        let is: String = i64_to_str(idx);
        out.push_str(str7(String::from("  __ESBMC_assert(v"), is,
            String::from(" >= 0 && v"), is,
            String::from(" < v"), vs, String::from(".len, \"vec bounds\");\n")));
        out.push_str(str5(String::from("  v"), i64_to_str(id),
            String::from(" = v"), vs, str3(String::from(".data[v"),
            is, String::from("];\n"))));
        return;
    }
    if ds == String::from("__vow_vec_len") {
        let vec: i64 = iargs[0];
        out.push_str(str5(String::from("  v"), i64_to_str(id),
            String::from(" = v"), i64_to_str(vec), String::from(".len;\n")));
        return;
    }
    if ds == String::from("__vow_vec_pop") {
        let vec: i64 = iargs[0];
        let vs: String = i64_to_str(vec);
        out.push_str(str5(String::from("  if (v"), vs,
            String::from(".len > 0) { v"), i64_to_str(vec),
            String::from(".len--; }\n")));
        return;
    }
    if ds == String::from("__vow_vec_set_val") {
        let vec: i64 = iargs[0];
        let idx: i64 = iargs[1];
        let val: i64 = iargs[2];
        let vs: String = i64_to_str(vec);
        let is: String = i64_to_str(idx);
        let vas: String = i64_to_str(val);
        out.push_str(str7(String::from("  __ESBMC_assert(v"), is,
            String::from(" >= 0 && v"), is,
            String::from(" < v"), vs, String::from(".len, \"vec bounds\");\n")));
        out.push_str(str6(String::from("  v"), vs, String::from(".data[v"),
            is, String::from("] = v"), str2(vas, String::from(";\n"))));
        return;
    }
    emit_unmodelled(out, inst);
}

// Walk every instruction in the function and append each unordered (lo, hi)
// __vow_string_eq operand pair into the parallel `eq_lo`/`eq_hi` arrays, in
// IR-traversal order with linear deduplication. Mirrors the Rust emitter's
// `compute_string_eq_pairs`.
fn compute_string_eq_pairs(blocks: Vec<IrBlock>, eq_lo: Vec<i64>, eq_hi: Vec<i64>) {
    let n_blocks: i64 = blocks.len();
    let mut bi: i64 = 0;
    while bi < n_blocks {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_CALL() && inst.dk == IDATA_CALL_EXTERN()
                && inst.ds == String::from("__vow_string_eq") {
                let ea: Vec<i64> = inst.args;
                if ea.len() == 2 {
                    let a: i64 = ea[0];
                    let b: i64 = ea[1];
                    if a != b {
                        let lo: i64 = if a < b { a } else { b };
                        let hi: i64 = if a < b { b } else { a };
                        let mut found: bool = false;
                        let mut pi: i64 = 0;
                        while pi < eq_lo.len() {
                            if eq_lo[pi] == lo && eq_hi[pi] == hi { found = true; }
                            pi = pi + 1;
                        }
                        if !found {
                            eq_lo.push(lo);
                            eq_hi.push(hi);
                        }
                    }
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
}

// Re-sample every cached `__str_eq_<lo>_<hi>` whose pair touches `operand`.
// Called immediately after each modeled string mutation so the verifier
// cannot prove a stale equality across the mutation.
fn emit_string_eq_invalidate(out: String, operand: i64, eq_lo: Vec<i64>, eq_hi: Vec<i64>) {
    let n: i64 = eq_lo.len();
    let mut i: i64 = 0;
    while i < n {
        let lo: i64 = eq_lo[i];
        let hi: i64 = eq_hi[i];
        if lo == operand || hi == operand {
            out.push_str(str5(String::from("  __str_eq_"), i64_to_str(lo),
                String::from("_"), i64_to_str(hi),
                String::from(" = __VERIFIER_nondet_bool();\n")));
        }
        i = i + 1;
    }
}

fn emit_nondet_string_len(out: String, id: i64, string_max: i64) {
    let ids: String = i64_to_str(id);
    out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
    out.push_str(str5(String::from("  __ESBMC_assume(v"), ids,
        String::from(".len >= 0 && v"), ids,
        str3(String::from(".len < "), i64_to_str(string_max), String::from(");\n"))));
}

fn emit_nondet_vec_len(out: String, id: i64, vec_max: i64) {
    let ids: String = i64_to_str(id);
    out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
    out.push_str(str5(String::from("  __ESBMC_assume(v"), ids,
        String::from(".len >= 0 && v"), ids,
        str3(String::from(".len < "), i64_to_str(vec_max), String::from(");\n"))));
}

fn const_str_index_for(ids: Vec<i64>, idxs: Vec<i64>, id: i64) -> i64 {
    let mut i: i64 = 0;
    while i < ids.len() {
        if ids[i] == id {
            return idxs[i];
        }
        i = i + 1;
    }
    -1
}

fn emit_string_op(out: String, inst: IrInst, f: IrFunction, m: IrModule, vec_max: i64, string_max: i64,
                  const_str_ids: Vec<i64>, const_str_idxs: Vec<i64>,
                  eq_lo: Vec<i64>, eq_hi: Vec<i64>) {
    let id: i64 = inst.id;
    let ds: String = inst.ds;
    let iargs: Vec<i64> = inst.args;

    if ds == String::from("__vow_string_new") || ds == String::from("__vow_string_new_in_arena") {
        let len_arg: i64 = if ds == String::from("__vow_string_new_in_arena") { iargs[2] } else { iargs[1] };
        let ids: String = i64_to_str(id);
        let ls: String = i64_to_str(len_arg);
        out.push_str(str5(String::from("  __ESBMC_assume(v"), ls,
            String::from(" >= 0 && v"), ls,
            str3(String::from(" < "), i64_to_str(string_max), String::from(");\n"))));
        out.push_str(str5(String::from("  v"), ids, String::from(".len = v"), ls, String::from(";\n")));
        return;
    }
    if ds == String::from("__vow_string_from_cstr")
        || ds == String::from("__vow_string_from_cstr_in_arena") {
        let ids: String = i64_to_str(id);
        out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
        out.push_str(str5(String::from("  __ESBMC_assume(v"), ids,
            String::from(".len >= 0 && v"), ids,
            str3(String::from(".len < "), i64_to_str(string_max), String::from(");\n"))));
        return;
    }
    if ds == String::from("__vow_string_literal") {
        let lit_idx: i64 = if iargs.len() > 0 { const_str_index_for(const_str_ids, const_str_idxs, iargs[0]) } else { -1 };
        let ids: String = i64_to_str(id);
        if lit_idx >= 0 {
            let strings: Vec<String> = m.strings;
            if lit_idx < strings.len() {
                out.push_str(str5(String::from("  v"), ids, String::from(".len = "), i64_to_str(strings[lit_idx].len()), String::from(";\n")));
                return;
            }
        }
        out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
        out.push_str(str5(String::from("  __ESBMC_assume(v"), ids,
            String::from(".len >= 0 && v"), ids,
            str3(String::from(".len < "), i64_to_str(string_max), String::from(");\n"))));
        return;
    }
    if ds == String::from("__vow_string_from_raw_parts_copy") {
        let len_arg: i64 = iargs[1];
        let ids: String = i64_to_str(id);
        let ls: String = i64_to_str(len_arg);
        out.push_str(str5(String::from("  __ESBMC_assume(v"), ls,
            String::from(" >= 0 && v"), ls,
            str3(String::from(" < "), i64_to_str(string_max), String::from(");\n"))));
        out.push_str(str5(String::from("  v"), ids, String::from(".len = v"), ls, String::from(";\n")));
        return;
    }
    if ds == String::from("__vow_string_clone") || ds == String::from("__vow_string_clone_in_arena") || ds == String::from("__vow_string_pin_to_root") {
        let src_idx: i64 = if ds == String::from("__vow_string_clone_in_arena") { 1 } else { 0 };
        let src: i64 = iargs[src_idx];
        out.push_str(str5(String::from("  v"), i64_to_str(id),
            String::from(" = v"), i64_to_str(src), String::from(";\n")));
        return;
    }
    if ds == String::from("__vow_string_from_i64") || ds == String::from("__vow_string_from_i64_in_arena") {
        let ids: String = i64_to_str(id);
        out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
        out.push_str(str5(String::from("  __ESBMC_assume(v"), ids,
            String::from(".len >= 0 && v"), ids,
            str3(String::from(".len < "), i64_to_str(string_max), String::from(");\n"))));
        return;
    }
    if ds == String::from("__vow_string_split") || ds == String::from("__vow_string_split_in_arena") {
        emit_nondet_vec_len(out, id, vec_max);
        return;
    }
    if is_string_fresh_helper(ds) {
        emit_nondet_string_len(out, id, string_max);
        return;
    }
    if ds == String::from("__vow_string_len") {
        let s: i64 = iargs[0];
        out.push_str(str5(String::from("  v"), i64_to_str(id),
            String::from(" = v"), i64_to_str(s), String::from(".len;\n")));
        return;
    }
    if ds == String::from("__vow_string_push_str") || ds == String::from("__vow_string_push_str_in_arena") {
        let dest: i64 = if ds == String::from("__vow_string_push_str_in_arena") { iargs[1] } else { iargs[0] };
        let src: i64 = if ds == String::from("__vow_string_push_str_in_arena") { iargs[2] } else { iargs[1] };
        let dests: String = i64_to_str(dest);
        let srcs: String = i64_to_str(src);
        out.push_str(str7(String::from("  __ESBMC_assert(v"), dests,
            String::from(".len + v"), srcs,
            String::from(".len <= "), i64_to_str(string_max),
            String::from(", \"string capacity\");\n")));
        out.push_str(str5(String::from("  v"), dests,
            String::from(".len += v"), srcs, String::from(".len;\n")));
        emit_string_eq_invalidate(out, dest, eq_lo, eq_hi);
        return;
    }
    if ds == String::from("__vow_string_push_byte") || ds == String::from("__vow_string_push_byte_in_arena") {
        let s: i64 = if ds == String::from("__vow_string_push_byte_in_arena") { iargs[1] } else { iargs[0] };
        let byte: i64 = if ds == String::from("__vow_string_push_byte_in_arena") { iargs[2] } else { iargs[1] };
        let ss: String = i64_to_str(s);
        out.push_str(str5(String::from("  __ESBMC_assert(v"), ss,
            String::from(".len < "), i64_to_str(string_max), String::from(", \"string capacity\");\n")));
        out.push_str(str6(String::from("  v"), ss, String::from(".data[v"), ss,
            String::from(".len] = (int8_t)v"), str2(i64_to_str(byte), String::from(";\n"))));
        out.push_str(str3(String::from("  v"), ss, String::from(".len++;\n")));
        emit_string_eq_invalidate(out, s, eq_lo, eq_hi);
        return;
    }
    if ds == String::from("__vow_string_clear") {
        let s: i64 = iargs[0];
        out.push_str(str3(String::from("  v"), i64_to_str(s), String::from(".len = 0;\n")));
        emit_string_eq_invalidate(out, s, eq_lo, eq_hi);
        return;
    }
    if ds == String::from("__vow_string_byte_at") {
        let s: i64 = iargs[0];
        let idx: i64 = iargs[1];
        let ss: String = i64_to_str(s);
        let is: String = i64_to_str(idx);
        let ids: String = i64_to_str(id);
        out.push_str(str7(String::from("  __ESBMC_assert(v"), is,
            String::from(" >= 0 && v"), is,
            String::from(" < v"), ss, String::from(".len, \"string bounds\");\n")));
        out.push_str(str5(String::from("  v"), ids,
            String::from(" = (int64_t)(unsigned char)v"), ss,
            str3(String::from(".data[v"), is, String::from("];\n"))));
        out.push_str(str5(String::from("  __ESBMC_assume(v"), ids,
            String::from(" >= 0 && v"), ids, String::from(" <= 255);\n")));
        return;
    }
    if ds == String::from("__vow_string_eq") {
        let a: i64 = iargs[0];
        let b: i64 = iargs[1];
        let ids: String = i64_to_str(id);
        if a == b {
            out.push_str(str3(String::from("  v"), ids, String::from(" = 1;\n")));
        } else {
            let lo: i64 = if a < b { a } else { b };
            let hi: i64 = if a < b { b } else { a };
            let as_: String = i64_to_str(a);
            let bs: String = i64_to_str(b);
            let los: String = i64_to_str(lo);
            let his: String = i64_to_str(hi);
            out.push_str(str5(String::from("  v"), ids,
                String::from(" = (v"), as_, str3(String::from(".len == v"),
                bs, String::from(".len)"))));
            out.push_str(str5(String::from(" ? __str_eq_"), los,
                String::from("_"), his, String::from(" : 0;\n")));
        }
        return;
    }
    if ds == String::from("__vow_string_contains") {
        let h: i64 = iargs[0];
        let n: i64 = iargs[1];
        let hs: String = i64_to_str(h);
        let ns: String = i64_to_str(n);
        let ids: String = i64_to_str(id);
        out.push_str(str3(String::from("  v"), ids, String::from(" = 0;\n")));
        out.push_str(str3(String::from("  if (v"), ns, String::from(".len == 0) { v")));
        out.push_str(str2(ids, String::from(" = 1; }\n")));
        out.push_str(str5(String::from("  else if (v"), ns,
            String::from(".len <= v"), hs, String::from(".len) {\n")));
        out.push_str(str5(String::from("    for (int64_t __i = 0; __i <= v"), hs,
            String::from(".len - v"), ns, String::from(".len; __i++) {\n")));
        out.push_str(String::from("      _Bool __match = 1;\n"));
        out.push_str(str3(String::from("      for (int64_t __j = 0; __j < v"), ns, String::from(".len; __j++) {\n")));
        out.push_str(str6(String::from("        if (v"), hs,
            String::from(".data[__i + __j] != v"), ns,
            String::from(".data[__j]) { __match = 0; break; }\n"),
            String::from("")));
        out.push_str(String::from("      }\n"));
        out.push_str(str3(String::from("      if (__match) { v"), ids, String::from(" = 1; break; }\n")));
        out.push_str(String::from("    }\n"));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_string_matches_literal_at") {
        let s: i64 = iargs[0];
        let pos: i64 = iargs[1];
        let literal_ptr: i64 = iargs[2];
        let ss: String = i64_to_str(s);
        let ps: String = i64_to_str(pos);
        let ids: String = i64_to_str(id);
        let mut found: bool = false;
        let mut literal: String = String::from("");
        let blocks: Vec<IrBlock> = f.blocks;
        let mut bi: i64 = 0;
        while bi < blocks.len() {
            if found { break; }
            let blk: IrBlock = blocks[bi];
            let insts: Vec<IrInst> = blk.insts;
            let mut ii: i64 = 0;
            while ii < insts.len() {
                let candidate: IrInst = insts[ii];
                if candidate.id == literal_ptr && candidate.op == IOP_CONST_STR() && candidate.dk == IDATA_CONST_STR() {
                    let strings: Vec<String> = m.strings;
                    if candidate.dv >= 0 && candidate.dv < strings.len() {
                        literal = strings[candidate.dv];
                        found = true;
                    }
                }
                if found { break; }
                ii = ii + 1;
            }
            bi = bi + 1;
        }
        if !found {
            emit_unmodelled(out, inst);
            return;
        }
        let len: i64 = literal.len();
        out.push_str(str3(String::from("  v"), ids, String::from(" = 0;\n")));
        out.push_str(str3(String::from("  if (v"), ps, String::from(" >= 0 && v")));
        out.push_str(str5(ps, String::from(" <= v"), ss, String::from(".len && "), i64_to_str(len)));
        out.push_str(str5(String::from("LL <= v"), ss, String::from(".len - v"), ps, String::from(") {\n")));
        if len == 0 {
            out.push_str(str3(String::from("    v"), ids, String::from(" = 1;\n")));
        } else {
            out.push_str(String::from("    _Bool __match = 1;\n"));
            let mut j: i64 = 0;
            while j < len {
                let byte: i64 = literal.byte_at(j);
                out.push_str(str3(String::from("    if ((unsigned char)v"), ss, String::from(".data[v")));
                out.push_str(str5(ps, String::from(" + "), i64_to_str(j), String::from("] != "), i64_to_str(byte)));
                out.push_str(String::from(") { __match = 0; }\n"));
                j = j + 1;
            }
            out.push_str(str3(String::from("    v"), ids, String::from(" = __match ? 1 : 0;\n")));
        }
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_string_substr") || ds == String::from("__vow_string_substr_in_arena") {
        let s: i64 = if ds == String::from("__vow_string_substr_in_arena") { iargs[1] } else { iargs[0] };
        let start: i64 = if ds == String::from("__vow_string_substr_in_arena") { iargs[2] } else { iargs[1] };
        let len: i64 = if ds == String::from("__vow_string_substr_in_arena") { iargs[3] } else { iargs[2] };
        let ss: String = i64_to_str(s);
        let starts: String = i64_to_str(start);
        let lens: String = i64_to_str(len);
        let ids: String = i64_to_str(id);
        let start_tmp: String = str2(String::from("__substr_start_"), ids);
        let len_tmp: String = str2(String::from("__substr_len_"), ids);
        let max_tmp: String = str2(String::from("__substr_max_len_"), ids);
        out.push_str(str5(String::from("  int64_t "), start_tmp, String::from(" = v"), starts, String::from(";\n")));
        out.push_str(str5(String::from("  if ("), start_tmp, String::from(" < 0) { "), start_tmp, String::from(" = 0; }\n")));
        out.push_str(str7(String::from("  if ("), start_tmp, String::from(" > v"), ss, String::from(".len) { "), start_tmp, String::from(" = v")));
        out.push_str(str2(ss, String::from(".len; }\n")));
        out.push_str(str5(String::from("  int64_t "), len_tmp, String::from(" = v"), lens, String::from(";\n")));
        out.push_str(str5(String::from("  if ("), len_tmp, String::from(" < 0) { "), len_tmp, String::from(" = 0; }\n")));
        out.push_str(str5(String::from("  int64_t "), max_tmp, String::from(" = v"), ss, String::from(".len - ")));
        out.push_str(str2(start_tmp, String::from(";\n")));
        out.push_str(str5(String::from("  if ("), len_tmp, String::from(" > "), max_tmp, String::from(") { ")));
        out.push_str(str5(len_tmp, String::from(" = "), max_tmp, String::from("; }\n"), String::from("")));
        out.push_str(str5(String::from("  v"), ids, String::from(".len = "), len_tmp, String::from(";\n")));
        out.push_str(str5(String::from("  for (int64_t __i = 0; __i < v"), ids,
            String::from(".len && __i < "), i64_to_str(string_max), String::from("; __i++) {\n")));
        out.push_str(str5(String::from("    v"), ids, String::from(".data[__i] = v"), ss, String::from(".data[")));
        out.push_str(str2(start_tmp, String::from(" + __i];\n")));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_string_substring") || ds == String::from("__vow_string_substring_in_arena") {
        let s2: i64 = if ds == String::from("__vow_string_substring_in_arena") { iargs[1] } else { iargs[0] };
        let start2: i64 = if ds == String::from("__vow_string_substring_in_arena") { iargs[2] } else { iargs[1] };
        let end2: i64 = if ds == String::from("__vow_string_substring_in_arena") { iargs[3] } else { iargs[2] };
        let ss2: String = i64_to_str(s2);
        let starts2: String = i64_to_str(start2);
        let ends2: String = i64_to_str(end2);
        let ids2: String = i64_to_str(id);
        let start_tmp2: String = str2(String::from("__substring_start_"), ids2);
        let end_tmp2: String = str2(String::from("__substring_end_"), ids2);
        out.push_str(str5(String::from("  int64_t "), start_tmp2, String::from(" = v"), starts2, String::from(";\n")));
        out.push_str(str5(String::from("  if ("), start_tmp2, String::from(" < 0) { "), start_tmp2, String::from(" = 0; }\n")));
        out.push_str(str7(String::from("  if ("), start_tmp2, String::from(" > v"), ss2, String::from(".len) { "), start_tmp2, String::from(" = v")));
        out.push_str(str2(ss2, String::from(".len; }\n")));
        out.push_str(str5(String::from("  int64_t "), end_tmp2, String::from(" = v"), ends2, String::from(";\n")));
        out.push_str(str5(String::from("  if ("), end_tmp2, String::from(" < "), start_tmp2, String::from(") { ")));
        out.push_str(str5(end_tmp2, String::from(" = "), start_tmp2, String::from("; }\n"), String::from("")));
        out.push_str(str7(String::from("  if ("), end_tmp2, String::from(" > v"), ss2, String::from(".len) { "), end_tmp2, String::from(" = v")));
        out.push_str(str2(ss2, String::from(".len; }\n")));
        out.push_str(str5(String::from("  v"), ids2, String::from(".len = "), end_tmp2, String::from(" - ")));
        out.push_str(str2(start_tmp2, String::from(";\n")));
        out.push_str(str5(String::from("  for (int64_t __i = 0; __i < v"), ids2,
            String::from(".len && __i < "), i64_to_str(string_max), String::from("; __i++) {\n")));
        out.push_str(str5(String::from("    v"), ids2, String::from(".data[__i] = v"), ss2, String::from(".data[")));
        out.push_str(str2(start_tmp2, String::from(" + __i];\n")));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_string_print") {
        out.push_str(String::from("  /* string print not modelled */\n"));
        return;
    }
    emit_unmodelled(out, inst);
}

fn emit_map_op(out: String, inst: IrInst, hashmap_max: i64) {
    let id: i64 = inst.id;
    let ds: String = inst.ds;
    let iargs: Vec<i64> = inst.args;

    // _in_arena variants share their bodies with the root forms; the leading
    // arena pointer is opaque to the verifier and is consumed via arg_offset.
    let arg_offset: i64 = {
        if ds == String::from("__vow_map_new_in_arena") { 1 }
        else if ds == String::from("__vow_map_insert_in_arena") { 1 }
        else if ds == String::from("__vow_map_remove_in_arena") { 1 }
        else { 0 }
    };

    if ds == String::from("__vow_map_new") || ds == String::from("__vow_map_new_in_arena") {
        let ids: String = i64_to_str(id);
        out.push_str(str3(String::from("  v"), ids, String::from(".len = 0;\n")));
        return;
    }
    if ds == String::from("__vow_map_len") {
        let mp: i64 = iargs[0];
        out.push_str(str5(String::from("  v"), i64_to_str(id),
            String::from(" = v"), i64_to_str(mp), String::from(".len;\n")));
        return;
    }
    if ds == String::from("__vow_map_insert") || ds == String::from("__vow_map_insert_in_arena") {
        let mp: i64 = iargs[arg_offset];
        let k: i64 = iargs[arg_offset + 1];
        let v: i64 = iargs[arg_offset + 2];
        let ms: String = i64_to_str(mp);
        let ks: String = i64_to_str(k);
        let vs: String = i64_to_str(v);
        out.push_str(String::from("  {\n"));
        out.push_str(String::from("    _Bool __found = 0;\n"));
        out.push_str(str3(String::from("    for (int64_t __i = 0; __i < v"), ms, String::from(".len; __i++) {\n")));
        out.push_str(str6(String::from("      if (v"), ms, String::from(".keys[__i] == v"),
            ks, String::from(") { v"), str2(ms, String::from(".vals[__i] = v"))));
        out.push_str(str2(vs, String::from("; __found = 1; break; }\n")));
        out.push_str(String::from("    }\n"));
        out.push_str(String::from("    if (!__found) {\n"));
        out.push_str(str5(String::from("      __ESBMC_assert(v"), ms,
            String::from(".len < "), i64_to_str(hashmap_max), String::from(", \"hashmap capacity\");\n")));
        out.push_str(str6(String::from("      v"), ms, String::from(".keys[v"), ms,
            String::from(".len] = v"), str2(ks, String::from("; v"))));
        out.push_str(str5(ms, String::from(".vals[v"), ms,
            String::from(".len] = v"), str2(vs, String::from("; v"))));
        out.push_str(str3(i64_to_str(mp), String::from(".len++;\n"), String::from("")));
        out.push_str(String::from("    }\n"));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_map_get") {
        let mp: i64 = iargs[0];
        let k: i64 = iargs[1];
        let ms: String = i64_to_str(mp);
        let ks: String = i64_to_str(k);
        let ids: String = i64_to_str(id);
        out.push_str(str3(String::from("  v"), ids, String::from(" = 0;\n")));
        out.push_str(str3(String::from("  for (int64_t __i = 0; __i < v"), ms, String::from(".len; __i++) {\n")));
        out.push_str(str6(String::from("    if (v"), ms, String::from(".keys[__i] == v"),
            ks, String::from(") { v"), str2(ids, String::from(" = v"))));
        out.push_str(str3(ms, String::from(".vals[__i]; break; }\n"), String::from("")));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_map_contains") {
        let mp: i64 = iargs[0];
        let k: i64 = iargs[1];
        let ms: String = i64_to_str(mp);
        let ks: String = i64_to_str(k);
        let ids: String = i64_to_str(id);
        out.push_str(str3(String::from("  v"), ids, String::from(" = 0;\n")));
        out.push_str(str3(String::from("  for (int64_t __i = 0; __i < v"), ms, String::from(".len; __i++) {\n")));
        out.push_str(str6(String::from("    if (v"), ms, String::from(".keys[__i] == v"),
            ks, String::from(") { v"), str2(ids, String::from(" = 1; break; }\n"))));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_map_remove") || ds == String::from("__vow_map_remove_in_arena") {
        let mp: i64 = iargs[arg_offset];
        let k: i64 = iargs[arg_offset + 1];
        let ms: String = i64_to_str(mp);
        let ks: String = i64_to_str(k);
        out.push_str(str3(String::from("  for (int64_t __i = 0; __i < v"), ms, String::from(".len; __i++) {\n")));
        out.push_str(str4(String::from("    if (v"), ms, String::from(".keys[__i] == v"),
            str2(ks, String::from(") {\n"))));
        out.push_str(str5(String::from("      v"), ms, String::from(".keys[__i] = v"), ms,
            str2(String::from(".keys[v"), ms)));
        out.push_str(String::from(".len - 1];\n"));
        out.push_str(str5(String::from("      v"), ms, String::from(".vals[__i] = v"), ms,
            str2(String::from(".vals[v"), ms)));
        out.push_str(String::from(".len - 1];\n"));
        out.push_str(str3(String::from("      v"), ms, String::from(".len--;\n")));
        out.push_str(String::from("      break;\n"));
        out.push_str(String::from("    }\n"));
        out.push_str(String::from("  }\n"));
        return;
    }
    emit_unmodelled(out, inst);
}

fn emit_btreemap_op(out: String, inst: IrInst, btreemap_max: i64) {
    let id: i64 = inst.id;
    let ds: String = inst.ds;
    let iargs: Vec<i64> = inst.args;
    let ids: String = i64_to_str(id);

    if ds == String::from("__vow_btreemap_new") {
        out.push_str(str3(String::from("  v"), ids, String::from(".len = 0;\n")));
        return;
    }
    if ds == String::from("__vow_btreemap_len") {
        let mp: i64 = iargs[0];
        out.push_str(str5(String::from("  v"), ids,
            String::from(" = v"), i64_to_str(mp), String::from(".len;\n")));
        return;
    }
    if ds == String::from("__vow_btreemap_insert") {
        let mp: i64 = iargs[0];
        let k: i64 = iargs[1];
        let v: i64 = iargs[2];
        let ms: String = i64_to_str(mp);
        let ks: String = i64_to_str(k);
        let vs: String = i64_to_str(v);
        let bms: String = i64_to_str(btreemap_max);
        out.push_str(str3(String::from("  v"), ids, String::from(".tag = 0; v")));
        out.push_str(str3(ids, String::from(".payload = 0;\n"), String::from("")));
        out.push_str(String::from("  {\n"));
        out.push_str(String::from("    _Bool __found = 0;\n"));
        out.push_str(str3(String::from("    int64_t __pos = v"), ms, String::from(".len;\n")));
        out.push_str(str3(String::from("    for (int64_t __i = 0; __i < v"), ms, String::from(".len; __i++) {\n")));
        out.push_str(str3(String::from("      if (v"), ms, String::from(".keys[__i] == v")));
        out.push_str(str3(ks, String::from(") { v"), ids));
        out.push_str(str3(String::from(".tag = 1; v"), ids, String::from(".payload = v")));
        out.push_str(str3(ms, String::from(".vals[__i]; v"), ms));
        out.push_str(str3(String::from(".vals[__i] = v"), vs, String::from("; __found = 1; break; }\n")));
        out.push_str(str3(String::from("      if (v"), ms, String::from(".keys[__i] > v")));
        out.push_str(str2(ks, String::from(") { __pos = __i; break; }\n")));
        out.push_str(String::from("    }\n"));
        out.push_str(String::from("    if (!__found) {\n"));
        out.push_str(str5(String::from("      __ESBMC_assert(v"), ms,
            String::from(".len < "), bms, String::from(", \"btreemap capacity\");\n")));
        out.push_str(str3(String::from("      for (int64_t __j = v"), ms, String::from(".len; __j > __pos; __j--) {\n")));
        out.push_str(str3(String::from("        v"), ms, String::from(".keys[__j] = v")));
        out.push_str(str3(ms, String::from(".keys[__j - 1]; v"), ms));
        out.push_str(str3(String::from(".vals[__j] = v"), ms, String::from(".vals[__j - 1];\n")));
        out.push_str(String::from("      }\n"));
        out.push_str(str3(String::from("      v"), ms, String::from(".keys[__pos] = v")));
        out.push_str(str3(ks, String::from("; v"), ms));
        out.push_str(str3(String::from(".vals[__pos] = v"), vs, String::from(";\n")));
        out.push_str(str3(String::from("      v"), ms, String::from(".len++;\n")));
        out.push_str(String::from("    }\n"));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_btreemap_get") {
        let mp: i64 = iargs[0];
        let k: i64 = iargs[1];
        let ms: String = i64_to_str(mp);
        let ks: String = i64_to_str(k);
        out.push_str(str3(String::from("  v"), ids, String::from(".tag = 0; v")));
        out.push_str(str3(ids, String::from(".payload = 0;\n"), String::from("")));
        out.push_str(str3(String::from("  for (int64_t __i = 0; __i < v"), ms, String::from(".len; __i++) {\n")));
        out.push_str(str3(String::from("    if (v"), ms, String::from(".keys[__i] == v")));
        out.push_str(str3(ks, String::from(") { v"), ids));
        out.push_str(str3(String::from(".tag = 1; v"), ids, String::from(".payload = v")));
        out.push_str(str3(ms, String::from(".vals[__i]; break; }\n"), String::from("")));
        out.push_str(str3(String::from("    if (v"), ms, String::from(".keys[__i] > v")));
        out.push_str(str2(ks, String::from(") { break; }\n")));
        out.push_str(String::from("  }\n"));
        return;
    }
    if ds == String::from("__vow_btreemap_contains") {
        let mp: i64 = iargs[0];
        let k: i64 = iargs[1];
        let ms: String = i64_to_str(mp);
        let ks: String = i64_to_str(k);
        out.push_str(str3(String::from("  v"), ids, String::from(" = 0;\n")));
        out.push_str(str3(String::from("  for (int64_t __i = 0; __i < v"), ms, String::from(".len; __i++) {\n")));
        out.push_str(str3(String::from("    if (v"), ms, String::from(".keys[__i] == v")));
        out.push_str(str3(ks, String::from(") { v"), ids));
        out.push_str(String::from(" = 1; break; }\n"));
        out.push_str(str3(String::from("    if (v"), ms, String::from(".keys[__i] > v")));
        out.push_str(str2(ks, String::from(") { break; }\n")));
        out.push_str(String::from("  }\n"));
        return;
    }
    emit_unmodelled(out, inst);
}

fn emit_c_function(out: String, f: IrFunction, const_fn_indices: Vec<i64>, modelable_fi_set: Vec<i64>, m: IrModule,
                   vec_max: i64, string_max: i64, hashmap_max: i64, btreemap_max: i64) {
    let vec_vars: Vec<i64> = collect_vec_vars(f);
    let string_vars: Vec<i64> = collect_string_vars(f);
    let hashmap_vars: Vec<i64> = collect_hashmap_vars(f);
    let btreemap_vars: Vec<i64> = collect_btreemap_vars(f);
    let option_vars: Vec<i64> = collect_option_vars(f);

    let ret_c: String = {
        if f.return_ty == ITY_UNIT() {
            String::from("void")
        } else if f.return_ty == ITY_PTR() || f.return_ty == ITY_LPTR() {
            String::from("int64_t")
        } else {
            ir_ty_to_c(f.return_ty)
        }
    };

    let params_list: String = String::from("");
    let param_tys: Vec<i64> = f.params;
    let n_params: i64 = param_tys.len();
    let arg_map_ir: Vec<i64> = Vec::new();
    let arg_map_cl: Vec<i64> = Vec::new();
    let mut cl_idx: i64 = 0;
    let mut pi: i64 = 0;
    while pi < n_params {
        let pty: i64 = param_tys[pi];
        if pty != ITY_UNIT() {
            if cl_idx > 0 { params_list.push_str(String::from(", ")); }
            let p_c: String = {
                if pty == ITY_PTR() || pty == ITY_LPTR() {
                    String::from("int64_t")
                } else {
                    ir_ty_to_c(pty)
                }
            };
            params_list.push_str(p_c);
            params_list.push_str(str2(String::from(" p"), i64_to_str(cl_idx)));
            arg_map_ir.push(pi);
            arg_map_cl.push(cl_idx);
            cl_idx = cl_idx + 1;
        }
        pi = pi + 1;
    }

    let param_str: String = if cl_idx == 0 { String::from("void") } else { params_list };
    out.push_str(str5(ret_c, String::from(" "), f.name, String::from("("), str3(param_str, String::from(") {\n"), String::from(""))));

    let blocks: Vec<IrBlock> = f.blocks;
    let n_blocks: i64 = blocks.len();
    let const_str_ids: Vec<i64> = Vec::new();
    let const_str_idxs: Vec<i64> = Vec::new();

    let mut bi: i64 = 0;
    while bi < n_blocks {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_CONST_STR() && inst.dk == IDATA_CONST_STR() {
                const_str_ids.push(inst.id);
                const_str_idxs.push(inst.dv);
            }
            if inst.op == IOP_GET_ARG() && inst.dk == IDATA_ARG_INDEX() {
                let arg_idx: i64 = inst.dv;
                let iid: i64 = inst.id;
                let mut found_cl: i64 = -1;
                let mut ai: i64 = 0;
                while ai < arg_map_ir.len() {
                    if arg_map_ir[ai] == arg_idx {
                        found_cl = arg_map_cl[ai];
                    }
                    ai = ai + 1;
                }
                if found_cl >= 0 {
                    if vec_contains_i64(vec_vars, iid) {
                        let ids: String = i64_to_str(iid);
                        out.push_str(str3(String::from("  __vow_vec_t v"), ids, String::from(";\n")));
                        out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
                        out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
                        out.push_str(str4(ids, String::from(".len <= "), i64_to_str(vec_max), String::from(");\n")));
                    } else if vec_contains_i64(string_vars, iid) {
                        let ids: String = i64_to_str(iid);
                        out.push_str(str3(String::from("  __vow_string_t v"), ids, String::from(";\n")));
                        out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
                        out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
                        out.push_str(str4(ids, String::from(".len <= "), i64_to_str(string_max), String::from(");\n")));
                    } else if vec_contains_i64(hashmap_vars, iid) {
                        let ids: String = i64_to_str(iid);
                        out.push_str(str3(String::from("  __vow_hashmap_t v"), ids, String::from(";\n")));
                        out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
                        out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
                        out.push_str(str4(ids, String::from(".len <= "), i64_to_str(hashmap_max), String::from(");\n")));
                    } else if vec_contains_i64(btreemap_vars, iid) {
                        let ids: String = i64_to_str(iid);
                        out.push_str(str3(String::from("  __vow_btreemap_t v"), ids, String::from(";\n")));
                        out.push_str(str3(String::from("  v"), ids, String::from(".len = __VERIFIER_nondet_long();\n")));
                        out.push_str(str3(String::from("  __ESBMC_assume(v"), ids, String::from(".len >= 0 && v")));
                        out.push_str(str4(ids, String::from(".len <= "), i64_to_str(btreemap_max), String::from(");\n")));
                        // Sorted-keys assume: get/contains/insert C model requires ascending-key state.
                        out.push_str(str3(String::from("  for (int64_t __si = 0; __si + 1 < v"), ids, String::from(".len; __si++)\n")));
                        out.push_str(str3(String::from("    __ESBMC_assume(v"), ids, String::from(".keys[__si] < v")));
                        out.push_str(str3(ids, String::from(".keys[__si + 1]);\n"), String::from("")));
                    } else {
                        let c_ty: String = {
                            if inst.ty == ITY_PTR() || inst.ty == ITY_LPTR() {
                                String::from("int64_t")
                            } else {
                                ir_ty_to_c(inst.ty)
                            }
                        };
                        out.push_str(str6(String::from("  "), c_ty, String::from(" v"),
                            i64_to_str(iid), String::from(" = p"),
                            str2(i64_to_str(found_cl), String::from(";\n"))));
                    }
                } else {
                    out.push_str(str3(String::from("  int32_t v"), i64_to_str(iid),
                        String::from(" = 0; /* unit arg */\n")));
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }

    bi = 0;
    while bi < n_blocks {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_GET_ARG() || inst.op == IOP_UPSILON()
               || iop_is_terminal(inst.op)
               || inst.op == IOP_VOW_REQ() || inst.op == IOP_VOW_ENS() || inst.op == IOP_VOW_INV() {
                ii = ii + 1;
            } else if inst.ty == ITY_UNIT() && inst.op != IOP_CONST_UNIT() && inst.op != IOP_PHI() {
                ii = ii + 1;
            } else {
                let iid: i64 = inst.id;
                if vec_contains_i64(vec_vars, iid) {
                    out.push_str(str3(String::from("  __vow_vec_t v"), i64_to_str(iid), String::from(";\n")));
                } else if vec_contains_i64(string_vars, iid) {
                    out.push_str(str3(String::from("  __vow_string_t v"), i64_to_str(iid), String::from(";\n")));
                } else if vec_contains_i64(hashmap_vars, iid) {
                    out.push_str(str3(String::from("  __vow_hashmap_t v"), i64_to_str(iid), String::from(";\n")));
                } else if vec_contains_i64(btreemap_vars, iid) {
                    out.push_str(str3(String::from("  __vow_btreemap_t v"), i64_to_str(iid), String::from(";\n")));
                } else if vec_contains_i64(option_vars, iid) {
                    out.push_str(str3(String::from("  __vow_option_t v"), i64_to_str(iid), String::from(";\n")));
                } else {
                    let c_ty: String = {
                        if inst.ty == ITY_UNIT() {
                            String::from("int32_t")
                        } else if inst.ty == ITY_PTR() || inst.ty == ITY_LPTR() {
                            String::from("int64_t")
                        } else {
                            ir_ty_to_c(inst.ty)
                        }
                    };
                    out.push_str(str4(String::from("  "), c_ty,
                        String::from(" v"), str2(i64_to_str(iid), String::from(";\n"))));
                }
                ii = ii + 1;
            }
        }
        bi = bi + 1;
    }

    let ups_sources: Vec<i64> = Vec::new();
    bi = 0;
    while bi < n_blocks {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_UPSILON() && inst.dk == IDATA_PHI_TARGET() {
                let u_args: Vec<i64> = inst.args;
                if u_args.len() > 0 {
                    let src_val: i64 = u_args[0];
                    if src_val >= 0 {
                        vec_insert_i64(ups_sources, src_val);
                    }
                }
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    let mut ui: i64 = 0;
    while ui < ups_sources.len() {
        let src: i64 = ups_sources[ui];
        // Upsilon temps must share the source's struct type; struct-to-int64 assignment corrupts the payload.
        if vec_contains_i64(option_vars, src) {
            out.push_str(str3(String::from("  __vow_option_t __ups_"), i64_to_str(src), String::from(";\n")));
        } else if vec_contains_i64(vec_vars, src) {
            out.push_str(str3(String::from("  __vow_vec_t __ups_"), i64_to_str(src), String::from(";\n")));
        } else if vec_contains_i64(string_vars, src) {
            out.push_str(str3(String::from("  __vow_string_t __ups_"), i64_to_str(src), String::from(";\n")));
        } else if vec_contains_i64(hashmap_vars, src) {
            out.push_str(str3(String::from("  __vow_hashmap_t __ups_"), i64_to_str(src), String::from(";\n")));
        } else if vec_contains_i64(btreemap_vars, src) {
            out.push_str(str3(String::from("  __vow_btreemap_t __ups_"), i64_to_str(src), String::from(";\n")));
        } else {
            out.push_str(str3(String::from("  int64_t __ups_"), i64_to_str(src), String::from(";\n")));
        }
        ui = ui + 1;
    }

    // Per-pair nondet cache for abstract __vow_string_eq. Mirrors the Rust
    // emitter: one shared _Bool per unordered (a, b) pair ensures repeated
    // comparisons of the same pair agree, and emit_string_eq_invalidate
    // re-samples the entry after each modeled mutation on either operand.
    let eq_lo: Vec<i64> = Vec::new();
    let eq_hi: Vec<i64> = Vec::new();
    compute_string_eq_pairs(blocks, eq_lo, eq_hi);
    let mut ei: i64 = 0;
    while ei < eq_lo.len() {
        out.push_str(str5(String::from("  _Bool __str_eq_"), i64_to_str(eq_lo[ei]),
            String::from("_"), i64_to_str(eq_hi[ei]),
            String::from(" = __VERIFIER_nondet_bool();\n")));
        ei = ei + 1;
    }

    bi = 0;
    while bi < n_blocks {
        let blk: IrBlock = blocks[bi];
        out.push_str(str3(String::from("  int __blk_"), i64_to_str(blk.id), String::from(" = 0;\n")));
        bi = bi + 1;
    }

    let first_block_id: i64 = {
        if n_blocks > 0 {
            let fb: IrBlock = blocks[0];
            fb.id
        } else {
            -1
        }
    };

    bi = 0;
    while bi < n_blocks {
        let blk: IrBlock = blocks[bi];
        if blk.id != first_block_id {
            out.push_str(str3(String::from("block"), i64_to_str(blk.id), String::from(":;\n")));
        }
        out.push_str(str3(String::from("  __blk_"), i64_to_str(blk.id), String::from(" = 1;\n")));

        let insts: Vec<IrInst> = blk.insts;
        let regular: Vec<i64> = Vec::new();
        let ups_phi: Vec<i64> = Vec::new();
        let ups_src: Vec<i64> = Vec::new();
        let mut terminal_idx: i64 = -1;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == IOP_GET_ARG() {
                ii = ii + 1;
            } else if inst.op == IOP_UPSILON() {
                if inst.dk == IDATA_PHI_TARGET() {
                    let u_args: Vec<i64> = inst.args;
                    if u_args[0] >= 0 {
                        ups_phi.push(inst.dv);
                        ups_src.push(u_args[0]);
                    }
                }
                ii = ii + 1;
            } else if iop_is_terminal(inst.op) {
                terminal_idx = ii;
                ii = ii + 1;
            } else {
                regular.push(ii);
                ii = ii + 1;
            }
        }

        let mut ri: i64 = 0;
        while ri < regular.len() {
            let inst: IrInst = insts[regular[ri]];
            emit_inst(out, inst, f, vec_vars, string_vars, hashmap_vars, btreemap_vars, option_vars, const_fn_indices, modelable_fi_set, m, const_str_ids, const_str_idxs, eq_lo, eq_hi, vec_max, string_max, hashmap_max, btreemap_max);
            ri = ri + 1;
        }

        if ups_phi.len() > 0 {
            let mut ui: i64 = 0;
            while ui < ups_src.len() {
                let src: i64 = ups_src[ui];
                out.push_str(str5(String::from("  __ups_"), i64_to_str(src),
                    String::from(" = v"), i64_to_str(src), String::from(";\n")));
                ui = ui + 1;
            }
            ui = 0;
            while ui < ups_phi.len() {
                let phi: i64 = ups_phi[ui];
                let src: i64 = ups_src[ui];
                out.push_str(str5(String::from("  v"), i64_to_str(phi),
                    String::from(" = __ups_"), i64_to_str(src), String::from(";\n")));
                ui = ui + 1;
            }
        }

        if terminal_idx >= 0 {
            let term: IrInst = insts[terminal_idx];
            emit_inst(out, term, f, vec_vars, string_vars, hashmap_vars, btreemap_vars, option_vars, const_fn_indices, modelable_fi_set, m, const_str_ids, const_str_idxs, eq_lo, eq_hi, vec_max, string_max, hashmap_max, btreemap_max);
        }

        bi = bi + 1;
    }

    out.push_str(String::from("}\n"));
}

fn func_has_shift_op(f: IrFunction, target_op: i64) -> i64 {
    let blocks: Vec<IrBlock> = f.blocks;
    let mut bi: i64 = 0;
    while bi < blocks.len() {
        let blk: IrBlock = blocks[bi];
        let insts: Vec<IrInst> = blk.insts;
        let mut ii: i64 = 0;
        while ii < insts.len() {
            let inst: IrInst = insts[ii];
            if inst.op == target_op {
                return 1;
            }
            ii = ii + 1;
        }
        bi = bi + 1;
    }
    0
}

fn scan_shift_needs_in_fns(fns: Vec<IrFunction>, start: i64, end: i64, target_op: i64) -> i64 {
    let mut fi: i64 = start;
    while fi < end {
        let f: IrFunction = fns[fi];
        if func_has_shift_op(f, target_op) == 1 {
            return 1;
        }
        fi = fi + 1;
    }
    0
}

fn cemit_preamble_with_limits(need_shl_i64: i64, need_shr_i64: i64, need_shl_u64: i64, need_shr_u64: i64,
                              vec_max: i64, string_max: i64, hashmap_max: i64, btreemap_max: i64) -> String {
    let out: String = String::from("");
    out.push_str(String::from("#include <stdint.h>\n"));
    out.push_str(String::from("#include <stdlib.h>\n"));
    out.push_str(String::from("#include <stdbool.h>\n"));
    out.push_str(String::from("extern void __ESBMC_assume(_Bool);\n"));
    out.push_str(String::from("extern void __ESBMC_assert(_Bool, const char*);\n"));
    out.push_str(String::from("extern int __VERIFIER_nondet_int(void);\n"));
    out.push_str(String::from("extern long __VERIFIER_nondet_long(void);\n"));
    out.push_str(String::from("extern float __VERIFIER_nondet_float(void);\n"));
    out.push_str(String::from("extern double __VERIFIER_nondet_double(void);\n"));
    out.push_str(String::from("extern _Bool __VERIFIER_nondet_bool(void);\n\n"));
    out.push_str(str3(
        String::from("typedef struct { int64_t len; int64_t data["),
        i64_to_str(vec_max),
        String::from("]; } __vow_vec_t;\n")
    ));
    out.push_str(str3(
        String::from("typedef struct { int64_t len; int8_t data["),
        i64_to_str(string_max),
        String::from("]; } __vow_string_t;\n")
    ));
    out.push_str(str5(
        String::from("typedef struct { int64_t len; int64_t keys["),
        i64_to_str(hashmap_max),
        String::from("]; int64_t vals["),
        i64_to_str(hashmap_max),
        String::from("]; } __vow_hashmap_t;\n")
    ));
    out.push_str(str5(
        String::from("typedef struct { int64_t len; int64_t keys["),
        i64_to_str(btreemap_max),
        String::from("]; int64_t vals["),
        i64_to_str(btreemap_max),
        String::from("]; } __vow_btreemap_t;\n")
    ));
    out.push_str(String::from("typedef struct { int64_t tag; int64_t payload; } __vow_option_t;\n\n"));
    if need_shl_i64 != 0 {
        out.push_str(String::from("static inline int64_t __vow_shl_i64(int64_t value, int64_t count) {\n"));
        out.push_str(String::from("  uint64_t shift = ((uint64_t)count) & 63ULL;\n"));
        out.push_str(String::from("  return (int64_t)(((uint64_t)value) << shift);\n"));
        out.push_str(String::from("}\n"));
    }
    if need_shr_i64 != 0 {
        out.push_str(String::from("static inline int64_t __vow_shr_i64(int64_t value, int64_t count) {\n"));
        out.push_str(String::from("  uint64_t shift = ((uint64_t)count) & 63ULL;\n"));
        out.push_str(String::from("  uint64_t bits = (uint64_t)value;\n"));
        out.push_str(String::from("  uint64_t logical = bits >> shift;\n"));
        out.push_str(String::from("  uint64_t sign_fill = value < 0 ? ~(~0ULL >> shift) : 0ULL;\n"));
        out.push_str(String::from("  return (int64_t)(logical | sign_fill);\n"));
        out.push_str(String::from("}\n"));
    }
    if need_shl_u64 != 0 {
        out.push_str(String::from("static inline uint64_t __vow_shl_u64(uint64_t value, uint64_t count) {\n"));
        out.push_str(String::from("  return value << (count & 63ULL);\n"));
        out.push_str(String::from("}\n"));
    }
    if need_shr_u64 != 0 {
        out.push_str(String::from("static inline uint64_t __vow_shr_u64(uint64_t value, uint64_t count) {\n"));
        out.push_str(String::from("  return value >> (count & 63ULL);\n"));
        out.push_str(String::from("}\n"));
    }
    if need_shl_i64 != 0 || need_shr_i64 != 0 || need_shl_u64 != 0 || need_shr_u64 != 0 {
        out.push_byte(10);
    }
    out
}

fn cemit_preamble(need_shl_i64: i64, need_shr_i64: i64, need_shl_u64: i64, need_shr_u64: i64) -> String {
    cemit_preamble_with_limits(need_shl_i64, need_shr_i64, need_shl_u64, need_shr_u64, VOW_VEC_MAX(), VOW_STRING_MAX(), VOW_HASHMAP_MAX(), VOW_BTREEMAP_MAX())
}

fn emit_forward_declaration(out: String, f: IrFunction) {
    let ret_c: String = {
        if f.return_ty == ITY_UNIT() {
            String::from("void")
        } else if f.return_ty == ITY_PTR() || f.return_ty == ITY_LPTR() {
            String::from("int64_t")
        } else {
            ir_ty_to_c(f.return_ty)
        }
    };
    let params_list: String = String::from("");
    let param_tys: Vec<i64> = f.params;
    let mut cl_idx: i64 = 0;
    let mut pi: i64 = 0;
    while pi < param_tys.len() {
        let pty: i64 = param_tys[pi];
        if pty != ITY_UNIT() {
            if cl_idx > 0 { params_list.push_str(String::from(", ")); }
            let p_c: String = {
                if pty == ITY_PTR() || pty == ITY_LPTR() {
                    String::from("int64_t")
                } else {
                    ir_ty_to_c(pty)
                }
            };
            params_list.push_str(p_c);
            params_list.push_str(str2(String::from(" p"), i64_to_str(cl_idx)));
            cl_idx = cl_idx + 1;
        }
        pi = pi + 1;
    }
    let param_str: String = if cl_idx == 0 { String::from("void") } else { params_list };
    out.push_str(str5(ret_c, String::from(" "), f.name, String::from("("), str2(param_str, String::from(");\n"))));
}

fn emit_c_module(m: IrModule, vec_max: i64, string_max: i64, hashmap_max: i64, btreemap_max: i64) -> String {
    let fns: Vec<IrFunction> = m.functions;
    let n: i64 = fns.len();
    let need_shl_i64: i64 = scan_shift_needs_in_fns(fns, 0, n, IOP_SHL_I64());
    let need_shr_i64: i64 = scan_shift_needs_in_fns(fns, 0, n, IOP_SHR_I64());
    let need_shl_u64: i64 = scan_shift_needs_in_fns(fns, 0, n, IOP_SHL_U64());
    let need_shr_u64: i64 = scan_shift_needs_in_fns(fns, 0, n, IOP_SHR_U64());
    let out: String = cemit_preamble_with_limits(need_shl_i64, need_shr_i64, need_shl_u64, need_shr_u64, vec_max, string_max, hashmap_max, btreemap_max);

    let const_fn_indices: Vec<i64> = detect_const_fns(m);
    let empty_modelable: Vec<i64> = Vec::new();

    let mut fi: i64 = 0;
    while fi < fns.len() {
        let f: IrFunction = fns[fi];
        emit_c_function(out, f, const_fn_indices, empty_modelable, m, vec_max, string_max, hashmap_max, btreemap_max);
        out.push_byte(10);
        fi = fi + 1;
    }
    out
}

fn scan_shift_op_in_module_fns(fns: Vec<IrFunction>, target_fi: i64, callee_fis: Vec<i64>, target_op: i64) -> i64 {
    let mut fi: i64 = 0;
    while fi < fns.len() {
        let f: IrFunction = fns[fi];
        let mut check: i64 = 0;
        if f.id == target_fi { check = 1; }
        if check == 0 {
            let mut ci: i64 = 0;
            while ci < callee_fis.len() {
                if callee_fis[ci] == f.id { check = 1; ci = callee_fis.len(); }
                ci = ci + 1;
            }
        }
        if check == 1 {
            if func_has_shift_op(f, target_op) == 1 { return 1; }
        }
        fi = fi + 1;
    }
    0
}

fn emit_c_module_with_callees(m: IrModule, target_fi: i64, callee_fis: Vec<i64>, modelable_fi_set: Vec<i64>,
                              vec_max: i64, string_max: i64, hashmap_max: i64, btreemap_max: i64) -> String {
    let fns: Vec<IrFunction> = m.functions;
    let need_shl_i64: i64 = scan_shift_op_in_module_fns(fns, target_fi, callee_fis, IOP_SHL_I64());
    let need_shr_i64: i64 = scan_shift_op_in_module_fns(fns, target_fi, callee_fis, IOP_SHR_I64());
    let need_shl_u64: i64 = scan_shift_op_in_module_fns(fns, target_fi, callee_fis, IOP_SHL_U64());
    let need_shr_u64: i64 = scan_shift_op_in_module_fns(fns, target_fi, callee_fis, IOP_SHR_U64());
    let out: String = cemit_preamble_with_limits(need_shl_i64, need_shr_i64, need_shl_u64, need_shr_u64, vec_max, string_max, hashmap_max, btreemap_max);
    let const_fn_indices: Vec<i64> = detect_const_fns(m);

    let mut ci: i64 = 0;
    while ci < callee_fis.len() {
        let cfid: i64 = callee_fis[ci];
        let mut fi: i64 = 0;
        while fi < fns.len() {
            let callee: IrFunction = fns[fi];
            if callee.id == cfid {
                emit_forward_declaration(out, callee);
                fi = fns.len();
            }
            fi = fi + 1;
        }
        ci = ci + 1;
    }
    if callee_fis.len() > 0 {
        out.push_byte(10);
    }

    ci = 0;
    while ci < callee_fis.len() {
        let cfid: i64 = callee_fis[ci];
        let mut fi: i64 = 0;
        while fi < fns.len() {
            let callee: IrFunction = fns[fi];
            if callee.id == cfid {
                emit_c_function(out, callee, const_fn_indices, modelable_fi_set, m, vec_max, string_max, hashmap_max, btreemap_max);
                out.push_byte(10);
                fi = fns.len();
            }
            fi = fi + 1;
        }
        ci = ci + 1;
    }

    let mut fi: i64 = 0;
    while fi < fns.len() {
        let f: IrFunction = fns[fi];
        if f.id == target_fi {
            emit_c_function(out, f, const_fn_indices, modelable_fi_set, m, vec_max, string_max, hashmap_max, btreemap_max);
            out.push_byte(10);
            fi = fns.len();
        }
        fi = fi + 1;
    }
    out
}
