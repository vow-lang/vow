fn EXPR_LIT_FLOAT() -> i64 { 3 }
fn EXPR_IDENT() -> i64 { 4 }
fn EXPR_BINOP() -> i64 { 5 }
fn EXPR_UNOP() -> i64 { 6 }
fn EXPR_CALL() -> i64 { 7 }
fn EXPR_METHOD() -> i64 { 8 }
fn EXPR_FIELD() -> i64 { 9 }
fn EXPR_INDEX() -> i64 { 10 }
fn EXPR_IF() -> i64 { 11 }
fn EXPR_WHILE() -> i64 { 12 }
fn EXPR_MATCH() -> i64 { 13 }
fn EXPR_RETURN() -> i64 { 14 }
fn EXPR_BREAK() -> i64 { 15 }
fn EXPR_BLOCK() -> i64 { 16 }
