module TestComplexityIo

use complexity
use diag

fn temp_complexity_path() -> String [io] {
    let pargs: Vec<String> = Vec::new();
    pargs.push(String::from("-c"));
    pargs.push(String::from("mktemp \"${TMPDIR:-/tmp}/vow-complexity-io.XXXXXXXXXX\""));
    let rc: i64 = process_run(String::from("sh"), pargs);
    if rc != 0 {
        return String::from("");
    }
    string_trim(process_get_stdout())
}

fn complexity_fixture_source() -> String {
    let src: String = String::from("");
    src.push_str(String::from("module CalleeFreeVars\n\n"));
    src.push_str(String::from("fn id(n: i64) -> i64 {\n"));
    src.push_str(String::from("    n\n"));
    src.push_str(String::from("}\n\n"));
    src.push_str(String::from("fn checked(n: i64) -> i64 vow {\n"));
    src.push_str(String::from("    requires: id(n) > 0,\n"));
    src.push_str(String::from("    ensures: id(result) == n\n"));
    src.push_str(String::from("} {\n"));
    src.push_str(String::from("    n\n"));
    src.push_str(String::from("}\n"));
    src
}

fn check_missing_path_fails() -> i64 [io, read] {
    let path: String = temp_complexity_path();
    if path.len() == 0 { return 9; }
    if fs_remove(path) != 0 { return 10; }

    let r: CxReadSource = cx_read_source(path);
    if r.ok { return 1; }
    if r.src.len() != 0 { return 2; }
    if r.err.len() == 0 { return 7; }
    0
}

fn check_empty_readable_file_succeeds() -> i64 [read] {
    let r: CxReadSource = cx_read_source(String::from("/dev/null"));
    if !r.ok { return 3; }
    if r.src.len() != 0 { return 4; }
    0
}

fn check_nonempty_file_succeeds() -> i64 [io, read, write] {
    let path: String = temp_complexity_path();
    if path.len() == 0 { return 9; }
    if fs_write(path, complexity_fixture_source()) != 0 {
        fs_remove(path);
        return 11;
    }

    let r: CxReadSource = cx_read_source(path);
    if fs_remove(path) != 0 { return 12; }
    if !r.ok { return 5; }
    if string_starts_with(r.src, String::from("module CalleeFreeVars")) == 0 { return 6; }
    if diag_compute_line(r.src, r.src.len()) != 13 { return 8; }
    0
}

fn i64_result_to_i32(r: i64) -> i32 {
    if r == 1 { return 1; }
    if r == 2 { return 2; }
    if r == 3 { return 3; }
    if r == 4 { return 4; }
    if r == 5 { return 5; }
    if r == 6 { return 6; }
    if r == 7 { return 7; }
    if r == 8 { return 8; }
    if r == 9 { return 9; }
    if r == 10 { return 10; }
    if r == 11 { return 11; }
    if r == 12 { return 12; }
    if r != 0 { return 99; }
    0
}

fn main() -> i32 [io, read, write] {
    let r1: i64 = check_missing_path_fails();
    if r1 != 0 { return i64_result_to_i32(r1); }
    let r2: i64 = check_empty_readable_file_succeeds();
    if r2 != 0 { return i64_result_to_i32(r2); }
    let r3: i64 = check_nonempty_file_succeeds();
    if r3 != 0 { return i64_result_to_i32(r3); }
    0
}
