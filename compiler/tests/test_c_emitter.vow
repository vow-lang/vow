module TestCEmitter

use ir
use c_emitter
use tests.builders

fn identity_function(id: i64, name: String) -> IrFunction {
    let insts: Vec<IrInst> = Vec::new();
    insts.push(mk_inst_arg(0, ITY_I64(), 0));
    insts.push(mk_inst_return(1, 0));

    let blocks: Vec<IrBlock> = Vec::new();
    blocks.push(mk_block(0, insts));

    let params: Vec<i64> = Vec::new();
    params.push(ITY_I64());
    mk_function(id, name, params, ITY_I64(), blocks)
}

fn raw_i64_signature(name: String) -> String {
    let s: String = String::from("int64_t ");
    s.push_str(name);
    s.push_str(String::from("("));
    s
}

fn mangled_i64_signature(id: i64) -> String {
    let s: String = String::from("int64_t vow_user_fn_");
    s.push_str(i64_to_string(id));
    s.push_str(String::from("("));
    s
}

fn check_name_modelable_and_mangled(name: String, id: i64, base_code: i64) -> i64 {
    let f: IrFunction = identity_function(id, name);
    let funcs: Vec<IrFunction> = Vec::new();
    funcs.push(f);
    let m: IrModule = mk_module(funcs);
    let const_fn_indices: Vec<i64> = Vec::new();

    let reason: String = non_modelable_reason(f, m, const_fn_indices);
    if reason != String::from("") {
        return base_code;
    }

    let c: String = emit_c_module(m, 16, 16, 16, 16);
    if !c.contains(mangled_i64_signature(id)) {
        return base_code + 1;
    }
    if c.contains(raw_i64_signature(name)) {
        return base_code + 2;
    }
    0
}

fn check_modelable_call_target_is_mangled() -> i64 {
    let callee: IrFunction = identity_function(5, String::from("ldiv"));

    let target_insts: Vec<IrInst> = Vec::new();
    target_insts.push(mk_inst_arg(0, ITY_I64(), 0));
    let call_args: Vec<i64> = Vec::new();
    call_args.push(0);
    target_insts.push(mk_inst_call_target(1, ITY_I64(), call_args, 5));
    target_insts.push(mk_inst_return(2, 1));

    let target_blocks: Vec<IrBlock> = Vec::new();
    target_blocks.push(mk_block(0, target_insts));
    let target_params: Vec<i64> = Vec::new();
    target_params.push(ITY_I64());
    let target: IrFunction = mk_function(2, String::from("labs"), target_params, ITY_I64(), target_blocks);

    let funcs: Vec<IrFunction> = Vec::new();
    funcs.push(target);
    funcs.push(callee);
    let m: IrModule = mk_module(funcs);

    let const_fn_indices: Vec<i64> = Vec::new();
    let reason: String = non_modelable_reason(target, m, const_fn_indices);
    if reason != String::from("") {
        return 20;
    }

    let callee_fis: Vec<i64> = Vec::new();
    callee_fis.push(5);
    let modelable_fis: Vec<i64> = Vec::new();
    modelable_fis.push(5);
    let c: String = emit_c_module_with_callees(m, 2, callee_fis, modelable_fis, 16, 16, 16, 16, false, false);

    if !c.contains(String::from("int64_t vow_user_fn_5(int64_t p0);")) {
        return 21;
    }
    if !c.contains(String::from("int64_t vow_user_fn_5(int64_t p0) {")) {
        return 22;
    }
    if !c.contains(String::from("v1 = vow_user_fn_5(v0);")) {
        return 23;
    }
    if c.contains(String::from("int64_t ldiv(")) {
        return 24;
    }
    if c.contains(String::from(" ldiv(v0)")) {
        return 25;
    }
    if c.contains(String::from("int64_t labs(")) {
        return 26;
    }
    0
}

fn check_complexity_descriptor_routing() -> i64 {
    let descriptor_only_insts: Vec<IrInst> = Vec::new();
    descriptor_only_insts.push(mk_inst_arg(0, ITY_I64(), 0));
    descriptor_only_insts.push(mk_inst(1, IOP_COMPLEXITY_DESCRIPTOR(), ITY_UNIT(), Vec::new()));
    descriptor_only_insts.push(mk_inst_return(2, 0));
    let descriptor_only_blocks: Vec<IrBlock> = Vec::new();
    descriptor_only_blocks.push(mk_block(0, descriptor_only_insts));
    let descriptor_only_params: Vec<i64> = Vec::new();
    descriptor_only_params.push(ITY_I64());
    let descriptor_only: IrFunction = mk_function(
        11,
        String::from("linear_identity"),
        descriptor_only_params,
        ITY_I64(),
        descriptor_only_blocks
    );

    let descriptor_only_funcs: Vec<IrFunction> = Vec::new();
    descriptor_only_funcs.push(descriptor_only);
    let descriptor_only_module: IrModule = mk_module(descriptor_only_funcs);
    let const_fn_indices: Vec<i64> = Vec::new();
    if non_modelable_reason(descriptor_only, descriptor_only_module, const_fn_indices) != String::from("") {
        return 27;
    }
    let descriptor_only_c: String = emit_c_module(descriptor_only_module, 16, 16, 16, 16);
    if descriptor_only_c.contains(String::from("  __ESBMC_assume("))
       || descriptor_only_c.contains(String::from("  __ESBMC_assert(")) {
        return 28;
    }

    let ensured_insts: Vec<IrInst> = Vec::new();
    ensured_insts.push(mk_inst_arg(0, ITY_I64(), 0));
    ensured_insts.push(mk_inst(1, IOP_COMPLEXITY_DESCRIPTOR(), ITY_UNIT(), Vec::new()));
    let eq_args: Vec<i64> = Vec::new();
    eq_args.push(0);
    eq_args.push(0);
    ensured_insts.push(mk_inst(2, IOP_EQ_I64(), ITY_BOOL(), eq_args));
    let ensures_args: Vec<i64> = Vec::new();
    ensures_args.push(2);
    ensured_insts.push(ir_inst_new(
        3,
        IOP_VOW_ENS(),
        ITY_UNIT(),
        ensures_args,
        IDATA_VOW_ID(),
        0,
        0,
        String::from("")
    ));
    ensured_insts.push(mk_inst_return(4, 0));
    let ensured_blocks: Vec<IrBlock> = Vec::new();
    ensured_blocks.push(mk_block(0, ensured_insts));
    let ensured_params: Vec<i64> = Vec::new();
    ensured_params.push(ITY_I64());
    let ensured: IrFunction = mk_function(
        12,
        String::from("identity_with_ensures"),
        ensured_params,
        ITY_I64(),
        ensured_blocks
    );
    let ensured_funcs: Vec<IrFunction> = Vec::new();
    ensured_funcs.push(ensured);
    let ensured_c: String = emit_c_module(mk_module(ensured_funcs), 16, 16, 16, 16);
    if !ensured_c.contains(String::from("  __ESBMC_assert(v2, \"vow:0\");")) {
        return 29;
    }
    0
}

fn i64_result_to_i32(r: i64) -> i32 {
    if r == 1 { return 1; }
    if r == 2 { return 2; }
    if r == 3 { return 3; }
    if r == 4 { return 4; }
    if r == 5 { return 5; }
    if r == 6 { return 6; }
    if r == 7 { return 7; }
    if r == 8 { return 8; }
    if r == 9 { return 9; }
    if r == 10 { return 10; }
    if r == 11 { return 11; }
    if r == 12 { return 12; }
    if r == 20 { return 20; }
    if r == 21 { return 21; }
    if r == 22 { return 22; }
    if r == 23 { return 23; }
    if r == 24 { return 24; }
    if r == 25 { return 25; }
    if r == 26 { return 26; }
    if r == 27 { return 27; }
    if r == 28 { return 28; }
    if r == 29 { return 29; }
    if r != 0 { return 99; }
    0
}

fn main() -> i32 {
    let r1: i64 = check_name_modelable_and_mangled(String::from("abs"), 7, 1);
    if r1 != 0 { return i64_result_to_i32(r1); }
    let r2: i64 = check_name_modelable_and_mangled(String::from("labs"), 8, 4);
    if r2 != 0 { return i64_result_to_i32(r2); }
    let r3: i64 = check_name_modelable_and_mangled(String::from("div"), 9, 7);
    if r3 != 0 { return i64_result_to_i32(r3); }
    let r4: i64 = check_name_modelable_and_mangled(String::from("ldiv"), 10, 10);
    if r4 != 0 { return i64_result_to_i32(r4); }
    let r5: i64 = check_modelable_call_target_is_mangled();
    if r5 != 0 { return i64_result_to_i32(r5); }
    let r6: i64 = check_complexity_descriptor_routing();
    if r6 != 0 { return i64_result_to_i32(r6); }
    0
}
