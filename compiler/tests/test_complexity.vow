module TestComplexity

use complexity_graph

fn check_fanin_counts() -> i64 {
    let source_files: Vec<String> = Vec::new();
    source_files.push(String::from("entry.vow"));
    source_files.push(String::from("dep.vow"));
    source_files.push(String::from("entry.vow"));

    let c0: Vec<i64> = Vec::new();
    c0.push(1);
    c0.push(2);
    c0.push(9);

    let c1: Vec<i64> = Vec::new();
    c1.push(2);

    let c2: Vec<i64> = Vec::new();
    c2.push(1);
    c2.push(-1);

    let callee_sets: Vec<Vec<i64>> = Vec::new();
    callee_sets.push(c0);
    callee_sets.push(c1);
    callee_sets.push(c2);

    let counts: BTreeMap<i64, i64> = cx_ir_fan_in_counts(String::from("entry.vow"), source_files, callee_sets, 4);

    if cx_ir_fan_in_lookup(counts, 1) != 2 { return 1; }
    if cx_ir_fan_in_lookup(counts, 2) != 1 { return 2; }
    if cx_ir_fan_in_lookup(counts, 3) != 0 { return 3; }
    if cx_ir_fan_in_lookup(counts, 9) != 0 { return 4; }
    if cx_ir_fan_in_lookup(counts, -1) != 0 { return 5; }
    0
}

fn i64_result_to_i32(r: i64) -> i32 {
    if r == 1 { return 1; }
    if r == 2 { return 2; }
    if r == 3 { return 3; }
    if r == 4 { return 4; }
    if r == 5 { return 5; }
    if r != 0 { return 99; }
    0
}

fn main() -> i32 {
    let r: i64 = check_fanin_counts();
    if r != 0 { return i64_result_to_i32(r); }
    0
}
